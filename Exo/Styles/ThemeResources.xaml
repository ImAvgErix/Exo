    </Style>

    <Style x:Key="OptiStatusRail" TargetType="Border">
        <Setter Property="Width" Value="2" />
        <Setter Property="CornerRadius" Value="1" />
        <Setter Property="Background" Value="{ThemeResource OptiSuccessBrush}" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Margin" Value="0,1,0,1" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>

    <Style x:Key="OptiMessageBanner" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource OptiAccentSoftBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource OptiTileRadius}" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="OptiIconWell" TargetType="Border">
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="30" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{ThemeResource OptiAccentSoftBrush}" />
