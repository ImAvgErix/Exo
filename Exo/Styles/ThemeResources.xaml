<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:Exo.Helpers">

    <FontFamily x:Key="OptiDisplayFontItalic">ms-appx:///Assets/Fonts/CormorantGaramond-Italic.ttf#Cormorant Garamond</FontFamily>
    <FontFamily x:Key="OptiUiFont">ms-appx:///Assets/Fonts/PlusJakartaSans.ttf#Plus Jakarta Sans</FontFamily>
    <FontFamily x:Key="OptiUiFontMedium">ms-appx:///Assets/Fonts/PlusJakartaSans.ttf#Plus Jakarta Sans</FontFamily>
    <FontFamily x:Key="OptiUiFontSemiBold">ms-appx:///Assets/Fonts/PlusJakartaSans.ttf#Plus Jakarta Sans</FontFamily>

    <CornerRadius x:Key="OptiCardRadius">18</CornerRadius>
    <CornerRadius x:Key="OptiTileRadius">14</CornerRadius>
    <x:Double x:Key="OptiPageMaxWidth">1000</x:Double>
    <Thickness x:Key="OptiPagePadding">32,18,32,24</Thickness>

    <helpers:InverseBoolConverter x:Key="InverseBoolConverter" />
    <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
    <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    <helpers:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
    <helpers:BoolToShowOpacityConverter x:Key="BoolToShowOpacityConverter" />
    <helpers:AssetPathToImageSourceConverter x:Key="AssetPathToImageSourceConverter" />

    <Style x:Key="OptiTagline" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OptiDisplayFontItalic}" />
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontStyle" Value="Italic" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="-8" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="LineHeight" Value="44" />
        <Setter Property="OpticalMarginAlignment" Value="TrimSideBearings" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Foreground" Value="{ThemeResource OptiPrimaryTextBrush}" />
    </Style>

    <Style x:Key="OptiTaglineSupport" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OptiUiFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{ThemeResource OptiMutedTextBrush}" />
    </Style>

    <Style x:Key="OptiSectionTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OptiUiFontSemiBold}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="80" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="Foreground" Value="{ThemeResource OptiMutedTextBrush}" />
    </Style>

    <Style x:Key="OptiBody" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OptiUiFont}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{ThemeResource OptiSecondaryTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="20" />
    </Style>

    <Style x:Key="OptiCaption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OptiUiFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource OptiMutedTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- Optimizer page headline (kept for Internet / Display / module pages) -->
    <Style x:Key="OptiPageTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OptiUiFontSemiBold}" />
        <Setter Property="FontSize" Value="21" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="-12" />
        <Setter Property="LineHeight" Value="27" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
        <Setter Property="Foreground" Value="{ThemeResource OptiPrimaryTextBrush}" />
    </Style>

    <Style x:Key="OptiFeatureTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OptiUiFontSemiBold}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource OptiPrimaryTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="OpticalMarginAlignment" Value="TrimSideBearings" />
    </Style>

    <Style x:Key="OptiFeatureDetail" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OptiUiFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="16" />
        <Setter Property="Foreground" Value="{ThemeResource OptiMutedTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="OptiFeatureTile" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource OptiCardFillBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource OptiCardStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource OptiTileRadius}" />
        <Setter Property="Padding" Value="14,13" />
        <Setter Property="MinHeight" Value="64" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="OptiMessageBanner" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource OptiAccentSoftBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource OptiCardStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource OptiTileRadius}" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <!-- Soft fill, no stroke — glyph icons look cleaner without a box outline -->
    <Style x:Key="OptiIconWell" TargetType="Border">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Background" Value="{ThemeResource OptiAccentSoftBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="OptiCard" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource OptiCardRadius}" />
        <Setter Property="Padding" Value="18,16" />
        <Setter Property="Background" Value="{ThemeResource OptiCardFillBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource OptiCardStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="OptiRiskCard" TargetType="Border">
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Background" Value="{ThemeResource OptiWarningSoftBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource OptiWarningBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="OptiRiskLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OptiUiFontSemiBold}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="100" />
        <Setter Property="Foreground" Value="{ThemeResource OptiWarningBrush}" />
    </Style>

    <!-- Borderless logo host (no outline — cleaner cards). Fill optional if reused. -->
    <Style x:Key="OptiLogoWell" TargetType="Border">
        <Setter Property="Width" Value="64" />
        <Setter Property="Height" Value="64" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="OptiLogoWellSmall" TargetType="Border" BasedOn="{StaticResource OptiLogoWell}">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!--
      Dark / Light tiles. MUST use layered fills:
      PointerOver + Checked both apply in WinUI — if hover sets Background it wipes
      the white selected fill and black label “disappears” on dark shell.
    -->
    <Style x:Key="OptiThemeChoice" TargetType="RadioButton">
        <Setter Property="FontFamily" Value="{StaticResource OptiUiFontSemiBold}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{ThemeResource OptiPrimaryTextBrush}" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid x:Name="Root"
                          MinHeight="{TemplateBinding MinHeight}"
                          HorizontalAlignment="Stretch">
                        <!-- Base + stroke (always visible) -->
                        <Border x:Name="Base"
                                Background="{ThemeResource OptiPageBackgroundBrush}"
                                BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource OptiTileRadius}" />
                        <!-- Hover underlay — never paints over selected white -->
                        <Border x:Name="HoverFill"
                                Background="{ThemeResource OptiAccentSoftBrush}"
                                CornerRadius="{StaticResource OptiTileRadius}"
                                Margin="1"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <!-- Selected white — ON TOP of hover so it never vanishes -->
                        <Border x:Name="CheckedFill"
                                Background="#FFFFFF"
                                BorderBrush="#FFFFFF"
                                BorderThickness="1"
                                CornerRadius="{StaticResource OptiTileRadius}"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <TextBlock x:Name="Label"
                                   Text="{TemplateBinding Content}"
                                   FontFamily="{TemplateBinding FontFamily}"
                                   FontSize="{TemplateBinding FontSize}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   Foreground="{TemplateBinding Foreground}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="{TemplateBinding Padding}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Target="HoverFill.Opacity" Value="0" />
                                        <Setter Target="Root.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="HoverFill.Opacity" Value="1" />
                                        <Setter Target="Root.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.92" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.45" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="CheckStates">
                                <VisualState x:Name="Checked">
                                    <VisualState.Setters>
                                        <Setter Target="CheckedFill.Opacity" Value="1" />
                                        <Setter Target="Label.Foreground" Value="#0A0A0A" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Unchecked">
                                    <VisualState.Setters>
                                        <Setter Target="CheckedFill.Opacity" Value="0" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Indeterminate" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="OptiThemeRadio" TargetType="RadioButton" BasedOn="{StaticResource OptiThemeChoice}" />

    <!-- Compact toggle — hide On/Off labels, no huge min width -->
    <Style x:Key="OptiCompactSwitch" TargetType="ToggleSwitch">
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="OnContent" Value="" />
        <Setter Property="OffContent" Value="" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{StaticResource OptiUiFont}" />
    </Style>

    <!--
      Theme flip control: always high-contrast so mode is obvious.
      Dark shell → near-black fill + white type ("Dark mode").
      Light shell → cream fill + near-black type ("Light mode").
      Hover only dims slightly — never wipes the fill.
    -->
    <Style x:Key="OptiThemeToggleButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource OptiUiFontSemiBold}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="MinHeight" Value="56" />
        <Setter Property="Padding" Value="18,14" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="ClickMode" Value="Press" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="{ThemeResource OptiThemeToggleFillBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource OptiThemeToggleTextBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource OptiThemeToggleStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="Root"
                          Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          CornerRadius="{TemplateBinding CornerRadius}"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <CompositeTransform x:Name="RootScale" ScaleX="1" ScaleY="1" />
                        </Grid.RenderTransform>
                        <ContentPresenter x:Name="Content"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Foreground="{TemplateBinding Foreground}"
                                          FontFamily="{TemplateBinding FontFamily}"
                                          FontSize="{TemplateBinding FontSize}"
                                          FontWeight="{TemplateBinding FontWeight}"
                                          Padding="{TemplateBinding Padding}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.32">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.28" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.32">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.28" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.12" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <!-- Keep fill; only soft lift via opacity (never blank the button) -->
                                        <Setter Target="Root.Opacity" Value="0.94" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleX"
                                                         To="0.97" Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleY"
                                                         To="0.97" Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="0.9" Duration="0:0:0.08" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.45" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
      Clean motion language (crisp, not soft):
      - Never scale content (that blurs logos/type).
      - Hover/press = animated highlight wash + ring on a separate layer.
      - Short ease-out (~140ms) so you always know what you're on.
    -->
    <Style x:Key="OptiPrimaryButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource OptiUiFontSemiBold}" />
        <Setter Property="Padding" Value="18,12" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="ClickMode" Value="Press" />
        <Setter Property="AllowFocusOnInteraction" Value="True" />
        <Setter Property="Background" Value="{ThemeResource OptiAccentBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource OptiOnAccentBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="Root"
                          UseLayoutRounding="True"
                          Background="{TemplateBinding Background}"
                          CornerRadius="{TemplateBinding CornerRadius}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}">
                        <!-- Wash sits under label; content never scaled -->
                        <Border x:Name="HoverWash"
                                Background="{ThemeResource OptiOnAccentBrush}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Padding="{TemplateBinding Padding}"
                                          Foreground="{TemplateBinding Foreground}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.12" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0.10" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.1" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0.18" Duration="0:0:0.08">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="0.96" Duration="0:0:0.08" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.45" />
                                        <Setter Target="HoverWash.Opacity" Value="0" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="OptiQuietButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource OptiUiFontMedium}" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="MinHeight" Value="42" />
        <Setter Property="ClickMode" Value="Press" />
        <Setter Property="AllowFocusOnInteraction" Value="True" />
        <Setter Property="Background" Value="{ThemeResource OptiQuietButtonFillBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource OptiCardStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="Foreground" Value="{ThemeResource OptiPrimaryTextBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="Root"
                          UseLayoutRounding="True"
                          Background="{TemplateBinding Background}"
                          CornerRadius="{TemplateBinding CornerRadius}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}">
                        <Border x:Name="HoverWash"
                                Background="{ThemeResource OptiAccentSoftBrush}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <Border x:Name="HoverRing"
                                BorderBrush="{ThemeResource OptiAccentBrush}"
                                BorderThickness="1"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Padding="{TemplateBinding Padding}"
                                          Foreground="{TemplateBinding Foreground}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="HoverRing" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.12" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="HoverRing" Storyboard.TargetProperty="Opacity"
                                                         To="0.35" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="HoverRing" Storyboard.TargetProperty="Opacity"
                                                         To="0.7" Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="0.96" Duration="0:0:0.08" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.45" />
                                        <Setter Target="HoverWash.Opacity" Value="0" />
                                        <Setter Target="HoverRing.Opacity" Value="0" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
      Premium secondary (Marcel craft): soft fill + deliberate stroke in rest,
      lift on hover without wiping fill, press scale. Gradient-ish via layered soft brush.
    -->
    <Style x:Key="OptiSecondaryButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource OptiUiFontSemiBold}" />
        <Setter Property="Padding" Value="16,11" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinHeight" Value="42" />
        <Setter Property="ClickMode" Value="Press" />
        <Setter Property="Background" Value="{ThemeResource OptiSecondaryButtonFillBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource OptiSecondaryButtonStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{ThemeResource OptiPrimaryTextBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="Root"
                          RenderTransformOrigin="0.5,0.5"
                          Background="{TemplateBinding Background}"
                          CornerRadius="{TemplateBinding CornerRadius}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid.RenderTransform>
                            <CompositeTransform x:Name="RootScale" ScaleX="1" ScaleY="1" />
                        </Grid.RenderTransform>
                        <!-- Soft top highlight (secondary-button craft) -->
                        <Border x:Name="Sheen"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Margin="1"
                                IsHitTestVisible="False"
                                Opacity="0.55"
                                Background="{ThemeResource OptiSecondaryButtonSheenBrush}" />
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding Content}"
                                          Foreground="{TemplateBinding Foreground}"
                                          FontFamily="{TemplateBinding FontFamily}"
                                          FontSize="{TemplateBinding FontSize}"
                                          FontWeight="{TemplateBinding FontWeight}"
                                          Padding="{TemplateBinding Padding}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.22" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.22" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.12" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.96" />
                                        <Setter Target="Sheen.Opacity" Value="0.75" />
                                    </VisualState.Setters>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleX"
                                                         To="1.015" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleY"
                                                         To="1.015" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleX"
                                                         To="0.97" Duration="0:0:0.07" />
                                        <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleY"
                                                         To="0.97" Duration="0:0:0.07" />
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="0.9" Duration="0:0:0.07" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.45" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Live continuous slider (premium track + thumb) -->
    <Style x:Key="OptiLiveSlider" TargetType="Slider">
        <Setter Property="Foreground" Value="{ThemeResource OptiAccentBrush}" />
        <Setter Property="Background" Value="{ThemeResource OptiAccentSoftBrush}" />
        <Setter Property="Minimum" Value="0" />
        <Setter Property="Maximum" Value="100" />
        <Setter Property="StepFrequency" Value="1" />
        <Setter Property="IsThumbToolTipEnabled" Value="False" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Margin" Value="0,2,0,0" />
    </Style>

    <!-- Solid white CTA — wash + fill animation, no scale. -->
    <Style x:Key="OptiWhiteButton" TargetType="Button" BasedOn="{StaticResource OptiQuietButton}">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="#FFFFFF" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="#0A0A0A" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="Root"
                          UseLayoutRounding="True"
                          Background="#FFFFFF"
                          CornerRadius="{TemplateBinding CornerRadius}">
                        <Border x:Name="HoverWash"
                                Background="#000000"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Padding="{TemplateBinding Padding}"
                                          Foreground="{TemplateBinding Foreground}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0.06" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0.12" Duration="0:0:0.08" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.45" />
                                        <Setter Target="HoverWash.Opacity" Value="0" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
      Home cards: logos/labels stay sharp (no scale).
      Hover = soft wash + accent ring so you always know focus.
      Press = stronger ring (clear "this is the one").
    -->
    <Style x:Key="OptiCardButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource OptiCardRadius}" />
        <Setter Property="ClickMode" Value="Press" />
        <Setter Property="AllowFocusOnInteraction" Value="True" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="Root"
                          Background="Transparent"
                          UseLayoutRounding="True"
                          CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter x:Name="Content"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Padding="{TemplateBinding Padding}"
                                          CornerRadius="{TemplateBinding CornerRadius}" />
                        <!-- Highlight layers above content so ring reads; never scale content -->
                        <Border x:Name="HoverWash"
                                Background="{ThemeResource OptiAccentSoftBrush}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <Border x:Name="HoverRing"
                                BorderBrush="{ThemeResource OptiAccentBrush}"
                                BorderThickness="1.5"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="HoverRing" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.12" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0.55" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="HoverRing" Storyboard.TargetProperty="Opacity"
                                                         To="0.75" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0.85" Duration="0:0:0.07" />
                                        <DoubleAnimation Storyboard.TargetName="HoverRing" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.07" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.45" />
                                        <Setter Target="HoverWash.Opacity" Value="0" />
                                        <Setter Target="HoverRing.Opacity" Value="0" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="OptiIconButton" TargetType="Button">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="ClickMode" Value="Press" />
        <Setter Property="AllowFocusOnInteraction" Value="True" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="Root"
                          Background="Transparent"
                          UseLayoutRounding="True"
                          CornerRadius="{TemplateBinding CornerRadius}">
                        <Border x:Name="HoverWash"
                                Background="{ThemeResource OptiAccentSoftBrush}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.12" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.07" />
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="0.9" Duration="0:0:0.07" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.4" />
                                        <Setter Target="HoverWash.Opacity" Value="0" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
