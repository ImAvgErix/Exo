<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:Exo.Helpers">

    <FontFamily x:Key="ExoDisplayFontItalic">ms-appx:///Assets/Fonts/CormorantGaramond-Italic.ttf#Cormorant Garamond</FontFamily>
    <FontFamily x:Key="ExoUiFont">ms-appx:///Assets/Fonts/PlusJakartaSans.ttf#Plus Jakarta Sans</FontFamily>
    <FontFamily x:Key="ExoUiFontMedium">ms-appx:///Assets/Fonts/PlusJakartaSans.ttf#Plus Jakarta Sans</FontFamily>
    <FontFamily x:Key="ExoUiFontSemiBold">ms-appx:///Assets/Fonts/PlusJakartaSans.ttf#Plus Jakarta Sans</FontFamily>

    <!-- Spacing scale: 8 / 12 / 16 / 20 / 28 — denser v2.5 directory chrome -->
    <CornerRadius x:Key="ExoCardRadius">16</CornerRadius>
    <CornerRadius x:Key="ExoTileRadius">12</CornerRadius>
    <x:Double x:Key="ExoPageMaxWidth">980</x:Double>
    <Thickness x:Key="ExoPagePadding">24,16,28,16</Thickness>

    <helpers:InverseBoolConverter x:Key="InverseBoolConverter" />
    <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
    <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    <helpers:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
    <helpers:BoolToShowOpacityConverter x:Key="BoolToShowOpacityConverter" />
    <helpers:AssetPathToImageSourceConverter x:Key="AssetPathToImageSourceConverter" />

    <Style x:Key="ExoTagline" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ExoDisplayFontItalic}" />
        <Setter Property="FontSize" Value="34" />
        <Setter Property="FontStyle" Value="Italic" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="-6" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="LineHeight" Value="42" />
        <Setter Property="OpticalMarginAlignment" Value="TrimSideBearings" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Foreground" Value="{ThemeResource ExoPrimaryTextBrush}" />
    </Style>

    <Style x:Key="ExoSectionTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ExoUiFontSemiBold}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="90" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="Foreground" Value="{ThemeResource ExoMutedTextBrush}" />
    </Style>

    <Style x:Key="ExoBody" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ExoUiFont}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{ThemeResource ExoSecondaryTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="19" />
    </Style>

    <Style x:Key="ExoCaption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ExoUiFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="16" />
        <Setter Property="Foreground" Value="{ThemeResource ExoMutedTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="ExoPageTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ExoUiFontSemiBold}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="-20" />
        <Setter Property="LineHeight" Value="34" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
        <Setter Property="Foreground" Value="{ThemeResource ExoPrimaryTextBrush}" />
    </Style>

    <Style x:Key="ExoFeatureTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ExoUiFontSemiBold}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource ExoPrimaryTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="OpticalMarginAlignment" Value="TrimSideBearings" />
    </Style>

    <Style x:Key="ExoFeatureDetail" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ExoUiFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="16" />
        <Setter Property="Foreground" Value="{ThemeResource ExoMutedTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="ExoFeatureTile" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource ExoCardFillBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ExoCardStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource ExoTileRadius}" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="MinHeight" Value="56" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <!-- Home directory row chrome -->
    <Style x:Key="ExoDirectoryRow" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource ExoCardFillBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ExoCardStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="MinHeight" Value="72" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <!-- Sticky module action bar -->
    <Style x:Key="ExoActionBar" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource ExoCardFillBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ExoCardStrokeBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="ExoStatusRail" TargetType="Border">
        <Setter Property="Width" Value="2" />
        <Setter Property="CornerRadius" Value="1" />
        <Setter Property="Background" Value="{ThemeResource ExoSuccessBrush}" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Margin" Value="0,1,0,1" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>

    <Style x:Key="ExoMessageBanner" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource ExoAccentSoftBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource ExoTileRadius}" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="ExoIconWell" TargetType="Border">
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="30" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{ThemeResource ExoAccentSoftBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="ExoCard" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource ExoCardRadius}" />
        <Setter Property="Padding" Value="16,14" />
        <Setter Property="Background" Value="{ThemeResource ExoCardFillBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ExoCardStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="ExoRiskCard" TargetType="Border">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Background" Value="{ThemeResource ExoWarningSoftBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ExoWarningBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="ExoRiskLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ExoUiFontSemiBold}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="100" />
        <Setter Property="Foreground" Value="{ThemeResource ExoWarningBrush}" />
    </Style>

    <!--
      Dark / Light tiles. MUST use layered fills:
      PointerOver + Checked both apply in WinUI — if hover sets Background it wipes
      the white selected fill and black label “disappears” on dark shell.
    -->
    <Style x:Key="ExoThemeChoice" TargetType="RadioButton">
        <Setter Property="FontFamily" Value="{StaticResource ExoUiFontSemiBold}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{ThemeResource ExoPrimaryTextBrush}" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid x:Name="Root"
                          MinHeight="{TemplateBinding MinHeight}"
                          HorizontalAlignment="Stretch">
                        <Border x:Name="Base"
                                Background="{ThemeResource ExoPageBackgroundBrush}"
                                BorderBrush="{ThemeResource ExoCardStrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource ExoTileRadius}" />
                        <Border x:Name="HoverFill"
                                Background="{ThemeResource ExoAccentSoftBrush}"
                                CornerRadius="{StaticResource ExoTileRadius}"
                                Margin="1"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <Border x:Name="CheckedFill"
                                Background="#FFFFFF"
                                BorderBrush="#FFFFFF"
                                BorderThickness="1"
                                CornerRadius="{StaticResource ExoTileRadius}"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <TextBlock x:Name="Label"
                                   Text="{TemplateBinding Content}"
                                   FontFamily="{TemplateBinding FontFamily}"
                                   FontSize="{TemplateBinding FontSize}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   Foreground="{TemplateBinding Foreground}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="{TemplateBinding Padding}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Target="HoverFill.Opacity" Value="0" />
                                        <Setter Target="Root.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="HoverFill.Opacity" Value="1" />
                                        <Setter Target="Root.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.92" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.45" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="CheckStates">
                                <VisualState x:Name="Checked">
                                    <VisualState.Setters>
                                        <Setter Target="CheckedFill.Opacity" Value="1" />
                                        <Setter Target="Label.Foreground" Value="#0A0A0A" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Unchecked">
                                    <VisualState.Setters>
                                        <Setter Target="CheckedFill.Opacity" Value="0" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Indeterminate" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ExoThemeRadio" TargetType="RadioButton" BasedOn="{StaticResource ExoThemeChoice}" />

    <Style x:Key="ExoCompactSwitch" TargetType="ToggleSwitch">
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="OnContent" Value="" />
        <Setter Property="OffContent" Value="" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{StaticResource ExoUiFont}" />
    </Style>

    <!--
      Clean motion language (crisp, not soft):
      - Never scale content (that blurs logos/type).
      - Hover/press = animated highlight wash + ring on a separate layer.
      - Short ease-out (~140ms) so you always know what you're on.
    -->
    <Style x:Key="ExoPrimaryButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource ExoUiFontSemiBold}" />
        <Setter Property="Padding" Value="20,13" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinHeight" Value="46" />
        <Setter Property="ClickMode" Value="Press" />
        <Setter Property="AllowFocusOnInteraction" Value="True" />
        <Setter Property="Background" Value="{ThemeResource ExoAccentBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource ExoOnAccentBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="Root"
                          UseLayoutRounding="True"
                          Background="{TemplateBinding Background}"
                          CornerRadius="{TemplateBinding CornerRadius}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}">
                        <Border x:Name="HoverWash"
                                Background="{ThemeResource ExoOnAccentBrush}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Padding="{TemplateBinding Padding}"
                                          Foreground="{TemplateBinding Foreground}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.12" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0.10" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.1" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0.18" Duration="0:0:0.08">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="0.96" Duration="0:0:0.08" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.45" />
                                        <Setter Target="HoverWash.Opacity" Value="0" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ExoQuietButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource ExoUiFontMedium}" />
        <Setter Property="Padding" Value="14,9" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="ClickMode" Value="Press" />
        <Setter Property="AllowFocusOnInteraction" Value="True" />
        <Setter Property="Background" Value="{ThemeResource ExoQuietButtonFillBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ExoCardStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{ThemeResource ExoPrimaryTextBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="Root"
                          UseLayoutRounding="True"
                          Background="{TemplateBinding Background}"
                          CornerRadius="{TemplateBinding CornerRadius}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}">
                        <Border x:Name="HoverWash"
                                Background="{ThemeResource ExoAccentSoftBrush}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <Border x:Name="HoverRing"
                                BorderBrush="{ThemeResource ExoAccentBrush}"
                                BorderThickness="1"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Padding="{TemplateBinding Padding}"
                                          Foreground="{TemplateBinding Foreground}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="HoverRing" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.12" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="HoverRing" Storyboard.TargetProperty="Opacity"
                                                         To="0.35" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="HoverRing" Storyboard.TargetProperty="Opacity"
                                                         To="0.7" Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="0.96" Duration="0:0:0.08" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.45" />
                                        <Setter Target="HoverWash.Opacity" Value="0" />
                                        <Setter Target="HoverRing.Opacity" Value="0" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ExoLiveSlider" TargetType="Slider">
        <Setter Property="Foreground" Value="{ThemeResource ExoAccentBrush}" />
        <Setter Property="Background" Value="{ThemeResource ExoAccentSoftBrush}" />
        <Setter Property="Minimum" Value="0" />
        <Setter Property="Maximum" Value="100" />
        <Setter Property="StepFrequency" Value="1" />
        <Setter Property="IsThumbToolTipEnabled" Value="False" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style x:Key="ExoWhiteButton" TargetType="Button" BasedOn="{StaticResource ExoQuietButton}">
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="#FFFFFF" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="#0A0A0A" />
        <Setter Property="MinHeight" Value="46" />
        <Setter Property="Padding" Value="20,13" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="Root"
                          UseLayoutRounding="True"
                          Background="#FFFFFF"
                          CornerRadius="{TemplateBinding CornerRadius}">
                        <Border x:Name="HoverWash"
                                Background="#000000"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Padding="{TemplateBinding Padding}"
                                          Foreground="{TemplateBinding Foreground}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0.06" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0.12" Duration="0:0:0.08" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.45" />
                                        <Setter Target="HoverWash.Opacity" Value="0" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
      Home cards: logos/labels stay sharp (no scale).
      Hover = soft wash + accent ring so you always know focus.
      Press = stronger ring (clear "this is the one").
    -->
    <Style x:Key="ExoCardButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource ExoCardRadius}" />
        <Setter Property="ClickMode" Value="Press" />
        <Setter Property="AllowFocusOnInteraction" Value="True" />
