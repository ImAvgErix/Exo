<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:Exo.Helpers">

    <!-- Native variable fonts render more cleanly than small bundled glyphs at 100–175% DPI. -->
    <FontFamily x:Key="ExoDisplayFontItalic">Segoe UI Variable Display</FontFamily>
    <FontFamily x:Key="ExoUiFont">Segoe UI Variable Text</FontFamily>
    <FontFamily x:Key="ExoUiFontMedium">Segoe UI Variable Text</FontFamily>
    <FontFamily x:Key="ExoUiFontSemiBold">Segoe UI Variable Display</FontFamily>

    <!-- Spacing scale: 8 / 12 / 16 / 20 / 28 — v2.6 Liquid Glass chrome -->
    <CornerRadius x:Key="ExoCardRadius">18</CornerRadius>
    <CornerRadius x:Key="ExoTileRadius">12</CornerRadius>
    <CornerRadius x:Key="ExoGlassRadius">20</CornerRadius>
    <x:Double x:Key="ExoPageMaxWidth">1120</x:Double>
    <Thickness x:Key="ExoPagePadding">24,16,28,16</Thickness>

    <helpers:InverseBoolConverter x:Key="InverseBoolConverter" />
    <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
    <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    <helpers:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
    <helpers:BoolToShowOpacityConverter x:Key="BoolToShowOpacityConverter" />
    <helpers:AssetPathToImageSourceConverter x:Key="AssetPathToImageSourceConverter" />

    <!-- Home status under brand — native text rendering, no synthetic italics. -->
    <Style x:Key="ExoTagline" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ExoDisplayFontItalic}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontStyle" Value="Normal" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="0" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
        <Setter Property="TextAlignment" Value="Left" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="OpticalMarginAlignment" Value="TrimSideBearings" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Foreground" Value="{ThemeResource ExoSecondaryTextBrush}" />
    </Style>

    <Style x:Key="ExoSectionTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ExoUiFontSemiBold}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="120" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="Foreground" Value="{ThemeResource ExoMutedTextBrush}" />
    </Style>

    <Style x:Key="ExoBody" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ExoUiFont}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{ThemeResource ExoSecondaryTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="19" />
    </Style>

    <Style x:Key="ExoCaption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ExoUiFont}" />
        <Setter Property="FontSize" Value="12.5" />
        <Setter Property="LineHeight" Value="17" />
        <Setter Property="Foreground" Value="{ThemeResource ExoMutedTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="ExoPageTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ExoUiFontSemiBold}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="-20" />
        <Setter Property="LineHeight" Value="34" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
        <Setter Property="Foreground" Value="{ThemeResource ExoPrimaryTextBrush}" />
    </Style>

    <Style x:Key="ExoFeatureTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ExoUiFontSemiBold}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource ExoPrimaryTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="OpticalMarginAlignment" Value="TrimSideBearings" />
    </Style>

    <Style x:Key="ExoFeatureDetail" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ExoUiFont}" />
        <Setter Property="FontSize" Value="12.5" />
        <Setter Property="LineHeight" Value="17" />
        <Setter Property="Foreground" Value="{ThemeResource ExoMutedTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- Module instrument plate — one edge-glass surface for header + list + actions -->
    <Style x:Key="ExoModulePlate" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource ExoGlassFillBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ExoGlassStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <!-- Feature rows — hairline list rows inside the plate (not separate pills) -->
    <Style x:Key="ExoFeatureTile" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{ThemeResource ExoDividerBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="14,11" />
        <Setter Property="MinHeight" Value="52" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <!-- Sticky module action bar — frosted glass strip with specular top edge -->
    <Style x:Key="ExoActionBar" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource ExoSurfaceSunkenBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ExoDividerBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="16,8,16,10" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="ExoStatusRail" TargetType="Border">
        <Setter Property="Width" Value="3" />
        <Setter Property="CornerRadius" Value="1.5" />
        <Setter Property="Background" Value="{ThemeResource ExoSuccessBrush}" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Margin" Value="0,0,0,0" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>

    <Style x:Key="ExoMessageBanner" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource ExoAccentSoftBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ExoSpecularStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="ExoMessageText" TargetType="TextBlock" BasedOn="{StaticResource ExoBody}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="16" />
    </Style>

    <Style x:Key="ExoInfoMessageText" TargetType="TextBlock" BasedOn="{StaticResource ExoMessageText}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="16" />
        <Setter Property="Foreground" Value="{ThemeResource ExoMutedTextBrush}" />
    </Style>

    <Style x:Key="ExoIconWell" TargetType="Border">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="CornerRadius" Value="9" />
        <Setter Property="Background" Value="{ThemeResource ExoAccentSoftBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ExoSpecularStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="ExoCard" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource ExoCardRadius}" />
        <Setter Property="Padding" Value="16,14" />
        <Setter Property="Background" Value="{ThemeResource ExoSurfaceRaisedBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ExoDividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="ExoRiskCard" TargetType="Border">
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Background" Value="{ThemeResource ExoWarningSoftBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ExoWarningBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="ExoRiskLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ExoUiFontSemiBold}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="100" />
        <Setter Property="Foreground" Value="{ThemeResource ExoWarningBrush}" />
    </Style>

    <Style x:Key="ExoCompactSwitch" TargetType="ToggleSwitch">
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="OnContent" Value="" />
        <Setter Property="OffContent" Value="" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{StaticResource ExoUiFont}" />
    </Style>

    <!--
      Clean motion language (crisp, not soft):
      - Never scale content (that blurs logos/type).
      - Hover/press = animated highlight wash + ring on a separate layer.
      - Short ease-out (~140ms) so you always know what you're on.
    -->
    <Style x:Key="ExoPrimaryButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource ExoUiFontSemiBold}" />
        <Setter Property="Padding" Value="18,11" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="ClickMode" Value="Press" />
        <Setter Property="AllowFocusOnInteraction" Value="True" />
        <Setter Property="Background" Value="{ThemeResource ExoPrimaryButtonFillBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ExoPrimaryButtonStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{ThemeResource ExoPrimaryTextBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="Root"
                          UseLayoutRounding="True"
                          Background="{TemplateBinding Background}"
                          CornerRadius="{TemplateBinding CornerRadius}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}">
                        <Border x:Name="HoverWash"
                                Background="{ThemeResource ExoAccentSoftBrush}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Padding="{TemplateBinding Padding}"
                                          Foreground="{TemplateBinding Foreground}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.12" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0.10" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.1" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0.18" Duration="0:0:0.08">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="0.96" Duration="0:0:0.08" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.45" />
                                        <Setter Target="HoverWash.Opacity" Value="0" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Secondary glass actions — Repair / Reset / Refresh / CPL (never solid white) -->
    <Style x:Key="ExoQuietButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource ExoUiFontMedium}" />
        <Setter Property="Padding" Value="14,9" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="ClickMode" Value="Press" />
        <Setter Property="AllowFocusOnInteraction" Value="True" />
        <Setter Property="Background" Value="{ThemeResource ExoQuietButtonFillBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ExoDividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{ThemeResource ExoPrimaryTextBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="Root"
                          UseLayoutRounding="True"
                          Background="{TemplateBinding Background}"
                          CornerRadius="{TemplateBinding CornerRadius}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}">
                        <Border x:Name="HoverWash"
                                Background="{ThemeResource ExoAccentSoftBrush}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <Border x:Name="HoverRing"
                                BorderBrush="{ThemeResource ExoAccentBrush}"
                                BorderThickness="1"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Padding="{TemplateBinding Padding}"
                                          Foreground="{TemplateBinding Foreground}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="HoverRing" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.12" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="HoverRing" Storyboard.TargetProperty="Opacity"
                                                         To="0.35" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="HoverRing" Storyboard.TargetProperty="Opacity"
                                                         To="0.7" Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="0.96" Duration="0:0:0.08" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.45" />
                                        <Setter Target="HoverWash.Opacity" Value="0" />
                                        <Setter Target="HoverRing.Opacity" Value="0" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ExoLiveSlider" TargetType="Slider">
        <Setter Property="Foreground" Value="{ThemeResource ExoAccentBrush}" />
        <Setter Property="Background" Value="{ThemeResource ExoAccentSoftBrush}" />
        <Setter Property="Minimum" Value="0" />
        <Setter Property="Maximum" Value="100" />
        <Setter Property="StepFrequency" Value="1" />
        <Setter Property="IsThumbToolTipEnabled" Value="False" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <!-- Alias for Internet dual CTAs — identical role to ExoPrimaryButton -->
    <Style x:Key="ExoWhiteButton" TargetType="Button" BasedOn="{StaticResource ExoPrimaryButton}" />

    <!--
      Home cards: logos/labels stay sharp (no scale).
      Hover = soft wash + accent ring so you always know focus.
      Press = stronger ring (clear "this is the one").
    -->
    <Style x:Key="ExoCardButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource ExoCardRadius}" />
        <Setter Property="ClickMode" Value="Press" />
        <Setter Property="AllowFocusOnInteraction" Value="True" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="Root"
                          Background="Transparent"
                          UseLayoutRounding="True"
                          CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter x:Name="Content"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Padding="{TemplateBinding Padding}"
                                          CornerRadius="{TemplateBinding CornerRadius}" />
                        <Border x:Name="HoverWash"
                                Background="{ThemeResource ExoAccentSoftBrush}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <Border x:Name="HoverRing"
                                BorderBrush="{ThemeResource ExoAccentBrush}"
                                BorderThickness="1.5"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="HoverRing" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.12" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0.72" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="HoverRing" Storyboard.TargetProperty="Opacity"
                                                         To="0.92" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0.95" Duration="0:0:0.06" />
                                        <DoubleAnimation Storyboard.TargetName="HoverRing" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.06" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.45" />
                                        <Setter Target="HoverWash.Opacity" Value="0" />
                                        <Setter Target="HoverRing.Opacity" Value="0" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ExoIconButton" TargetType="Button">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="9" />
        <Setter Property="ClickMode" Value="Press" />
        <Setter Property="AllowFocusOnInteraction" Value="True" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="Root"
                          Background="Transparent"
                          UseLayoutRounding="True"
                          CornerRadius="{TemplateBinding CornerRadius}">
                        <Border x:Name="HoverWash"
                                Background="{ThemeResource ExoAccentSoftBrush}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.12" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.07" />
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="0.9" Duration="0:0:0.07" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.4" />
                                        <Setter Target="HoverWash.Opacity" Value="0" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
      Left rail nav: glass pill items — logos stay sharp (no scale).
      Selection ring applied from MainWindow code via BorderBrush/Thickness.
    -->
    <!-- Top-bar nav chip — width set by caller (home / modules / gear) -->
    <Style x:Key="ExoRailButton" TargetType="Button">
        <Setter Property="MinWidth" Value="44" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Height" Value="44" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="ClickMode" Value="Press" />
        <Setter Property="AllowFocusOnInteraction" Value="True" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{ThemeResource ExoPrimaryTextBrush}" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <!-- Full plate is the hit target (better-ui min 44px). SelectionFill used to be
                         IsHitTestVisible=False so only the logo pixels received clicks. -->
                    <Grid x:Name="Root"
                          Background="Transparent"
                          UseLayoutRounding="True"
                          CornerRadius="{TemplateBinding CornerRadius}">
                        <Border x:Name="SelectionFill"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                IsHitTestVisible="True" />
                        <!-- Wash behind content so logos stay sharp on top -->
                        <Border x:Name="HoverWash"
                                Background="{ThemeResource ExoAccentSoftBrush}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Foreground="{TemplateBinding Foreground}"
                                          IsHitTestVisible="False" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.12" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="0.85" Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverWash" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.08" />
                                        <!-- Opacity dip only — never ScaleTransform on logo content -->
                                        <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                                                         To="0.94" Duration="0:0:0.08" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.4" />
                                        <Setter Target="HoverWash.Opacity" Value="0" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Dark instrument wells keep white/brand PNG marks legible in both themes. -->
    <Style x:Key="ExoGlassCircle" TargetType="Button" BasedOn="{StaticResource ExoRailButton}">
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="46" />
        <Setter Property="MinWidth" Value="46" />
        <Setter Property="MinHeight" Value="46" />
        <Setter Property="CornerRadius" Value="23" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="#3AFFFFFF" />
        <Setter Property="Foreground" Value="#F5F5F4" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF202024" Offset="0" />
                    <GradientStop Color="#FF111114" Offset="0.52" />
                    <GradientStop Color="#FF09090B" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
