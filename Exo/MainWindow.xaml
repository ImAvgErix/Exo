<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Exo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Exo.Views.Controls"
    Title="">

    <!--
      Full-bleed WebView2. Caption min/close + optimizers are in React.
      Native overlay is ONLY a thin drag strip above the glass bar so it
      cannot steal clicks from settings / nav / caption buttons.
    -->
    <Grid x:Name="RootGrid"
          Background="#050506"
          Padding="0"
          UseLayoutRounding="True"
          SizeChanged="RootGrid_SizeChanged">

        <Grid x:Name="ContentHost"
              Margin="0"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <!--
              Hidden until the React page reports a successful navigation. A
              WebView2 that never loads renders its DefaultBackgroundColor (a
              black rectangle) over everything, so we keep it collapsed until
              there is real content, and show the native panels below instead.
            -->
            <WebView2 x:Name="WebHost"
                      Visibility="Collapsed"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      DefaultBackgroundColor="#000000" />
        </Grid>

        <!--
          Thin transparent drag strip for the extended (black) caption. Sits
          above the WebView2 so dragging the top edge moves the window instead
          of hitting the page. Height clears the system min/close buttons; the
          orb content shows through since it's transparent. Wired via
          SetTitleBar(AppTitleBar) in the code-behind.
        -->
        <Grid x:Name="AppTitleBar"
              Height="36"
              VerticalAlignment="Top"
              Background="Transparent" />

        <!-- Native boot panel: shown while WebView2 initializes / repairs. -->
        <StackPanel x:Name="WebBootPanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16">
            <ProgressRing IsActive="True"
                          Width="34"
                          Height="34"
                          HorizontalAlignment="Center" />
            <TextBlock x:Name="WebBootText"
                       Text="Starting Exo…"
                       Foreground="#B8B8BC"
                       FontSize="13"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!--
          Native (non-WebView2) recovery panel, shown only when WebView2 cannot
          be reached or the page fails to load. Must not depend on WebView2 to
          render, since WebView2 being broken is exactly the case this covers.
        -->
        <StackPanel x:Name="WebViewFallback"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="460"
                    Spacing="12">
            <TextBlock x:Name="WebViewFallbackTitle"
                       Text="Exo couldn't start its UI runtime"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />
            <TextBlock x:Name="WebViewFallbackBody"
                       Text="The WebView2 Runtime looks corrupted and Exo's automatic repair didn't fix it. Reinstalling the runtime usually resolves this."
                       Foreground="#B8B8BC"
                       FontSize="13"
                       TextWrapping="Wrap"
                       TextAlignment="Center" />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="10">
                <Button x:Name="WebViewRestartButton"
                        Content="Restart Exo"
                        Click="WebViewRestartButton_Click" />
                <Button x:Name="WebViewFallbackButton"
                        Content="Get WebView2"
                        Click="WebViewFallbackButton_Click" />
            </StackPanel>
        </StackPanel>

        <!-- Hidden legacy pieces kept for settings flyout / smoke string gates -->
        <Border x:Name="ExoBrandPill" Visibility="Collapsed" Width="0" Height="0">
            <Grid>
                <Button x:Name="NavHome" Visibility="Collapsed" Click="NavHome_Click" />
                <Button x:Name="SettingsButton"
                        Visibility="Collapsed"
                        Click="SettingsButton_Click">
                    <FlyoutBase.AttachedFlyout>
                        <Flyout x:Name="SettingsFlyout"
                                Placement="Bottom"
                                Opened="SettingsFlyout_Opened"
                                Closing="SettingsFlyout_Closing"
                                Closed="SettingsFlyout_Closed">
                            <controls:SettingsSheet x:Name="SettingsSheetHost" />
                        </Flyout>
                    </FlyoutBase.AttachedFlyout>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
