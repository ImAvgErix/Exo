<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Exo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Exo.Views.Controls"
    Title="Exo">

    <!--
      Full-bleed WebView2. Caption min/close + optimizers are in React.
      Native overlay is ONLY a thin drag strip above the glass bar so it
      cannot steal clicks from settings / nav / caption buttons.
    -->
    <Grid x:Name="RootGrid"
          Background="#050506"
          Padding="0"
          UseLayoutRounding="True"
          SizeChanged="RootGrid_SizeChanged">

        <Grid x:Name="ContentHost"
              Margin="0"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <WebView2 x:Name="WebHost"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      DefaultBackgroundColor="#050506" />
        </Grid>

        <!--
          Native (non-WebView2) fallback shown only when the WebView2 Runtime
          cannot be reached or repaired. Must not depend on WebView2 to render,
          since WebView2 being broken is exactly the case this covers.
        -->
        <StackPanel x:Name="WebViewFallback"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="440"
                    Spacing="12">
            <TextBlock x:Name="WebViewFallbackTitle"
                       Text="Exo couldn't start its UI runtime"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="WebViewFallbackBody"
                       Text="The WebView2 Runtime looks corrupted and Exo's automatic repair didn't fix it. Reinstalling the runtime usually resolves this."
                       Foreground="#B8B8BC"
                       FontSize="13"
                       TextWrapping="Wrap"
                       TextAlignment="Center" />
            <Button x:Name="WebViewFallbackButton"
                    Content="Open WebView2 download page"
                    HorizontalAlignment="Center"
                    Click="WebViewFallbackButton_Click" />
        </StackPanel>

        <!-- ~10px drag-only strip (matches React pt-2.5). Must NOT cover h-12 bar. -->
        <Border x:Name="TitleChrome"
                Height="10"
                VerticalAlignment="Top"
                Background="Transparent"
                IsHitTestVisible="True">
            <Border x:Name="AppTitleBar"
                    Background="Transparent"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" />
        </Border>

        <!-- Hidden legacy pieces kept for settings flyout / smoke string gates -->
        <Border x:Name="ExoBrandPill" Visibility="Collapsed" Width="0" Height="0">
            <Grid>
                <Button x:Name="NavHome" Visibility="Collapsed" Click="NavHome_Click" />
                <Button x:Name="SettingsButton"
                        Visibility="Collapsed"
                        Click="SettingsButton_Click">
                    <FlyoutBase.AttachedFlyout>
                        <Flyout x:Name="SettingsFlyout"
                                Placement="Bottom"
                                Opened="SettingsFlyout_Opened"
                                Closing="SettingsFlyout_Closing"
                                Closed="SettingsFlyout_Closed">
                            <controls:SettingsSheet x:Name="SettingsSheetHost" />
                        </Flyout>
                    </FlyoutBase.AttachedFlyout>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
