<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Exo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Exo.Views.Controls"
    Title="Exo">

    <!--
      v3.0.3 shell (exo-ui-craft + better-ui hit targets):
      - Left chrome: Settings on home, morphs to Home on module pages (same circle slot)
      - Module icons optically centered in the full bar (not shoved by left/right chrome)
      - CaptionSpacer clears Windows min/close
      - Full circle is clickable (SelectionFill hit-test true)
    -->
    <Grid x:Name="RootGrid"
          Background="{ThemeResource ExoPageBackgroundBrush}"
          Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="NavRail"
                Grid.Row="0"
                Background="Transparent"
                BorderThickness="0"
                Padding="2,4"
                MinHeight="52"
                HorizontalAlignment="Stretch">
            <Grid x:Name="NavRailInner">
                <!-- Layer 1: module icons true-centered in the full bar width -->
                <StackPanel x:Name="ModuleIcons"
                            Orientation="Horizontal"
                            Spacing="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button x:Name="NavDiscord"
                            Style="{StaticResource ExoGlassCircle}"
                            AutomationProperties.Name="Discord"
                            Click="NavDiscord_Click"
                            Tag="discord">
                        <Image Source="ms-appx:///Assets/Logos/discord.png"
                               Width="24" Height="24"
                               Stretch="Uniform"
                               UseLayoutRounding="True"
                               IsHitTestVisible="False"
                               AutomationProperties.AccessibilityView="Raw" />
                    </Button>
                    <Button x:Name="NavSteam"
                            Style="{StaticResource ExoGlassCircle}"
                            AutomationProperties.Name="Steam"
                            Click="NavSteam_Click"
                            Tag="steam">
                        <Image Source="ms-appx:///Assets/Logos/steam.png"
                               Width="24" Height="24"
                               Stretch="Uniform"
                               UseLayoutRounding="True"
                               IsHitTestVisible="False"
                               AutomationProperties.AccessibilityView="Raw" />
                    </Button>
                    <Button x:Name="NavInternet"
                            Style="{StaticResource ExoGlassCircle}"
                            AutomationProperties.Name="Internet"
                            Click="NavInternet_Click"
                            Tag="internet">
                        <Image Source="ms-appx:///Assets/Logos/internet.png"
                               Width="24" Height="24"
                               Stretch="Uniform"
                               UseLayoutRounding="True"
                               IsHitTestVisible="False"
                               AutomationProperties.AccessibilityView="Raw" />
                    </Button>
                    <Button x:Name="NavNvidia"
                            Style="{StaticResource ExoGlassCircle}"
                            AutomationProperties.Name="NVIDIA"
                            Click="NavNvidia_Click"
                            Tag="nvidia">
                        <Image Source="ms-appx:///Assets/Logos/nvidia.png"
                               Width="24" Height="24"
                               Stretch="Uniform"
                               UseLayoutRounding="True"
                               IsHitTestVisible="False"
                               AutomationProperties.AccessibilityView="Raw" />
                    </Button>
                </StackPanel>

                <!-- Layer 2: left chrome — Settings (home) or Home (module) same slot -->
                <Button x:Name="SettingsButton"
                        Style="{StaticResource ExoGlassCircle}"
                        AutomationProperties.Name="Settings"
                        Click="SettingsButton_Click"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="0,0,0,0">
                    <Grid>
                        <FontIcon x:Name="SettingsGearIcon"
                                  Glyph="&#xE713;"
                                  FontSize="15"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsHitTestVisible="False"
                                  RenderTransformOrigin="0.5,0.5">
                            <FontIcon.RenderTransform>
                                <RotateTransform x:Name="SettingsGearRotate" Angle="0" />
                            </FontIcon.RenderTransform>
                        </FontIcon>
                        <FontIcon x:Name="HomeChromeIcon"
                                  Glyph="&#xE80F;"
                                  FontSize="15"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Visibility="Collapsed"
                                  IsHitTestVisible="False" />
                    </Grid>
                    <FlyoutBase.AttachedFlyout>
                        <Flyout x:Name="SettingsFlyout"
                                Placement="Bottom"
                                Opened="SettingsFlyout_Opened"
                                Closing="SettingsFlyout_Closing"
                                Closed="SettingsFlyout_Closed">
                            <Flyout.FlyoutPresenterStyle>
                                <Style TargetType="FlyoutPresenter">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="CornerRadius" Value="0" />
                                    <Setter Property="MaxWidth" Value="392" />
                                </Style>
                            </Flyout.FlyoutPresenterStyle>
                            <controls:SettingsSheet x:Name="SettingsSheetHost" />
                        </Flyout>
                    </FlyoutBase.AttachedFlyout>
                </Button>

                <!-- Hidden legacy name kept for selection chrome code paths -->
                <Button x:Name="NavHome"
                        Visibility="Collapsed"
                        IsHitTestVisible="False"
                        Width="0" Height="0"
                        Click="NavHome_Click" />

                <!-- Layer 3: dead zone under Windows caption buttons -->
                <Border x:Name="CaptionSpacerHost"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        Width="146"
                        IsHitTestVisible="False" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBarHost"
                  Grid.Row="0"
                  Background="Transparent"
                  MinHeight="0">
                <Button x:Name="BackButton"
                        Style="{StaticResource ExoQuietButton}"
                        AutomationProperties.Name="Back to NVIDIA"
                        Click="BackButton_Click"
                        Visibility="Collapsed"
                        MinHeight="32"
                        Padding="12,4"
                        Margin="0,0,0,8"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        AllowFocusOnInteraction="True"
                        IsTabStop="True"
                        UseSystemFocusVisuals="True">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72B;" FontSize="12" VerticalAlignment="Center" IsHitTestVisible="False" />
                        <TextBlock Text="NVIDIA"
                                   Style="{StaticResource ExoCaption}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Border x:Name="ContextLogoHost" Visibility="Collapsed" Width="0" Height="0" />
                <Image x:Name="ContextLogo" Visibility="Collapsed" Width="0" Height="0" />
                <TextBlock x:Name="AppTitleText" Visibility="Collapsed" Text="" />
                <Grid x:Name="TitleBarDragRegion"
                      Background="Transparent"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      MinHeight="0" />
            </Grid>

            <Frame x:Name="ContentFrame"
                   Grid.Row="1"
                   Padding="0"
                   IsTabStop="True"
                   IsNavigationStackEnabled="False" />
        </Grid>
    </Grid>
</Window>
