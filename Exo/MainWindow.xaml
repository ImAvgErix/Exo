<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Exo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Exo.Views.Controls"
    Title="Exo">

    <!--
      v3.0.1 top bar:
      Settings (left, where EXO used to live) · module icons · Home pill when away
      RightInset padding keeps chrome clear of min/close caption buttons.
      Entire NavRail is SetTitleBar — empty glass is draggable.
    -->
    <Grid x:Name="RootGrid"
          Background="{ThemeResource ExoPageBackgroundBrush}"
          Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="NavRail"
                Grid.Row="0"
                Background="Transparent"
                BorderThickness="0"
                Padding="2,4"
                MinHeight="52"
                HorizontalAlignment="Stretch">
            <Grid x:Name="NavRailInner">
                <Grid.ColumnDefinitions>
                    <!-- Settings (always) -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Home when not on dashboard -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Drag + centered modules -->
                    <ColumnDefinition Width="*" />
                    <!-- Clear of Windows caption buttons -->
                    <ColumnDefinition x:Name="CaptionSpacer" Width="138" />
                </Grid.ColumnDefinitions>

                <!-- Settings — left end (replaces EXO bubble position) -->
                <Button x:Name="SettingsButton"
                        Grid.Column="0"
                        Style="{StaticResource ExoGlassCircle}"
                        AutomationProperties.Name="Settings"
                        Click="SettingsButton_Click"
                        Margin="0,0,8,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                    <FontIcon x:Name="SettingsGearIcon"
                              Glyph="&#xE713;"
                              FontSize="15"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              RenderTransformOrigin="0.5,0.5">
                        <FontIcon.RenderTransform>
                            <RotateTransform x:Name="SettingsGearRotate" Angle="0" />
                        </FontIcon.RenderTransform>
                    </FontIcon>
                    <FlyoutBase.AttachedFlyout>
                        <Flyout x:Name="SettingsFlyout"
                                Placement="Bottom"
                                Opened="SettingsFlyout_Opened"
                                Closing="SettingsFlyout_Closing"
                                Closed="SettingsFlyout_Closed">
                            <Flyout.FlyoutPresenterStyle>
                                <Style TargetType="FlyoutPresenter">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="CornerRadius" Value="0" />
                                    <Setter Property="MaxWidth" Value="360" />
                                </Style>
                            </Flyout.FlyoutPresenterStyle>
                            <controls:SettingsSheet x:Name="SettingsSheetHost" />
                        </Flyout>
                    </FlyoutBase.AttachedFlyout>
                </Button>

                <!-- Home — clear pill (away from modules); goes to dashboard -->
                <Button x:Name="NavHome"
                        Grid.Column="1"
                        Style="{StaticResource ExoQuietButton}"
                        AutomationProperties.Name="Home"
                        Click="NavHome_Click"
                        MinWidth="88"
                        MinHeight="36"
                        Padding="14,6"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE80F;" FontSize="14" VerticalAlignment="Center" />
                        <TextBlock Text="Home"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Transparent drag field + centered module circles -->
                <Grid Grid.Column="2" Background="Transparent" MinHeight="48">
                    <StackPanel Orientation="Horizontal"
                                Spacing="10"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Button x:Name="NavDiscord"
                                Style="{StaticResource ExoGlassCircle}"
                                AutomationProperties.Name="Discord"
                                Click="NavDiscord_Click"
                                Tag="discord">
                            <Image Source="ms-appx:///Assets/Logos/discord.png"
                                   Width="22" Height="22"
                                   Stretch="Uniform"
                                   UseLayoutRounding="True"
                                   AutomationProperties.AccessibilityView="Raw" />
                        </Button>
                        <Button x:Name="NavSteam"
                                Style="{StaticResource ExoGlassCircle}"
                                AutomationProperties.Name="Steam"
                                Click="NavSteam_Click"
                                Tag="steam">
                            <Image Source="ms-appx:///Assets/Logos/steam.png"
                                   Width="22" Height="22"
                                   Stretch="Uniform"
                                   UseLayoutRounding="True"
                                   AutomationProperties.AccessibilityView="Raw" />
                        </Button>
                        <Button x:Name="NavInternet"
                                Style="{StaticResource ExoGlassCircle}"
                                AutomationProperties.Name="Internet"
                                Click="NavInternet_Click"
                                Tag="internet">
                            <Image Source="ms-appx:///Assets/Logos/internet.png"
                                   Width="22" Height="22"
                                   Stretch="Uniform"
                                   UseLayoutRounding="True"
                                   AutomationProperties.AccessibilityView="Raw" />
                        </Button>
                        <Button x:Name="NavNvidia"
                                Style="{StaticResource ExoGlassCircle}"
                                AutomationProperties.Name="NVIDIA"
                                Click="NavNvidia_Click"
                                Tag="nvidia">
                            <Image Source="ms-appx:///Assets/Logos/nvidia.png"
                                   Width="22" Height="22"
                                   Stretch="Uniform"
                                   UseLayoutRounding="True"
                                   AutomationProperties.AccessibilityView="Raw" />
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Empty column under caption buttons — not interactive chrome -->
                <Border Grid.Column="3" Background="Transparent" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Secondary back only for NVIDIA panel → optimizer -->
            <Grid x:Name="TitleBarHost"
                  Grid.Row="0"
                  Background="Transparent"
                  MinHeight="0">
                <Button x:Name="BackButton"
                        Style="{StaticResource ExoQuietButton}"
                        AutomationProperties.Name="Back to NVIDIA"
                        Click="BackButton_Click"
                        Visibility="Collapsed"
                        MinHeight="32"
                        Padding="12,4"
                        Margin="0,0,0,8"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        AllowFocusOnInteraction="True"
                        IsTabStop="True"
                        UseSystemFocusVisuals="True">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72B;" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="NVIDIA"
                                   Style="{StaticResource ExoCaption}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Border x:Name="ContextLogoHost" Visibility="Collapsed" Width="0" Height="0" />
                <Image x:Name="ContextLogo" Visibility="Collapsed" Width="0" Height="0" />
                <TextBlock x:Name="AppTitleText" Visibility="Collapsed" Text="" />
                <Grid x:Name="TitleBarDragRegion"
                      Background="Transparent"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      MinHeight="0" />
            </Grid>

            <Frame x:Name="ContentFrame"
                   Grid.Row="1"
                   Padding="0"
                   IsTabStop="True"
                   IsNavigationStackEnabled="False" />
        </Grid>
    </Grid>
</Window>
