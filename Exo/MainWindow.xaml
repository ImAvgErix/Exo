<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Exo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Exo.Views.Controls"
    Title="Exo">

    <!--
      v2.5 remodel shell:
      left icon rail (custom — not NavigationView) + content column.
      Settings gear stays a flyout on the rail.
    -->
    <Grid x:Name="RootGrid" Background="{ThemeResource ExoPageBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="76" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== LEFT RAIL ===== -->
        <Border x:Name="NavRail"
                Grid.Column="0"
                Background="#050505"
                BorderBrush="{ThemeResource ExoCardStrokeBrush}"
                BorderThickness="0,0,1,0"
                Padding="10,12,10,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Brand → Home -->
                <Button x:Name="NavHome"
                        Style="{StaticResource ExoRailButton}"
                        AutomationProperties.Name="Home"
                        Click="NavHome_Click"
                        Margin="0,0,0,14"
                        Height="48">
                    <TextBlock Text="EXO"
                               FontFamily="{StaticResource ExoUiFontSemiBold}"
                               FontSize="13"
                               FontWeight="Bold"
                               CharacterSpacing="120"
                               Foreground="{ThemeResource ExoPrimaryTextBrush}"
                               HorizontalAlignment="Center" />
                </Button>

                <StackPanel Grid.Row="1" Spacing="6">
                    <Button x:Name="NavDiscord"
                            Style="{StaticResource ExoRailButton}"
                            AutomationProperties.Name="Discord"
                            Click="NavDiscord_Click"
                            Tag="discord">
                        <StackPanel Spacing="3" HorizontalAlignment="Center">
                            <Image Source="ms-appx:///Assets/Logos/discord.png"
                                   Width="22" Height="22"
                                   Stretch="Uniform"
                                   UseLayoutRounding="True"
                                   AutomationProperties.AccessibilityView="Raw" />
                            <TextBlock Text="Discord" FontSize="10" FontFamily="{StaticResource ExoUiFont}" Opacity="0.75" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavSteam"
                            Style="{StaticResource ExoRailButton}"
                            AutomationProperties.Name="Steam"
                            Click="NavSteam_Click"
                            Tag="steam">
                        <StackPanel Spacing="3" HorizontalAlignment="Center">
                            <Image Source="ms-appx:///Assets/Logos/steam.png"
                                   Width="22" Height="22"
                                   Stretch="Uniform"
                                   UseLayoutRounding="True"
                                   AutomationProperties.AccessibilityView="Raw" />
                            <TextBlock Text="Steam" FontSize="10" FontFamily="{StaticResource ExoUiFont}" Opacity="0.75" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavInternet"
                            Style="{StaticResource ExoRailButton}"
                            AutomationProperties.Name="Internet"
                            Click="NavInternet_Click"
                            Tag="internet">
                        <StackPanel Spacing="3" HorizontalAlignment="Center">
                            <Image Source="ms-appx:///Assets/Logos/internet.png"
                                   Width="22" Height="22"
                                   Stretch="Uniform"
                                   UseLayoutRounding="True"
                                   AutomationProperties.AccessibilityView="Raw" />
                            <TextBlock Text="Net" FontSize="10" FontFamily="{StaticResource ExoUiFont}" Opacity="0.75" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavNvidia"
                            Style="{StaticResource ExoRailButton}"
                            AutomationProperties.Name="NVIDIA"
                            Click="NavNvidia_Click"
                            Tag="nvidia">
                        <StackPanel Spacing="3" HorizontalAlignment="Center">
                            <Image Source="ms-appx:///Assets/Logos/nvidia.png"
                                   Width="22" Height="22"
                                   Stretch="Uniform"
                                   UseLayoutRounding="True"
                                   AutomationProperties.AccessibilityView="Raw" />
                            <TextBlock Text="GPU" FontSize="10" FontFamily="{StaticResource ExoUiFont}" Opacity="0.75" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Button x:Name="SettingsButton"
                        Grid.Row="2"
                        Style="{StaticResource ExoRailButton}"
                        AutomationProperties.Name="Settings"
                        Click="SettingsButton_Click"
                        Height="44">
                    <FontIcon x:Name="SettingsGearIcon"
                              Glyph="&#xE713;"
                              FontSize="15"
                              RenderTransformOrigin="0.5,0.5">
                        <FontIcon.RenderTransform>
                            <RotateTransform x:Name="SettingsGearRotate" Angle="0" />
                        </FontIcon.RenderTransform>
                    </FontIcon>
                    <FlyoutBase.AttachedFlyout>
                        <Flyout x:Name="SettingsFlyout"
                                Placement="Right"
                                Opened="SettingsFlyout_Opened"
                                Closing="SettingsFlyout_Closing"
                                Closed="SettingsFlyout_Closed">
                            <Flyout.FlyoutPresenterStyle>
                                <Style TargetType="FlyoutPresenter">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="CornerRadius" Value="0" />
                                    <Setter Property="MaxWidth" Value="360" />
                                </Style>
                            </Flyout.FlyoutPresenterStyle>
                            <controls:SettingsSheet x:Name="SettingsSheetHost" />
                        </Flyout>
                    </FlyoutBase.AttachedFlyout>
                </Button>
            </Grid>
        </Border>

        <!-- ===== CONTENT COLUMN ===== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Drag strip + contextual back (Nvidia panel only) -->
            <Grid Grid.Row="0" Background="{ThemeResource ExoPageBackgroundBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition x:Name="CaptionSpacer" Width="138" />
                </Grid.ColumnDefinitions>

                <Button x:Name="BackButton"
                        Style="{StaticResource ExoIconButton}"
                        AutomationProperties.Name="Back"
                        Click="BackButton_Click"
                        Visibility="Collapsed"
                        Width="32" Height="32"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        AllowFocusOnInteraction="True"
                        IsTabStop="True"
                        UseSystemFocusVisuals="True">
                    <FontIcon Glyph="&#xE72B;" FontSize="12" />
                </Button>

                <!-- Hidden legacy chrome names kept for zero refs / a11y tooling -->
                <Border x:Name="ContextLogoHost" Visibility="Collapsed" Width="0" Height="0" />
                <Image x:Name="ContextLogo" Visibility="Collapsed" Width="0" Height="0" />
                <TextBlock x:Name="AppTitleText" Visibility="Collapsed" Text="" />

                <Grid x:Name="TitleBarDragRegion"
                      Grid.Column="1"
                      Background="Transparent"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" />
            </Grid>

            <Frame x:Name="ContentFrame"
                   Grid.Row="1"
                   Padding="0"
                   IsTabStop="True"
                   IsNavigationStackEnabled="False" />
        </Grid>
    </Grid>
</Window>
