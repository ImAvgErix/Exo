<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Exo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Exo.Views.Controls"
    Title="Exo">

    <!--
      v2.6 top bar: EXO · icon modules (no text labels) · Settings.
      Live modules are not duplicated on the home page.
    -->
    <Grid x:Name="RootGrid"
          Background="{ThemeResource ExoPageBackgroundBrush}"
          Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="NavRail"
                Grid.Row="0"
                Background="{ThemeResource ExoRailGlassFillBrush}"
                BorderBrush="{ThemeResource ExoGlassStrokeBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="8,6"
                MinHeight="56"
                HorizontalAlignment="Stretch">
            <Grid>
                <Border BorderBrush="{ThemeResource ExoSpecularStrokeBrush}"
                        BorderThickness="0,1,0,0"
                        CornerRadius="14"
                        Margin="1,0,1,0"
                        IsHitTestVisible="False"
                        VerticalAlignment="Top"
                        Height="16"
                        Opacity="0.7" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="NavHome"
                            Style="{StaticResource ExoRailButton}"
                            AutomationProperties.Name="Home"
                            Click="NavHome_Click"
                            Width="64"
                            Height="44"
                            HorizontalAlignment="Left">
                        <TextBlock Text="EXO"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   CharacterSpacing="120"
                                   Foreground="{ThemeResource ExoPrimaryTextBrush}"
                                   HorizontalAlignment="Center" />
                    </Button>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Button x:Name="NavDiscord"
                                Style="{StaticResource ExoRailButton}"
                                AutomationProperties.Name="Discord"
                                Click="NavDiscord_Click"
                                Tag="discord"
                                Width="48"
                                Height="44">
                            <Image Source="ms-appx:///Assets/Logos/discord.png"
                                   Width="22" Height="22"
                                   Stretch="Uniform"
                                   UseLayoutRounding="True"
                                   AutomationProperties.AccessibilityView="Raw" />
                        </Button>
                        <Button x:Name="NavSteam"
                                Style="{StaticResource ExoRailButton}"
                                AutomationProperties.Name="Steam"
                                Click="NavSteam_Click"
                                Tag="steam"
                                Width="48"
                                Height="44">
                            <Image Source="ms-appx:///Assets/Logos/steam.png"
                                   Width="22" Height="22"
                                   Stretch="Uniform"
                                   UseLayoutRounding="True"
                                   AutomationProperties.AccessibilityView="Raw" />
                        </Button>
                        <Button x:Name="NavInternet"
                                Style="{StaticResource ExoRailButton}"
                                AutomationProperties.Name="Internet"
                                Click="NavInternet_Click"
                                Tag="internet"
                                Width="48"
                                Height="44">
                            <Image Source="ms-appx:///Assets/Logos/internet.png"
                                   Width="22" Height="22"
                                   Stretch="Uniform"
                                   UseLayoutRounding="True"
                                   AutomationProperties.AccessibilityView="Raw" />
                        </Button>
                        <Button x:Name="NavNvidia"
                                Style="{StaticResource ExoRailButton}"
                                AutomationProperties.Name="NVIDIA"
                                Click="NavNvidia_Click"
                                Tag="nvidia"
                                Width="48"
                                Height="44">
                            <Image Source="ms-appx:///Assets/Logos/nvidia.png"
                                   Width="22" Height="22"
                                   Stretch="Uniform"
                                   UseLayoutRounding="True"
                                   AutomationProperties.AccessibilityView="Raw" />
                        </Button>
                    </StackPanel>

                    <Button x:Name="SettingsButton"
                            Grid.Column="2"
                            Style="{StaticResource ExoRailButton}"
                            AutomationProperties.Name="Settings"
                            Click="SettingsButton_Click"
                            Width="48"
                            Height="44"
                            HorizontalAlignment="Right">
                        <FontIcon x:Name="SettingsGearIcon"
                                  Glyph="&#xE713;"
                                  FontSize="15"
                                  RenderTransformOrigin="0.5,0.5">
                            <FontIcon.RenderTransform>
                                <RotateTransform x:Name="SettingsGearRotate" Angle="0" />
                            </FontIcon.RenderTransform>
                        </FontIcon>
                        <FlyoutBase.AttachedFlyout>
                            <Flyout x:Name="SettingsFlyout"
                                    Placement="Bottom"
                                    Opened="SettingsFlyout_Opened"
                                    Closing="SettingsFlyout_Closing"
                                    Closed="SettingsFlyout_Closed">
                                <Flyout.FlyoutPresenterStyle>
                                    <Style TargetType="FlyoutPresenter">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="CornerRadius" Value="0" />
                                        <Setter Property="MaxWidth" Value="360" />
                                    </Style>
                                </Flyout.FlyoutPresenterStyle>
                                <controls:SettingsSheet x:Name="SettingsSheetHost" />
                            </Flyout>
                        </FlyoutBase.AttachedFlyout>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBarHost"
                  Grid.Row="0"
                  Background="Transparent"
                  MinHeight="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition x:Name="CaptionSpacer" Width="138" />
                </Grid.ColumnDefinitions>

                <Button x:Name="BackButton"
                        Style="{StaticResource ExoIconButton}"
                        AutomationProperties.Name="Back"
                        Click="BackButton_Click"
                        Visibility="Collapsed"
                        Width="32" Height="32"
                        Margin="0,0,0,8"
                        VerticalAlignment="Center"
                        AllowFocusOnInteraction="True"
                        IsTabStop="True"
                        UseSystemFocusVisuals="True">
                    <FontIcon Glyph="&#xE72B;" FontSize="12" />
                </Button>

                <Border x:Name="ContextLogoHost" Visibility="Collapsed" Width="0" Height="0" />
                <Image x:Name="ContextLogo" Visibility="Collapsed" Width="0" Height="0" />
                <TextBlock x:Name="AppTitleText" Visibility="Collapsed" Text="" />

                <Grid x:Name="TitleBarDragRegion"
                      Grid.Column="1"
                      Background="Transparent"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      MinHeight="8" />
            </Grid>

            <Frame x:Name="ContentFrame"
                   Grid.Row="1"
                   Padding="0"
                   IsTabStop="True"
                   IsNavigationStackEnabled="False" />
        </Grid>
    </Grid>
</Window>
