<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Exo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Exo.Views.Controls"
    Title="Exo">

    <!--
      Full-bleed WebView2. Caption min/close + optimizers are in React.
      Native overlay is ONLY a thin drag strip above the glass bar so it
      cannot steal clicks from settings / nav / caption buttons.
    -->
    <Grid x:Name="RootGrid"
          Background="#050506"
          Padding="0"
          UseLayoutRounding="True"
          SizeChanged="RootGrid_SizeChanged">

        <Grid x:Name="ContentHost"
              Margin="0"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <WebView2 x:Name="WebHost"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      DefaultBackgroundColor="#050506" />
        </Grid>

        <!-- ~10px drag-only strip (matches React pt-2.5). Must NOT cover h-12 bar. -->
        <Border x:Name="TitleChrome"
                Height="10"
                VerticalAlignment="Top"
                Background="Transparent"
                IsHitTestVisible="True">
            <Border x:Name="AppTitleBar"
                    Background="Transparent"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" />
        </Border>

        <!-- Hidden legacy pieces kept for settings flyout / smoke string gates -->
        <Border x:Name="ExoBrandPill" Visibility="Collapsed" Width="0" Height="0">
            <Grid>
                <Button x:Name="NavHome" Visibility="Collapsed" Click="NavHome_Click" />
                <Button x:Name="SettingsButton"
                        Visibility="Collapsed"
                        Click="SettingsButton_Click">
                    <FlyoutBase.AttachedFlyout>
                        <Flyout x:Name="SettingsFlyout"
                                Placement="Bottom"
                                Opened="SettingsFlyout_Opened"
                                Closing="SettingsFlyout_Closing"
                                Closed="SettingsFlyout_Closed">
                            <controls:SettingsSheet x:Name="SettingsSheetHost" />
                        </Flyout>
                    </FlyoutBase.AttachedFlyout>
                </Button>
            </Grid>
        </Border>
        <Border x:Name="NavRail" Visibility="Collapsed" Width="0" Height="0">
            <StackPanel x:Name="ModuleIcons">
                <Button x:Name="NavDiscord" Tag="discord" Click="NavDiscord_Click" />
                <Button x:Name="NavSteam" Tag="steam" Click="NavSteam_Click" />
                <Button x:Name="NavInternet" Tag="internet" Click="NavInternet_Click" />
                <Button x:Name="NavNvidia" Tag="nvidia" Click="NavNvidia_Click" />
                <Button x:Name="NavRiot" Tag="riot" Click="NavRiot_Click" />
                <Button x:Name="NavEpic" Tag="epic" Click="NavEpic_Click" />
            </StackPanel>
        </Border>
        <Frame x:Name="ContentFrame" Visibility="Collapsed" Width="0" Height="0" />
    </Grid>
</Window>
