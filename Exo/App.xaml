                    <SolidColorBrush x:Key="ExoGlassFillBrush" Color="#FF08080A" />
                    <SolidColorBrush x:Key="ExoGlassStrokeBrush" Color="#30FFFFFF" />
                    <SolidColorBrush x:Key="ExoRailGlassFillBrush" Color="#FF08080A" />
