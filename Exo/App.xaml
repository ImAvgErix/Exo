                    <SolidColorBrush x:Key="ExoWarningSoftBrush" Color="#22F59E0B" />
                    <SolidColorBrush x:Key="ExoErrorBrush" Color="#F87171" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <SolidColorBrush x:Key="ExoDiscordBrush" Color="#8B7CFF" />
            <SolidColorBrush x:Key="ExoSteamBrush" Color="#5AA9FF" />
            <SolidColorBrush x:Key="ExoInternetBrush" Color="#22D3EE" />
