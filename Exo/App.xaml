<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Exo.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Styles/ThemeResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <!-- AMOLED pure black shell + slightly lifted cards for clearer depth -->
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="SystemAccentColor">#F5F5F4</Color>
                    <Color x:Key="SystemAccentColorLight1">#FAFAF9</Color>
                    <Color x:Key="SystemAccentColorLight2">#E7E5E4</Color>
                    <Color x:Key="SystemAccentColorLight3">#D6D3D1</Color>
                    <Color x:Key="SystemAccentColorDark1">#A8A29E</Color>
                    <Color x:Key="SystemAccentColorDark2">#78716C</Color>
                    <Color x:Key="SystemAccentColorDark3">#57534E</Color>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#F5F5F4" />
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#E7E5E4" />
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#D6D3D1" />
                    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#F5F5F4" />
                    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="#A8A29E" />
                    <SolidColorBrush x:Key="ExoPageBackgroundBrush" Color="#000000" />
                    <SolidColorBrush x:Key="ExoCardFillBrush" Color="#0C0C0C" />
                    <SolidColorBrush x:Key="ExoCardStrokeBrush" Color="#28FFFFFF" />
                    <SolidColorBrush x:Key="ExoAccentBrush" Color="#F5F5F4" />
                    <SolidColorBrush x:Key="ExoOnAccentBrush" Color="#000000" />
                    <SolidColorBrush x:Key="ExoAccentSoftBrush" Color="#18FFFFFF" />
                    <SolidColorBrush x:Key="ExoQuietButtonFillBrush" Color="#0C0C0C" />
                    <SolidColorBrush x:Key="ExoPrimaryTextBrush" Color="#FAFAF9" />
                    <SolidColorBrush x:Key="ExoSecondaryTextBrush" Color="#D6D3D1" />
                    <SolidColorBrush x:Key="ExoMutedTextBrush" Color="#A1A1AA" />
                    <SolidColorBrush x:Key="ExoSuccessBrush" Color="#34D399" />
                    <SolidColorBrush x:Key="ExoWarningBrush" Color="#FBBF24" />
                    <SolidColorBrush x:Key="ExoWarningSoftBrush" Color="#22F59E0B" />
                    <SolidColorBrush x:Key="ExoErrorBrush" Color="#F87171" />
                </ResourceDictionary>
                <!-- Warm cream / beige light mode for easier long-session reading -->
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="SystemAccentColor">#3D3429</Color>
                    <Color x:Key="SystemAccentColorLight1">#4A4034</Color>
                    <Color x:Key="SystemAccentColorLight2">#5C5144</Color>
                    <Color x:Key="SystemAccentColorLight3">#6B5F50</Color>
                    <Color x:Key="SystemAccentColorDark1">#2A231C</Color>
                    <Color x:Key="SystemAccentColorDark2">#1C1712</Color>
                    <Color x:Key="SystemAccentColorDark3">#14100C</Color>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#3D3429" />
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#4A4034" />
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#5C5144" />
                    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#2A231C" />
                    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="#5C5144" />
                    <!-- Cream page — single source of truth with ThemeService.SoftStone (#F3EDE3) -->
                    <SolidColorBrush x:Key="ExoPageBackgroundBrush" Color="#F3EDE3" />
                    <SolidColorBrush x:Key="ExoCardFillBrush" Color="#FCFAF6" />
                    <SolidColorBrush x:Key="ExoCardStrokeBrush" Color="#593D3429" />
                    <SolidColorBrush x:Key="ExoAccentBrush" Color="#3D3429" />
                    <SolidColorBrush x:Key="ExoOnAccentBrush" Color="#FCFAF6" />
                    <SolidColorBrush x:Key="ExoAccentSoftBrush" Color="#1A3D3429" />
                    <SolidColorBrush x:Key="ExoQuietButtonFillBrush" Color="#FCFAF6" />
                    <SolidColorBrush x:Key="ExoPrimaryTextBrush" Color="#1C1712" />
                    <SolidColorBrush x:Key="ExoSecondaryTextBrush" Color="#3D3429" />
                    <SolidColorBrush x:Key="ExoMutedTextBrush" Color="#6B5F50" />
                    <SolidColorBrush x:Key="ExoSuccessBrush" Color="#15803D" />
                    <SolidColorBrush x:Key="ExoWarningBrush" Color="#B45309" />
                    <SolidColorBrush x:Key="ExoWarningSoftBrush" Color="#18B45309" />
                    <SolidColorBrush x:Key="ExoErrorBrush" Color="#B91C1C" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Default">
                    <Color x:Key="SystemAccentColor">#F5F5F4</Color>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#F5F5F4" />
                    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#F5F5F4" />
                    <SolidColorBrush x:Key="ExoPageBackgroundBrush" Color="#000000" />
                    <SolidColorBrush x:Key="ExoCardFillBrush" Color="#0C0C0C" />
                    <SolidColorBrush x:Key="ExoCardStrokeBrush" Color="#30FFFFFF" />
                    <SolidColorBrush x:Key="ExoAccentBrush" Color="#F5F5F4" />
                    <SolidColorBrush x:Key="ExoOnAccentBrush" Color="#000000" />
                    <SolidColorBrush x:Key="ExoAccentSoftBrush" Color="#16FFFFFF" />
                    <SolidColorBrush x:Key="ExoQuietButtonFillBrush" Color="#0C0C0C" />
                    <SolidColorBrush x:Key="ExoPrimaryTextBrush" Color="#FAFAF9" />
                    <SolidColorBrush x:Key="ExoSecondaryTextBrush" Color="#D6D3D1" />
                    <SolidColorBrush x:Key="ExoMutedTextBrush" Color="#A8A29E" />
                    <SolidColorBrush x:Key="ExoSuccessBrush" Color="#4ADE80" />
                    <SolidColorBrush x:Key="ExoWarningBrush" Color="#FBBF24" />
                    <SolidColorBrush x:Key="ExoWarningSoftBrush" Color="#22F59E0B" />
                    <SolidColorBrush x:Key="ExoErrorBrush" Color="#F87171" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
