{
  "_comment": "Host/boot keys only. Apply-DiscordProfile never copies audio, tray, startup, window geometry, or in-app prefs from this file.",
  "SKIP_HOST_UPDATE": true,
  "debugLogging": false,
  "DESKTOP_TTI_REMOVE_V8_CACHE_CLEAR": true,
  "DESKTOP_TTI_DNSTCP_WARMUP": true,
  "DESKTOP_TTI_EARLY_UPDATE_CHECK": false,
  "DESKTOP_TTI_UPDATE_BACKOFF_MAX_MS": 2000,
  "DESKTOP_TTI_SPLASH_USE_WEBP": true,
  "chromiumSwitches": {
    "disable-breakpad": 1,
    "disable-crash-reporter": 1,
    "disable-domain-reliability": 1,
    "disable-logging": 1,
    "disable-component-update": 1,
    "disable-background-networking": 1,
    "no-pings": 1,
    "disable-renderer-backgrounding": 1,
    "disable-backgrounding-occluded-windows": 1,
    "disable-background-timer-throttling": 1,
    "disable-hang-monitor": 1
  }
}
