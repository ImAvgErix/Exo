<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Exo.Views.Controls.SettingsSheet"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="UserControl_Loaded"
    Width="304">

    <!--
      Frosted glass gear flyout (opens Right of gear).
      SheetRoot is the open-animation target (fade + soft drop from the gear).
      v2.6: acrylic-backed panel, denser grouping, specular rim.
    -->
    <Border x:Name="SheetRoot"
            Background="{ThemeResource ExoSettingsAcrylicBrush}"
            BorderBrush="{ThemeResource ExoGlassStrokeBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource ExoGlassRadius}"
            Padding="16,14,16,14"
            RenderTransformOrigin="0.5,0">
        <Border.RenderTransform>
            <CompositeTransform x:Name="SheetTransform" />
        </Border.RenderTransform>
        <Grid>
            <Border BorderBrush="{ThemeResource ExoSpecularStrokeBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="{StaticResource ExoGlassRadius}"
                    Margin="1,0,1,0"
                    IsHitTestVisible="False"
                    VerticalAlignment="Top"
                    Height="20"
                    Opacity="0.9" />
            <StackPanel Spacing="0">

                <TextBlock Text="APPEARANCE"
                           Style="{StaticResource ExoSectionTitle}"
                           Margin="0,0,0,8" />
                <Grid ColumnSpacing="8" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="DarkModeRadio"
                                 Grid.Column="0"
                                 Style="{StaticResource ExoThemeChoice}"
                                 Content="Dark"
                                 GroupName="ExoTheme"
                                 MinHeight="36"
                                 Padding="8,7"
                                 IsChecked="{x:Bind ViewModel.IsDarkMode, Mode=TwoWay}"
                                 Click="DarkMode_Click"
                                 AutomationProperties.Name="Dark mode" />
                    <RadioButton x:Name="LightModeRadio"
                                 Grid.Column="1"
                                 Style="{StaticResource ExoThemeChoice}"
                                 Content="Light"
                                 GroupName="ExoTheme"
                                 MinHeight="36"
                                 Padding="8,7"
                                 IsChecked="{x:Bind ViewModel.IsLightMode, Mode=TwoWay}"
                                 Click="LightMode_Click"
                                 AutomationProperties.Name="Light mode" />
                </Grid>

                <Rectangle Height="1" Margin="0,14" Fill="{ThemeResource ExoSpecularStrokeBrush}" />

                <TextBlock Text="UPDATES"
                           Style="{StaticResource ExoSectionTitle}"
                           Margin="0,0,0,8" />
                <Grid Margin="0,0,0,10" MinHeight="28">
                    <TextBlock Text="Check on launch"
                               FontFamily="{StaticResource ExoUiFont}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                    <ToggleSwitch Style="{StaticResource ExoCompactSwitch}"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  AutomationProperties.Name="Check for updates on launch"
                                  IsOn="{x:Bind ViewModel.CheckForUpdatesOnLaunch, Mode=TwoWay}"
                                  OnContent=""
                                  OffContent="" />
                </Grid>
                <Button Style="{StaticResource ExoPrimaryButton}"
                        Content="Check for updates"
                        MinHeight="40"
                        Padding="14,9"
                        HorizontalAlignment="Stretch"
                        AutomationProperties.Name="Check for Exo app updates"
                        Command="{x:Bind ViewModel.CheckForUpdatesCommand}"
                        IsEnabled="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                <Grid MinHeight="34" Margin="0,8,0,0">
                    <StackPanel Spacing="6"
                                VerticalAlignment="Center"
                                Visibility="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{x:Bind ViewModel.UpdateProgressLabel, Mode=OneWay}"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                        <ProgressBar Minimum="0"
                                     Maximum="100"
                                     Value="{x:Bind ViewModel.UpdateProgressPercent, Mode=OneWay}"
                                     IsIndeterminate="{x:Bind ViewModel.IsUpdateProgressIndeterminate, Mode=OneWay}"
                                     Height="3"
                                     CornerRadius="2"
                                     Foreground="{ThemeResource ExoAccentBrush}" />
                    </StackPanel>
                    <TextBlock Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}"
                               Style="{StaticResource ExoCaption}"
                               TextWrapping="WrapWholeWords"
                               MaxLines="2"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               Visibility="{x:Bind ViewModel.ShowIdleUpdateStatus, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                               AutomationProperties.LiveSetting="Polite" />
                </Grid>

                <Rectangle Height="1" Margin="0,14" Fill="{ThemeResource ExoSpecularStrokeBrush}" />

                <Grid ColumnSpacing="8" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Style="{StaticResource ExoQuietButton}"
                            Content="Report issue"
                            MinHeight="36"
                            Padding="10,7"
                            HorizontalAlignment="Stretch"
                            AutomationProperties.Name="Report Exo issue on GitHub"
                            Command="{x:Bind ViewModel.ReportIssueCommand}" />
                    <Button Grid.Column="1"
                            Style="{StaticResource ExoQuietButton}"
                            Content="Open logs"
                            MinHeight="36"
                            Padding="10,7"
                            HorizontalAlignment="Stretch"
                            AutomationProperties.Name="Open Exo logs folder"
                            Command="{x:Bind ViewModel.OpenLogsFolderCommand}" />
                </Grid>

                <Grid>
                    <TextBlock Text="App version"
                               FontFamily="{StaticResource ExoUiFont}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource ExoMutedTextBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                               FontFamily="{StaticResource ExoUiFontSemiBold}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
