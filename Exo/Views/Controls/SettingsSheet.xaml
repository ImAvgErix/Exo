<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Exo.Views.Controls.SettingsSheet"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="UserControl_Loaded"
    Width="308">

    <!--
      Compact dropdown panel (Flyout content). Matches OptiCard chrome.
      SheetRoot is the open-animation target (fade + soft drop from the gear).
      Dismiss by clicking outside — no close button.
    -->
    <Border x:Name="SheetRoot"
            Background="{ThemeResource OptiCardFillBrush}"
            BorderBrush="{ThemeResource OptiCardStrokeBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource OptiCardRadius}"
            Padding="18,16,18,16"
            RenderTransformOrigin="0.5,0">
        <Border.RenderTransform>
            <CompositeTransform x:Name="SheetTransform" />
        </Border.RenderTransform>
        <StackPanel Spacing="0">

            <!-- Appearance — selected theme reads as white pill -->
            <TextBlock Text="APPEARANCE"
                       Style="{StaticResource OptiSectionTitle}"
                       Margin="0,0,0,10" />
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <RadioButton x:Name="DarkModeRadio"
                             Grid.Column="0"
                             Style="{StaticResource OptiThemeChoice}"
                             Content="Dark"
                             GroupName="OptiTheme"
                             MinHeight="40"
                             Padding="10,8"
                             IsChecked="{x:Bind ViewModel.IsDarkMode, Mode=TwoWay}"
                             Click="DarkMode_Click"
                             AutomationProperties.Name="Dark mode" />
                <RadioButton x:Name="LightModeRadio"
                             Grid.Column="1"
                             Style="{StaticResource OptiThemeChoice}"
                             Content="Light"
                             GroupName="OptiTheme"
                             MinHeight="40"
                             Padding="10,8"
                             IsChecked="{x:Bind ViewModel.IsLightMode, Mode=TwoWay}"
                             Click="LightMode_Click"
                             AutomationProperties.Name="Light mode" />
            </Grid>

            <Rectangle Height="1" Margin="0,16" Fill="{ThemeResource OptiCardStrokeBrush}" Opacity="0.55" />

            <!-- Updates -->
            <TextBlock Text="UPDATES"
                       Style="{StaticResource OptiSectionTitle}"
                       Margin="0,0,0,10" />
            <Grid Margin="0,0,0,12" MinHeight="32">
                <TextBlock Text="Check on launch"
                           FontFamily="{StaticResource OptiUiFont}"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                <ToggleSwitch Style="{StaticResource OptiCompactSwitch}"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              AutomationProperties.Name="Check for updates on launch"
                              IsOn="{x:Bind ViewModel.AutoUpdateScripts, Mode=TwoWay}"
                              OnContent=""
                              OffContent="" />
            </Grid>
            <Button Style="{StaticResource OptiPrimaryButton}"
                    Content="Check for updates"
                    MinHeight="40"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="Check for Exo app updates"
                    Command="{x:Bind ViewModel.CheckForUpdatesCommand}"
                    IsEnabled="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
            <!-- Fixed-height status slot so progress never jumps the flyout -->
            <Grid MinHeight="40" Margin="0,8,0,0">
                <StackPanel Spacing="6"
                            VerticalAlignment="Center"
                            Visibility="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{x:Bind ViewModel.UpdateProgressLabel, Mode=OneWay}"
                               FontFamily="{StaticResource OptiUiFontSemiBold}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                    <ProgressBar Minimum="0"
                                 Maximum="100"
                                 Value="{x:Bind ViewModel.UpdateProgressPercent, Mode=OneWay}"
                                 IsIndeterminate="{x:Bind ViewModel.IsUpdateProgressIndeterminate, Mode=OneWay}"
                                 Height="3"
                                 CornerRadius="2"
                                 Foreground="{ThemeResource OptiAccentBrush}" />
                </StackPanel>
                <TextBlock Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}"
                           Style="{StaticResource OptiCaption}"
                           TextWrapping="WrapWholeWords"
                           MaxLines="2"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"
                           Visibility="{x:Bind ViewModel.ShowIdleUpdateStatus, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                           AutomationProperties.LiveSetting="Polite" />
            </Grid>

            <Rectangle Height="1" Margin="0,16" Fill="{ThemeResource OptiCardStrokeBrush}" Opacity="0.55" />

            <!-- Support -->
            <Grid ColumnSpacing="8" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Style="{StaticResource OptiQuietButton}"
                        Content="Report issue"
                        MinHeight="38"
                        HorizontalAlignment="Stretch"
                        AutomationProperties.Name="Report Exo issue on GitHub"
                        Command="{x:Bind ViewModel.ReportIssueCommand}" />
                <Button Grid.Column="1"
                        Style="{StaticResource OptiQuietButton}"
                        Content="Open logs"
                        MinHeight="38"
                        HorizontalAlignment="Stretch"
                        AutomationProperties.Name="Open Exo logs folder"
                        Command="{x:Bind ViewModel.OpenLogsFolderCommand}" />
            </Grid>

            <!-- Version footer -->
            <Grid>
                <TextBlock Text="App version"
                           FontFamily="{StaticResource OptiUiFont}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource OptiMutedTextBrush}" />
                <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
