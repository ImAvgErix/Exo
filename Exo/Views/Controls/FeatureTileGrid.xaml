<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Exo.Views.Controls.FeatureTileGrid"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Exo.ViewModels"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">

    <!--
      Dense two-column capability grid sized for the fixed 1200x800 shell.
      One-line title + one-line detail; up to ~12 tiles without page scroll.
    -->
    <ItemsRepeater x:Name="TileRepeater"
                   ItemsSource="{x:Bind ItemsSource, Mode=OneWay}"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch">
        <ItemsRepeater.Layout>
            <UniformGridLayout MinItemWidth="300"
                               MinItemHeight="48"
                               MinRowSpacing="5"
                               MinColumnSpacing="5"
                               ItemsJustification="Start"
                               ItemsStretch="Fill" />
        </ItemsRepeater.Layout>
        <ItemsRepeater.ItemTemplate>
            <DataTemplate x:DataType="vm:FeatureRowViewModel">
                <Border Background="{ThemeResource ExoSurfaceSunkenBrush}"
                        BorderBrush="{ThemeResource ExoDividerBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Opacity="{x:Bind Opacity}"
                        Height="48"
                        MinHeight="48"
                        MaxHeight="48"
                        Padding="10,5"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        UseLayoutRounding="True">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource ExoStatusRail}"
                                Opacity="{x:Bind RailOpacity}" />
                        <StackPanel Grid.Column="1"
                                    Spacing="1"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Title}"
                                       Style="{StaticResource ExoFeatureTitle}"
                                       FontSize="13"
                                       CharacterSpacing="-2"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1" />
                            <TextBlock Text="{x:Bind Detail}"
                                       Style="{StaticResource ExoFeatureDetail}"
                                       FontSize="11"
                                       LineHeight="14"
                                       TextWrapping="NoWrap"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </Border>
            </DataTemplate>
        </ItemsRepeater.ItemTemplate>
    </ItemsRepeater>
</UserControl>
