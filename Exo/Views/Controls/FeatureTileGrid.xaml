<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Exo.Views.Controls.FeatureTileGrid"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Exo.ViewModels"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Top">

    <ItemsRepeater x:Name="TileRepeater"
                   ItemsSource="{x:Bind ItemsSource, Mode=OneWay}"
                   HorizontalAlignment="Stretch">
        <ItemsRepeater.Layout>
            <UniformGridLayout MinItemWidth="360"
                               MinItemHeight="72"
                               MinRowSpacing="12"
                               MinColumnSpacing="12"
                               ItemsJustification="Start"
                               ItemsStretch="Fill" />
        </ItemsRepeater.Layout>
        <ItemsRepeater.ItemTemplate>
            <DataTemplate x:DataType="vm:FeatureRowViewModel">
                <Border Style="{StaticResource ExoFeatureTile}"
                        Opacity="{x:Bind Opacity}">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource ExoStatusRail}"
                                Opacity="{x:Bind RailOpacity}" />
                        <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Title}"
                                       Style="{StaticResource ExoFeatureTitle}"
                                       CharacterSpacing="-2"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{x:Bind Detail}"
                                       Style="{StaticResource ExoFeatureDetail}"
                                       TextWrapping="WrapWholeWords"
                                       MaxLines="2"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </Border>
            </DataTemplate>
        </ItemsRepeater.ItemTemplate>
    </ItemsRepeater>
</UserControl>
