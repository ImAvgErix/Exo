<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Exo.Views.Controls.FeatureTileGrid"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Exo.ViewModels"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">

    <!--
      UniformGridLayout inside ScrollViewer collapses to 0 width without an explicit
      ItemsRepeater width — tiles stack at (0,0). SizeChanged keeps stretch honest.
    -->
    <ScrollViewer x:Name="ScrollHost"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalScrollMode="Disabled"
                  ZoomMode="Disabled"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  SizeChanged="ScrollHost_SizeChanged">
        <ItemsRepeater x:Name="TileRepeater"
                       ItemsSource="{x:Bind ItemsSource, Mode=OneWay}"
                       HorizontalAlignment="Stretch">
            <ItemsRepeater.Layout>
                <UniformGridLayout MaximumRowsOrColumns="2"
                                   Orientation="Horizontal"
                                   MinItemWidth="248"
                                   MinColumnSpacing="12"
                                   MinRowSpacing="12"
                                   ItemsStretch="Fill" />
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
                <DataTemplate x:DataType="vm:FeatureRowViewModel">
                    <Border Style="{StaticResource OptiFeatureTile}" Opacity="{x:Bind Opacity}">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource OptiStatusRail}"
                                    Opacity="{x:Bind RailOpacity}" />
                            <Border Grid.Column="1" Style="{StaticResource OptiIconWell}">
                                <FontIcon Glyph="{x:Bind Glyph}"
                                          FontSize="13"
                                          Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Title}" Style="{StaticResource OptiFeatureTitle}" />
                                <TextBlock Text="{x:Bind Detail}" Style="{StaticResource OptiFeatureDetail}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsRepeater.ItemTemplate>
        </ItemsRepeater>
    </ScrollViewer>
</UserControl>
