<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Exo.Views.Controls.FeatureTileGrid"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Exo.ViewModels"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">

    <!--
      Vertical feature list. SizeChanged keeps ItemsRepeater width honest
      so tiles stretch full-width inside ScrollViewer.
      v2.6: denser row chrome, 3px status rail, title + detail only.
    -->
    <ScrollViewer x:Name="ScrollHost"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalScrollMode="Disabled"
                  ZoomMode="Disabled"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  SizeChanged="ScrollHost_SizeChanged">
        <ItemsRepeater x:Name="TileRepeater"
                       ItemsSource="{x:Bind ItemsSource, Mode=OneWay}"
                       HorizontalAlignment="Stretch">
            <ItemsRepeater.Layout>
                <StackLayout Orientation="Vertical" Spacing="0" />
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
                <DataTemplate x:DataType="vm:FeatureRowViewModel">
                    <Border Style="{StaticResource ExoFeatureTile}"
                            Opacity="{x:Bind Opacity}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource ExoStatusRail}"
                                    Width="3"
                                    CornerRadius="1.5"
                                    Opacity="{x:Bind RailOpacity}" />
                            <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Title}"
                                           Style="{StaticResource ExoFeatureTitle}"
                                           FontSize="13"
                                           CharacterSpacing="-4" />
                                <TextBlock Text="{x:Bind Detail}"
                                           Style="{StaticResource ExoFeatureDetail}"
                                           FontSize="11"
                                           LineHeight="15" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsRepeater.ItemTemplate>
        </ItemsRepeater>
    </ScrollViewer>
</UserControl>
