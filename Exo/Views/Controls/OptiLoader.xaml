<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Exo.Views.Controls.OptiLoader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="48"
    Height="48">

    <!--
      One loader language everywhere: soft track + single orbit bead + soft core breath.
      No competing sweep/trail rings (those felt like mixed animations).
    -->
    <Grid x:Name="Root"
          Width="48"
          Height="48"
          HorizontalAlignment="Center"
          VerticalAlignment="Center">

        <Ellipse x:Name="Halo"
                 Width="42"
                 Height="42"
                 Fill="{ThemeResource OptiAccentBrush}"
                 Opacity="0.08"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 IsHitTestVisible="False"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="HaloScale" ScaleX="1" ScaleY="1" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <Ellipse Width="32"
                 Height="32"
                 Stroke="{ThemeResource OptiCardStrokeBrush}"
                 StrokeThickness="1.5"
                 Opacity="0.5"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 IsHitTestVisible="False" />

        <!-- Kept for code-compat; collapsed so only one orbit language shows -->
        <Ellipse x:Name="Sweep"
                 Width="32"
                 Height="32"
                 Visibility="Collapsed"
                 Stroke="{ThemeResource OptiAccentBrush}"
                 StrokeThickness="2"
                 Opacity="0"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 IsHitTestVisible="False"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <RotateTransform x:Name="SweepRotate" Angle="0" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <Grid x:Name="Orbit"
              Width="32"
              Height="32"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5"
              IsHitTestVisible="False">
            <Grid.RenderTransform>
                <RotateTransform x:Name="OrbitRotate" Angle="0" />
            </Grid.RenderTransform>
            <Ellipse Width="7"
                     Height="7"
                     Fill="{ThemeResource OptiAccentBrush}"
                     VerticalAlignment="Top"
                     HorizontalAlignment="Center"
                     Margin="0,-2,0,0" />
        </Grid>

        <!-- Soft trail bead (same orbit family, lower opacity) -->
        <Grid x:Name="TrailOrbit"
              Width="32"
              Height="32"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5"
              IsHitTestVisible="False">
            <Grid.RenderTransform>
                <RotateTransform x:Name="TrailRotate" Angle="-48" />
            </Grid.RenderTransform>
            <Ellipse Width="4.5"
                     Height="4.5"
                     Fill="{ThemeResource OptiAccentBrush}"
                     VerticalAlignment="Top"
                     HorizontalAlignment="Center"
                     Margin="0,-1,0,0"
                     Opacity="0.35" />
        </Grid>

        <Grid x:Name="GhostOrbit"
              Width="32"
              Height="32"
              Visibility="Collapsed"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5"
              IsHitTestVisible="False">
            <Grid.RenderTransform>
                <RotateTransform x:Name="GhostRotate" Angle="-78" />
            </Grid.RenderTransform>
            <Ellipse Width="3"
                     Height="3"
                     Fill="{ThemeResource OptiAccentBrush}"
                     VerticalAlignment="Top"
                     HorizontalAlignment="Center"
                     Opacity="0.18" />
        </Grid>

        <Ellipse x:Name="Core"
                 Width="8"
                 Height="8"
                 Fill="{ThemeResource OptiAccentBrush}"
                 Opacity="0.9"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 IsHitTestVisible="False"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="CoreScale" ScaleX="1" ScaleY="1" />
            </Ellipse.RenderTransform>
        </Ellipse>
    </Grid>
</UserControl>
