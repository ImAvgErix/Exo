<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Exo.Views.NvidiaOptimizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Exo.ViewModels"
    xmlns:controls="using:Exo.Views.Controls"
    Background="Transparent">

    <!--
      Module craft surface: header + G-SYNC/Display controls + feature list + sticky bar.
      Reset clears Exo status only — status clear, not a driver restore.
    -->
    <Border Style="{StaticResource ExoModulePlate}">
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Padding="20,16,20,8">
            <Grid
                  HorizontalAlignment="Stretch"
                  RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="NVIDIA"
                                   Style="{StaticResource ExoSectionTitle}"
                                   Margin="0" />
                        <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                                   Style="{StaticResource ExoPageTitle}"
                                   FontSize="26"
                                   LineHeight="32"
                                   CharacterSpacing="-24" />
                    </StackPanel>
                    <Border Style="{StaticResource ExoCard}" Padding="14,10">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ToggleSwitch Header="G-SYNC"
                                          IsOn="{x:Bind ViewModel.UseGsync, Mode=TwoWay}"
                                          OnContent="On" OffContent="Off"
                                          VerticalAlignment="Center"
                                          IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                          AutomationProperties.Name="G-SYNC" />
                            <Button Grid.Column="1"
                                    Style="{StaticResource ExoQuietButton}"
                                    Content="Display panel"
                                    Click="Panel_Click"
                                    MinWidth="120"
                                    MinHeight="34"
                                    Padding="12,8"
                                    VerticalAlignment="Center"
                                    IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                    AutomationProperties.Name="Open NVIDIA Panel" />
                        </Grid>
                    </Border>
                </StackPanel>

                <Grid Grid.Row="1">
                    <controls:ExoLoader IsActive="{x:Bind ViewModel.IsStatusLoading, Mode=OneWay}"
                                         Visibility="{x:Bind ViewModel.IsStatusLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <controls:FeatureTileGrid x:Name="FeatureGrid"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              ItemsSource="{x:Bind ViewModel.Features, Mode=OneWay}"
                                              Visibility="{x:Bind ViewModel.IsFeatureListVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                </Grid>
            </Grid>
        </Grid>

        <Border Grid.Row="1"
                Style="{StaticResource ExoActionBar}"
                Padding="20,12,20,14">
            <StackPanel
                        HorizontalAlignment="Stretch"
                        Spacing="10">
                <Border Style="{StaticResource ExoMessageBanner}"
                        Visibility="{x:Bind ViewModel.HasLastResult, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="{x:Bind ViewModel.LastResultGlyph, Mode=OneWay}" FontSize="14"
                                  Foreground="{x:Bind ViewModel.LastResultBrush, Mode=OneWay}" VerticalAlignment="Top" />
                        <TextBlock Text="{x:Bind ViewModel.LastResult, Mode=OneWay}" Grid.Column="1"
                                   Style="{StaticResource ExoBody}" TextWrapping="Wrap" />
                    </Grid>
                </Border>
                <StackPanel Spacing="6"
                            Visibility="{x:Bind ViewModel.IsProgressVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ProgressBar Minimum="0" Maximum="100" Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                                 Height="3" CornerRadius="2" Foreground="{ThemeResource ExoAccentBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.ProgressStatus, Mode=OneWay}" Style="{StaticResource ExoCaption}" TextAlignment="Center" />
                </StackPanel>

                <Button Style="{StaticResource ExoPrimaryButton}"
                        Content="{x:Bind ViewModel.RunButtonLabel, Mode=OneWay}"
                        Click="Run_Click"
                        HorizontalAlignment="Stretch"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                        AutomationProperties.Name="Apply NVIDIA" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Style="{StaticResource ExoQuietButton}"
                            Content="Reset"
                            Click="Repair_Click"
                            MinHeight="34"
                            Padding="12,6"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                    <Button Grid.Column="1"
                            Style="{StaticResource ExoQuietButton}"
                            Content="Refresh"
                            Click="Refresh_Click"
                            MinHeight="34"
                            Padding="12,6"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                </Grid>
                <TextBlock Text="Reset clears Exo status only — NVIDIA driver and profiles stay."
                           Style="{StaticResource ExoCaption}"
                           TextAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
    </Border>
</Page>
