<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Exo.Views.NvidiaOptimizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Exo.ViewModels"
    xmlns:controls="using:Exo.Views.Controls"
    Background="Transparent">

    <!--
      SharedModulePlate (v3): NVIDIA plate + G-SYNC header + Reset status-clear only.
    -->
    <controls:SharedModulePlate
        x:Name="Plate"
        ModuleTitle="NVIDIA"
        StatusText="{x:Bind ViewModel.StatusText, Mode=OneWay}"
        GuidanceText="{x:Bind ViewModel.GuidanceText, Mode=OneWay}"
        HasGuidance="{x:Bind ViewModel.HasGuidance, Mode=OneWay}"
        FeatureItems="{x:Bind ViewModel.Features, Mode=OneWay}"
        IsLoading="{x:Bind ViewModel.IsStatusLoading, Mode=OneWay}"
        IsFeatureListVisible="{x:Bind ViewModel.IsFeatureListVisible, Mode=OneWay}"
        HasLastResult="{x:Bind ViewModel.HasLastResult, Mode=OneWay}"
        LastResult="{x:Bind ViewModel.LastResult, Mode=OneWay}"
        LastResultGlyph="{x:Bind ViewModel.LastResultGlyph, Mode=OneWay}"
        LastResultBrush="{x:Bind ViewModel.LastResultBrush, Mode=OneWay}"
        IsProgressVisible="{x:Bind ViewModel.IsProgressVisible, Mode=OneWay}"
        ProgressPercent="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
        ProgressStatus="{x:Bind ViewModel.ProgressStatus, Mode=OneWay}"
        ShowSecondaryActions="True"
        SecondaryLeftLabel="Reset"
        SecondaryRightLabel="Refresh"
        SecondaryActionsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
        SecondaryLeftClick="Repair_Click"
        SecondaryRightClick="Refresh_Click">
        <controls:SharedModulePlate.HeaderExtra>
            <Border Style="{StaticResource ExoCard}" Padding="14,10">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ToggleSwitch Header="G-SYNC"
                                  IsOn="{x:Bind ViewModel.UseGsync, Mode=TwoWay}"
                                  OnContent="On" OffContent="Off"
                                  VerticalAlignment="Center"
                                  IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                  AutomationProperties.Name="G-SYNC" />
                    <Button Grid.Column="1"
                            Style="{StaticResource ExoQuietButton}"
                            Content="Display panel"
                            Click="Panel_Click"
                            MinWidth="120"
                            MinHeight="34"
                            Padding="12,8"
                            VerticalAlignment="Center"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                            AutomationProperties.Name="Open NVIDIA Panel" />
                </Grid>
            </Border>
        </controls:SharedModulePlate.HeaderExtra>
        <controls:SharedModulePlate.PrimaryActions>
            <StackPanel Spacing="6">
                <Button Style="{StaticResource ExoPrimaryButton}"
                        Content="{x:Bind ViewModel.RunButtonLabel, Mode=OneWay}"
                        Click="Run_Click"
                        HorizontalAlignment="Stretch"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                        AutomationProperties.Name="Apply NVIDIA" />
                <TextBlock Text="Reset clears Exo status only — NVIDIA driver and profiles stay."
                           Style="{StaticResource ExoCaption}"
                           TextAlignment="Center" />
            </StackPanel>
        </controls:SharedModulePlate.PrimaryActions>
    </controls:SharedModulePlate>
</Page>
