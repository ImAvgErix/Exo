<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Exo.Views.NvidiaOptimizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Exo.ViewModels"
    xmlns:controls="using:Exo.Views.Controls"
    Background="Transparent">

    <controls:SharedModulePlate
        x:Name="Plate"
        ModuleTitle="NVIDIA"
        StatusText="{x:Bind ViewModel.StatusText, Mode=OneWay}"
        FeatureItems="{x:Bind ViewModel.Features, Mode=OneWay}"
        IsLoading="{x:Bind ViewModel.IsStatusLoading, Mode=OneWay}"
        IsFeatureListVisible="{x:Bind ViewModel.IsFeatureListVisible, Mode=OneWay}"
        HasLastResult="{x:Bind ViewModel.HasLastResult, Mode=OneWay}"
        LastResult="{x:Bind ViewModel.LastResult, Mode=OneWay}"
        LastResultGlyph="{x:Bind ViewModel.LastResultGlyph, Mode=OneWay}"
        LastResultBrush="{x:Bind ViewModel.LastResultBrush, Mode=OneWay}"
        IsProgressVisible="{x:Bind ViewModel.IsProgressVisible, Mode=OneWay}"
        ProgressPercent="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
        ProgressStatus="{x:Bind ViewModel.ProgressStatus, Mode=OneWay}"
        SelectedApplyMode="{x:Bind ViewModel.SelectedApplyMode, Mode=TwoWay}"
        ApplyModeOptions="{x:Bind ViewModel.ApplyModeOptions, Mode=OneWay}"
        PolicyTogglesEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
        SecondaryLeftLabel="Repair"
        SecondaryActionsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
        SecondaryLeftClick="Repair_Click">
        <controls:SharedModulePlate.HeaderExtra>
            <StackPanel Spacing="6">
                <Border Style="{StaticResource ExoCard}" Padding="12,8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="Profile"
                                       FontFamily="{StaticResource ExoUiFontSemiBold}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.HardwarePolicyText, Mode=OneWay}"
                                       Style="{StaticResource ExoCaption}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1" />
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  MinWidth="168"
                                  SelectedItem="{x:Bind ViewModel.SelectedProfileOption, Mode=TwoWay}"
                                  ItemsSource="{x:Bind ViewModel.ProfileOptions, Mode=OneWay}"
                                  IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                  AutomationProperties.Name="NVIDIA profile" />
                    </Grid>
                </Border>
                <Button Style="{StaticResource ExoQuietButton}"
                        Content="Control Panel"
                        Command="{x:Bind ViewModel.OpenControlPanelCommand}"
                        HorizontalAlignment="Stretch"
                        MinHeight="36"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                        AutomationProperties.Name="Open NVIDIA Control Panel" />
            </StackPanel>
        </controls:SharedModulePlate.HeaderExtra>
        <controls:SharedModulePlate.PrimaryActions>
            <Button Style="{StaticResource ExoPrimaryButton}"
                    Content="{x:Bind ViewModel.RunButtonLabel, Mode=OneWay}"
                    Click="Run_Click"
                    HorizontalAlignment="Stretch"
                    IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                    AutomationProperties.Name="Apply NVIDIA" />
        </controls:SharedModulePlate.PrimaryActions>
    </controls:SharedModulePlate>
</Page>
