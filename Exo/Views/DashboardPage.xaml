<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Exo.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:Exo.ViewModels"
    Background="Transparent"
    Loaded="Page_Loaded">

    <!--
      Brand-forward home: Exo mark → italic tagline → module directory.
      No support subtitle. No RenderTransform on italic type. No status chips.
    -->
    <Grid x:Name="PageRoot"
          Padding="40,28,40,32"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          UseLayoutRounding="True">
        <StackPanel x:Name="HomeStack"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    MaxWidth="720"
                    Spacing="0"
                    UseLayoutRounding="True">

            <TextBlock x:Name="HeroBrand"
                       Text="Exo"
                       FontFamily="{StaticResource ExoUiFontSemiBold}"
                       FontSize="44"
                       FontWeight="SemiBold"
                       CharacterSpacing="-28"
                       LineHeight="48"
                       Foreground="{ThemeResource ExoPrimaryTextBrush}"
                       TextAlignment="Left"
                       HorizontalAlignment="Stretch"
                       OpticalMarginAlignment="TrimSideBearings"
                       UseLayoutRounding="True"
                       Margin="0,0,0,6" />

            <TextBlock x:Name="HeroTagline"
                       Text="Maximum performance. No compromise."
                       Style="{StaticResource ExoTagline}"
                       FontSize="22"
                       LineHeight="28"
                       TextWrapping="WrapWholeWords"
                       TextAlignment="Left"
                       HorizontalAlignment="Stretch"
                       Margin="0,0,0,28"
                       UseLayoutRounding="True" />

            <ItemsControl x:Name="CardList"
                          HorizontalAlignment="Stretch"
                          ItemsSource="{x:Bind ViewModel.Cards, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsStackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:OptimizerCardViewModel">
                        <Button Style="{StaticResource ExoCardButton}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,8"
                                Click="CardButton_Click"
                                Tag="{x:Bind Definition.Id}"
                                AutomationProperties.Name="{x:Bind Definition.Title}"
                                IsEnabled="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                            <Border Style="{StaticResource ExoDirectoryRow}"
                                    Opacity="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToOpacityConverter}}">
                                <Grid ColumnSpacing="14" UseLayoutRounding="True">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Image Width="44"
                                           Height="44"
                                           Source="{x:Bind Definition.LogoPath, Mode=OneWay, Converter={StaticResource AssetPathToImageSourceConverter}}"
                                           VerticalAlignment="Center"
                                           Stretch="Uniform"
                                           UseLayoutRounding="True"
                                           AutomationProperties.AccessibilityView="Raw" />
                                    <StackPanel Grid.Column="1"
                                                Spacing="2"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Definition.Title, Mode=OneWay}"
                                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   CharacterSpacing="-4"
                                                   Foreground="{ThemeResource ExoPrimaryTextBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1"
                                                   UseLayoutRounding="True" />
                                        <TextBlock Text="Coming soon"
                                                   FontFamily="{StaticResource ExoUiFont}"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource ExoMutedTextBrush}"
                                                   Visibility="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </StackPanel>
                                    <FontIcon Grid.Column="2"
                                              Glyph="&#xE76C;"
                                              FontSize="14"
                                              Foreground="{ThemeResource ExoSecondaryTextBrush}"
                                              VerticalAlignment="Center"
                                              Opacity="0.85" />
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</Page>
