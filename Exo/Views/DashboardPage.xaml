<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Exo.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:Exo.ViewModels"
    Background="Transparent"
    Loaded="Page_Loaded">

    <!--
      Fixed 1180×760.
      Tagline = full-width centered hero.
      Cards = compact under it with logo wells + labels.
    -->
    <Grid x:Name="PageRoot"
          Padding="40,18,40,26"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          UseLayoutRounding="True"
          SizeChanged="PageRoot_SizeChanged">
        <StackPanel x:Name="HomeStack"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="920"
                    Spacing="0"
                    UseLayoutRounding="True">

            <!-- Hero: no RenderTransform — transforms keep italic type soft -->
            <TextBlock x:Name="HeroTagline"
                       Text="Maximum performance. No compromise."
                       Style="{StaticResource OptiTagline}"
                       TextWrapping="WrapWholeWords"
                       TextAlignment="Center"
                       HorizontalAlignment="Stretch"
                       Margin="0,0,0,28"
                       MaxWidth="860"
                       UseLayoutRounding="True" />

            <ItemsControl x:Name="CardList"
                          HorizontalAlignment="Stretch"
                          ItemsSource="{x:Bind ViewModel.Cards, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       MaximumRowsOrColumns="3"
                                       HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:OptimizerCardViewModel">
                        <Button Style="{StaticResource OptiCardButton}"
                                Width="250"
                                Height="156"
                                Margin="6"
                                Click="CardButton_Click"
                                Tag="{x:Bind Definition.Id}"
                                AutomationProperties.Name="{x:Bind Definition.Title}"
                                IsEnabled="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                            <Border Style="{StaticResource OptiCard}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Padding="14,14,14,12"
                                    UseLayoutRounding="True"
                                    Opacity="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToOpacityConverter}}">
                                <Grid UseLayoutRounding="True">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <!-- Borderless logo @ 64px, decoded 2× for crisp DPI -->
                                    <Image Width="64"
                                           Height="64"
                                           Source="{x:Bind Definition.LogoPath, Mode=OneWay, Converter={StaticResource AssetPathToImageSourceConverter}}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Stretch="Uniform"
                                           UseLayoutRounding="True"
                                           AutomationProperties.AccessibilityView="Raw" />
                                    <StackPanel Grid.Row="1"
                                                Spacing="2"
                                                HorizontalAlignment="Center"
                                                Margin="0,8,0,0">
                                        <TextBlock Text="{x:Bind Definition.Title, Mode=OneWay}"
                                                   FontFamily="{StaticResource OptiUiFontSemiBold}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1"
                                                   UseLayoutRounding="True" />
                                        <TextBlock Text="Coming soon"
                                                   FontFamily="{StaticResource OptiUiFont}"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource OptiMutedTextBrush}"
                                                   HorizontalAlignment="Center"
                                                   Visibility="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</Page>
