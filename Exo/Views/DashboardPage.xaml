<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Exo.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:Exo.ViewModels"
    Background="Transparent"
    Loaded="Page_Loaded">

    <!--
      Brand-only home — live modules live in the top bar (no duplicate Discord/Steam/… strip).
      Coming soon is a quiet centered line.
    -->
    <Grid x:Name="PageRoot"
          Padding="8,8,8,8"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          UseLayoutRounding="True">
        <StackPanel x:Name="HomeStack"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Margin="0,48,0,0"
                    Spacing="0"
                    UseLayoutRounding="True">

            <TextBlock x:Name="HeroBrand"
                       Text="Exo"
                       FontFamily="{StaticResource ExoUiFontSemiBold}"
                       FontSize="56"
                       FontWeight="SemiBold"
                       CharacterSpacing="-40"
                       LineHeight="56"
                       Foreground="{ThemeResource ExoPrimaryTextBrush}"
                       TextAlignment="Center"
                       HorizontalAlignment="Stretch"
                       OpticalMarginAlignment="TrimSideBearings"
                       UseLayoutRounding="True"
                       Margin="0,0,0,6" />

            <TextBlock x:Name="HeroTagline"
                       Text="Maximum performance. No compromise."
                       Style="{StaticResource ExoTagline}"
                       FontSize="22"
                       LineHeight="28"
                       TextWrapping="WrapWholeWords"
                       TextAlignment="Center"
                       HorizontalAlignment="Stretch"
                       Margin="0,0,0,16"
                       UseLayoutRounding="True" />

            <StackPanel x:Name="SoonRow"
                        Orientation="Horizontal"
                        Spacing="10"
                        HorizontalAlignment="Center">
                <TextBlock Text="Coming soon"
                           FontFamily="{StaticResource ExoUiFontSemiBold}"
                           FontSize="11"
                           CharacterSpacing="60"
                           Foreground="{ThemeResource ExoMutedTextBrush}"
                           VerticalAlignment="Center" />
                <ItemsControl x:Name="SoonList"
                              ItemsSource="{x:Bind ViewModel.SoonCards, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="12" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:OptimizerCardViewModel">
                            <TextBlock Text="{x:Bind Definition.Title, Mode=OneWay}"
                                       FontFamily="{StaticResource ExoUiFont}"
                                       FontSize="12"
                                       Foreground="{ThemeResource ExoMutedTextBrush}"
                                       Opacity="0.75" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
