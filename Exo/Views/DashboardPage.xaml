<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Exo.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:Exo.ViewModels"
    Background="Transparent"
    Loaded="Page_Loaded">

    <!--
      Home instrument plate: brand + capability pillars + text module directory.
      Logos stay in the top bar only — home rows are title / Ready / chevron.
    -->
    <Border x:Name="PageRoot"
            Style="{StaticResource ExoModulePlate}"
            Padding="28,24,28,16"
            UseLayoutRounding="True">
        <Grid RowSpacing="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Brand -->
            <StackPanel x:Name="HeroBlock"
                        Spacing="6"
                        MaxWidth="640"
                        HorizontalAlignment="Left">
                <TextBlock x:Name="HeroBrand"
                           Text="Exo"
                           FontFamily="{StaticResource ExoUiFontSemiBold}"
                           FontSize="56"
                           FontWeight="SemiBold"
                           CharacterSpacing="-40"
                           LineHeight="56"
                           Foreground="{ThemeResource ExoPrimaryTextBrush}"
                           OpticalMarginAlignment="TrimSideBearings"
                           UseLayoutRounding="True" />
                <TextBlock x:Name="HeroTagline"
                           Text="Maximum performance. No compromise."
                           Style="{StaticResource ExoTagline}"
                           FontSize="20"
                           LineHeight="26"
                           TextWrapping="WrapWholeWords"
                           UseLayoutRounding="True" />
            </StackPanel>

            <!-- Capability pillars -->
            <Grid x:Name="PillarRow"
                  Grid.Row="1"
                  ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Background="{ThemeResource ExoGlassFillBrush}"
                        BorderBrush="{ThemeResource ExoGlassStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14,12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Trim"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   FontSize="13"
                                   Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                        <TextBlock Text="Aggressive memory and background cut"
                                   FontFamily="{StaticResource ExoUiFont}"
                                   FontSize="12"
                                   Foreground="{ThemeResource ExoMutedTextBrush}"
                                   TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1"
                        Background="{ThemeResource ExoGlassFillBrush}"
                        BorderBrush="{ThemeResource ExoGlassStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14,12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Debloat"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   FontSize="13"
                                   Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                        <TextBlock Text="Client strip without breaking repair"
                                   FontFamily="{StaticResource ExoUiFont}"
                                   FontSize="12"
                                   Foreground="{ThemeResource ExoMutedTextBrush}"
                                   TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2"
                        Background="{ThemeResource ExoGlassFillBrush}"
                        BorderBrush="{ThemeResource ExoGlassStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14,12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Latency"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   FontSize="13"
                                   Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                        <TextBlock Text="Stack, GPU, and FPS-facing paths"
                                   FontFamily="{StaticResource ExoUiFont}"
                                   FontSize="12"
                                   Foreground="{ThemeResource ExoMutedTextBrush}"
                                   TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Text module directory (no logos) -->
            <StackPanel x:Name="ModuleDirectory"
                        Grid.Row="2"
                        Spacing="0"
                        VerticalAlignment="Stretch">
                <TextBlock Text="MODULES"
                           FontFamily="{StaticResource ExoUiFontSemiBold}"
                           FontSize="10"
                           CharacterSpacing="100"
                           Foreground="{ThemeResource ExoMutedTextBrush}"
                           Margin="0,0,0,6" />
                <ItemsControl ItemsSource="{x:Bind ViewModel.ReadyModules, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:OptimizerCardViewModel">
                            <Button Style="{StaticResource ExoCardButton}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Padding="4,10"
                                    MinHeight="48"
                                    CornerRadius="0"
                                    BorderBrush="{ThemeResource ExoGlassStrokeBrush}"
                                    BorderThickness="0,1,0,0"
                                    Command="{x:Bind OpenCommand}">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind Definition.Title, Mode=OneWay}"
                                               FontFamily="{StaticResource ExoUiFontSemiBold}"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="Ready"
                                               FontFamily="{StaticResource ExoUiFontSemiBold}"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               Foreground="{ThemeResource ExoMutedTextBrush}" />
                                    <TextBlock Grid.Column="2"
                                               Text="›"
                                               FontSize="18"
                                               VerticalAlignment="Center"
                                               Foreground="{ThemeResource ExoMutedTextBrush}"
                                               Opacity="0.7" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Coming soon -->
            <Border x:Name="SoonRow"
                    Grid.Row="3"
                    BorderBrush="{ThemeResource ExoGlassStrokeBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="0,10,0,0">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Coming soon"
                               FontFamily="{StaticResource ExoUiFontSemiBold}"
                               FontSize="11"
                               CharacterSpacing="60"
                               Foreground="{ThemeResource ExoMutedTextBrush}"
                               VerticalAlignment="Center" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.SoonCards, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="12" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:OptimizerCardViewModel">
                                <TextBlock Text="{x:Bind Definition.Title, Mode=OneWay}"
                                           FontFamily="{StaticResource ExoUiFont}"
                                           FontSize="12"
                                           Foreground="{ThemeResource ExoMutedTextBrush}"
                                           Opacity="0.75" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Page>
