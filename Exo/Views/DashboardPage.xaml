<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Exo.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Exo.ViewModels"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded">

    <!--
      Honest home layout:
      - Top: machine strip (CPU · GPU · RAM · Windows) + applied count
      - Center: 2×2 metric tiles (number + thick bar only — no empty sparklines)
      - Bottom: 6 compact optimizer chips
      Rhythm: 12px padding, 8px gaps everywhere.
    -->
    <Grid x:Name="PageRoot"
          Padding="0,6,0,2"
          RowSpacing="10"
          UseLayoutRounding="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Machine strip -->
        <Border x:Name="HeroBlock"
                Style="{StaticResource ExoModulePlate}"
                Padding="14,12">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="THIS PC"
                               Style="{StaticResource ExoSectionTitle}"
                               Margin="0" />
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="1">
                            <TextBlock Text="CPU"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       CharacterSpacing="80"
                                       Foreground="{ThemeResource ExoMutedTextBrush}" />
                            <TextBlock x:Name="HeroBrand"
                                       Text="{x:Bind ViewModel.SpecsCpu, Mode=OneWay}"
                                       FontFamily="{StaticResource ExoUiFontSemiBold}"
                                       FontSize="14"
                                       Foreground="{ThemeResource ExoPrimaryTextBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="1">
                            <TextBlock Text="GPU"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       CharacterSpacing="80"
                                       Foreground="{ThemeResource ExoMutedTextBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.SpecsGpu, Mode=OneWay}"
                                       FontFamily="{StaticResource ExoUiFontSemiBold}"
                                       FontSize="14"
                                       Foreground="{ThemeResource ExoPrimaryTextBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="1" MinWidth="72">
                            <TextBlock Text="RAM"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       CharacterSpacing="80"
                                       Foreground="{ThemeResource ExoMutedTextBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.SpecsRam, Mode=OneWay}"
                                       FontFamily="{StaticResource ExoUiFontSemiBold}"
                                       FontSize="14"
                                       Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Spacing="1" MinWidth="100">
                            <TextBlock Text="WINDOWS"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       CharacterSpacing="80"
                                       Foreground="{ThemeResource ExoMutedTextBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.SpecsOs, Mode=OneWay}"
                                       FontFamily="{StaticResource ExoUiFontSemiBold}"
                                       FontSize="14"
                                       Foreground="{ThemeResource ExoPrimaryTextBrush}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center">
                    <Border Background="{ThemeResource ExoSurfaceSunkenBrush}"
                            BorderBrush="{ThemeResource ExoDividerBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12,8"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="HeroTagline"
                                   Text="{x:Bind ViewModel.OverviewPrimary, Mode=OneWay}"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   FontSize="13"
                                   Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                    </Border>
                    <Button Style="{StaticResource ExoPrimaryButton}"
                            MinWidth="96"
                            MinHeight="36"
                            Padding="14,8"
                            Content="{x:Bind ViewModel.NextActionLabel, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.HasNextAction, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                            Click="NextAction_Click"
                            AutomationProperties.Name="Open recommended next optimizer" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 2×2 live meters -->
        <Grid x:Name="StatRow"
              Grid.Row="1"
              RowSpacing="8"
              ColumnSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Memory -->
            <Border x:Name="TileRam"
                    Style="{StaticResource ExoModulePlate}"
                    Padding="14"
                    VerticalAlignment="Stretch">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Background="{ThemeResource ExoAccentBrush}" CornerRadius="2" Opacity="0.9" />
                        <TextBlock Grid.Column="1"
                                   Text="MEMORY"
                                   Style="{StaticResource ExoSectionTitle}"
                                   Margin="0"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind ViewModel.MemorySecondary, Mode=OneWay}"
                                   Style="{StaticResource ExoCaption}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                    <TextBlock Grid.Row="1"
                               Text="{x:Bind ViewModel.MemoryPrimary, Mode=OneWay}"
                               FontFamily="{StaticResource ExoUiFontSemiBold}"
                               FontSize="42"
                               LineHeight="46"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                    <Grid Grid.Row="2" Height="12">
                        <Border Background="{ThemeResource ExoSurfaceSunkenBrush}"
                                CornerRadius="6"
                                BorderBrush="{ThemeResource ExoDividerBrush}"
                                BorderThickness="1" />
                        <ProgressBar Minimum="0" Maximum="100"
                                     Value="{x:Bind ViewModel.MemoryLoadPercent, Mode=OneWay}"
                                     Height="12"
                                     CornerRadius="6"
                                     Background="Transparent"
                                     Foreground="{ThemeResource ExoAccentBrush}"
                                     AutomationProperties.Name="Memory load" />
                    </Grid>
                    <TextBlock Grid.Row="3"
                               Text="In use"
                               Style="{StaticResource ExoCaption}"
                               Foreground="{ThemeResource ExoMutedTextBrush}" />
                </Grid>
            </Border>

            <!-- CPU -->
            <Border x:Name="TileCpu"
                    Grid.Column="1"
                    Style="{StaticResource ExoModulePlate}"
                    Padding="14"
                    VerticalAlignment="Stretch">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Background="{ThemeResource ExoSteamBrush}" CornerRadius="2" Opacity="0.95" />
                        <TextBlock Grid.Column="1"
                                   Text="CPU"
                                   Style="{StaticResource ExoSectionTitle}"
                                   Margin="0"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="Load"
                                   Style="{StaticResource ExoCaption}"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock Grid.Row="1"
                               Text="{x:Bind ViewModel.CpuPrimary, Mode=OneWay}"
                               FontFamily="{StaticResource ExoUiFontSemiBold}"
                               FontSize="42"
                               LineHeight="46"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                    <Grid Grid.Row="2" Height="12">
                        <Border Background="{ThemeResource ExoSurfaceSunkenBrush}"
                                CornerRadius="6"
                                BorderBrush="{ThemeResource ExoDividerBrush}"
                                BorderThickness="1" />
                        <ProgressBar Minimum="0" Maximum="100"
                                     Value="{x:Bind ViewModel.CpuLoadPercent, Mode=OneWay}"
                                     Height="12"
                                     CornerRadius="6"
                                     Background="Transparent"
                                     Foreground="{ThemeResource ExoSteamBrush}"
                                     AutomationProperties.Name="CPU load" />
                    </Grid>
                    <TextBlock Grid.Row="3"
                               Text="{x:Bind ViewModel.SpecsCpu, Mode=OneWay}"
                               Style="{StaticResource ExoCaption}"
                               Foreground="{ThemeResource ExoMutedTextBrush}"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1" />
                </Grid>
            </Border>

            <!-- GPU -->
            <Border x:Name="TileGpu"
                    Grid.Row="1"
                    Style="{StaticResource ExoModulePlate}"
                    Padding="14"
                    VerticalAlignment="Stretch">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Background="{ThemeResource ExoNvidiaBrush}" CornerRadius="2" Opacity="0.95" />
                        <TextBlock Grid.Column="1"
                                   Text="GPU"
                                   Style="{StaticResource ExoSectionTitle}"
                                   Margin="0"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="Load"
                                   Style="{StaticResource ExoCaption}"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock Grid.Row="1"
                               Text="{x:Bind ViewModel.GpuPrimary, Mode=OneWay}"
                               FontFamily="{StaticResource ExoUiFontSemiBold}"
                               FontSize="42"
                               LineHeight="46"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                    <Grid Grid.Row="2" Height="12">
                        <Border Background="{ThemeResource ExoSurfaceSunkenBrush}"
                                CornerRadius="6"
                                BorderBrush="{ThemeResource ExoDividerBrush}"
                                BorderThickness="1" />
                        <ProgressBar Minimum="0" Maximum="100"
                                     Value="{x:Bind ViewModel.GpuLoadPercent, Mode=OneWay}"
                                     Height="12"
                                     CornerRadius="6"
                                     Background="Transparent"
                                     Foreground="{ThemeResource ExoNvidiaBrush}"
                                     AutomationProperties.Name="GPU load" />
                    </Grid>
                    <TextBlock Grid.Row="3"
                               Text="{x:Bind ViewModel.SpecsGpu, Mode=OneWay}"
                               Style="{StaticResource ExoCaption}"
                               Foreground="{ThemeResource ExoMutedTextBrush}"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1" />
                </Grid>
            </Border>

            <!-- Network -->
            <Border x:Name="TileNet"
                    Grid.Row="1"
                    Grid.Column="1"
                    Style="{StaticResource ExoModulePlate}"
                    Padding="14"
                    VerticalAlignment="Stretch">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Background="{ThemeResource ExoInternetBrush}" CornerRadius="2" Opacity="0.95" />
                        <TextBlock Grid.Column="1"
                                   Text="NETWORK"
                                   Style="{StaticResource ExoSectionTitle}"
                                   Margin="0"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind ViewModel.NetPrimary, Mode=OneWay}"
                                   Style="{StaticResource ExoCaption}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="120" />
                    </Grid>
                    <TextBlock Grid.Row="1"
                               Text="{x:Bind ViewModel.NetSecondary, Mode=OneWay}"
                               FontFamily="{StaticResource ExoUiFontSemiBold}"
                               FontSize="36"
                               LineHeight="40"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource ExoPrimaryTextBrush}"
                               TextTrimming="CharacterEllipsis" />
                    <Grid Grid.Row="2" Height="12">
                        <Border Background="{ThemeResource ExoSurfaceSunkenBrush}"
                                CornerRadius="6"
                                BorderBrush="{ThemeResource ExoDividerBrush}"
                                BorderThickness="1" />
                        <ProgressBar Minimum="0" Maximum="100"
                                     Value="{x:Bind ViewModel.NetMetricPercent, Mode=OneWay}"
                                     Height="12"
                                     CornerRadius="6"
                                     Background="Transparent"
                                     Foreground="{ThemeResource ExoInternetBrush}"
                                     AutomationProperties.Name="Network quality" />
                    </Grid>
                    <TextBlock Grid.Row="3"
                               Text="Idle latency sample"
                               Style="{StaticResource ExoCaption}"
                               Foreground="{ThemeResource ExoMutedTextBrush}" />
                </Grid>
            </Border>
        </Grid>

        <!-- Optimizer chips — compact, full width -->
        <Border x:Name="FrameHero"
                Grid.Row="2"
                Style="{StaticResource ExoModulePlate}"
                Padding="10">
            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="OPTIMIZERS"
                           Style="{StaticResource ExoSectionTitle}"
                           Margin="0" />
                <ItemsRepeater x:Name="CheckList"
                               Grid.Row="1"
                               ItemsSource="{x:Bind ViewModel.CheckRows, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MaximumRowsOrColumns="3"
                                           Orientation="Horizontal"
                                           MinItemWidth="160"
                                           MinItemHeight="44"
                                           MinRowSpacing="6"
                                           MinColumnSpacing="6" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:OptimizerCheckRowViewModel">
                            <Button Style="{StaticResource ExoCardButton}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Padding="10,8"
                                    Click="CheckRow_Click"
                                    Tag="{x:Bind ModuleId}"
                                    AutomationProperties.Name="{x:Bind Title}">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Background="{x:Bind GlyphBrush, Mode=OneWay}"
                                            Opacity="{x:Bind GlyphOpacity, Mode=OneWay}"
                                            CornerRadius="1.5" />
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind Title}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource ExoPrimaryTextBrush}"
                                               VerticalAlignment="Center" />
                                    <FontIcon Grid.Column="2"
                                              Glyph="{x:Bind Glyph, Mode=OneWay}"
                                              FontSize="13"
                                              Foreground="{x:Bind GlyphBrush, Mode=OneWay}"
                                              Opacity="{x:Bind GlyphOpacity, Mode=OneWay}"
                                              VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </Grid>
        </Border>
    </Grid>
</Page>
