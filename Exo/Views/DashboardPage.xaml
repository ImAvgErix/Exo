<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Exo.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid x:Name="PageRoot"
              Padding="{StaticResource ExoPagePadding}"
              RowSpacing="12"
              UseLayoutRounding="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid x:Name="HeroBlock">
                <StackPanel Spacing="4">
                    <TextBlock Text="EXO"
                               Style="{StaticResource ExoSectionTitle}"
                               Margin="0" />
                    <TextBlock x:Name="HeroBrand"
                               Text="System overview"
                               Style="{StaticResource ExoPageTitle}" />
                    <TextBlock x:Name="HeroTagline"
                               Text="{x:Bind ViewModel.HeroSummary, Mode=OneWay}"
                               Style="{StaticResource ExoTagline}"
                               MaxWidth="680"
                               HorizontalAlignment="Left" />
                </StackPanel>
            </Grid>

            <Border x:Name="FrameHero"
                    Grid.Row="1"
                    Style="{StaticResource ExoModulePlate}"
                    Padding="20,16">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="280" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="VERIFIED OPTIMIZERS"
                                   Style="{StaticResource ExoSectionTitle}"
                                   Margin="0" />
                        <TextBlock Text="{x:Bind ViewModel.OverviewPrimary, Mode=OneWay}"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   FontSize="28"
                                   LineHeight="36"
                                   Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                        <TextBlock Text="Live detection decides what is applied. Open a module to review or change it."
                                   Style="{StaticResource ExoCaption}"
                                   MaxWidth="560"
                                   HorizontalAlignment="Left" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{ThemeResource ExoSurfaceSunkenBrush}"
                            BorderBrush="{ThemeResource ExoDividerBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource ExoTileRadius}"
                            Padding="16,12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="SYSTEM MEMORY"
                                       Style="{StaticResource ExoSectionTitle}"
                                       Margin="0" />
                            <TextBlock Text="{x:Bind ViewModel.MemoryPrimary, Mode=OneWay}"
                                       FontFamily="{StaticResource ExoUiFontSemiBold}"
                                       FontSize="20"
                                       LineHeight="28"
                                       Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.MemorySecondary, Mode=OneWay}"
                                       Style="{StaticResource ExoCaption}"
                                       TextTrimming="CharacterEllipsis" />
                            <ProgressBar Minimum="0"
                                         Maximum="100"
                                         Height="4"
                                         Margin="0,4,0,0"
                                         Value="{x:Bind ViewModel.MemoryLoadPercent, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid x:Name="StatRow"
                  Grid.Row="2"
                  RowSpacing="12"
                  ColumnSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Grid.Row="0" Grid.Column="0"
                        Style="{StaticResource ExoCardButton}"
                        AutomationProperties.Name="Open Discord optimizer"
                        Click="DiscordCard_Click">
                    <Grid MinHeight="128" RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{ThemeResource ExoDiscordBrush}" CornerRadius="2" />
                            <TextBlock Grid.Column="1" Text="Discord" Style="{StaticResource ExoFeatureTitle}" />
                            <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.DiscordStatusTag, Mode=OneWay}" Style="{StaticResource ExoCaption}" />
                        </Grid>
                        <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.DiscordStatusPrimary, Mode=OneWay}" Style="{StaticResource ExoBody}" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="2" Text="{x:Bind ViewModel.DiscordStatusSecondary, Mode=OneWay}" Style="{StaticResource ExoCaption}" />
                        <TextBlock Grid.Row="3" Text="{x:Bind ViewModel.DiscordLiveMetric, Mode=OneWay}" Style="{StaticResource ExoCaption}" Foreground="{ThemeResource ExoSecondaryTextBrush}" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Button>

                <Button Grid.Row="0" Grid.Column="1"
                        Style="{StaticResource ExoCardButton}"
                        AutomationProperties.Name="Open Steam optimizer"
                        Click="SteamCard_Click">
                    <Grid MinHeight="128" RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{ThemeResource ExoSteamBrush}" CornerRadius="2" />
                            <TextBlock Grid.Column="1" Text="Steam" Style="{StaticResource ExoFeatureTitle}" />
                            <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.SteamStatusTag, Mode=OneWay}" Style="{StaticResource ExoCaption}" />
                        </Grid>
                        <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.SteamStatusPrimary, Mode=OneWay}" Style="{StaticResource ExoBody}" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="2" Text="{x:Bind ViewModel.SteamStatusSecondary, Mode=OneWay}" Style="{StaticResource ExoCaption}" />
                        <TextBlock Grid.Row="3" Text="{x:Bind ViewModel.SteamLiveMetric, Mode=OneWay}" Style="{StaticResource ExoCaption}" Foreground="{ThemeResource ExoSecondaryTextBrush}" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Button>

                <Button Grid.Row="1" Grid.Column="0"
                        Style="{StaticResource ExoCardButton}"
                        AutomationProperties.Name="Open Internet optimizer"
                        Click="InternetCard_Click">
                    <Grid MinHeight="128" RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{ThemeResource ExoInternetBrush}" CornerRadius="2" />
                            <TextBlock Grid.Column="1" Text="Internet" Style="{StaticResource ExoFeatureTitle}" />
                            <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.InternetStatusTag, Mode=OneWay}" Style="{StaticResource ExoCaption}" />
                        </Grid>
                        <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.LatencyPrimary, Mode=OneWay}" Style="{StaticResource ExoBody}" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="2" Text="{x:Bind ViewModel.LatencySecondary, Mode=OneWay}" Style="{StaticResource ExoCaption}" />
                        <TextBlock Grid.Row="3" Text="{x:Bind ViewModel.InternetLiveMetric, Mode=OneWay}" Style="{StaticResource ExoCaption}" Foreground="{ThemeResource ExoSecondaryTextBrush}" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Button>

                <Button Grid.Row="1" Grid.Column="1"
                        Style="{StaticResource ExoCardButton}"
                        AutomationProperties.Name="Open NVIDIA optimizer"
                        Click="NvidiaCard_Click">
                    <Grid MinHeight="128" RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{ThemeResource ExoNvidiaBrush}" CornerRadius="2" />
                            <TextBlock Grid.Column="1" Text="NVIDIA" Style="{StaticResource ExoFeatureTitle}" />
                            <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.NvidiaStatusTag, Mode=OneWay}" Style="{StaticResource ExoCaption}" />
                        </Grid>
                        <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.NvidiaPathPrimary, Mode=OneWay}" Style="{StaticResource ExoBody}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Row="2" Text="{x:Bind ViewModel.NvidiaPathSecondary, Mode=OneWay}" Style="{StaticResource ExoCaption}" />
                        <TextBlock Grid.Row="3" Text="{x:Bind ViewModel.NvidiaLiveMetric, Mode=OneWay}" Style="{StaticResource ExoCaption}" Foreground="{ThemeResource ExoSecondaryTextBrush}" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Button>

                <Button Grid.Row="2" Grid.Column="0"
                        Style="{StaticResource ExoCardButton}"
                        AutomationProperties.Name="Open Riot optimizer"
                        Click="RiotCard_Click">
                    <Grid MinHeight="128" RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{ThemeResource ExoRiotBrush}" CornerRadius="2" />
                            <TextBlock Grid.Column="1" Text="Riot" Style="{StaticResource ExoFeatureTitle}" />
                            <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.RiotStatusTag, Mode=OneWay}" Style="{StaticResource ExoCaption}" />
                        </Grid>
                        <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.RiotStatusPrimary, Mode=OneWay}" Style="{StaticResource ExoBody}" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="2" Text="{x:Bind ViewModel.RiotStatusSecondary, Mode=OneWay}" Style="{StaticResource ExoCaption}" />
                        <TextBlock Grid.Row="3" Text="{x:Bind ViewModel.RiotLiveMetric, Mode=OneWay}" Style="{StaticResource ExoCaption}" Foreground="{ThemeResource ExoSecondaryTextBrush}" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Button>

                <Button Grid.Row="2" Grid.Column="1"
                        Style="{StaticResource ExoCardButton}"
                        AutomationProperties.Name="Open Epic optimizer"
                        Click="EpicCard_Click">
                    <Grid MinHeight="128" RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{ThemeResource ExoEpicBrush}" CornerRadius="2" />
                            <TextBlock Grid.Column="1" Text="Epic" Style="{StaticResource ExoFeatureTitle}" />
                            <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.EpicStatusTag, Mode=OneWay}" Style="{StaticResource ExoCaption}" />
                        </Grid>
                        <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.EpicStatusPrimary, Mode=OneWay}" Style="{StaticResource ExoBody}" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="2" Text="{x:Bind ViewModel.EpicStatusSecondary, Mode=OneWay}" Style="{StaticResource ExoCaption}" />
                        <TextBlock Grid.Row="3" Text="{x:Bind ViewModel.EpicLiveMetric, Mode=OneWay}" Style="{StaticResource ExoCaption}" Foreground="{ThemeResource ExoSecondaryTextBrush}" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Button>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
