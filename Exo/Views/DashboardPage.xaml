<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Exo.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:Exo.ViewModels"
    Background="Transparent"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded">

    <!--
      Home — useful at a glance:
      System RAM (live) · Steam reclaim · module status strip · Internet ping/status
    -->
    <Border x:Name="PageRoot"
            Style="{StaticResource ExoModulePlate}"
            Padding="24,20,24,16"
            UseLayoutRounding="True">
        <Grid RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel x:Name="HeroBlock"
                        Orientation="Horizontal"
                        Spacing="14"
                        VerticalAlignment="Center">
                <TextBlock x:Name="HeroBrand"
                           Text="Exo"
                           FontFamily="{StaticResource ExoUiFontSemiBold}"
                           FontSize="36"
                           FontWeight="SemiBold"
                           CharacterSpacing="-32"
                           LineHeight="36"
                           Foreground="{ThemeResource ExoPrimaryTextBrush}"
                           OpticalMarginAlignment="TrimSideBearings"
                           VerticalAlignment="Center"
                           UseLayoutRounding="True" />
                <TextBlock x:Name="HeroTagline"
                           Text="{x:Bind ViewModel.HeroSummary, Mode=OneWay}"
                           Style="{StaticResource ExoTagline}"
                           FontSize="15"
                           LineHeight="20"
                           TextWrapping="WrapWholeWords"
                           VerticalAlignment="Center"
                           Opacity="0.9"
                           UseLayoutRounding="True" />
            </StackPanel>

            <Grid x:Name="FrameHero"
                  Grid.Row="1"
                  ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Live system RAM — always useful -->
                <Border Grid.Column="0"
                        Background="{ThemeResource ExoGlassFillBrush}"
                        BorderBrush="{ThemeResource ExoGlassStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="18,16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="SYSTEM RAM"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   FontSize="10"
                                   CharacterSpacing="100"
                                   Foreground="{ThemeResource ExoMutedTextBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.MemoryPrimary, Mode=OneWay}"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   FontSize="44"
                                   CharacterSpacing="-36"
                                   LineHeight="48"
                                   Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.MemorySecondary, Mode=OneWay}"
                                   FontFamily="{StaticResource ExoUiFont}"
                                   FontSize="13"
                                   Foreground="{ThemeResource ExoMutedTextBrush}"
                                   TextWrapping="WrapWholeWords" />
                        <TextBlock Text="{x:Bind ViewModel.MemoryLoadText, Mode=OneWay}"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   FontSize="14"
                                   Foreground="{ThemeResource ExoAccentBrush}" />
                    </StackPanel>
                </Border>

                <!-- Steam reclaim + helper status -->
                <Border Grid.Column="1"
                        Background="{ThemeResource ExoGlassFillBrush}"
                        BorderBrush="{ThemeResource ExoGlassStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="18,16">
                    <Grid RowSpacing="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="STEAM RECLAIMED"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   FontSize="10"
                                   CharacterSpacing="100"
                                   Foreground="{ThemeResource ExoMutedTextBrush}" />
                        <TextBlock Grid.Row="1"
                                   Text="{x:Bind ViewModel.ReclaimedPrimary, Mode=OneWay}"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   FontSize="44"
                                   CharacterSpacing="-36"
                                   LineHeight="48"
                                   Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                        <TextBlock Grid.Row="2"
                                   Text="{x:Bind ViewModel.ReclaimedSecondary, Mode=OneWay}"
                                   FontFamily="{StaticResource ExoUiFont}"
                                   FontSize="13"
                                   Foreground="{ThemeResource ExoMutedTextBrush}"
                                   TextWrapping="WrapWholeWords" />
                        <ItemsControl Grid.Row="3"
                                      ItemsSource="{x:Bind ViewModel.SparkBars, Mode=OneWay}"
                                      VerticalAlignment="Bottom"
                                      Margin="0,8,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="3"
                                                VerticalAlignment="Bottom" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:HomeSparkBar">
                                    <Border Width="6"
                                            Height="{x:Bind Height}"
                                            CornerRadius="2"
                                            VerticalAlignment="Bottom"
                                            Background="{ThemeResource ExoAccentSoftBrush}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>

            <!-- Module status row — what is optimized -->
            <Grid x:Name="StatRow"
                  Grid.Row="2"
                  ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource ExoCard}" Padding="12,10" MinHeight="88">
                    <StackPanel Spacing="4">
                        <TextBlock Text="DISCORD" FontSize="10" CharacterSpacing="80"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   Foreground="{ThemeResource ExoMutedTextBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.DiscordStatusPrimary, Mode=OneWay}"
                                   FontSize="18" FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.DiscordStatusSecondary, Mode=OneWay}"
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{ThemeResource ExoMutedTextBrush}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource ExoCard}" Padding="12,10" MinHeight="88">
                    <StackPanel Spacing="4">
                        <TextBlock Text="STEAM" FontSize="10" CharacterSpacing="80"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   Foreground="{ThemeResource ExoMutedTextBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.SteamStatusPrimary, Mode=OneWay}"
                                   FontSize="18" FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.SteamStatusSecondary, Mode=OneWay}"
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{ThemeResource ExoMutedTextBrush}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource ExoCard}" Padding="12,10" MinHeight="88">
                    <StackPanel Spacing="4">
                        <TextBlock Text="INTERNET" FontSize="10" CharacterSpacing="80"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   Foreground="{ThemeResource ExoMutedTextBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.LatencyPrimary, Mode=OneWay}"
                                   FontSize="18" FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.LatencySecondary, Mode=OneWay}"
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{ThemeResource ExoMutedTextBrush}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource ExoCard}" Padding="12,10" MinHeight="88">
                    <StackPanel Spacing="4">
                        <TextBlock Text="NVIDIA" FontSize="10" CharacterSpacing="80"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   Foreground="{ThemeResource ExoMutedTextBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.NvidiaPathPrimary, Mode=OneWay}"
                                   FontSize="18" FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.NvidiaPathSecondary, Mode=OneWay}"
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{ThemeResource ExoMutedTextBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border x:Name="SoonRow"
                    Grid.Row="3"
                    BorderBrush="{ThemeResource ExoGlassStrokeBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="0,10,0,0">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Coming soon"
                               FontFamily="{StaticResource ExoUiFontSemiBold}"
                               FontSize="11"
                               CharacterSpacing="60"
                               Foreground="{ThemeResource ExoMutedTextBrush}"
                               VerticalAlignment="Center" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.SoonCards, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="12" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:OptimizerCardViewModel">
                                <TextBlock Text="{x:Bind Definition.Title, Mode=OneWay}"
                                           FontFamily="{StaticResource ExoUiFont}"
                                           FontSize="12"
                                           Foreground="{ThemeResource ExoMutedTextBrush}"
                                           Opacity="0.75" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Page>
