<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Exo.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:Exo.ViewModels"
    Background="Transparent"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded">

    <!--
      Home instrument plate = performance dashboard.
      Modules live in the top bar; home shows reclaim + live memory + latency proof.
    -->
    <Border x:Name="PageRoot"
            Style="{StaticResource ExoModulePlate}"
            Padding="28,22,28,16"
            UseLayoutRounding="True">
        <Grid RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Compact brand -->
            <StackPanel x:Name="HeroBlock"
                        Orientation="Horizontal"
                        Spacing="16"
                        VerticalAlignment="Center">
                <TextBlock x:Name="HeroBrand"
                           Text="Exo"
                           FontFamily="{StaticResource ExoUiFontSemiBold}"
                           FontSize="40"
                           FontWeight="SemiBold"
                           CharacterSpacing="-36"
                           LineHeight="40"
                           Foreground="{ThemeResource ExoPrimaryTextBrush}"
                           OpticalMarginAlignment="TrimSideBearings"
                           VerticalAlignment="Center"
                           UseLayoutRounding="True" />
                <TextBlock x:Name="HeroTagline"
                           Text="Maximum performance. No compromise."
                           Style="{StaticResource ExoTagline}"
                           FontSize="16"
                           LineHeight="22"
                           TextWrapping="WrapWholeWords"
                           VerticalAlignment="Center"
                           Opacity="0.9"
                           UseLayoutRounding="True" />
            </StackPanel>

            <!-- RAM reclaim hero -->
            <Border x:Name="RamHero"
                    Grid.Row="1"
                    Background="{ThemeResource ExoGlassFillBrush}"
                    BorderBrush="{ThemeResource ExoGlassStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20,18">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="RAM RECLAIMED"
                               FontFamily="{StaticResource ExoUiFontSemiBold}"
                               FontSize="10"
                               CharacterSpacing="100"
                               Foreground="{ThemeResource ExoMutedTextBrush}" />
                    <TextBlock Grid.Row="1"
                               Text="{x:Bind ViewModel.ReclaimedPrimary, Mode=OneWay}"
                               FontFamily="{StaticResource ExoUiFontSemiBold}"
                               FontSize="48"
                               CharacterSpacing="-40"
                               LineHeight="52"
                               Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                    <TextBlock Grid.Row="2"
                               Text="{x:Bind ViewModel.ReclaimedSecondary, Mode=OneWay}"
                               FontFamily="{StaticResource ExoUiFont}"
                               FontSize="13"
                               Foreground="{ThemeResource ExoMutedTextBrush}"
                               TextWrapping="WrapWholeWords" />
                    <ItemsControl Grid.Row="3"
                                  ItemsSource="{x:Bind ViewModel.SparkBars, Mode=OneWay}"
                                  VerticalAlignment="Bottom"
                                  Margin="0,8,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="3"
                                            VerticalAlignment="Bottom" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:HomeSparkBar">
                                <Border Width="7"
                                        Height="{x:Bind Height}"
                                        CornerRadius="2"
                                        VerticalAlignment="Bottom"
                                        Background="{ThemeResource ExoAccentSoftBrush}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- Live / proof tiles -->
            <Grid x:Name="StatRow"
                  Grid.Row="2"
                  ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{ThemeResource ExoGlassFillBrush}"
                        BorderBrush="{ThemeResource ExoGlassStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14,12"
                        MinHeight="96">
                    <StackPanel Spacing="4">
                        <TextBlock Text="MEMORY"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   FontSize="10"
                                   CharacterSpacing="80"
                                   Foreground="{ThemeResource ExoMutedTextBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{x:Bind ViewModel.MemoryPrimary, Mode=OneWay}"
                                       FontFamily="{StaticResource ExoUiFontSemiBold}"
                                       FontSize="22"
                                       Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.MemoryLoadText, Mode=OneWay}"
                                       FontFamily="{StaticResource ExoUiFontSemiBold}"
                                       FontSize="13"
                                       VerticalAlignment="Bottom"
                                       Margin="0,0,0,3"
                                       Foreground="{ThemeResource ExoMutedTextBrush}" />
                        </StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.MemorySecondary, Mode=OneWay}"
                                   FontFamily="{StaticResource ExoUiFont}"
                                   FontSize="12"
                                   Foreground="{ThemeResource ExoMutedTextBrush}"
                                   TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="{ThemeResource ExoGlassFillBrush}"
                        BorderBrush="{ThemeResource ExoGlassStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14,12"
                        MinHeight="96">
                    <StackPanel Spacing="4">
                        <TextBlock Text="LATENCY"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   FontSize="10"
                                   CharacterSpacing="80"
                                   Foreground="{ThemeResource ExoMutedTextBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.LatencyPrimary, Mode=OneWay}"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   FontSize="22"
                                   Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.LatencySecondary, Mode=OneWay}"
                                   FontFamily="{StaticResource ExoUiFont}"
                                   FontSize="12"
                                   Foreground="{ThemeResource ExoMutedTextBrush}"
                                   TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Background="{ThemeResource ExoGlassFillBrush}"
                        BorderBrush="{ThemeResource ExoGlassStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14,12"
                        MinHeight="96">
                    <StackPanel Spacing="4">
                        <TextBlock Text="TRIM PASSES"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   FontSize="10"
                                   CharacterSpacing="80"
                                   Foreground="{ThemeResource ExoMutedTextBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.TrimPassesText, Mode=OneWay}"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   FontSize="22"
                                   Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.TrimPassesDetail, Mode=OneWay}"
                                   FontFamily="{StaticResource ExoUiFont}"
                                   FontSize="12"
                                   Foreground="{ThemeResource ExoMutedTextBrush}"
                                   TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Coming soon -->
            <Border x:Name="SoonRow"
                    Grid.Row="3"
                    BorderBrush="{ThemeResource ExoGlassStrokeBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="0,10,0,0">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Coming soon"
                               FontFamily="{StaticResource ExoUiFontSemiBold}"
                               FontSize="11"
                               CharacterSpacing="60"
                               Foreground="{ThemeResource ExoMutedTextBrush}"
                               VerticalAlignment="Center" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.SoonCards, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="12" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:OptimizerCardViewModel">
                                <TextBlock Text="{x:Bind Definition.Title, Mode=OneWay}"
                                           FontFamily="{StaticResource ExoUiFont}"
                                           FontSize="12"
                                           Foreground="{ThemeResource ExoMutedTextBrush}"
                                           Opacity="0.75" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Page>
