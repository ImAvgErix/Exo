<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Exo.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:Exo.ViewModels"
    Background="Transparent"
    Loaded="Page_Loaded">

    <!--
      Centered instrument home under the top bar — fills the stage.
      Blade strip spans width; coming soon is a quiet centered line.
    -->
    <Grid x:Name="PageRoot"
          Padding="8,8,8,12"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          UseLayoutRounding="True">
        <StackPanel x:Name="HomeStack"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Spacing="0"
                    UseLayoutRounding="True">

            <TextBlock x:Name="HeroBrand"
                       Text="Exo"
                       FontFamily="{StaticResource ExoUiFontSemiBold}"
                       FontSize="72"
                       FontWeight="SemiBold"
                       CharacterSpacing="-40"
                       LineHeight="72"
                       Foreground="{ThemeResource ExoPrimaryTextBrush}"
                       TextAlignment="Center"
                       HorizontalAlignment="Stretch"
                       OpticalMarginAlignment="TrimSideBearings"
                       UseLayoutRounding="True"
                       Margin="0,0,0,8" />

            <TextBlock x:Name="HeroTagline"
                       Text="Maximum performance. No compromise."
                       Style="{StaticResource ExoTagline}"
                       FontSize="24"
                       LineHeight="30"
                       TextWrapping="WrapWholeWords"
                       TextAlignment="Center"
                       HorizontalAlignment="Stretch"
                       Margin="0,0,0,28"
                       UseLayoutRounding="True" />

            <Border x:Name="BladeStrip"
                    Background="{ThemeResource ExoGlassFillBrush}"
                    BorderBrush="{ThemeResource ExoGlassStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="4"
                    Margin="0,0,0,16"
                    HorizontalAlignment="Stretch"
                    MaxWidth="920">
                <ItemsControl x:Name="CardList"
                              HorizontalAlignment="Stretch"
                              ItemsSource="{x:Bind ViewModel.LiveCards, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" Rows="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:OptimizerCardViewModel">
                            <Button Style="{StaticResource ExoCardButton}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Margin="2"
                                    MinHeight="104"
                                    Click="CardButton_Click"
                                    Tag="{x:Bind Definition.Id}"
                                    AutomationProperties.Name="{x:Bind Definition.Title}">
                                <StackPanel Spacing="8"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Padding="8,14">
                                    <Image Width="30"
                                           Height="30"
                                           Source="{x:Bind Definition.LogoPath, Mode=OneWay, Converter={StaticResource AssetPathToImageSourceConverter}}"
                                           Stretch="Uniform"
                                           UseLayoutRounding="True"
                                           HorizontalAlignment="Center"
                                           AutomationProperties.AccessibilityView="Raw" />
                                    <TextBlock Text="{x:Bind Definition.Title, Mode=OneWay}"
                                               FontFamily="{StaticResource ExoUiFontSemiBold}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               CharacterSpacing="-4"
                                               Foreground="{ThemeResource ExoPrimaryTextBrush}"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               UseLayoutRounding="True" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <StackPanel Orientation="Horizontal"
                        Spacing="10"
                        HorizontalAlignment="Center">
                <TextBlock Text="Coming soon"
                           FontFamily="{StaticResource ExoUiFontSemiBold}"
                           FontSize="11"
                           CharacterSpacing="60"
                           Foreground="{ThemeResource ExoMutedTextBrush}"
                           VerticalAlignment="Center" />
                <ItemsControl ItemsSource="{x:Bind ViewModel.SoonCards, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="12" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:OptimizerCardViewModel">
                            <TextBlock Text="{x:Bind Definition.Title, Mode=OneWay}"
                                       FontFamily="{StaticResource ExoUiFont}"
                                       FontSize="12"
                                       Foreground="{ThemeResource ExoMutedTextBrush}"
                                       Opacity="0.75" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
