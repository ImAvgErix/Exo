<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Exo.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:Exo.ViewModels"
    Background="Transparent"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded">

    <!--
      Home:
      System RAM (full-width hero) · live Discord/Steam RAM · Internet ping+link · NVIDIA profile policy
    -->
    <Border x:Name="PageRoot"
            Style="{StaticResource ExoModulePlate}"
            Padding="24,20,24,16"
            UseLayoutRounding="True">
        <Grid RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel x:Name="HeroBlock"
                        Orientation="Horizontal"
                        Spacing="14"
                        VerticalAlignment="Center">
                <Border Width="4" Height="28"
                        CornerRadius="2"
                        Background="{ThemeResource ExoAccentBrush}"
                        VerticalAlignment="Center" />
                <TextBlock x:Name="HeroBrand"
                           Text="Exo"
                           FontFamily="{StaticResource ExoUiFontSemiBold}"
                           FontSize="36"
                           FontWeight="SemiBold"
                           CharacterSpacing="-32"
                           LineHeight="36"
                           Foreground="{ThemeResource ExoPrimaryTextBrush}"
                           OpticalMarginAlignment="TrimSideBearings"
                           VerticalAlignment="Center"
                           UseLayoutRounding="True" />
                <TextBlock x:Name="HeroTagline"
                           Text="{x:Bind ViewModel.HeroSummary, Mode=OneWay}"
                           Style="{StaticResource ExoTagline}"
                           FontSize="15"
                           LineHeight="20"
                           TextWrapping="WrapWholeWords"
                           VerticalAlignment="Center"
                           Opacity="0.9"
                           UseLayoutRounding="True" />
            </StackPanel>

            <!-- Full-width system RAM -->
            <Border x:Name="FrameHero"
                    Grid.Row="1"
                    Background="{ThemeResource ExoSurfaceSunkenBrush}"
                    BorderBrush="{ThemeResource ExoDividerBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="22,18"
                    MinHeight="120">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="SYSTEM RAM"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   FontSize="10"
                                   CharacterSpacing="100"
                                   Foreground="{ThemeResource ExoMutedTextBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.MemoryPrimary, Mode=OneWay}"
                                   FontFamily="{StaticResource ExoUiFontSemiBold}"
                                   FontSize="44"
                                   CharacterSpacing="-36"
                                   LineHeight="48"
                                   Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.MemorySecondary, Mode=OneWay}"
                                   FontFamily="{StaticResource ExoUiFont}"
                                   FontSize="13"
                                   Foreground="{ThemeResource ExoMutedTextBrush}"
                                   TextWrapping="WrapWholeWords" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="{x:Bind ViewModel.MemoryLoadText, Mode=OneWay}"
                               FontFamily="{StaticResource ExoUiFontSemiBold}"
                               FontSize="22"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource ExoAccentBrush}" />
                    <ProgressBar Grid.Row="1" Grid.ColumnSpan="2"
                                 Minimum="0" Maximum="100"
                                 Value="{x:Bind ViewModel.MemoryLoadPercent, Mode=OneWay}"
                                 Height="4"
                                 Margin="0,14,0,0"
                                 CornerRadius="2"
                                 Background="{ThemeResource ExoAccentSoftBrush}"
                                 Foreground="{ThemeResource ExoAccentBrush}" />
                </Grid>
            </Border>

            <!-- Four even module tiles -->
            <Grid x:Name="StatRow"
                  Grid.Row="2"
                  ColumnSpacing="10"
                  RowSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Discord: RAM reclaimed (peak−live) + live WS, 2s background -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource ExoCard}" Padding="14,12" MinHeight="110">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="3" CornerRadius="1.5" Background="{ThemeResource ExoDiscordBrush}" />
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="DISCORD RAM" FontSize="10" CharacterSpacing="100"
                                       FontFamily="{StaticResource ExoUiFontSemiBold}"
                                       Foreground="{ThemeResource ExoMutedTextBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.DiscordStatusPrimary, Mode=OneWay}"
                                       FontSize="28" FontFamily="{StaticResource ExoUiFontSemiBold}"
                                       CharacterSpacing="-20"
                                       Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.DiscordStatusSecondary, Mode=OneWay}"
                                       Style="{StaticResource ExoCaption}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Steam: live client RAM + contention-guard state -->
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource ExoCard}" Padding="14,12" MinHeight="110">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="3" CornerRadius="1.5" Background="{ThemeResource ExoSteamBrush}" />
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="STEAM RAM" FontSize="10" CharacterSpacing="100"
                                       FontFamily="{StaticResource ExoUiFontSemiBold}"
                                       Foreground="{ThemeResource ExoMutedTextBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.SteamStatusPrimary, Mode=OneWay}"
                                       FontSize="28" FontFamily="{StaticResource ExoUiFontSemiBold}"
                                       CharacterSpacing="-20"
                                       Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.SteamStatusSecondary, Mode=OneWay}"
                                       Style="{StaticResource ExoCaption}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Internet: before→after ping / jitter / DNS + live link speed -->
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource ExoCard}" Padding="14,12" MinHeight="110">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="3" CornerRadius="1.5" Background="{ThemeResource ExoInternetBrush}" />
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="INTERNET" FontSize="10" CharacterSpacing="100"
                                       FontFamily="{StaticResource ExoUiFontSemiBold}"
                                       Foreground="{ThemeResource ExoMutedTextBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.LatencyPrimary, Mode=OneWay}"
                                       FontSize="28" FontFamily="{StaticResource ExoUiFontSemiBold}"
                                       CharacterSpacing="-20"
                                       Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.LatencySecondary, Mode=OneWay}"
                                       Style="{StaticResource ExoCaption}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- NVIDIA: Max FPS NIP -->
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ExoCard}" Padding="14,12" MinHeight="110">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="3" CornerRadius="1.5" Background="{ThemeResource ExoNvidiaBrush}" />
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="NVIDIA" FontSize="10" CharacterSpacing="100"
                                       FontFamily="{StaticResource ExoUiFontSemiBold}"
                                       Foreground="{ThemeResource ExoMutedTextBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.NvidiaPathPrimary, Mode=OneWay}"
                                       FontSize="28" FontFamily="{StaticResource ExoUiFontSemiBold}"
                                       CharacterSpacing="-20"
                                       Foreground="{ThemeResource ExoPrimaryTextBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.NvidiaPathSecondary, Mode=OneWay}"
                                       Style="{StaticResource ExoCaption}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Border x:Name="SoonRow"
                    Grid.Row="3"
                    BorderBrush="{ThemeResource ExoGlassStrokeBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="0,10,0,0">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Coming soon"
                               FontFamily="{StaticResource ExoUiFontSemiBold}"
                               FontSize="11"
                               CharacterSpacing="60"
                               Foreground="{ThemeResource ExoMutedTextBrush}"
                               VerticalAlignment="Center" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.SoonCards, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="12" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:OptimizerCardViewModel">
                                <TextBlock Text="{x:Bind Definition.Title, Mode=OneWay}"
                                           FontFamily="{StaticResource ExoUiFont}"
                                           FontSize="12"
                                           Foreground="{ThemeResource ExoMutedTextBrush}"
                                           Opacity="0.75" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Page>
