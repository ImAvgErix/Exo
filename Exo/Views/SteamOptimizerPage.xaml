<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Exo.Views.SteamOptimizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Exo.ViewModels"
    xmlns:controls="using:Exo.Views.Controls"
    Background="Transparent">

    <Grid Padding="{StaticResource OptiPagePadding}">
        <Grid MaxWidth="{StaticResource OptiPageMaxWidth}" HorizontalAlignment="Stretch" RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Spacing="3">
                <TextBlock Text="STEAM" Style="{StaticResource OptiSectionTitle}" Margin="0,0,0,2" />
                <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" Style="{StaticResource OptiPageTitle}" />
            </StackPanel>
            <Grid Grid.Row="1">
                <controls:OptiLoader IsActive="{x:Bind ViewModel.IsStatusLoading, Mode=OneWay}"
                                     Visibility="{x:Bind ViewModel.IsStatusLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              HorizontalScrollMode="Disabled"
                              ZoomMode="Disabled"
                              Visibility="{x:Bind ViewModel.IsFeatureListVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsRepeater x:Name="FeatureRepeater" ItemsSource="{x:Bind ViewModel.Features, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MaximumRowsOrColumns="2" Orientation="Horizontal"
                                               MinItemWidth="260" MinColumnSpacing="10" MinRowSpacing="10" ItemsStretch="Fill" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:FeatureRowViewModel">
                                <Border Style="{StaticResource OptiFeatureTile}" Opacity="{x:Bind Opacity}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource OptiStatusRail}"
                                                Opacity="{x:Bind RailOpacity}" />
                                        <Border Grid.Column="1" Style="{StaticResource OptiIconWell}">
                                            <FontIcon Glyph="{x:Bind Glyph}" FontSize="14"
                                                      Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Title}" Style="{StaticResource OptiFeatureTitle}" />
                                            <TextBlock Text="{x:Bind Detail}" Style="{StaticResource OptiFeatureDetail}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
            </Grid>
            <StackPanel Grid.Row="2" Spacing="10">
                <Border Style="{StaticResource OptiMessageBanner}"
                        Visibility="{x:Bind ViewModel.HasLastResult, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="{x:Bind ViewModel.LastResultGlyph, Mode=OneWay}" FontSize="15"
                                  Foreground="{x:Bind ViewModel.LastResultBrush, Mode=OneWay}" VerticalAlignment="Top" />
                        <TextBlock Text="{x:Bind ViewModel.LastResult, Mode=OneWay}" Grid.Column="1"
                                   Style="{StaticResource OptiBody}" TextWrapping="Wrap" />
                    </Grid>
                </Border>
                <StackPanel Spacing="6"
                            Visibility="{x:Bind ViewModel.IsProgressVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ProgressBar Minimum="0" Maximum="100" Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                                 Height="4" CornerRadius="2" Foreground="{ThemeResource OptiAccentBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.ProgressStatus, Mode=OneWay}" Style="{StaticResource OptiCaption}" TextAlignment="Center" />
                </StackPanel>
                <!-- Resident trim proof: RAM reclaimed (steam-trim-stats.json, when present) -->
                <TextBlock Text="{x:Bind ViewModel.TrimStatsText, Mode=OneWay}"
                           Style="{StaticResource OptiCaption}"
                           Foreground="{ThemeResource OptiSuccessBrush}"
                           TextAlignment="Center"
                           Visibility="{x:Bind ViewModel.HasTrimStats, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <!-- Compact expandable last-apply step report -->
                <StackPanel Spacing="6"
                            Visibility="{x:Bind ViewModel.HasApplyReport, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button Style="{StaticResource OptiQuietButton}"
                            MinHeight="34"
                            Padding="12,6"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Command="{x:Bind ViewModel.ToggleApplyReportCommand}"
                            AutomationProperties.Name="Toggle last apply report">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Bind ViewModel.ApplyReportSummary, Mode=OneWay}"
                                       Style="{StaticResource OptiCaption}"
                                       Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                       VerticalAlignment="Center" />
                            <FontIcon Grid.Column="1"
                                      Glyph="{x:Bind ViewModel.ApplyReportChevron, Mode=OneWay}"
                                      FontSize="10"
                                      Foreground="{ThemeResource OptiMutedTextBrush}"
                                      VerticalAlignment="Center" />
                        </Grid>
                    </Button>
                    <ScrollViewer MaxHeight="150"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="{x:Bind ViewModel.IsApplyReportOpen, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.ApplyReportRows, Mode=OneWay}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:ApplyReportRowViewModel">
                                    <Grid ColumnSpacing="8" Padding="8,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Glyph="{x:Bind Glyph}" FontSize="11"
                                                  Foreground="{x:Bind Brush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Text}"
                                                   Style="{StaticResource OptiCaption}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </StackPanel>
                <Button Style="{StaticResource OptiPrimaryButton}" Content="{x:Bind ViewModel.RunButtonLabel, Mode=OneWay}" Click="Run_Click" HorizontalAlignment="Stretch"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                        AutomationProperties.Name="Apply Steam" />
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Style="{StaticResource OptiQuietButton}" Content="Repair" Click="Repair_Click" HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                    <Button Grid.Column="1" Style="{StaticResource OptiQuietButton}" Content="Refresh" Click="Refresh_Click" HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
