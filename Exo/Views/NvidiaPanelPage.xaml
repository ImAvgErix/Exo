<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Exo.Views.NvidiaPanelPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Exo.ViewModels"
    xmlns:controls="using:Exo.Views.Controls"
    Background="Transparent">

    <!--
      Tool-like layout: header + scrollable display cards + sticky footer
      (CPL button + Refresh). Selectors only — no policy "applied" tiles.
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Padding="28,18,28,10">
            <Grid MaxWidth="{StaticResource ExoPageMaxWidth}"
                  HorizontalAlignment="Stretch"
                  RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock Text="DISPLAY"
                               Style="{StaticResource ExoSectionTitle}"
                               Margin="0" />
                    <TextBlock Text="{x:Bind ViewModel.HeaderStatus, Mode=OneWay}"
                               Style="{StaticResource ExoPageTitle}"
                               FontSize="26"
                               LineHeight="32"
                               CharacterSpacing="-24" />
                    <TextBlock Text="{x:Bind ViewModel.HeaderDetail, Mode=OneWay}"
                               Style="{StaticResource ExoCaption}"
                               Margin="0,2,0,0" />
                </StackPanel>

                <Grid Grid.Row="1">
                    <controls:ExoLoader IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                         Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  HorizontalScrollMode="Disabled"
                                  ZoomMode="Disabled"
                                  Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <StackPanel Spacing="10"
                                    Visibility="{x:Bind ViewModel.HasDisplays, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsControl ItemsSource="{x:Bind ViewModel.Displays, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsStackPanel Orientation="Vertical" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:NvidiaDisplayColorRowViewModel">
                                        <Border Style="{StaticResource ExoCard}"
                                                Padding="14,12"
                                                Margin="0,0,0,10"
                                                HorizontalAlignment="Stretch">
                                            <StackPanel Spacing="12">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Spacing="2" VerticalAlignment="Center">
                                                        <TextBlock Text="{x:Bind Title}"
                                                                   Style="{StaticResource ExoFeatureTitle}"
                                                                   FontSize="14"
                                                                   CharacterSpacing="-4" />
                                                        <TextBlock Text="{x:Bind ChangeHint, Mode=OneWay}"
                                                                   Style="{StaticResource ExoCaption}"
                                                                   FontSize="11"
                                                                   TextWrapping="WrapWholeWords"
                                                                   Visibility="{x:Bind HasChangeHint, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            Style="{StaticResource ExoPrimaryButton}"
                                                            Content="{x:Bind ApplyLabel, Mode=OneWay}"
                                                            MinWidth="96"
                                                            MinHeight="36"
                                                            Padding="12,8"
                                                            Click="ApplyDisplay_Click"
                                                            Tag="{x:Bind}"
                                                            IsEnabled="{x:Bind CanApply, Mode=OneWay}"
                                                            AutomationProperties.Name="Apply display settings" />
                                                </Grid>

                                                <Grid ColumnSpacing="10" RowSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <StackPanel Spacing="4">
                                                        <TextBlock Text="Resolution" Style="{StaticResource ExoCaption}" />
                                                        <ComboBox ItemsSource="{x:Bind ResolutionOptions}"
                                                                  SelectedItem="{x:Bind SelectedResolution, Mode=TwoWay}"
                                                                  HorizontalAlignment="Stretch"
                                                                  MinHeight="34"
                                                                  AutomationProperties.Name="Resolution" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Spacing="4">
                                                        <TextBlock Text="Refresh rate" Style="{StaticResource ExoCaption}" />
                                                        <ComboBox ItemsSource="{x:Bind RefreshOptions}"
                                                                  SelectedItem="{x:Bind SelectedRefresh, Mode=TwoWay}"
                                                                  HorizontalAlignment="Stretch"
                                                                  MinHeight="34"
                                                                  AutomationProperties.Name="Refresh rate" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="1" Spacing="4">
                                                        <TextBlock Text="Color depth" Style="{StaticResource ExoCaption}" />
                                                        <ComboBox ItemsSource="{x:Bind DepthOptions}"
                                                                  SelectedItem="{x:Bind SelectedDepth, Mode=TwoWay}"
                                                                  HorizontalAlignment="Stretch"
                                                                  MinHeight="34"
                                                                  AutomationProperties.Name="Color depth" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                                        <TextBlock Text="NVIDIA color" Style="{StaticResource ExoCaption}" />
                                                        <ComboBox ItemsSource="{x:Bind ColorRangeOptions}"
                                                                  SelectedItem="{x:Bind SelectedColorRange, Mode=TwoWay}"
                                                                  HorizontalAlignment="Stretch"
                                                                  MinHeight="34"
                                                                  AutomationProperties.Name="NVIDIA color range" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Spacing="4">
                                                        <TextBlock Text="Scaling" Style="{StaticResource ExoCaption}" />
                                                        <ComboBox ItemsSource="{x:Bind ScalingOptions}"
                                                                  SelectedItem="{x:Bind SelectedScaling, Mode=TwoWay}"
                                                                  HorizontalAlignment="Stretch"
                                                                  MinHeight="34"
                                                                  AutomationProperties.Name="Scaling" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Spacing="4"
                                                                Visibility="{x:Bind VibranceSupported, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <Grid ColumnSpacing="8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="Digital vibrance" Style="{StaticResource ExoCaption}" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{x:Bind VibranceValueLabel, Mode=OneWay}"
                                                                       Style="{StaticResource ExoCaption}" />
                                                        </Grid>
                                                        <Slider Style="{StaticResource ExoLiveSlider}"
                                                                Minimum="{x:Bind VibranceMinimum, Mode=OneWay}"
                                                                Maximum="{x:Bind VibranceMaximum, Mode=OneWay}"
                                                                Value="{x:Bind SelectedVibrance, Mode=TwoWay}"
                                                                StepFrequency="1"
                                                                HorizontalAlignment="Stretch"
                                                                AutomationProperties.Name="Digital vibrance" />
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>

        <Border Grid.Row="1"
                Style="{StaticResource ExoActionBar}"
                Padding="28,12,28,14">
            <StackPanel MaxWidth="{StaticResource ExoPageMaxWidth}"
                        HorizontalAlignment="Stretch"
                        Spacing="10">
                <Border Style="{StaticResource ExoMessageBanner}"
                        Visibility="{x:Bind ViewModel.HasMessage, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="{x:Bind ViewModel.MessageGlyph, Mode=OneWay}"
                                  FontSize="14"
                                  Foreground="{x:Bind ViewModel.MessageBrush, Mode=OneWay}"
                                  VerticalAlignment="Top" />
                        <TextBlock Text="{x:Bind ViewModel.Message, Mode=OneWay}"
                                   Grid.Column="1"
                                   Style="{StaticResource ExoBody}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </Border>

                <StackPanel Spacing="6"
                            Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ProgressBar Minimum="0" Maximum="100"
                                 Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                                 Height="3"
                                 CornerRadius="2"
                                 Foreground="{ThemeResource ExoAccentBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.ProgressStatus, Mode=OneWay}"
                               Style="{StaticResource ExoCaption}"
                               TextAlignment="Center" />
                </StackPanel>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Style="{StaticResource ExoQuietButton}"
                            Content="Open NVIDIA Control Panel"
                            Click="OpenControlPanel_Click"
                            MinHeight="36"
                            Padding="12,8"
                            HorizontalAlignment="Stretch"
                            Visibility="{x:Bind ViewModel.HasControlPanel, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                            AutomationProperties.Name="Open NVIDIA Control Panel" />
                    <Button Grid.Column="1"
                            Style="{StaticResource ExoQuietButton}"
                            Content="Refresh"
                            Click="Refresh_Click"
                            MinHeight="36"
                            MinWidth="96"
                            Padding="12,8"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                            AutomationProperties.Name="Refresh displays" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Page>
