<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Exo.Views.InternetOptimizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Exo.ViewModels"
    xmlns:controls="using:Exo.Views.Controls"
    Background="Transparent">

    <!--
      One adaptive action: measure first, then apply one verified link policy.
      Repair stays separate from optimization.
    -->
    <controls:SharedModulePlate
        x:Name="Plate"
        ModuleTitle="INTERNET"
        StatusText="{x:Bind ViewModel.HeaderStatus, Mode=OneWay}"
        GuidanceText="{x:Bind ViewModel.GuidanceText, Mode=OneWay}"
        HasGuidance="{x:Bind ViewModel.HasGuidance, Mode=OneWay}"
        IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
        FeatureItems="{x:Bind ViewModel.Rows, Mode=OneWay}"
        IsFeatureListVisible="{x:Bind ViewModel.IsFeatureListVisible, Mode=OneWay}"
        HasLastResult="{x:Bind ViewModel.HasMessage, Mode=OneWay}"
        LastResult="{x:Bind ViewModel.Message, Mode=OneWay}"
        LastResultGlyph="{x:Bind ViewModel.MessageGlyph, Mode=OneWay}"
        LastResultBrush="{x:Bind ViewModel.MessageBrush, Mode=OneWay}"
        HasApplyReport="False"
        ShowSecondaryActions="False">
        <controls:SharedModulePlate.FootExtra>
            <StackPanel Spacing="6">
                <Border Style="{StaticResource ExoMessageBanner}"
                        Visibility="{x:Bind ViewModel.HasRollback, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE7BA;" FontSize="12"
                                  Foreground="{ThemeResource ExoWarningBrush}" VerticalAlignment="Top" />
                        <TextBlock Text="{x:Bind ViewModel.RollbackNotice, Mode=OneWay}" Grid.Column="1"
                                   Style="{StaticResource ExoMessageText}" TextWrapping="Wrap" />
                    </Grid>
                </Border>
                <TextBlock Text="{x:Bind ViewModel.QualitySummary, Mode=OneWay}"
                           Style="{StaticResource ExoCaption}"
                           FontFamily="{StaticResource ExoUiFontSemiBold}"
                           TextAlignment="Center"
                           Visibility="{x:Bind ViewModel.HasQualityResult, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBlock Text="{x:Bind ViewModel.ProgressStatus, Mode=OneWay}" Style="{StaticResource ExoCaption}"
                           TextAlignment="Center"
                           Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </controls:SharedModulePlate.FootExtra>
        <controls:SharedModulePlate.PrimaryActions>
            <StackPanel Spacing="6">
                <Button Style="{StaticResource ExoPrimaryButton}"
                        Content="Analyze &amp; Apply"
                        Command="{x:Bind ViewModel.AnalyzeAndApplyCommand}"
                        HorizontalAlignment="Stretch"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                        AutomationProperties.Name="Analyze this connection and apply the best measured settings" />
                <Button Style="{StaticResource ExoQuietButton}"
                        Content="Repair"
                        Click="Repair_Click"
                        MinHeight="40"
                        Padding="12,6"
                        HorizontalAlignment="Stretch"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                        AutomationProperties.Name="Repair internet stack" />
                <TextBlock Text="{x:Bind ViewModel.RepairHint, Mode=OneWay}"
                           Style="{StaticResource ExoCaption}"
                           TextAlignment="Center" />
            </StackPanel>
        </controls:SharedModulePlate.PrimaryActions>
    </controls:SharedModulePlate>
</Page>
