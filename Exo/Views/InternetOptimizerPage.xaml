<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Exo.Views.InternetOptimizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Exo.ViewModels"
    xmlns:controls="using:Exo.Views.Controls"
    Background="Transparent">

    <!--
      SharedModulePlate (v3): dual primary CTAs + custom foot proof layer.
      Secondary row disabled — Repair/Refresh live in the single-row action grid.
    -->
    <controls:SharedModulePlate
        x:Name="Plate"
        ModuleTitle="INTERNET"
        StatusText="{x:Bind ViewModel.HeaderStatus, Mode=OneWay}"
        GuidanceText="{x:Bind ViewModel.GuidanceText, Mode=OneWay}"
        HasGuidance="{x:Bind ViewModel.HasGuidance, Mode=OneWay}"
        FeatureItems="{x:Bind ViewModel.Rows, Mode=OneWay}"
        IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
        IsFeatureListVisible="{x:Bind ViewModel.IsFeatureListVisible, Mode=OneWay}"
        HasLastResult="{x:Bind ViewModel.HasMessage, Mode=OneWay}"
        LastResult="{x:Bind ViewModel.Message, Mode=OneWay}"
        LastResultGlyph="{x:Bind ViewModel.MessageGlyph, Mode=OneWay}"
        LastResultBrush="{x:Bind ViewModel.MessageBrush, Mode=OneWay}"
        HasApplyReport="{x:Bind ViewModel.HasApplyReport, Mode=OneWay}"
        IsApplyReportOpen="{x:Bind ViewModel.IsApplyReportOpen, Mode=OneWay}"
        ApplyReportSummary="{x:Bind ViewModel.ApplyReportSummary, Mode=OneWay}"
        ApplyReportChevron="{x:Bind ViewModel.ApplyReportChevron, Mode=OneWay}"
        ApplyReportRows="{x:Bind ViewModel.ApplyReportRows, Mode=OneWay}"
        ShowSecondaryActions="False"
        ToggleReportClick="ToggleReport_Click">
        <controls:SharedModulePlate.FootExtra>
            <StackPanel Spacing="6">
                <Border Style="{StaticResource ExoMessageBanner}"
                        Visibility="{x:Bind ViewModel.HasRollback, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE7BA;" FontSize="12"
                                  Foreground="{ThemeResource ExoWarningBrush}" VerticalAlignment="Top" />
                        <TextBlock Text="{x:Bind ViewModel.RollbackNotice, Mode=OneWay}" Grid.Column="1"
                                   Style="{StaticResource ExoMessageText}" TextWrapping="Wrap" />
                    </Grid>
                </Border>
                <TextBlock Text="{x:Bind ViewModel.BenchmarkSummary, Mode=OneWay}"
                           Style="{StaticResource ExoCaption}"
                           Foreground="{x:Bind ViewModel.BenchmarkBrush, Mode=OneWay}"
                           TextAlignment="Center"
                           Visibility="{x:Bind ViewModel.HasBenchmark, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBlock Text="{x:Bind ViewModel.ProgressStatus, Mode=OneWay}" Style="{StaticResource ExoCaption}"
                           TextAlignment="Center"
                           Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </controls:SharedModulePlate.FootExtra>
        <controls:SharedModulePlate.PrimaryActions>
            <StackPanel Spacing="6">
                <!-- Wide plate: keep all four actions on one row so results do not squeeze the feature list. -->
                <Grid x:Name="ExoInternetActionGrid" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>
                    <Button Style="{StaticResource ExoWhiteButton}"
                            Content="Low latency"
                            Click="Latency_Click"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                            AutomationProperties.Name="Apply lowest latency network stack" />
                    <Button Grid.Column="1"
                            Style="{StaticResource ExoWhiteButton}"
                            Content="Highest download"
                            Click="Throughput_Click"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                            AutomationProperties.Name="Apply highest download network stack" />
                    <Button Grid.Column="2"
                            Style="{StaticResource ExoQuietButton}"
                            Content="Repair"
                            Click="Repair_Click"
                            MinHeight="40"
                            Padding="12,6"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                            AutomationProperties.Name="Repair internet stack" />
                    <Button Grid.Column="3"
                            Style="{StaticResource ExoQuietButton}"
                            Content="Refresh"
                            Click="Refresh_Click"
                            MinHeight="40"
                            Padding="12,6"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                </Grid>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.PrivateDnsEnabled, Mode=TwoWay}"
                                  IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                  AutomationProperties.Name="Private DNS, encrypted DNS over HTTPS" />
                    <TextBlock Text="Private DNS — encrypt lookups via Cloudflare DoH (Win11 22H2+)"
                               Style="{StaticResource ExoCaption}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="{x:Bind ViewModel.RepairHint, Mode=OneWay}"
                           Style="{StaticResource ExoCaption}"
                           TextAlignment="Center" />
            </StackPanel>
        </controls:SharedModulePlate.PrimaryActions>
    </controls:SharedModulePlate>
</Page>
