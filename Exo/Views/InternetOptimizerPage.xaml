<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Exo.Views.InternetOptimizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Exo.ViewModels"
    xmlns:controls="using:Exo.Views.Controls"
    Background="Transparent">

    <Grid Padding="{StaticResource OptiPagePadding}">
        <Grid MaxWidth="{StaticResource OptiPageMaxWidth}" HorizontalAlignment="Stretch" RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Spacing="3">
                <TextBlock Text="INTERNET" Style="{StaticResource OptiSectionTitle}" Margin="0,0,0,2" />
                <TextBlock Text="{x:Bind ViewModel.HeaderStatus, Mode=OneWay}" Style="{StaticResource OptiPageTitle}" />
            </StackPanel>
            <Grid Grid.Row="1">
                <controls:OptiLoader IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                     Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              HorizontalScrollMode="Disabled"
                              ZoomMode="Disabled"
                              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MaximumRowsOrColumns="2" Orientation="Horizontal"
                                               MinItemWidth="260" MinColumnSpacing="10" MinRowSpacing="10" ItemsStretch="Fill" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:FeatureRowViewModel">
                                <Border Style="{StaticResource OptiFeatureTile}" Opacity="{x:Bind Opacity}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource OptiStatusRail}"
                                                Opacity="{x:Bind RailOpacity}" />
                                        <Border Grid.Column="1" Style="{StaticResource OptiIconWell}">
                                            <FontIcon Glyph="{x:Bind Glyph}" FontSize="14"
                                                      Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Title}" Style="{StaticResource OptiFeatureTitle}" />
                                            <TextBlock Text="{x:Bind Detail}" Style="{StaticResource OptiFeatureDetail}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
            </Grid>
            <StackPanel Grid.Row="2" Spacing="10">
                <Border Style="{StaticResource OptiMessageBanner}"
                        Visibility="{x:Bind ViewModel.HasMessage, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="{x:Bind ViewModel.MessageGlyph, Mode=OneWay}" FontSize="15"
                                  Foreground="{x:Bind ViewModel.MessageBrush, Mode=OneWay}" VerticalAlignment="Top" />
                        <TextBlock Text="{x:Bind ViewModel.Message, Mode=OneWay}" Grid.Column="1"
                                   Style="{StaticResource OptiBody}" TextWrapping="Wrap" />
                    </Grid>
                </Border>
                <TextBlock Text="{x:Bind ViewModel.ProgressStatus, Mode=OneWay}" Style="{StaticResource OptiCaption}"
                           TextAlignment="Center"
                           Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Style="{StaticResource OptiWhiteButton}"
                            Content="Low latency"
                            Click="Latency_Click"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                            AutomationProperties.Name="Apply lowest latency network stack" />
                    <Button Grid.Column="1"
                            Style="{StaticResource OptiWhiteButton}"
                            Content="Highest download"
                            Click="Throughput_Click"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                            AutomationProperties.Name="Apply highest download network stack" />
                </Grid>
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Style="{StaticResource OptiQuietButton}" Content="Repair" Click="Repair_Click"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                            AutomationProperties.Name="Repair internet stack" />
                    <Button Grid.Column="1" Style="{StaticResource OptiQuietButton}" Content="Refresh" Click="Refresh_Click"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
