<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Exo.Views.InternetOptimizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Exo.ViewModels"
    xmlns:controls="using:Exo.Views.Controls"
    Background="Transparent">

    <!--
      Module craft surface: header zone + feature list + sticky instrument bar.
      Dual primary CTAs (Low latency / Highest download) via ExoWhiteButton→ExoPrimaryButton; quiet secondaries.
    -->
    <Border Style="{StaticResource ExoModulePlate}">
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Padding="20,16,20,8">
            <Grid MaxWidth="{StaticResource ExoPageMaxWidth}"
                  HorizontalAlignment="Stretch"
                  RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="6">
                    <TextBlock Text="INTERNET"
                               Style="{StaticResource ExoSectionTitle}"
                               Margin="0" />
                    <TextBlock Text="{x:Bind ViewModel.HeaderStatus, Mode=OneWay}"
                               Style="{StaticResource ExoPageTitle}"
                               FontSize="26"
                               LineHeight="32"
                               CharacterSpacing="-24" />
                </StackPanel>

                <Grid Grid.Row="1">
                    <controls:ExoLoader IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                         Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <controls:FeatureTileGrid x:Name="FeatureGrid"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}"
                                              Visibility="{x:Bind ViewModel.IsFeatureListVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                </Grid>
            </Grid>
        </Grid>

        <Border Grid.Row="1"
                Style="{StaticResource ExoActionBar}"
                Padding="20,12,20,14">
            <StackPanel MaxWidth="{StaticResource ExoPageMaxWidth}"
                        HorizontalAlignment="Stretch"
                        Spacing="10">
                <Border Style="{StaticResource ExoMessageBanner}"
                        Visibility="{x:Bind ViewModel.HasRollback, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE7BA;" FontSize="14"
                                  Foreground="{ThemeResource ExoWarningBrush}" VerticalAlignment="Top" />
                        <TextBlock Text="{x:Bind ViewModel.RollbackNotice, Mode=OneWay}" Grid.Column="1"
                                   Style="{StaticResource ExoBody}" TextWrapping="Wrap" />
                    </Grid>
                </Border>
                <TextBlock Text="{x:Bind ViewModel.BenchmarkSummary, Mode=OneWay}"
                           Style="{StaticResource ExoCaption}"
                           Foreground="{x:Bind ViewModel.BenchmarkBrush, Mode=OneWay}"
                           TextAlignment="Center"
                           Visibility="{x:Bind ViewModel.HasBenchmark, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Border Style="{StaticResource ExoMessageBanner}"
                        Visibility="{x:Bind ViewModel.HasMessage, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="{x:Bind ViewModel.MessageGlyph, Mode=OneWay}" FontSize="14"
                                  Foreground="{x:Bind ViewModel.MessageBrush, Mode=OneWay}" VerticalAlignment="Top" />
                        <TextBlock Text="{x:Bind ViewModel.Message, Mode=OneWay}" Grid.Column="1"
                                   Style="{StaticResource ExoBody}" TextWrapping="Wrap" />
                    </Grid>
                </Border>
                <TextBlock Text="{x:Bind ViewModel.ProgressStatus, Mode=OneWay}" Style="{StaticResource ExoCaption}"
                           TextAlignment="Center"
                           Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <StackPanel Spacing="6"
                            Visibility="{x:Bind ViewModel.HasApplyReport, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button Style="{StaticResource ExoQuietButton}"
                            MinHeight="32"
                            Padding="12,6"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Command="{x:Bind ViewModel.ToggleApplyReportCommand}"
                            AutomationProperties.Name="Toggle last apply report">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Bind ViewModel.ApplyReportSummary, Mode=OneWay}"
                                       Style="{StaticResource ExoCaption}"
                                       Foreground="{ThemeResource ExoPrimaryTextBrush}"
                                       VerticalAlignment="Center" />
                            <FontIcon Grid.Column="1"
                                      Glyph="{x:Bind ViewModel.ApplyReportChevron, Mode=OneWay}"
                                      FontSize="10"
                                      Foreground="{ThemeResource ExoMutedTextBrush}"
                                      VerticalAlignment="Center" />
                        </Grid>
                    </Button>
                    <ScrollViewer MaxHeight="140"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="{x:Bind ViewModel.IsApplyReportOpen, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.ApplyReportRows, Mode=OneWay}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:ApplyReportRowViewModel">
                                    <Grid ColumnSpacing="8" Padding="8,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Glyph="{x:Bind Glyph}" FontSize="11"
                                                  Foreground="{x:Bind Brush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Text}"
                                                   Style="{StaticResource ExoCaption}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </StackPanel>

                <!-- Dual primary CTAs (same role as Apply elsewhere) -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Style="{StaticResource ExoWhiteButton}"
                            Content="Low latency"
                            Click="Latency_Click"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                            AutomationProperties.Name="Apply lowest latency network stack" />
                    <Button Grid.Column="1"
                            Style="{StaticResource ExoWhiteButton}"
                            Content="Highest download"
                            Click="Throughput_Click"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                            AutomationProperties.Name="Apply highest download network stack" />
                </Grid>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Style="{StaticResource ExoQuietButton}"
                            Content="Repair"
                            Click="Repair_Click"
                            MinHeight="34"
                            Padding="12,6"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                            AutomationProperties.Name="Repair internet stack" />
                    <Button Grid.Column="1"
                            Style="{StaticResource ExoQuietButton}"
                            Content="Refresh"
                            Click="Refresh_Click"
                            MinHeight="34"
                            Padding="12,6"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                </Grid>
                <TextBlock Text="{x:Bind ViewModel.RepairHint, Mode=OneWay}"
                           Style="{StaticResource ExoCaption}"
                           TextAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
    </Border>
</Page>
