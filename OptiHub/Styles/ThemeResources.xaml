<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:OptiHub.Helpers">

    <!-- Fonts: Outfit (display) · Manrope (UI) -->
    <FontFamily x:Key="OptiDisplayFont">ms-appx:///Assets/Fonts/Outfit-SemiBold.ttf#Outfit</FontFamily>
    <FontFamily x:Key="OptiDisplayFontMedium">ms-appx:///Assets/Fonts/Outfit-Medium.ttf#Outfit</FontFamily>
    <FontFamily x:Key="OptiUiFont">ms-appx:///Assets/Fonts/Manrope-Regular.ttf#Manrope</FontFamily>
    <FontFamily x:Key="OptiUiFontMedium">ms-appx:///Assets/Fonts/Manrope-Medium.ttf#Manrope</FontFamily>
    <FontFamily x:Key="OptiUiFontSemiBold">ms-appx:///Assets/Fonts/Manrope-SemiBold.ttf#Manrope</FontFamily>

    <CornerRadius x:Key="OptiCardRadius">16</CornerRadius>
    <x:Double x:Key="OptiPagePadding">32</x:Double>
    <x:Double x:Key="OptiPageMaxWidth">760</x:Double>

    <helpers:InverseBoolConverter x:Key="InverseBoolConverter" />
    <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    <helpers:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
    <helpers:AssetPathToImageSourceConverter x:Key="AssetPathToImageSourceConverter" />

    <Style x:Key="OptiTagline" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OptiDisplayFont}" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="-20" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="LineHeight" Value="36" />
        <Setter Property="OpticalMarginAlignment" Value="TrimSideBearings" />
        <Setter Property="Foreground" Value="{ThemeResource OptiPrimaryTextBrush}" />
    </Style>

    <Style x:Key="OptiPageTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OptiDisplayFont}" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="-15" />
        <Setter Property="OpticalMarginAlignment" Value="TrimSideBearings" />
        <Setter Property="Foreground" Value="{ThemeResource OptiPrimaryTextBrush}" />
    </Style>

    <Style x:Key="OptiSectionTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OptiUiFontSemiBold}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="Foreground" Value="{ThemeResource OptiPrimaryTextBrush}" />
    </Style>

    <Style x:Key="OptiBody" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OptiUiFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{ThemeResource OptiSecondaryTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="22" />
    </Style>

    <Style x:Key="OptiCaption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OptiUiFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource OptiMutedTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="OptiCard" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource OptiCardRadius}" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="Background" Value="{ThemeResource OptiCardFillBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource OptiCardStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="OptiPrimaryButton" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
        <Setter Property="FontFamily" Value="{StaticResource OptiUiFontSemiBold}" />
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Background" Value="{ThemeResource OptiAccentBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource OptiOnAccentBrush}" />
    </Style>

    <Style x:Key="OptiQuietButton" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="FontFamily" Value="{StaticResource OptiUiFontMedium}" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style x:Key="OptiIconButton" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- Rounded GridView item — kills square hover chrome -->
    <Style x:Key="OptiGridViewItemStyle" TargetType="GridViewItem">
        <Setter Property="Margin" Value="8" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FocusVisualPrimaryThickness" Value="0" />
        <Setter Property="FocusVisualSecondaryThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridViewItem">
                    <Grid Background="Transparent">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ContentRoot"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.92" Duration="0:0:0.12" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ContentRoot"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.82" Duration="0:0:0.08" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Selected" />
                                <VisualState x:Name="PointerOverSelected" />
                                <VisualState x:Name="PressedSelected" />
                                <VisualState x:Name="Disabled">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ContentRoot"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.5" Duration="0" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter x:Name="ContentRoot"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          ContentTransitions="{TemplateBinding ContentTransitions}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
