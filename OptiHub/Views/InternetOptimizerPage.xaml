<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OptiHub.Views.InternetOptimizerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:OptiHub.ViewModels"
      Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="{StaticResource OptiPageMaxWidth}"
                    HorizontalAlignment="Center"
                    Padding="{StaticResource OptiPagePadding}"
                    Spacing="28">
            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <TextBlock Text="Internet" Style="{StaticResource OptiPageTitle}"
                           HorizontalAlignment="Center" FontSize="36" CharacterSpacing="-60" />
                <TextBlock Text="{x:Bind ViewModel.HeaderStatus, Mode=OneWay}" Style="{StaticResource OptiCaption}"
                           HorizontalAlignment="Center" TextAlignment="Center" />
            </StackPanel>
            <Grid MinHeight="120">
                <ProgressRing Width="28" Height="28" IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}"
                               Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                               HorizontalAlignment="Center">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MaximumRowsOrColumns="3" Orientation="Horizontal"
                                           MinItemWidth="140" MinColumnSpacing="10" MinRowSpacing="10"
                                           ItemsStretch="None" ItemsJustification="Center" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:FeatureRowViewModel">
                            <Border Style="{StaticResource OptiFeatureTile}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="{x:Bind Glyph}" FontSize="13"
                                              Foreground="{ThemeResource OptiAccentBrush}" VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Bind Title}" Style="{StaticResource OptiFeatureTitle}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </Grid>
            <StackPanel Spacing="12" MaxWidth="360" HorizontalAlignment="Center">
                <Border Style="{StaticResource OptiMessageBanner}"
                        Visibility="{x:Bind ViewModel.HasMessage, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{x:Bind ViewModel.Message, Mode=OneWay}" Style="{StaticResource OptiBody}"
                               TextWrapping="Wrap" TextAlignment="Center" />
                </Border>
                <TextBlock Text="{x:Bind ViewModel.ProgressStatus, Mode=OneWay}" Style="{StaticResource OptiCaption}"
                           HorizontalAlignment="Center"
                           Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Button Style="{StaticResource OptiPrimaryButton}" Content="Lowest latency" Click="Latency_Click"
                        HorizontalAlignment="Stretch"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                <Button Style="{StaticResource OptiQuietButton}" Content="Highest download" Click="Throughput_Click"
                        HorizontalAlignment="Stretch"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                <Button Style="{StaticResource OptiQuietButton}" Content="Refresh" Click="Refresh_Click"
                        HorizontalAlignment="Stretch"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
