<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.InternetOptimizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:OptiHub.ViewModels"
    Background="Transparent">

    <Grid Padding="{StaticResource OptiPagePadding}">
        <Grid MaxWidth="{StaticResource OptiPageMaxWidth}"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{ThemeResource OptiSurfaceBrush}"
                    BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="22,18">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{ThemeResource OptiRailBrush}" CornerRadius="2" />
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="INTERNET" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <TextBlock Text="{x:Bind ViewModel.HeaderStatus, Mode=OneWay}" Style="{StaticResource OptiPageTitle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <ProgressRing Width="28" Height="28"
                              IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MaximumRowsOrColumns="2" Orientation="Horizontal"
                                               MinItemWidth="260" MinColumnSpacing="12" MinRowSpacing="12" ItemsStretch="Fill" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:FeatureRowViewModel">
                                <Border Style="{StaticResource OptiFeatureTile}" Opacity="{x:Bind Opacity}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Background="{ThemeResource OptiRailBrush}" CornerRadius="8,0,0,8" Opacity="0.85" />
                                        <Grid Grid.Column="1" ColumnSpacing="12" Padding="14,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Style="{StaticResource OptiIconWell}">
                                                <FontIcon Glyph="{x:Bind Glyph}" FontSize="14"
                                                          Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Title}" Style="{StaticResource OptiFeatureTitle}" />
                                                <TextBlock Text="{x:Bind Detail}" Style="{StaticResource OptiFeatureDetail}" />
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
            </Grid>

            <StackPanel Grid.Row="2" Spacing="12">
                <Border Style="{StaticResource OptiMessageBanner}"
                        Visibility="{x:Bind ViewModel.HasMessage, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="{x:Bind ViewModel.MessageGlyph, Mode=OneWay}" FontSize="15"
                                  Foreground="{x:Bind ViewModel.MessageBrush, Mode=OneWay}" VerticalAlignment="Top" />
                        <TextBlock Text="{x:Bind ViewModel.Message, Mode=OneWay}" Grid.Column="1"
                                   Style="{StaticResource OptiBody}" FontSize="12.5" TextWrapping="Wrap" />
                    </Grid>
                </Border>
                <TextBlock Text="{x:Bind ViewModel.ProgressStatus, Mode=OneWay}"
                           Style="{StaticResource OptiCaption}" TextAlignment="Center"
                           Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Style="{StaticResource OptiPrimaryButton}" Content="Lowest latency" Click="Latency_Click"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                    <Button Grid.Column="1" Style="{StaticResource OptiQuietButton}" Content="Highest download" Click="Throughput_Click"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                </Grid>
                <Button Style="{StaticResource OptiQuietButton}" Content="Refresh" Click="Refresh_Click"
                        HorizontalAlignment="Stretch"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
