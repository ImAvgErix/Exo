<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.SteamOptimizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:OptiHub.ViewModels"
    Background="Transparent">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition FromVerticalOffset="10" />
        </TransitionCollection>
    </Page.Transitions>

    <Grid Padding="28,12,28,18">
        <Border Style="{StaticResource OptiCard}"
                Padding="24,20"
                MaxWidth="{StaticResource OptiPageMaxWidth}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
                    <TextBlock Text="STATUS" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                    <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                               FontFamily="{StaticResource OptiUiFontSemiBold}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               CharacterSpacing="-20"
                               Foreground="{ThemeResource OptiPrimaryTextBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{x:Bind ViewModel.DetailText, Mode=OneWay}"
                               Style="{StaticResource OptiBody}"
                               FontSize="13"
                               LineHeight="19" />
                </StackPanel>

                <ItemsControl Grid.Row="1"
                              ItemsSource="{x:Bind ViewModel.Features, Mode=OneWay}"
                              Margin="0,0,0,14"
                              VerticalAlignment="Top">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="10" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:FeatureRowViewModel">
                            <Grid ColumnSpacing="12" Opacity="{x:Bind Opacity}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="34" Height="34"
                                        CornerRadius="10"
                                        Background="{ThemeResource OptiAccentSoftBrush}"
                                        BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                                        BorderThickness="1"
                                        VerticalAlignment="Center">
                                    <FontIcon Glyph="{x:Bind Glyph}"
                                              FontSize="15"
                                              Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Title}"
                                               FontFamily="{StaticResource OptiUiFontSemiBold}"
                                               FontSize="14.5"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1" />
                                    <TextBlock Text="{x:Bind Detail}"
                                               FontFamily="{StaticResource OptiUiFont}"
                                               FontSize="12.5"
                                               LineHeight="18"
                                               Foreground="{ThemeResource OptiMutedTextBrush}"
                                               TextWrapping="WrapWholeWords"
                                               MaxLines="2"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Grid.Row="2" Spacing="4" Margin="0,0,0,14">
                    <Border Height="1"
                            Background="{ThemeResource OptiCardStrokeBrush}"
                            Opacity="0.4"
                            Margin="0,0,0,10" />
                    <TextBlock Text="WHAT THIS DOES" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                    <TextBlock Style="{StaticResource OptiBody}"
                               FontSize="13"
                               LineHeight="20"
                               Foreground="{ThemeResource OptiPrimaryTextBrush}"
                               Text="Performance pack for steamwebhelper + downloads: CEF -disable-gpu launch, HIGH priority client, CEF/HTML cache wipe, idle webhelper RAM trim, unlimited download throttle when possible, snappier library hints, quieter startup. Not Electron (no Discord-style asar inject). Games/VAC untouched. Use the patched Steam shortcut so flags apply." />
                </StackPanel>

                <StackPanel Grid.Row="3" Spacing="6"
                            Visibility="{x:Bind ViewModel.IsProgressVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                            Margin="0,0,0,12">
                    <ProgressBar Minimum="0" Maximum="100"
                                 Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                                 Height="7"
                                 CornerRadius="3"
                                 Foreground="{ThemeResource OptiAccentBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.ProgressStatus, Mode=OneWay}"
                               Style="{StaticResource OptiCaption}"
                               TextAlignment="Center"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Row="4" Spacing="10">
                    <Border Style="{StaticResource OptiCard}"
                            Padding="12,10"
                            Visibility="{x:Bind ViewModel.HasLastResult, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="{ThemeResource OptiAccentSoftBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="{x:Bind ViewModel.LastResultGlyph, Mode=OneWay}"
                                      FontSize="15"
                                      Foreground="{x:Bind ViewModel.LastResultBrush, Mode=OneWay}"
                                      VerticalAlignment="Top" />
                            <TextBlock Text="{x:Bind ViewModel.LastResult, Mode=OneWay}"
                                       Style="{StaticResource OptiBody}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource OptiPrimaryButton}"
                            Content="{x:Bind ViewModel.RunButtonLabel, Mode=OneWay}"
                            Click="Run_Click"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Spacing="10">
                        <Button Style="{StaticResource OptiQuietButton}"
                                Content="Repair Steam"
                                Click="Repair_Click"
                                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                        <Button Style="{StaticResource OptiQuietButton}"
                                Content="Refresh status"
                                Click="Refresh_Click"
                                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
