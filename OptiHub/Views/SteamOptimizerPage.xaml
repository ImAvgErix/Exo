<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OptiHub.Views.SteamOptimizerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:OptiHub.ViewModels"
      Background="Transparent">
    <Grid Padding="{StaticResource OptiPagePadding}">
        <ContentControl Style="{StaticResource OptiCard}" MaxWidth="{StaticResource OptiPageMaxWidth}"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="20">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Spacing="4">
                    <TextBlock Text="Steam" Style="{StaticResource OptiPageTitle}" />
                    <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" Style="{StaticResource OptiStatusLine}" />
                </StackPanel>
                <Grid Grid.Row="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.Features, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <UniformGridLayout MaximumRowsOrColumns="2" Orientation="Horizontal"
                                                   MinItemWidth="220" MinColumnSpacing="8" MinRowSpacing="8" ItemsStretch="Fill" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:FeatureRowViewModel">
                                    <Border Style="{StaticResource OptiFeatureTile}">
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Style="{StaticResource OptiIconWell}">
                                                <FontIcon Glyph="{x:Bind Glyph}" FontSize="13" Foreground="{ThemeResource OptiAccentBrush}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Title}" Style="{StaticResource OptiFeatureTitle}" />
                                                <TextBlock Text="{x:Bind Detail}" Style="{StaticResource OptiFeatureDetail}"
                                                           MaxLines="2" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                    <ProgressRing Width="28" Height="28"
                                  IsActive="{x:Bind ViewModel.IsStatusLoading, Mode=OneWay}"
                                  Opacity="{x:Bind ViewModel.IsStatusLoading, Mode=OneWay, Converter={StaticResource BoolToShowOpacityConverter}}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" />
                </Grid>
                <StackPanel Grid.Row="2" Spacing="8">
                    <Border Style="{StaticResource OptiMessageBanner}"
                            Opacity="{x:Bind ViewModel.HasLastResult, Mode=OneWay, Converter={StaticResource BoolToShowOpacityConverter}}"
                            IsHitTestVisible="{x:Bind ViewModel.HasLastResult, Mode=OneWay}">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="{x:Bind ViewModel.LastResultGlyph, Mode=OneWay}" FontSize="13"
                                      Foreground="{x:Bind ViewModel.LastResultBrush, Mode=OneWay}" VerticalAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.LastResult, Mode=OneWay}" Grid.Column="1"
                                       Style="{StaticResource OptiStatusLine}" />
                        </Grid>
                    </Border>
                    <StackPanel Spacing="4" MinHeight="28">
                        <ProgressBar Minimum="0" Maximum="100" Height="4" CornerRadius="2"
                                     Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                                     Foreground="{ThemeResource OptiAccentBrush}"
                                     Opacity="{x:Bind ViewModel.IsProgressVisible, Mode=OneWay, Converter={StaticResource BoolToShowOpacityConverter}}" />
                        <TextBlock Text="{x:Bind ViewModel.ProgressStatus, Mode=OneWay}" Style="{StaticResource OptiStatusLine}"
                                   Opacity="{x:Bind ViewModel.IsProgressVisible, Mode=OneWay, Converter={StaticResource BoolToShowOpacityConverter}}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Style="{StaticResource OptiPrimaryButton}" Content="{x:Bind ViewModel.RunButtonLabel, Mode=OneWay}"
                                Click="Run_Click" MinWidth="140"
                                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                AutomationProperties.Name="Apply Steam" />
                        <Button Style="{StaticResource OptiQuietButton}" Content="Repair" Click="Repair_Click"
                                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                        <Button Style="{StaticResource OptiQuietButton}" Content="Refresh" Click="Refresh_Click"
                                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </ContentControl>
    </Grid>
</Page>
