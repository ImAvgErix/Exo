<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.DiscordOptimizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:OptiHub.ViewModels"
    Background="Transparent">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition FromVerticalOffset="10" />
        </TransitionCollection>
    </Page.Transitions>

    <Grid Padding="18,6,18,12">
        <Border Style="{StaticResource OptiCard}"
                Padding="18,16"
                MaxWidth="{StaticResource OptiPageMaxWidth}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,10">
                    <TextBlock Text="STATUS" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                    <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                               FontFamily="{StaticResource OptiUiFontSemiBold}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               CharacterSpacing="-20"
                               Foreground="{ThemeResource OptiPrimaryTextBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{x:Bind ViewModel.DetailText, Mode=OneWay}"
                               Style="{StaticResource OptiBody}"
                               FontSize="12"
                               LineHeight="18" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="0,0,0,10">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Features, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="6" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:FeatureRowViewModel">
                                <Border Background="{ThemeResource OptiAccentSoftBrush}"
                                        BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12,9"
                                        Opacity="{x:Bind Opacity}">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0"
                                                  Glyph="{x:Bind Glyph}"
                                                  FontSize="14"
                                                  Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                                  VerticalAlignment="Top"
                                                  Margin="0,1,0,0" />
                                        <StackPanel Grid.Column="1" Spacing="1">
                                            <TextBlock Text="{x:Bind Title}"
                                                       FontFamily="{StaticResource OptiUiFontSemiBold}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{x:Bind Detail}"
                                                       FontFamily="{StaticResource OptiUiFont}"
                                                       FontSize="11"
                                                       LineHeight="16"
                                                       Foreground="{ThemeResource OptiSecondaryTextBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Spacing="4" Margin="0,0,0,12">
                    <Border Height="1"
                            Background="{ThemeResource OptiCardStrokeBrush}"
                            Opacity="0.5"
                            Margin="0,0,0,8" />
                    <TextBlock Text="WHAT THIS DOES" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                    <TextBlock Style="{StaticResource OptiBody}"
                               FontSize="12"
                               LineHeight="18"
                               Foreground="{ThemeResource OptiPrimaryTextBrush}"
                               Text="Cuts Discord idle RAM with OpenASAR and DiscOpt memory trim, keeps CPU priority and raw input snappy for gaming, applies AMOLED and privacy plugins, and quiets startup toasts - without wiping your login." />
                </StackPanel>

                <StackPanel Grid.Row="3" Spacing="8"
                            Visibility="{x:Bind ViewModel.IsProgressVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                            Margin="0,0,0,10">
                    <ProgressBar Minimum="0" Maximum="100"
                                 Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                                 Height="7"
                                 CornerRadius="3"
                                 Foreground="{ThemeResource OptiAccentBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.ProgressStatus, Mode=OneWay}"
                               Style="{StaticResource OptiCaption}"
                               TextAlignment="Center"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Row="4" Spacing="8">
                    <Border Style="{StaticResource OptiCard}"
                            Padding="12,10"
                            Visibility="{x:Bind ViewModel.HasLastResult, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="{ThemeResource OptiAccentSoftBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="{x:Bind ViewModel.LastResultGlyph, Mode=OneWay}"
                                      FontSize="15"
                                      Foreground="{x:Bind ViewModel.LastResultBrush, Mode=OneWay}"
                                      VerticalAlignment="Top" />
                            <TextBlock Text="{x:Bind ViewModel.LastResult, Mode=OneWay}"
                                       Style="{StaticResource OptiBody}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource OptiPrimaryButton}"
                            Content="{x:Bind ViewModel.RunButtonLabel, Mode=OneWay}"
                            Click="Run_Click"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Spacing="10">
                        <Button Style="{StaticResource OptiQuietButton}"
                                Content="Repair Discord"
                                Click="Repair_Click"
                                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                        <Button Style="{StaticResource OptiQuietButton}"
                                Content="Refresh status"
                                Click="Refresh_Click"
                                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>