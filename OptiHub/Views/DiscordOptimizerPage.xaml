<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.DiscordOptimizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,8,32,32">
        <StackPanel MaxWidth="{StaticResource OptiPageMaxWidth}"
                    HorizontalAlignment="Center"
                    Spacing="24">

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Style="{StaticResource OptiIconButton}"
                        Click="Back_Click"
                        ToolTipService.ToolTip="Back"
                        Background="Transparent"
                        BorderThickness="0">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" />
                </Button>
                <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                    <Border Width="44" Height="44" CornerRadius="12"
                            Background="{ThemeResource OptiAccentSoftBrush}">
                        <Image Width="28" Height="28"
                               Source="{x:Bind ViewModel.LogoPath, Mode=OneWay, Converter={StaticResource AssetPathToImageSourceConverter}}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Stretch="Uniform" />
                    </Border>
                    <TextBlock Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                               Style="{StaticResource OptiPageTitle}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <Border Style="{StaticResource OptiCard}" Padding="24,20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Status"
                               Style="{StaticResource OptiSectionTitle}"
                               Margin="0" />
                    <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                               FontFamily="{StaticResource OptiDisplayFontMedium}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource OptiPrimaryTextBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{x:Bind ViewModel.DetailText, Mode=OneWay}"
                               Style="{StaticResource OptiBody}" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Checks, Mode=OneWay}"
                                  Margin="0,4,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="6" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border Background="{ThemeResource OptiAccentSoftBrush}"
                                        CornerRadius="8"
                                        Padding="12,6"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{x:Bind}"
                                               FontFamily="{StaticResource OptiUiFont}"
                                               FontSize="12"
                                               Foreground="{ThemeResource OptiSecondaryTextBrush}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource OptiCard}">
                <StackPanel Spacing="10">
                    <TextBlock Text="What this does"
                               Style="{StaticResource OptiSectionTitle}" />
                    <TextBlock Style="{StaticResource OptiBody}"
                               Text="Installs or repairs Discord stable when needed, then applies Equicord, OpenASAR, an AMOLED theme, privacy plugins, and the DiscOpt kernel for priority, memory trim, and raw input." />
                    <TextBlock Style="{StaticResource OptiBody}"
                               Text="Safe cache clean and quieter Windows startup toasts are included. Login and session storage stay intact. Run mode is detected automatically." />
                </StackPanel>
            </Border>

            <StackPanel Spacing="10"
                        Visibility="{x:Bind ViewModel.IsProgressVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <ProgressBar Minimum="0" Maximum="100"
                             Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                             Height="6"
                             CornerRadius="3"
                             Foreground="{ThemeResource OptiAccentBrush}"
                             ShowPaused="False"
                             ShowError="False" />
                <TextBlock Text="{x:Bind ViewModel.ProgressStatus, Mode=OneWay}"
                           Style="{StaticResource OptiCaption}"
                           TextAlignment="Center"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <Border Style="{StaticResource OptiCard}"
                    Visibility="{x:Bind ViewModel.HasLastResult, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="{ThemeResource OptiAccentSoftBrush}">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="{x:Bind ViewModel.LastResultGlyph, Mode=OneWay}"
                              FontSize="18"
                              Foreground="{x:Bind ViewModel.LastResultBrush, Mode=OneWay}"
                              VerticalAlignment="Top"
                              Margin="0,2,0,0" />
                    <TextBlock Text="{x:Bind ViewModel.LastResult, Mode=OneWay}"
                               Style="{StaticResource OptiBody}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <StackPanel Spacing="12">
                <Button Style="{StaticResource OptiPrimaryButton}"
                        Content="{x:Bind ViewModel.RunButtonLabel, Mode=OneWay}"
                        Click="Run_Click"
                        HorizontalAlignment="Stretch"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="10">
                    <Button Style="{StaticResource OptiQuietButton}"
                            Content="Repair Discord"
                            Click="Repair_Click"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                    <Button Style="{StaticResource OptiQuietButton}"
                            Content="Refresh status"
                            Click="Refresh_Click"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
