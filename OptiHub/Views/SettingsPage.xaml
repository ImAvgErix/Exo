<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OptiHub.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Grid Padding="36,16,36,20">
        <Border Style="{StaticResource OptiCard}"
                Padding="28,22"
                MaxWidth="{StaticResource OptiPageMaxWidth}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4" Margin="0,0,0,18">
                    <TextBlock Text="Settings"
                               FontFamily="{StaticResource OptiUiFontSemiBold}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               CharacterSpacing="-20"
                               Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                    <TextBlock Text="Theme, updates, and a little about OptiHub."
                               Style="{StaticResource OptiCaption}"
                               FontSize="13" />
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="18" VerticalAlignment="Top">
                    <StackPanel Spacing="10">
                        <TextBlock Text="APPEARANCE" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <StackPanel Orientation="Horizontal" Spacing="36">
                            <ToggleSwitch Header="Dark"
                                          IsOn="{x:Bind ViewModel.IsDarkMode, Mode=TwoWay}" />
                            <ToggleSwitch Header="Light"
                                          IsOn="{x:Bind ViewModel.IsLightMode, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>

                    <Border Height="1" Background="{ThemeResource OptiCardStrokeBrush}" Opacity="0.4" />

                    <StackPanel Spacing="12">
                        <TextBlock Text="UPDATES" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <ToggleSwitch Header="Check for updates automatically"
                                      IsOn="{x:Bind ViewModel.AutoUpdateScripts, Mode=TwoWay}"
                                      OnContent="On"
                                      OffContent="Off" />
                        <TextBlock Text="On launch: prompt when a new OptiHub app is available, and refresh optimizer scripts in the background."
                                   Style="{StaticResource OptiCaption}"
                                   TextWrapping="WrapWholeWords"
                                   Opacity="0.85"
                                   Margin="0,-4,0,0" />

                        <Grid ColumnSpacing="28" Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="3">
                                <TextBlock Text="App version" Style="{StaticResource OptiCaption}" />
                                <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="3">
                                <TextBlock Text="Script version" Style="{StaticResource OptiCaption}" />
                                <TextBlock Text="{x:Bind ViewModel.KitVersion, Mode=OneWay}"
                                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnSpacing="12" Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Style="{StaticResource OptiPrimaryButton}"
                                    Content="Check app update"
                                    Click="CheckAppUpdates_Click"
                                    HorizontalAlignment="Stretch"
                                    IsEnabled="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                            <Button Grid.Column="1"
                                    Style="{StaticResource OptiPrimaryButton}"
                                    Content="Check script update"
                                    Click="CheckScriptUpdates_Click"
                                    HorizontalAlignment="Stretch"
                                    IsEnabled="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                        </Grid>

                        <TextBlock Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}"
                                   Style="{StaticResource OptiBody}"
                                   FontSize="12"
                                   Foreground="{ThemeResource OptiSecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   MinHeight="16" />
                    </StackPanel>

                    <Border Height="1" Background="{ThemeResource OptiCardStrokeBrush}" Opacity="0.4" />

                    <StackPanel Spacing="10">
                        <TextBlock Text="SUPPORT" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <Button Style="{StaticResource OptiPrimaryButton}"
                                Content="Open logs folder"
                                HorizontalAlignment="Stretch"
                                Command="{x:Bind ViewModel.OpenLogsFolderCommand}" />
                    </StackPanel>

                    <Border Height="1" Background="{ThemeResource OptiCardStrokeBrush}" Opacity="0.4" />

                    <StackPanel Spacing="8">
                        <TextBlock Text="ABOUT" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <TextBlock Style="{StaticResource OptiBody}"
                                   FontSize="13"
                                   LineHeight="20"
                                   Foreground="{ThemeResource OptiSecondaryTextBrush}"
                                   Text="One hub. Max performance. Optimizers for Discord, Steam, and more - gaming and client tweaks in one place."
                                   TextWrapping="WrapWholeWords" />
                        <TextBlock Style="{StaticResource OptiCaption}"
                                   FontSize="11"
                                   Margin="0,4,0,0"
                                   Text="{x:Bind ViewModel.AboutFooter, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
