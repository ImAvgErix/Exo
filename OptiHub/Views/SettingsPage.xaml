<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OptiHub.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
  <Grid Padding="18,6,18,12">
    <Border Style="{StaticResource OptiCard}"
            Padding="18,16"
            MaxWidth="{StaticResource OptiPageMaxWidth}"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
      <StackPanel Spacing="12" VerticalAlignment="Top">
        <StackPanel Spacing="8">
          <TextBlock Text="APPEARANCE" Style="{StaticResource OptiSectionTitle}" Margin="0" />
          <StackPanel Orientation="Horizontal" Spacing="28">
            <ToggleSwitch Header="Dark" IsOn="{x:Bind ViewModel.IsDarkMode, Mode=TwoWay}" />
            <ToggleSwitch Header="Light" IsOn="{x:Bind ViewModel.IsLightMode, Mode=TwoWay}" />
          </StackPanel>
        </StackPanel>

        <Border Height="1" Background="{ThemeResource OptiCardStrokeBrush}" Opacity="0.5" />

        <StackPanel Spacing="8">
          <TextBlock Text="UPDATES" Style="{StaticResource OptiSectionTitle}" Margin="0" />
          <ToggleSwitch Header="Auto-update scripts on launch"
                        IsOn="{x:Bind ViewModel.AutoUpdateScripts, Mode=TwoWay}" />
          <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="2">
              <TextBlock Text="App version" Style="{StaticResource OptiCaption}" />
              <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                         FontFamily="{StaticResource OptiUiFontSemiBold}"
                         FontSize="15" FontWeight="SemiBold"
                         Foreground="{ThemeResource OptiPrimaryTextBrush}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="2">
              <TextBlock Text="Script kit" Style="{StaticResource OptiCaption}" />
              <TextBlock Text="{x:Bind ViewModel.KitVersion, Mode=OneWay}"
                         FontFamily="{StaticResource OptiUiFontSemiBold}"
                         FontSize="15" FontWeight="SemiBold"
                         Foreground="{ThemeResource OptiPrimaryTextBrush}" />
            </StackPanel>
          </Grid>
          <Grid ColumnSpacing="10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Style="{StaticResource OptiPrimaryButton}"
                    Content="Check app update"
                    Click="CheckAppUpdates_Click"
                    HorizontalAlignment="Stretch"
                    IsEnabled="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
            <Button Grid.Column="1"
                    Style="{StaticResource OptiPrimaryButton}"
                    Content="Check script update"
                    Click="CheckScriptUpdates_Click"
                    HorizontalAlignment="Stretch"
                    IsEnabled="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
          </Grid>
          <TextBlock Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}"
                     Style="{StaticResource OptiBody}"
                     FontSize="12"
                     Foreground="{ThemeResource OptiPrimaryTextBrush}"
                     TextWrapping="Wrap"
                     MinHeight="18" />
        </StackPanel>

        <Border Height="1" Background="{ThemeResource OptiCardStrokeBrush}" Opacity="0.5" />

        <StackPanel Spacing="6">
          <TextBlock Text="ABOUT" Style="{StaticResource OptiSectionTitle}" Margin="0" />
          <TextBlock Style="{StaticResource OptiBody}" FontSize="12" LineHeight="18"
                     Foreground="{ThemeResource OptiPrimaryTextBrush}"
                     Text="OptiHub is a hub for optional system optimizers - performance, privacy, and gaming. Use at your own risk." />
          <TextBlock Style="{StaticResource OptiCaption}"
                     Text="{x:Bind ViewModel.AboutFooter, Mode=OneWay}" />
        </StackPanel>
      </StackPanel>
    </Border>
  </Grid>
</Page>