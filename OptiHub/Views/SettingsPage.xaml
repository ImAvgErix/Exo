<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OptiHub.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Grid Padding="36,16,36,20">
        <Border Style="{StaticResource OptiCard}"
                Padding="28,18"
                MaxWidth="{StaticResource OptiPageMaxWidth}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4" Margin="0,0,0,14">
                    <TextBlock Text="Settings"
                               FontFamily="{StaticResource OptiUiFontSemiBold}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               CharacterSpacing="-20"
                               Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                    <TextBlock Text="Appearance, updates, and performance policy."
                               Style="{StaticResource OptiCaption}"
                               FontSize="13" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              AutomationProperties.Name="Settings content">
                <StackPanel Spacing="14" VerticalAlignment="Top" Margin="0,0,8,0">
                    <StackPanel Spacing="10">
                        <TextBlock Text="APPEARANCE" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <StackPanel Orientation="Horizontal" Spacing="28">
                            <RadioButton Content="Dark"
                                         GroupName="ThemeChoice"
                                         AutomationProperties.Name="Use dark theme"
                                         IsChecked="{x:Bind ViewModel.IsDarkMode, Mode=TwoWay}" />
                            <RadioButton Content="Light"
                                         GroupName="ThemeChoice"
                                         AutomationProperties.Name="Use light theme"
                                         IsChecked="{x:Bind ViewModel.IsLightMode, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>

                    <Border Height="1" Background="{ThemeResource OptiCardStrokeBrush}" Opacity="0.4" />

                    <StackPanel Spacing="8">
                        <TextBlock Text="PERFORMANCE POLICY" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <Border Style="{StaticResource OptiRiskCard}">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE7BA;"
                                          FontSize="14"
                                          Foreground="{ThemeResource OptiWarningBrush}"
                                          VerticalAlignment="Top"
                                          Margin="0,1,0,0" />
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="MAXIMUM PERFORMANCE IS THE DEFAULT"
                                               Style="{StaticResource OptiRiskLabel}" />
                                    <TextBlock Text="OptiHub intentionally uses aggressive profiles. A profile may reduce visual effects, background convenience, vendor extras, or power-saving behavior. Discord and Steam Repair restore OptiHub-managed changes. NVIDIA Reset only clears status; undo NVIDIA changes manually in NVIDIA settings or with a driver reinstall."
                                               Style="{StaticResource OptiCaption}"
                                               Foreground="{ThemeResource OptiSecondaryTextBrush}"
                                               LineHeight="17"
                                               TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <Border Height="1" Background="{ThemeResource OptiCardStrokeBrush}" Opacity="0.4" />

                    <StackPanel Spacing="12">
                        <TextBlock Text="UPDATES" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <ToggleSwitch Header="Check for updates automatically"
                                      AutomationProperties.Name="Check for updates automatically"
                                      IsOn="{x:Bind ViewModel.AutoUpdateScripts, Mode=TwoWay}"
                                      OnContent="On"
                                      OffContent="Off" />
                        <TextBlock Text="On launch: prompt for a new OptiHub app (ships matching Discord / Steam / NVIDIA scripts), then refresh kits from GitHub."
                                   Style="{StaticResource OptiCaption}"
                                   TextWrapping="WrapWholeWords"
                                   Opacity="0.85"
                                   Margin="0,-4,0,0" />

                        <Grid ColumnSpacing="28" Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="3">
                                <TextBlock Text="App version" Style="{StaticResource OptiCaption}" />
                                <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="3">
                                <TextBlock Text="Optimizer kits (Discord / Steam / NVIDIA)" Style="{StaticResource OptiCaption}" />
                                <TextBlock Text="{x:Bind ViewModel.KitVersion, Mode=OneWay}"
                                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                            </StackPanel>
                        </Grid>

                        <Button Style="{StaticResource OptiPrimaryButton}"
                                Content="Check for updates"
                                AutomationProperties.Name="Check for OptiHub app and optimizer kit updates"
                                AutomationProperties.HelpText="Checks for a new OptiHub app release and refreshes Discord, Steam, and NVIDIA optimizer scripts."
                                Command="{x:Bind ViewModel.CheckForUpdatesCommand}"
                                HorizontalAlignment="Stretch"
                                Margin="0,2,0,0"
                                IsEnabled="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />

                        <TextBlock Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}"
                                   Style="{StaticResource OptiBody}"
                                   FontSize="12"
                                   Foreground="{ThemeResource OptiSecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   AutomationProperties.LiveSetting="Polite"
                                   MinHeight="16" />
                    </StackPanel>

                    <Border Height="1" Background="{ThemeResource OptiCardStrokeBrush}" Opacity="0.4" />

                    <StackPanel Spacing="10">
                        <TextBlock Text="SUPPORT" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <Button Style="{StaticResource OptiQuietButton}"
                                Content="Open logs folder"
                                AutomationProperties.Name="Open OptiHub logs folder"
                                HorizontalAlignment="Stretch"
                                Command="{x:Bind ViewModel.OpenLogsFolderCommand}" />
                    </StackPanel>

                    <Border Height="1" Background="{ThemeResource OptiCardStrokeBrush}" Opacity="0.4" />

                    <StackPanel Spacing="8">
                        <TextBlock Text="ABOUT" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <TextBlock Style="{StaticResource OptiBody}"
                                   FontSize="13"
                                   LineHeight="20"
                                   Foreground="{ThemeResource OptiSecondaryTextBrush}"
                                   Text="OptiHub is for users who prioritize latency, FPS, and low background overhead over convenience defaults. Discord and Steam provide Repair for OptiHub-managed changes. NVIDIA Reset only clears OptiHub's status record; recovery is manual through NVIDIA settings or a driver reinstall."
                                   TextWrapping="WrapWholeWords" />
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <TextBlock Style="{StaticResource OptiCaption}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Text="{x:Bind ViewModel.AboutFooter, Mode=OneWay}" />
                            <HyperlinkButton Content="View on GitHub"
                                             FontSize="11"
                                             Padding="0"
                                             NavigateUri="https://github.com/BarcusEric/OptiHub"
                                             AutomationProperties.Name="Open the OptiHub project on GitHub" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
