<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OptiHub.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      Loaded="Page_Loaded">

    <!-- Centered settings shell: no scroll, balanced fill, clear sections. -->
    <Grid x:Name="PageRoot" Padding="40,20,40,28">
        <Grid MaxWidth="920"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel x:Name="HeaderPanel"
                        Spacing="6"
                        Margin="0,0,0,20"
                        HorizontalAlignment="Center"
                        Opacity="0"
                        RenderTransformOrigin="0.5,0.5">
                <StackPanel.RenderTransform>
                    <CompositeTransform x:Name="HeaderTransform" TranslateY="10" />
                </StackPanel.RenderTransform>
                <TextBlock Text="Settings"
                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                           FontSize="26"
                           FontWeight="SemiBold"
                           CharacterSpacing="-20"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />
            </StackPanel>

            <!-- Body: 2×2 balanced cards -->
            <Grid x:Name="BodyGrid"
                  Grid.Row="1"
                  ColumnSpacing="16"
                  RowSpacing="16"
                  Opacity="0"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <CompositeTransform x:Name="BodyTransform" TranslateY="14" />
                </Grid.RenderTransform>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Appearance -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource OptiCard}" Padding="22,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="APPEARANCE" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        </StackPanel>
                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    Spacing="20"
                                    VerticalAlignment="Center"
                                    Margin="0,16,0,0">
                            <RadioButton Content="Dark"
                                         GroupName="ThemeChoice"
                                         AutomationProperties.Name="Use dark theme"
                                         IsChecked="{x:Bind ViewModel.IsDarkMode, Mode=TwoWay}" />
                            <RadioButton Content="Light"
                                         GroupName="ThemeChoice"
                                         AutomationProperties.Name="Use light theme"
                                         IsChecked="{x:Bind ViewModel.IsLightMode, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Support -->
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource OptiCard}" Padding="22,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="SUPPORT" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="10" Margin="0,16,0,0">
                            <Button Style="{StaticResource OptiQuietButton}"
                                    Content="Open logs folder"
                                    AutomationProperties.Name="Open OptiHub logs folder"
                                    HorizontalAlignment="Stretch"
                                    Command="{x:Bind ViewModel.OpenLogsFolderCommand}" />
                        </StackPanel>
                        <HyperlinkButton Grid.Row="2"
                                         Content="Report an issue on GitHub"
                                         FontSize="12"
                                         Padding="0"
                                         Margin="0,10,0,0"
                                         NavigateUri="https://github.com/BarcusEric/OptiHub/issues"
                                         AutomationProperties.Name="Open OptiHub issues on GitHub" />
                    </Grid>
                </Border>

                <!-- About (version + disclaimer) -->
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource OptiCard}" Padding="22,16">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="ABOUT" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <StackPanel Grid.Row="1" Spacing="2">
                            <TextBlock Text="App version"
                                       Style="{StaticResource OptiCaption}"
                                       FontSize="12"
                                       Opacity="0.85" />
                            <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                                       FontFamily="{StaticResource OptiUiFontSemiBold}"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                       CharacterSpacing="-20" />
                        </StackPanel>
                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Margin="0,4,0,0">
                            <TextBlock Style="{StaticResource OptiCaption}"
                                       FontSize="11"
                                       LineHeight="15"
                                       Opacity="0.9"
                                       TextWrapping="WrapWholeWords"
                                       Text="Disclaimer: OptiHub is free, unofficial software. It is not affiliated with, endorsed by, or supported by Discord, Valve/Steam, NVIDIA, Microsoft, or any other third party.&#x0a;&#x0a;Applies aggressive changes to drivers, GPU settings, registry, services, and game/chat clients. You may need Administrator rights. Use at your own risk. Back up important data and create a system restore point first.&#x0a;&#x0a;No warranty — express or implied. The author is not liable for broken installs, lost data, banned accounts, hardware issues, or any other damage. By using OptiHub you accept full responsibility for the outcome." />
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Updates — same card size as Appearance / Support -->
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource OptiCard}" Padding="22,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="UPDATES" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        </StackPanel>
                        <StackPanel Grid.Row="1"
                                    VerticalAlignment="Center"
                                    Spacing="12"
                                    Margin="0,12,0,0">
                            <ToggleSwitch Header="Check on launch"
                                          AutomationProperties.Name="Check for OptiHub app updates automatically"
                                          IsOn="{x:Bind ViewModel.AutoUpdateScripts, Mode=TwoWay}"
                                          OnContent="On"
                                          OffContent="Off"
                                          HorizontalAlignment="Left" />
                            <Button Style="{StaticResource OptiPrimaryButton}"
                                    Content="Check for updates"
                                    AutomationProperties.Name="Check for OptiHub app updates"
                                    Command="{x:Bind ViewModel.CheckForUpdatesCommand}"
                                    HorizontalAlignment="Stretch"
                                    MinHeight="44"
                                    IsEnabled="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                        </StackPanel>
                        <TextBlock Grid.Row="2"
                                   Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}"
                                   Style="{StaticResource OptiCaption}"
                                   FontSize="11.5"
                                   Foreground="{ThemeResource OptiSecondaryTextBrush}"
                                   TextWrapping="WrapWholeWords"
                                   MaxLines="2"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,10,0,0"
                                   Visibility="{x:Bind ViewModel.HasUpdateStatus, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                   AutomationProperties.LiveSetting="Polite" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
