<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OptiHub.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      Loaded="Page_Loaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Padding="{StaticResource OptiPagePadding}">
        <StackPanel MaxWidth="640"
                    HorizontalAlignment="Left"
                    Spacing="20">

            <TextBlock x:Name="HeaderPanel"
                       Text="Settings"
                       Style="{StaticResource OptiPageTitle}" />

            <StackPanel x:Name="BodyGrid" Spacing="16">
                <ContentControl Style="{StaticResource OptiCard}" Padding="20">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Appearance" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Style="{StaticResource OptiThemePickButton}"
                                    Click="ThemeDark_Click"
                                    Height="88"
                                    AutomationProperties.Name="Use dark theme">
                                <Border Style="{StaticResource OptiThemePickOuter}" Padding="12">
                                    <StackPanel Spacing="8">
                                        <Border Height="28" CornerRadius="4" Background="#1A1A1A" />
                                        <TextBlock Text="Dark" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                                    </StackPanel>
                                </Border>
                            </Button>
                            <Button Grid.Column="1"
                                    Style="{StaticResource OptiThemePickButton}"
                                    Click="ThemeLight_Click"
                                    Height="88"
                                    AutomationProperties.Name="Use light theme">
                                <Border Style="{StaticResource OptiThemePickOuter}" Padding="12">
                                    <StackPanel Spacing="8">
                                        <Border Height="28" CornerRadius="4" Background="#FFFFFF"
                                                BorderBrush="#E0E0E0" BorderThickness="1" />
                                        <TextBlock Text="Light" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                                    </StackPanel>
                                </Border>
                            </Button>
                        </Grid>
                    </StackPanel>
                </ContentControl>

                <ContentControl Style="{StaticResource OptiCard}" Padding="20">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Updates" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <ToggleSwitch Header="Check for updates on launch"
                                      IsOn="{x:Bind ViewModel.AutoUpdateScripts, Mode=TwoWay}"
                                      OnContent="On" OffContent="Off" />
                        <Button Style="{StaticResource OptiPrimaryButton}"
                                Content="Check for updates"
                                Command="{x:Bind ViewModel.CheckForUpdatesCommand}"
                                HorizontalAlignment="Left"
                                IsEnabled="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                        <TextBlock Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}"
                                   Style="{StaticResource OptiCaption}"
                                   Visibility="{x:Bind ViewModel.HasUpdateStatus, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                </ContentControl>

                <ContentControl Style="{StaticResource OptiCard}" Padding="20">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Support" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <Button Style="{StaticResource OptiQuietButton}"
                                Content="Open logs folder"
                                HorizontalAlignment="Left"
                                Command="{x:Bind ViewModel.OpenLogsFolderCommand}" />
                        <Button Style="{StaticResource OptiQuietButton}"
                                Content="Report issue on GitHub"
                                HorizontalAlignment="Left"
                                Command="{x:Bind ViewModel.ReportIssueCommand}" />
                    </StackPanel>
                </ContentControl>

                <ContentControl Style="{StaticResource OptiCard}" Padding="20">
                    <StackPanel Spacing="6">
                        <TextBlock Text="About" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <TextBlock Text="Version" Style="{StaticResource OptiCaption}" />
                        <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                                   FontFamily="{StaticResource OptiUiFontSemiBold}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                    </StackPanel>
                </ContentControl>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
