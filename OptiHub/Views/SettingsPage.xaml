<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OptiHub.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      Loaded="Page_Loaded">

    <!-- v1.7 settings: centered head + 2-col panels + wide updates -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Padding="{StaticResource OptiPagePadding}">
        <StackPanel MaxWidth="920"
                    HorizontalAlignment="Center"
                    Spacing="16">

            <StackPanel x:Name="HeaderPanel"
                        Spacing="6"
                        Margin="0,0,0,12"
                        HorizontalAlignment="Center">
                <TextBlock Text="Settings"
                           Style="{StaticResource OptiPageTitle}"
                           FontSize="28"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Theme, updates, and support."
                           Style="{StaticResource OptiCaption}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <Grid x:Name="BodyGrid" ColumnSpacing="16" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Appearance -->
                <Border Grid.Row="0" Grid.Column="0"
                        Background="{ThemeResource OptiCardFillBrush}"
                        BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="22,20"
                        MinHeight="200">
                    <StackPanel Spacing="12">
                        <TextBlock Text="APPEARANCE" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <TextBlock Text="AMOLED black or warm cream."
                                   Style="{StaticResource OptiCaption}" />
                        <Grid ColumnSpacing="10" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Style="{StaticResource OptiThemePickButton}"
                                    Click="ThemeDark_Click"
                                    Height="48"
                                    AutomationProperties.Name="Use dark theme">
                                <Border Background="{ThemeResource OptiSurfaceBrush}"
                                        BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="12,8">
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                        <Border Width="14" Height="14" CornerRadius="7" Background="#000000"
                                                BorderBrush="{ThemeResource OptiPrimaryTextBrush}" BorderThickness="1" />
                                        <TextBlock Text="Dark" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Button>
                            <Button Grid.Column="1"
                                    Style="{StaticResource OptiThemePickButton}"
                                    Click="ThemeLight_Click"
                                    Height="48"
                                    AutomationProperties.Name="Use light theme">
                                <Border Background="{ThemeResource OptiSurfaceBrush}"
                                        BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="12,8">
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                        <Border Width="14" Height="14" CornerRadius="7" Background="#F3EDE3"
                                                BorderBrush="#3D3429" BorderThickness="1" />
                                        <TextBlock Text="Light" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Support -->
                <Border Grid.Row="0" Grid.Column="1"
                        Background="{ThemeResource OptiCardFillBrush}"
                        BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="22,20"
                        MinHeight="200">
                    <StackPanel Spacing="12">
                        <TextBlock Text="SUPPORT" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <TextBlock Text="Logs for Discord, Steam, and NVIDIA applies."
                                   Style="{StaticResource OptiCaption}" />
                        <Button Style="{StaticResource OptiQuietButton}"
                                Content="Open logs folder"
                                HorizontalAlignment="Stretch"
                                Margin="0,8,0,0"
                                Command="{x:Bind ViewModel.OpenLogsFolderCommand}" />
                        <Button Style="{StaticResource OptiQuietButton}"
                                Content="Report issue on GitHub"
                                HorizontalAlignment="Stretch"
                                Command="{x:Bind ViewModel.ReportIssueCommand}" />
                    </StackPanel>
                </Border>

                <!-- Updates (wide) -->
                <Border Grid.Row="1" Grid.ColumnSpan="2"
                        Background="{ThemeResource OptiCardFillBrush}"
                        BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="22,20">
                    <StackPanel Spacing="14">
                        <TextBlock Text="UPDATES" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <TextBlock Text="One release ships the app and matching optimizers."
                                   Style="{StaticResource OptiCaption}" />
                        <StackPanel Spacing="2">
                            <TextBlock Text="Installed" Style="{StaticResource OptiCaption}" />
                            <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                                       FontFamily="{StaticResource OptiUiFontSemiBold}"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                        </StackPanel>
                        <ToggleSwitch Header="Check for updates on launch"
                                      IsOn="{x:Bind ViewModel.AutoUpdateScripts, Mode=TwoWay}"
                                      OnContent="On" OffContent="Off" />
                        <Button Style="{StaticResource OptiPrimaryButton}"
                                Content="Check for updates"
                                HorizontalAlignment="Stretch"
                                Command="{x:Bind ViewModel.CheckForUpdatesCommand}"
                                IsEnabled="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                        <TextBlock Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}"
                                   Style="{StaticResource OptiCaption}"
                                   Visibility="{x:Bind ViewModel.HasUpdateStatus, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
