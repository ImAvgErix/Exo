<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OptiHub.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      Loaded="Page_Loaded">

    <!-- Centered settings shell: no scroll, balanced fill, clear sections. -->
    <Grid x:Name="PageRoot" Padding="40,20,40,28">
        <Grid MaxWidth="920"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel x:Name="HeaderPanel"
                        Spacing="6"
                        Margin="0,0,0,20"
                        HorizontalAlignment="Center"
                        Opacity="0"
                        RenderTransformOrigin="0.5,0.5">
                <StackPanel.RenderTransform>
                    <CompositeTransform x:Name="HeaderTransform" TranslateY="10" />
                </StackPanel.RenderTransform>
                <TextBlock Text="Settings"
                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                           FontSize="28"
                           FontWeight="SemiBold"
                           CharacterSpacing="-20"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                <TextBlock Text="Theme, updates, and support — everything in one place."
                           Style="{StaticResource OptiCaption}"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Opacity="0.9" />
            </StackPanel>

            <!-- Body: 2×2 balanced cards -->
            <Grid x:Name="BodyGrid"
                  Grid.Row="1"
                  ColumnSpacing="16"
                  RowSpacing="16"
                  Opacity="0"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <CompositeTransform x:Name="BodyTransform" TranslateY="14" />
                </Grid.RenderTransform>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Appearance -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource OptiCard}" Padding="22,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="APPEARANCE" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                            <TextBlock Text="Match the shell to your desktop."
                                       Style="{StaticResource OptiCaption}"
                                       FontSize="12"
                                       Opacity="0.85" />
                        </StackPanel>
                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    Spacing="20"
                                    VerticalAlignment="Center"
                                    Margin="0,16,0,0">
                            <RadioButton Content="Dark"
                                         GroupName="ThemeChoice"
                                         AutomationProperties.Name="Use dark theme"
                                         IsChecked="{x:Bind ViewModel.IsDarkMode, Mode=TwoWay}" />
                            <RadioButton Content="Light"
                                         GroupName="ThemeChoice"
                                         AutomationProperties.Name="Use light theme"
                                         IsChecked="{x:Bind ViewModel.IsLightMode, Mode=TwoWay}" />
                        </StackPanel>
                        <TextBlock Grid.Row="2"
                                   Style="{StaticResource OptiCaption}"
                                   FontSize="11.5"
                                   Opacity="0.75"
                                   Text="Applies instantly across OptiHub."
                                   Margin="0,8,0,0" />
                    </Grid>
                </Border>

                <!-- Support -->
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource OptiCard}" Padding="22,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="SUPPORT" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                            <TextBlock Text="Logs for Discord, Steam, and NVIDIA applies."
                                       Style="{StaticResource OptiCaption}"
                                       FontSize="12"
                                       Opacity="0.85"
                                       TextWrapping="WrapWholeWords" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="10" Margin="0,16,0,0">
                            <Button Style="{StaticResource OptiQuietButton}"
                                    Content="Open logs folder"
                                    AutomationProperties.Name="Open OptiHub logs folder"
                                    HorizontalAlignment="Stretch"
                                    Command="{x:Bind ViewModel.OpenLogsFolderCommand}" />
                        </StackPanel>
                        <HyperlinkButton Grid.Row="2"
                                         Content="Report an issue on GitHub"
                                         FontSize="12"
                                         Padding="0"
                                         Margin="0,10,0,0"
                                         NavigateUri="https://github.com/BarcusEric/OptiHub/issues"
                                         AutomationProperties.Name="Open OptiHub issues on GitHub" />
                    </Grid>
                </Border>

                <!-- Updates (full width bottom) -->
                <Border Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Style="{StaticResource OptiCard}"
                        Padding="26,22">
                    <Grid ColumnSpacing="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.15*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: version story -->
                        <StackPanel Spacing="14" VerticalAlignment="Center">
                            <TextBlock Text="UPDATES" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                            <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Installed"
                                               Style="{StaticResource OptiCaption}"
                                               FontSize="11"
                                               CharacterSpacing="40" />
                                    <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                                               FontFamily="{StaticResource OptiUiFontSemiBold}"
                                               FontSize="36"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                               CharacterSpacing="-30" />
                                </StackPanel>
                                <Border Width="1"
                                        Height="48"
                                        Background="{ThemeResource OptiCardStrokeBrush}"
                                        Opacity="0.4"
                                        VerticalAlignment="Center" />
                                <StackPanel Spacing="6" VerticalAlignment="Center">
                                    <TextBlock Text="Ships with this build"
                                               Style="{StaticResource OptiCaption}"
                                               FontSize="11"
                                               CharacterSpacing="20" />
                                    <TextBlock Text="{x:Bind ViewModel.KitVersion, Mode=OneWay}"
                                               FontFamily="{StaticResource OptiUiFontMedium}"
                                               FontSize="13"
                                               Foreground="{ThemeResource OptiSecondaryTextBrush}"
                                               TextWrapping="WrapWholeWords" />
                                    <TextBlock Text="Discord · Steam · NVIDIA"
                                               Style="{StaticResource OptiCaption}"
                                               FontSize="11"
                                               Opacity="0.7" />
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="One release includes the app and matching optimizers. No separate script update step."
                                       Style="{StaticResource OptiCaption}"
                                       FontSize="12.5"
                                       LineHeight="18"
                                       Opacity="0.9"
                                       TextWrapping="WrapWholeWords"
                                       MaxWidth="420" />
                        </StackPanel>

                        <!-- Right: actions -->
                        <StackPanel Grid.Column="1"
                                    Spacing="14"
                                    VerticalAlignment="Center">
                            <ToggleSwitch Header="Check for updates on launch"
                                          AutomationProperties.Name="Check for OptiHub app updates automatically"
                                          IsOn="{x:Bind ViewModel.AutoUpdateScripts, Mode=TwoWay}"
                                          OnContent="On"
                                          OffContent="Off"
                                          HorizontalAlignment="Left" />
                            <Button Style="{StaticResource OptiPrimaryButton}"
                                    Content="Check for updates"
                                    AutomationProperties.Name="Check for OptiHub app updates"
                                    Command="{x:Bind ViewModel.CheckForUpdatesCommand}"
                                    HorizontalAlignment="Stretch"
                                    MinHeight="48"
                                    IsEnabled="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                            <!-- Same result well as Discord/Steam/NVIDIA pages -->
                            <Border Style="{StaticResource OptiCard}"
                                    Padding="14,12"
                                    MinHeight="52"
                                    Background="{ThemeResource OptiAccentSoftBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE895;"
                                              FontSize="15"
                                              Foreground="{ThemeResource OptiMutedTextBrush}"
                                              VerticalAlignment="Top"
                                              Margin="0,1,0,0" />
                                    <TextBlock Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}"
                                               Style="{StaticResource OptiBody}"
                                               FontSize="12.5"
                                               Foreground="{ThemeResource OptiSecondaryTextBrush}"
                                               TextWrapping="WrapWholeWords"
                                               MaxLines="4"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"
                                               AutomationProperties.LiveSetting="Polite" />
                                </StackPanel>
                            </Border>
                            <TextBlock Text="{x:Bind ViewModel.AboutFooter, Mode=OneWay}"
                                       Style="{StaticResource OptiCaption}"
                                       FontSize="11"
                                       Opacity="0.65"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
