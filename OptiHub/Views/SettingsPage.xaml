<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition FromVerticalOffset="10" />
        </TransitionCollection>
    </Page.Transitions>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,10,28,24">
        <StackPanel MaxWidth="{StaticResource OptiPageMaxWidth}"
                    HorizontalAlignment="Stretch"
                    Spacing="14">

            <Border Style="{StaticResource OptiCard}" Padding="22,20">
                <StackPanel Spacing="14">
                    <TextBlock Text="APPEARANCE" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                    <ToggleSwitch Header="Dark"
                                  IsOn="{x:Bind ViewModel.IsDarkMode, Mode=TwoWay}" />
                    <ToggleSwitch Header="Light"
                                  IsOn="{x:Bind ViewModel.IsLightMode, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource OptiCard}" Padding="22,20">
                <StackPanel Spacing="14">
                    <TextBlock Text="SCRIPTS &amp; UPDATES" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                    <ToggleSwitch Header="Auto-update scripts on launch"
                                  IsOn="{x:Bind ViewModel.AutoUpdateScripts, Mode=TwoWay}" />
                    <TextBox Header="GitHub repository (owner/name)"
                             FontFamily="{StaticResource OptiUiFont}"
                             Text="{x:Bind ViewModel.ScriptsRepo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Header="Branch"
                             FontFamily="{StaticResource OptiUiFont}"
                             Text="{x:Bind ViewModel.ScriptsBranch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Header="Custom scripts folder (optional)"
                             FontFamily="{StaticResource OptiUiFont}"
                             PlaceholderText="Leave empty to use OptiHub-managed scripts"
                             Text="{x:Bind ViewModel.CustomScriptsPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Style="{StaticResource OptiBody}">
                        <Run Text="Installed kit version: " />
                        <Run Text="{x:Bind ViewModel.KitVersion, Mode=OneWay}" FontFamily="{StaticResource OptiUiFontSemiBold}" />
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Style="{StaticResource OptiPrimaryButton}"
                                Content="Check for script updates"
                                Click="CheckUpdates_Click"
                                IsEnabled="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                        <Button Style="{StaticResource OptiQuietButton}"
                                Content="Force re-download"
                                Click="ForceUpdate_Click"
                                IsEnabled="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                    </StackPanel>
                    <TextBlock Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}"
                               Style="{StaticResource OptiBody}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource OptiCard}" Padding="22,20">
                <StackPanel Spacing="10">
                    <TextBlock Text="ABOUT" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                    <TextBlock Style="{StaticResource OptiBody}"
                               Text="OptiHub is a hub for optional system optimizers — performance, privacy, and gaming." />
                    <TextBlock Style="{StaticResource OptiBody}"
                               Text="Use at your own risk. Optimizers may modify application files and Windows settings. You are responsible for compliance with any third-party terms." />
                    <TextBlock Style="{StaticResource OptiCaption}"
                               Margin="0,4,0,0"
                               Text="{x:Bind ViewModel.AboutFooter, Mode=OneWay}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
