<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OptiHub.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      Loaded="Page_Loaded">

    <!-- iOS-style grouped settings — single calm column -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="PageRoot"
                    MaxWidth="560"
                    HorizontalAlignment="Center"
                    Padding="32,36,32,48"
                    Spacing="28">

            <StackPanel x:Name="HeaderPanel"
                        Spacing="4"
                        Opacity="0"
                        RenderTransformOrigin="0.5,0">
                <StackPanel.RenderTransform>
                    <CompositeTransform x:Name="HeaderTransform" TranslateY="12" />
                </StackPanel.RenderTransform>
                <TextBlock Text="Settings"
                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                           FontSize="34"
                           FontWeight="SemiBold"
                           CharacterSpacing="-50"
                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />
            </StackPanel>

            <StackPanel x:Name="BodyGrid"
                        Spacing="22"
                        Opacity="0"
                        RenderTransformOrigin="0.5,0">
                <StackPanel.RenderTransform>
                    <CompositeTransform x:Name="BodyTransform" TranslateY="16" />
                </StackPanel.RenderTransform>

                <!-- Appearance -->
                <StackPanel Spacing="10">
                    <TextBlock Text="Appearance" Style="{StaticResource OptiSectionTitle}" Margin="4,0,0,0" />
                    <Border Background="{ThemeResource OptiCardFillBrush}" CornerRadius="16" Padding="6">
                        <Grid ColumnSpacing="8" Margin="10,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Style="{StaticResource OptiThemePickButton}"
                                    Click="ThemeDark_Click"
                                    Height="100"
                                    AutomationProperties.Name="Use dark theme">
                                <Border Background="{ThemeResource OptiSurfaceBrush}" CornerRadius="12" Padding="14">
                                    <StackPanel Spacing="10">
                                        <Border Height="36" CornerRadius="8" Background="#000000" />
                                        <TextBlock Text="Dark" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                                    </StackPanel>
                                </Border>
                            </Button>
                            <Button Grid.Column="1"
                                    Style="{StaticResource OptiThemePickButton}"
                                    Click="ThemeLight_Click"
                                    Height="100"
                                    AutomationProperties.Name="Use light theme">
                                <Border Background="{ThemeResource OptiSurfaceBrush}" CornerRadius="12" Padding="14">
                                    <StackPanel Spacing="10">
                                        <Border Height="36" CornerRadius="8" Background="#FFFFFF"
                                                BorderBrush="#E8E8ED" BorderThickness="1" />
                                        <TextBlock Text="Light" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                                    </StackPanel>
                                </Border>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Updates -->
                <StackPanel Spacing="10">
                    <TextBlock Text="Updates" Style="{StaticResource OptiSectionTitle}" Margin="4,0,0,0" />
                    <Border Background="{ThemeResource OptiCardFillBrush}" CornerRadius="16" Padding="18,14">
                        <StackPanel Spacing="14">
                            <ToggleSwitch Header="Check on launch"
                                          IsOn="{x:Bind ViewModel.AutoUpdateScripts, Mode=TwoWay}"
                                          OnContent="On" OffContent="Off" />
                            <Button Style="{StaticResource OptiPrimaryButton}"
                                    Content="Check for updates"
                                    Command="{x:Bind ViewModel.CheckForUpdatesCommand}"
                                    HorizontalAlignment="Stretch"
                                    IsEnabled="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                            <TextBlock Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}"
                                       Style="{StaticResource OptiCaption}"
                                       Visibility="{x:Bind ViewModel.HasUpdateStatus, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Support -->
                <StackPanel Spacing="10">
                    <TextBlock Text="Support" Style="{StaticResource OptiSectionTitle}" Margin="4,0,0,0" />
                    <Border Background="{ThemeResource OptiCardFillBrush}" CornerRadius="16" Padding="8">
                        <StackPanel>
                            <Button Style="{StaticResource OptiQuietButton}"
                                    Content="Open logs folder"
                                    HorizontalAlignment="Stretch"
                                    CornerRadius="12"
                                    Background="Transparent"
                                    Command="{x:Bind ViewModel.OpenLogsFolderCommand}" />
                            <Border Height="1" Background="{ThemeResource OptiDividerBrush}" Margin="12,0" />
                            <Button Style="{StaticResource OptiQuietButton}"
                                    Content="Report issue on GitHub"
                                    HorizontalAlignment="Stretch"
                                    CornerRadius="12"
                                    Background="Transparent"
                                    Command="{x:Bind ViewModel.ReportIssueCommand}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- About -->
                <StackPanel Spacing="10">
                    <TextBlock Text="About" Style="{StaticResource OptiSectionTitle}" Margin="4,0,0,0" />
                    <Border Background="{ThemeResource OptiCardFillBrush}" CornerRadius="16" Padding="18,16">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Version" Style="{StaticResource OptiCaption}" />
                            <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                                       FontFamily="{StaticResource OptiUiFontSemiBold}"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       CharacterSpacing="-40"
                                       Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
