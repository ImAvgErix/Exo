<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OptiHub.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      Loaded="Page_Loaded">

    <!-- Dense settings: fill the fixed shell without empty card gutters -->
    <Grid x:Name="PageRoot" Padding="22,10,22,14">
        <Grid MaxWidth="920"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="HeaderPanel"
                       Text="Settings"
                       FontFamily="{StaticResource OptiUiFontSemiBold}"
                       FontSize="20"
                       FontWeight="SemiBold"
                       CharacterSpacing="-12"
                       Margin="0,0,0,10"
                       HorizontalAlignment="Left"
                       Foreground="{ThemeResource OptiPrimaryTextBrush}"
                       Opacity="0"
                       RenderTransformOrigin="0.5,0.5">
                <TextBlock.RenderTransform>
                    <CompositeTransform x:Name="HeaderTransform" TranslateY="8" />
                </TextBlock.RenderTransform>
            </TextBlock>

            <Grid x:Name="BodyGrid"
                  Grid.Row="1"
                  ColumnSpacing="10"
                  RowSpacing="10"
                  Opacity="0"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <CompositeTransform x:Name="BodyTransform" TranslateY="12" />
                </Grid.RenderTransform>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Appearance -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource OptiCard}" Padding="16,14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="APPEARANCE" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <RadioButton Content="Dark"
                                         GroupName="ThemeChoice"
                                         ToolTipService.ToolTip="Dark shell"
                                         AutomationProperties.Name="Use dark theme"
                                         IsChecked="{x:Bind ViewModel.IsDarkMode, Mode=TwoWay}" />
                            <RadioButton Content="Light"
                                         GroupName="ThemeChoice"
                                         ToolTipService.ToolTip="Light shell"
                                         AutomationProperties.Name="Use light theme"
                                         IsChecked="{x:Bind ViewModel.IsLightMode, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Updates -->
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource OptiCard}" Padding="16,14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="UPDATES" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <ToggleSwitch Header="Check on launch"
                                      ToolTipService.ToolTip="Check GitHub for OptiHub updates when the app starts"
                                      AutomationProperties.Name="Check for OptiHub app updates automatically"
                                      IsOn="{x:Bind ViewModel.AutoUpdateScripts, Mode=TwoWay}"
                                      OnContent="On"
                                      OffContent="Off"
                                      HorizontalAlignment="Left" />
                        <Button Style="{StaticResource OptiPrimaryButton}"
                                Content="Check for updates"
                                ToolTipService.ToolTip="Check GitHub for a newer OptiHub release"
                                AutomationProperties.Name="Check for OptiHub app updates"
                                Command="{x:Bind ViewModel.CheckForUpdatesCommand}"
                                HorizontalAlignment="Stretch"
                                MinHeight="40"
                                IsEnabled="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                        <!-- Percent + bar only — no orbit loader -->
                        <StackPanel Spacing="6"
                                    Visibility="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid>
                                <TextBlock Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}"
                                           Style="{StaticResource OptiCaption}"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="1" />
                                <TextBlock Text="{x:Bind ViewModel.UpdateProgressLabel, Mode=OneWay}"
                                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                            </Grid>
                            <ProgressBar Minimum="0"
                                         Maximum="100"
                                         Value="{x:Bind ViewModel.UpdateProgressPercent, Mode=OneWay}"
                                         IsIndeterminate="{x:Bind ViewModel.IsUpdateProgressIndeterminate, Mode=OneWay}"
                                         Height="6"
                                         CornerRadius="3"
                                         Foreground="{ThemeResource OptiAccentBrush}" />
                        </StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}"
                                   Style="{StaticResource OptiCaption}"
                                   FontSize="11.5"
                                   Foreground="{ThemeResource OptiSecondaryTextBrush}"
                                   TextWrapping="WrapWholeWords"
                                   MaxLines="2"
                                   TextTrimming="CharacterEllipsis"
                                   Visibility="{x:Bind ViewModel.ShowIdleUpdateStatus, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                   AutomationProperties.LiveSetting="Polite" />
                    </StackPanel>
                </Border>

                <!-- About -->
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource OptiCard}" Padding="16,14">
                    <StackPanel Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="ABOUT" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                                   FontFamily="{StaticResource OptiUiFontSemiBold}"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                   CharacterSpacing="-24" />
                        <TextBlock Text="{x:Bind ViewModel.KitVersion, Mode=OneWay}"
                                   Style="{StaticResource OptiCaption}"
                                   FontSize="11.5"
                                   Opacity="0.8" />
                    </StackPanel>
                </Border>

                <!-- Support -->
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource OptiCard}" Padding="16,14">
                    <StackPanel Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="SUPPORT" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <Button Style="{StaticResource OptiWhiteButton}"
                                Content="Report issue"
                                ToolTipService.ToolTip="Open GitHub issues"
                                AutomationProperties.Name="Report OptiHub issue on GitHub"
                                HorizontalAlignment="Stretch"
                                Command="{x:Bind ViewModel.ReportIssueCommand}" />
                        <Button Style="{StaticResource OptiQuietButton}"
                                Content="Open logs"
                                ToolTipService.ToolTip="Open OptiHub logs folder"
                                AutomationProperties.Name="Open OptiHub logs folder"
                                HorizontalAlignment="Stretch"
                                Command="{x:Bind ViewModel.OpenLogsFolderCommand}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
