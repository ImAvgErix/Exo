<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OptiHub.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      Loaded="Page_Loaded">

    <!-- Centered settings shell: no scroll, balanced fill, clear sections. -->
    <Grid x:Name="PageRoot" Padding="40,20,40,28">
        <Grid MaxWidth="920"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel x:Name="HeaderPanel"
                        Spacing="6"
                        Margin="0,0,0,20"
                        HorizontalAlignment="Center"
                        Opacity="0"
                        RenderTransformOrigin="0.5,0.5">
                <StackPanel.RenderTransform>
                    <CompositeTransform x:Name="HeaderTransform" TranslateY="10" />
                </StackPanel.RenderTransform>
                <TextBlock Text="Settings"
                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                           FontSize="26"
                           FontWeight="SemiBold"
                           CharacterSpacing="-20"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />
            </StackPanel>

            <!-- Body: 2×2 balanced cards -->
            <Grid x:Name="BodyGrid"
                  Grid.Row="1"
                  ColumnSpacing="16"
                  RowSpacing="16"
                  Opacity="0"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <CompositeTransform x:Name="BodyTransform" TranslateY="14" />
                </Grid.RenderTransform>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Appearance — theme picker cards -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource OptiCard}" Padding="22,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="APPEARANCE" Style="{StaticResource OptiSectionTitle}" Margin="0" />

                        <Grid Grid.Row="1"
                              ColumnSpacing="12"
                              VerticalAlignment="Center"
                              Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Dark -->
                            <Button Grid.Column="0"
                                    Style="{StaticResource OptiThemePickButton}"
                                    Click="ThemeDark_Click"
                                    AutomationProperties.Name="Use dark theme"
                                    AutomationProperties.FullDescription="Dark theme">
                                <Grid>
                                    <Border Style="{StaticResource OptiThemePickOuter}"
                                            BorderBrush="{ThemeResource OptiCardStrokeBrush}" />
                                    <Border Style="{StaticResource OptiThemePickOuter}"
                                            BorderBrush="{ThemeResource OptiAccentBrush}"
                                            BorderThickness="2"
                                            Visibility="{x:Bind ViewModel.IsDarkMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <StackPanel Spacing="10" Padding="10,12">
                                        <Border Height="72"
                                                CornerRadius="12"
                                                Background="#0A0C10"
                                                BorderBrush="#2A3140"
                                                BorderThickness="1"
                                                Padding="10">
                                            <Grid>
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="6"
                                                            VerticalAlignment="Top"
                                                            HorizontalAlignment="Left">
                                                    <Ellipse Width="10" Height="10" Fill="#22C55E" />
                                                    <Ellipse Width="10" Height="10" Fill="#3B82F6" />
                                                    <Ellipse Width="10" Height="10" Fill="#A78BFA" />
                                                </StackPanel>
                                                <FontIcon Glyph="&#xE708;"
                                                          FontSize="22"
                                                          Foreground="#E8ECF4"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                                <Border Width="36" Height="8"
                                                        CornerRadius="4"
                                                        Background="#22C55E"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Bottom"
                                                        Opacity="0.9" />
                                            </Grid>
                                        </Border>
                                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                                            <TextBlock Text="Dark"
                                                       FontFamily="{StaticResource OptiUiFontSemiBold}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="Night mode"
                                                       FontSize="11"
                                                       Foreground="{ThemeResource OptiMutedTextBrush}"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                        <FontIcon Glyph="&#xE73E;"
                                                  FontSize="14"
                                                  Foreground="{ThemeResource OptiAccentBrush}"
                                                  HorizontalAlignment="Center"
                                                  Visibility="{x:Bind ViewModel.IsDarkMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <!-- Light -->
                            <Button Grid.Column="1"
                                    Style="{StaticResource OptiThemePickButton}"
                                    Click="ThemeLight_Click"
                                    AutomationProperties.Name="Use light theme"
                                    AutomationProperties.FullDescription="Light theme">
                                <Grid>
                                    <Border Style="{StaticResource OptiThemePickOuter}"
                                            BorderBrush="{ThemeResource OptiCardStrokeBrush}" />
                                    <Border Style="{StaticResource OptiThemePickOuter}"
                                            BorderBrush="{ThemeResource OptiAccentBrush}"
                                            BorderThickness="2"
                                            Visibility="{x:Bind ViewModel.IsLightMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <StackPanel Spacing="10" Padding="10,12">
                                        <Border Height="72"
                                                CornerRadius="12"
                                                Background="#F4F6FA"
                                                BorderBrush="#D0D7E2"
                                                BorderThickness="1"
                                                Padding="10">
                                            <Grid>
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="6"
                                                            VerticalAlignment="Top"
                                                            HorizontalAlignment="Left">
                                                    <Ellipse Width="10" Height="10" Fill="#16A34A" />
                                                    <Ellipse Width="10" Height="10" Fill="#2563EB" />
                                                    <Ellipse Width="10" Height="10" Fill="#7C3AED" />
                                                </StackPanel>
                                                <FontIcon Glyph="&#xE706;"
                                                          FontSize="22"
                                                          Foreground="#1A1F2A"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                                <Border Width="36" Height="8"
                                                        CornerRadius="4"
                                                        Background="#16A34A"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Bottom"
                                                        Opacity="0.9" />
                                            </Grid>
                                        </Border>
                                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                                            <TextBlock Text="Light"
                                                       FontFamily="{StaticResource OptiUiFontSemiBold}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="Day mode"
                                                       FontSize="11"
                                                       Foreground="{ThemeResource OptiMutedTextBrush}"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                        <FontIcon Glyph="&#xE73E;"
                                                  FontSize="14"
                                                  Foreground="{ThemeResource OptiAccentBrush}"
                                                  HorizontalAlignment="Center"
                                                  Visibility="{x:Bind ViewModel.IsLightMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Support -->
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource OptiCard}" Padding="22,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="SUPPORT" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="10" Margin="0,16,0,0">
                            <Button Style="{StaticResource OptiQuietButton}"
                                    Content="Open logs folder"
                                    AutomationProperties.Name="Open OptiHub logs folder"
                                    HorizontalAlignment="Stretch"
                                    Command="{x:Bind ViewModel.OpenLogsFolderCommand}" />
                        </StackPanel>
                        <HyperlinkButton Grid.Row="2"
                                         Content="Report an issue on GitHub"
                                         FontSize="12"
                                         Padding="0"
                                         Margin="0,10,0,0"
                                         NavigateUri="https://github.com/BarcusEric/OptiHub/issues"
                                         AutomationProperties.Name="Open OptiHub issues on GitHub" />
                    </Grid>
                </Border>

                <!-- About (version + disclaimer) -->
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource OptiCard}" Padding="22,16">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="ABOUT" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <StackPanel Grid.Row="1" Spacing="2">
                            <TextBlock Text="App version"
                                       Style="{StaticResource OptiCaption}"
                                       FontSize="12"
                                       Opacity="0.85" />
                            <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                                       FontFamily="{StaticResource OptiUiFontSemiBold}"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                       CharacterSpacing="-20" />
                        </StackPanel>
                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Margin="0,4,0,0">
                            <TextBlock Style="{StaticResource OptiCaption}"
                                       FontSize="11"
                                       LineHeight="15"
                                       Opacity="0.9"
                                       TextWrapping="WrapWholeWords"
                                       Text="Disclaimer: OptiHub is free, unofficial software. It is not affiliated with, endorsed by, or supported by Discord, Valve/Steam, NVIDIA, Microsoft, or any other third party.&#x0a;&#x0a;Applies aggressive changes to drivers, GPU settings, registry, services, and game/chat clients. You may need Administrator rights. Use at your own risk. Back up important data and create a system restore point first.&#x0a;&#x0a;No warranty — express or implied. The author is not liable for broken installs, lost data, banned accounts, hardware issues, or any other damage. By using OptiHub you accept full responsibility for the outcome." />
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Updates — same card size as Appearance / Support -->
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource OptiCard}" Padding="22,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="UPDATES" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        </StackPanel>
                        <StackPanel Grid.Row="1"
                                    VerticalAlignment="Center"
                                    Spacing="12"
                                    Margin="0,12,0,0">
                            <ToggleSwitch Header="Check on launch"
                                          AutomationProperties.Name="Check for OptiHub app updates automatically"
                                          IsOn="{x:Bind ViewModel.AutoUpdateScripts, Mode=TwoWay}"
                                          OnContent="On"
                                          OffContent="Off"
                                          HorizontalAlignment="Left" />
                            <Button Style="{StaticResource OptiPrimaryButton}"
                                    Content="Check for updates"
                                    AutomationProperties.Name="Check for OptiHub app updates"
                                    Command="{x:Bind ViewModel.CheckForUpdatesCommand}"
                                    HorizontalAlignment="Stretch"
                                    MinHeight="44"
                                    IsEnabled="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                        </StackPanel>
                        <TextBlock Grid.Row="2"
                                   Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}"
                                   Style="{StaticResource OptiCaption}"
                                   FontSize="11.5"
                                   Foreground="{ThemeResource OptiSecondaryTextBrush}"
                                   TextWrapping="WrapWholeWords"
                                   MaxLines="2"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,10,0,0"
                                   Visibility="{x:Bind ViewModel.HasUpdateStatus, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                   AutomationProperties.LiveSetting="Polite" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
