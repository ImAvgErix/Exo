<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.NvidiaPanelPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:OptiHub.ViewModels"
    Background="Transparent">

    <Grid Padding="{StaticResource OptiPagePadding}">
        <ContentControl Style="{StaticResource OptiCard}"
                        Padding="28,26"
                        MaxWidth="{StaticResource OptiPageMaxWidth}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,16">
                    <TextBlock Text="NVIDIA PANEL" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                    <TextBlock Text="{x:Bind ViewModel.HeaderStatus, Mode=OneWay}"
                               Style="{StaticResource OptiPageTitle}" />
                    <TextBlock Text="{x:Bind ViewModel.HeaderDetail, Mode=OneWay}"
                               Style="{StaticResource OptiCaption}"
                               Visibility="{x:Bind ViewModel.HeaderDetail, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <ProgressRing Width="28" Height="28"
                                  IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <StackPanel Spacing="16">
                            <!-- Live color depth pickers (like Control Panel / App) -->
                            <StackPanel Spacing="10"
                                        Visibility="{x:Bind ViewModel.HasDisplays, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="COLOR DEPTH" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                                <TextBlock Text="Pick the bit depth your monitor supports. Peak Optimize still chooses the highest automatically."
                                           Style="{StaticResource OptiCaption}" />
                                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Displays, Mode=OneWay}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Orientation="Vertical" Spacing="8" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="vm:NvidiaDisplayColorRowViewModel">
                                            <Border Style="{StaticResource OptiFeatureTile}" Padding="14,12">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="140" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Spacing="2" VerticalAlignment="Center">
                                                        <TextBlock Text="{x:Bind Title}" Style="{StaticResource OptiFeatureTitle}" />
                                                        <TextBlock Style="{StaticResource OptiFeatureDetail}">
                                                            <Run Text="Current: " />
                                                            <Run Text="{x:Bind CurrentDepth, Mode=OneWay}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <ComboBox Grid.Column="1"
                                                              ItemsSource="{x:Bind DepthOptions}"
                                                              SelectedItem="{x:Bind SelectedDepth, Mode=TwoWay}"
                                                              HorizontalAlignment="Stretch"
                                                              VerticalAlignment="Center"
                                                              MinWidth="120"
                                                              IsEnabled="{x:Bind IsApplying, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                                              AutomationProperties.Name="Color bit depth" />
                                                    <Button Grid.Column="2"
                                                            Style="{StaticResource OptiQuietButton}"
                                                            Content="Set"
                                                            MinWidth="72"
                                                            VerticalAlignment="Center"
                                                            Click="SetDepth_Click"
                                                            Tag="{x:Bind}"
                                                            IsEnabled="{x:Bind CanApply, Mode=OneWay}"
                                                            AutomationProperties.Name="Apply color depth" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>

                            <StackPanel Spacing="10">
                                <TextBlock Text="POLICY" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}">
                                    <ItemsRepeater.Layout>
                                        <UniformGridLayout MaximumRowsOrColumns="2"
                                                           Orientation="Horizontal"
                                                           MinItemWidth="240"
                                                           MinColumnSpacing="10"
                                                           MinRowSpacing="10"
                                                           ItemsStretch="Fill" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="vm:NvidiaPolicyRowViewModel">
                                            <Border Style="{StaticResource OptiFeatureTile}"
                                                    Opacity="{x:Bind Opacity}">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Style="{StaticResource OptiIconWell}">
                                                        <FontIcon Glyph="{x:Bind Glyph}"
                                                                  FontSize="14"
                                                                  Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                        <TextBlock Text="{x:Bind Title}" Style="{StaticResource OptiFeatureTitle}" />
                                                        <TextBlock Text="{x:Bind Status}" Style="{StaticResource OptiFeatureDetail}" />
                                                    </StackPanel>
                                                    <Button Grid.Column="2"
                                                            Style="{StaticResource OptiQuietButton}"
                                                            Content="Apply"
                                                            MinWidth="80"
                                                            VerticalAlignment="Center"
                                                            Visibility="{x:Bind NeedsFix, Mode=OneWay}"
                                                            Tag="{x:Bind Id}"
                                                            Click="ApplyRow_Click"
                                                            IsEnabled="{x:Bind CanApply, Mode=OneWay}"
                                                            AutomationProperties.Name="Apply this policy" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <StackPanel Grid.Row="2" Spacing="12">
                    <Border Style="{StaticResource OptiMessageBanner}"
                            Visibility="{x:Bind ViewModel.HasMessage, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="{x:Bind ViewModel.MessageGlyph, Mode=OneWay}"
                                      FontSize="15"
                                      Foreground="{x:Bind ViewModel.MessageBrush, Mode=OneWay}"
                                      VerticalAlignment="Top" />
                            <TextBlock Text="{x:Bind ViewModel.Message, Mode=OneWay}"
                                       Grid.Column="1"
                                       Style="{StaticResource OptiBody}"
                                       FontSize="12.5"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </Border>

                    <StackPanel Spacing="6"
                                Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ProgressBar Minimum="0" Maximum="100"
                                     Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                                     Height="6"
                                     CornerRadius="3"
                                     Foreground="{ThemeResource OptiAccentBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.ProgressStatus, Mode=OneWay}"
                                   Style="{StaticResource OptiCaption}"
                                   TextAlignment="Center" />
                    </StackPanel>

                    <Button Style="{StaticResource OptiPrimaryButton}"
                            Content="{x:Bind ViewModel.ApplyAllLabel, Mode=OneWay}"
                            Click="ApplyAll_Click"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.CanApplyAll, Mode=OneWay}"
                            AutomationProperties.Name="Apply all NVIDIA panel policies" />
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Style="{StaticResource OptiQuietButton}"
                                Content="Refresh"
                                Click="Refresh_Click"
                                HorizontalAlignment="Stretch"
                                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                        <Button Grid.Column="1"
                                Style="{StaticResource OptiQuietButton}"
                                Content="Clear tray"
                                Click="ClearTray_Click"
                                HorizontalAlignment="Stretch"
                                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                ToolTipService.ToolTip="Clear NVIDIA tray icons" />
                    </Grid>
                </StackPanel>
            </Grid>
        </ContentControl>
    </Grid>
</Page>
