<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OptiHub.Views.NvidiaPanelPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:OptiHub.ViewModels"
      Background="Transparent">
    <Grid Padding="{StaticResource OptiPagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Spacing="4" Margin="0,0,0,12">
            <TextBlock Text="Display" Style="{StaticResource OptiPageTitle}" />
            <TextBlock Text="{x:Bind ViewModel.HeaderStatus, Mode=OneWay}" Style="{StaticResource OptiCaption}" />
            <TextBlock Text="{x:Bind ViewModel.HeaderDetail, Mode=OneWay}" Style="{StaticResource OptiCaption}" />
        </StackPanel>
        <Grid Grid.Row="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Monitors" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Displays, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsStackPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:NvidiaDisplayColorRowViewModel">
                                    <Border Background="{ThemeResource OptiCardFillBrush}"
                                            BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8" Padding="14" Margin="0,0,0,8"
                                            HorizontalAlignment="Stretch">
                                        <StackPanel Spacing="10">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{x:Bind Title}" Style="{StaticResource OptiFeatureTitle}" />
                                                    <TextBlock Text="{x:Bind CurrentSummary, Mode=OneWay}" Style="{StaticResource OptiCaption}" />
                                                </StackPanel>
                                                <Button Grid.Column="1" Style="{StaticResource OptiPrimaryButton}"
                                                        Content="Apply" MinWidth="80" Padding="12,6"
                                                        Click="ApplyDisplay_Click" Tag="{x:Bind}"
                                                        IsEnabled="{x:Bind CanApply, Mode=OneWay}"
                                                        AutomationProperties.Name="Apply display settings" />
                                            </Grid>
                                            <Grid ColumnSpacing="10" RowSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="Resolution" Style="{StaticResource OptiCaption}" />
                                                    <ComboBox ItemsSource="{x:Bind ResolutionOptions}" SelectedItem="{x:Bind SelectedResolution, Mode=TwoWay}"
                                                              HorizontalAlignment="Stretch" MinHeight="32" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Spacing="4">
                                                    <TextBlock Text="Refresh rate" Style="{StaticResource OptiCaption}" />
                                                    <ComboBox ItemsSource="{x:Bind RefreshOptions}" SelectedItem="{x:Bind SelectedRefresh, Mode=TwoWay}"
                                                              HorizontalAlignment="Stretch" MinHeight="32" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Spacing="4">
                                                    <TextBlock Text="Color depth" Style="{StaticResource OptiCaption}" />
                                                    <ComboBox ItemsSource="{x:Bind DepthOptions}" SelectedItem="{x:Bind SelectedDepth, Mode=TwoWay}"
                                                              HorizontalAlignment="Stretch" MinHeight="32" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                                    <TextBlock Text="NVIDIA color" Style="{StaticResource OptiCaption}" />
                                                    <ComboBox ItemsSource="{x:Bind ColorRangeOptions}" SelectedItem="{x:Bind SelectedColorRange, Mode=TwoWay}"
                                                              HorizontalAlignment="Stretch" MinHeight="32" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Spacing="4">
                                                    <TextBlock Text="Scaling" Style="{StaticResource OptiCaption}" />
                                                    <ComboBox ItemsSource="{x:Bind ScalingOptions}" SelectedItem="{x:Bind SelectedScaling, Mode=TwoWay}"
                                                              HorizontalAlignment="Stretch" MinHeight="32" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    <StackPanel Spacing="8">
                        <TextBlock Text="Policy" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Vertical" Spacing="8" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:NvidiaPolicyRowViewModel">
                                    <Border Style="{StaticResource OptiFeatureTile}" HorizontalAlignment="Stretch">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Style="{StaticResource OptiIconWell}">
                                                <FontIcon Glyph="{x:Bind Glyph}" FontSize="13" Foreground="{ThemeResource OptiAccentBrush}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Title}" Style="{StaticResource OptiFeatureTitle}" />
                                                <TextBlock Text="{x:Bind Status}" Style="{StaticResource OptiFeatureDetail}"
                                                           MaxLines="1" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
            <ProgressRing Width="28" Height="28"
                          IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Opacity="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToShowOpacityConverter}}"
                          HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" />
        </Grid>
        <StackPanel Grid.Row="2" Spacing="8" Margin="0,12,0,0">
            <Border Style="{StaticResource OptiMessageBanner}"
                    Visibility="{x:Bind ViewModel.HasMessage, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{x:Bind ViewModel.Message, Mode=OneWay}" Style="{StaticResource OptiBody}"
                           TextTrimming="CharacterEllipsis" MaxLines="2" />
            </Border>
            <ProgressBar Minimum="0" Maximum="100" Height="3" CornerRadius="2"
                         Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                         Foreground="{ThemeResource OptiAccentBrush}"
                         Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Style="{StaticResource OptiPrimaryButton}" Content="{x:Bind ViewModel.ApplyAllLabel, Mode=OneWay}"
                        Click="ApplyAll_Click"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                <Button Style="{StaticResource OptiQuietButton}" Content="Refresh" Click="Refresh_Click"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                <Button Style="{StaticResource OptiQuietButton}" Content="Clear tray" Click="ClearTray_Click"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
