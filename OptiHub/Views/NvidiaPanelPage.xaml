<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.NvidiaPanelPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:OptiHub.ViewModels"
    Background="Transparent">

    <Grid Padding="28,16,28,22">
        <Border Style="{StaticResource OptiCard}"
                Padding="28,24"
                MaxWidth="1000"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,16">
                    <TextBlock Text="NVIDIA PANEL" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                    <TextBlock Text="{x:Bind ViewModel.HeaderStatus, Mode=OneWay}"
                               FontFamily="{StaticResource OptiUiFontSemiBold}"
                               FontSize="26"
                               FontWeight="SemiBold"
                               CharacterSpacing="-20"
                               Foreground="{ThemeResource OptiPrimaryTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <ProgressRing Width="28" Height="28"
                                  IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <UniformGridLayout MaximumRowsOrColumns="2"
                                                   Orientation="Horizontal"
                                                   MinItemWidth="240"
                                                   MinColumnSpacing="12"
                                                   MinRowSpacing="12"
                                                   ItemsStretch="Fill" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:NvidiaPolicyRowViewModel">
                                    <Border Style="{StaticResource OptiCard}"
                                            Padding="14,12"
                                            MinHeight="64"
                                            HorizontalAlignment="Stretch"
                                            Opacity="{x:Bind Opacity}"
                                            Background="{ThemeResource OptiAccentSoftBrush}">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="32" Height="32"
                                                    CornerRadius="9"
                                                    Background="{ThemeResource OptiCardFillBrush}"
                                                    BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                                                    BorderThickness="1"
                                                    VerticalAlignment="Center">
                                                <FontIcon Glyph="{x:Bind Glyph}"
                                                          FontSize="14"
                                                          Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Title}"
                                                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{x:Bind Status}"
                                                           FontFamily="{StaticResource OptiUiFont}"
                                                           FontSize="12"
                                                           LineHeight="16"
                                                           Foreground="{ThemeResource OptiMutedTextBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <Button Grid.Column="2"
                                                    Style="{StaticResource OptiQuietButton}"
                                                    Content="Apply"
                                                    MinWidth="80"
                                                    VerticalAlignment="Center"
                                                    Visibility="{x:Bind NeedsFix, Mode=OneWay}"
                                                    Tag="{x:Bind Id}"
                                                    Click="ApplyRow_Click"
                                                    IsEnabled="{x:Bind CanApply, Mode=OneWay}"
                                                    AutomationProperties.Name="Apply this policy" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </Grid>

                <StackPanel Grid.Row="2" Spacing="12">
                    <Border Style="{StaticResource OptiCard}"
                            Padding="14,12"
                            Visibility="{x:Bind ViewModel.HasMessage, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="{ThemeResource OptiAccentSoftBrush}">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="{x:Bind ViewModel.MessageGlyph, Mode=OneWay}"
                                      FontSize="15"
                                      Foreground="{x:Bind ViewModel.MessageBrush, Mode=OneWay}"
                                      VerticalAlignment="Top" />
                            <TextBlock Text="{x:Bind ViewModel.Message, Mode=OneWay}"
                                       Grid.Column="1"
                                       Style="{StaticResource OptiBody}"
                                       FontSize="12.5"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </Border>

                    <StackPanel Spacing="6"
                                Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ProgressBar Minimum="0" Maximum="100"
                                     Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                                     Height="8"
                                     CornerRadius="4"
                                     Foreground="{ThemeResource OptiAccentBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.ProgressStatus, Mode=OneWay}"
                                   Style="{StaticResource OptiCaption}"
                                   TextAlignment="Center" />
                    </StackPanel>

                    <Button Style="{StaticResource OptiPrimaryButton}"
                            Content="{x:Bind ViewModel.ApplyAllLabel, Mode=OneWay}"
                            Click="ApplyAll_Click"
                            HorizontalAlignment="Stretch"
                            MinHeight="48"
                            IsEnabled="{x:Bind ViewModel.CanApplyAll, Mode=OneWay}"
                            AutomationProperties.Name="Apply all NVIDIA panel policies" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Style="{StaticResource OptiQuietButton}"
                                Content="Refresh"
                                Click="Refresh_Click"
                                HorizontalAlignment="Stretch"
                                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                        <Button Grid.Column="1"
                                Style="{StaticResource OptiQuietButton}"
                                Content="Clear tray"
                                Click="ClearTray_Click"
                                HorizontalAlignment="Stretch"
                                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                ToolTipService.ToolTip="Clear NVIDIA tray icons" />
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
