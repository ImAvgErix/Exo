<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.NvidiaPanelPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:OptiHub.ViewModels"
    Background="Transparent">

    <!-- Selectors only: res / Hz / depth / color / scaling. No policy "applied" tiles. -->
    <Grid Padding="{StaticResource OptiPagePadding}">
        <Grid MaxWidth="{StaticResource OptiPageMaxWidth}"
              HorizontalAlignment="Stretch"
              RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="4">
                <TextBlock Text="DISPLAY" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                <TextBlock Text="{x:Bind ViewModel.HeaderStatus, Mode=OneWay}"
                           Style="{StaticResource OptiPageTitle}" />
                <TextBlock Text="{x:Bind ViewModel.HeaderDetail, Mode=OneWay}"
                           Style="{StaticResource OptiCaption}" />
            </StackPanel>

            <Grid Grid.Row="1">
                <ProgressRing Width="28" Height="28"
                              IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <StackPanel Spacing="12"
                                Visibility="{x:Bind ViewModel.HasDisplays, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Displays, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsStackPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:NvidiaDisplayColorRowViewModel">
                                    <Border Style="{StaticResource OptiCard}"
                                            Padding="18,16"
                                            Margin="0,0,0,10"
                                            HorizontalAlignment="Stretch">
                                        <StackPanel Spacing="12">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="4" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind Title}"
                                                               Style="{StaticResource OptiFeatureTitle}"
                                                               FontSize="15" />
                                                    <TextBlock Text="{x:Bind ChangeHint, Mode=OneWay}"
                                                               Style="{StaticResource OptiCaption}"
                                                               FontSize="11.5"
                                                               TextWrapping="WrapWholeWords"
                                                               Visibility="{x:Bind HasChangeHint, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Style="{StaticResource OptiPrimaryButton}"
                                                        Content="{x:Bind ApplyLabel, Mode=OneWay}"
                                                        MinWidth="108"
                                                        MinHeight="40"
                                                        Padding="14,8"
                                                        Click="ApplyDisplay_Click"
                                                        Tag="{x:Bind}"
                                                        IsEnabled="{x:Bind CanApply, Mode=OneWay}"
                                                        AutomationProperties.Name="Apply display settings" />
                                            </Grid>

                                            <Grid ColumnSpacing="12" RowSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="Resolution" Style="{StaticResource OptiCaption}" />
                                                    <ComboBox ItemsSource="{x:Bind ResolutionOptions}"
                                                              SelectedItem="{x:Bind SelectedResolution, Mode=TwoWay}"
                                                              HorizontalAlignment="Stretch"
                                                              MinHeight="36"
                                                              AutomationProperties.Name="Resolution" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Spacing="4">
                                                    <TextBlock Text="Refresh rate" Style="{StaticResource OptiCaption}" />
                                                    <ComboBox ItemsSource="{x:Bind RefreshOptions}"
                                                              SelectedItem="{x:Bind SelectedRefresh, Mode=TwoWay}"
                                                              HorizontalAlignment="Stretch"
                                                              MinHeight="36"
                                                              AutomationProperties.Name="Refresh rate" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Spacing="4">
                                                    <TextBlock Text="Color depth" Style="{StaticResource OptiCaption}" />
                                                    <ComboBox ItemsSource="{x:Bind DepthOptions}"
                                                              SelectedItem="{x:Bind SelectedDepth, Mode=TwoWay}"
                                                              HorizontalAlignment="Stretch"
                                                              MinHeight="36"
                                                              AutomationProperties.Name="Color depth" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                                    <TextBlock Text="NVIDIA color" Style="{StaticResource OptiCaption}" />
                                                    <ComboBox ItemsSource="{x:Bind ColorRangeOptions}"
                                                              SelectedItem="{x:Bind SelectedColorRange, Mode=TwoWay}"
                                                              HorizontalAlignment="Stretch"
                                                              MinHeight="36"
                                                              AutomationProperties.Name="NVIDIA color range" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Spacing="4">
                                                    <TextBlock Text="Scaling" Style="{StaticResource OptiCaption}" />
                                                    <ComboBox ItemsSource="{x:Bind ScalingOptions}"
                                                              SelectedItem="{x:Bind SelectedScaling, Mode=TwoWay}"
                                                              HorizontalAlignment="Stretch"
                                                              MinHeight="36"
                                                              AutomationProperties.Name="Scaling" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <StackPanel Grid.Row="2" Spacing="10">
                <Border Style="{StaticResource OptiMessageBanner}"
                        Visibility="{x:Bind ViewModel.HasMessage, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="{x:Bind ViewModel.MessageGlyph, Mode=OneWay}"
                                  FontSize="15"
                                  Foreground="{x:Bind ViewModel.MessageBrush, Mode=OneWay}"
                                  VerticalAlignment="Top" />
                        <TextBlock Text="{x:Bind ViewModel.Message, Mode=OneWay}"
                                   Grid.Column="1"
                                   Style="{StaticResource OptiBody}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </Border>

                <StackPanel Spacing="6"
                            Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ProgressBar Minimum="0" Maximum="100"
                                 Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                                 Height="4"
                                 CornerRadius="2"
                                 Foreground="{ThemeResource OptiAccentBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.ProgressStatus, Mode=OneWay}"
                               Style="{StaticResource OptiCaption}"
                               TextAlignment="Center" />
                </StackPanel>

                <Button Style="{StaticResource OptiQuietButton}"
                        Content="Refresh"
                        Click="Refresh_Click"
                        HorizontalAlignment="Stretch"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                        AutomationProperties.Name="Refresh displays" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
