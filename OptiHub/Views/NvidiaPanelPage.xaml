<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.NvidiaPanelPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:OptiHub.ViewModels"
    Background="Transparent">

    <Grid Padding="{StaticResource OptiPagePadding}">
        <Grid MaxWidth="1100" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,16">
                <TextBlock Text="DISPLAY" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                <TextBlock Text="{x:Bind ViewModel.HeaderStatus, Mode=OneWay}"
                           Style="{StaticResource OptiPageTitle}" />
                <TextBlock Text="{x:Bind ViewModel.HeaderDetail, Mode=OneWay}"
                           Style="{StaticResource OptiCaption}" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,14">
                <ProgressRing Width="32" Height="32"
                              IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <StackPanel Spacing="18">
                        <!-- Per-display Control Panel cards -->
                        <StackPanel Spacing="12"
                                    Visibility="{x:Bind ViewModel.HasDisplays, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="MONITORS" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Displays, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Vertical" Spacing="12" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:NvidiaDisplayColorRowViewModel">
                                        <ContentControl Style="{StaticResource OptiCard}" Padding="20,18">
                                            <StackPanel Spacing="14">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="{x:Bind Title}" Style="{StaticResource OptiFeatureTitle}" FontSize="15" />
                                                        <TextBlock Text="{x:Bind CurrentSummary, Mode=OneWay}"
                                                                   Style="{StaticResource OptiFeatureDetail}" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            Style="{StaticResource OptiPrimaryButton}"
                                                            Content="Apply"
                                                            MinWidth="100"
                                                            MinHeight="40"
                                                            Padding="16,8"
                                                            Click="ApplyDisplay_Click"
                                                            Tag="{x:Bind}"
                                                            IsEnabled="{x:Bind CanApply, Mode=OneWay}"
                                                            AutomationProperties.Name="Apply display settings" />
                                                </Grid>

                                                <Grid ColumnSpacing="12" RowSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <StackPanel Spacing="4">
                                                        <TextBlock Text="Resolution" Style="{StaticResource OptiCaption}" />
                                                        <ComboBox ItemsSource="{x:Bind ResolutionOptions}"
                                                                  SelectedItem="{x:Bind SelectedResolution, Mode=TwoWay}"
                                                                  HorizontalAlignment="Stretch"
                                                                  IsEnabled="{x:Bind IsApplying, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                                                  AutomationProperties.Name="Resolution" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Spacing="4">
                                                        <TextBlock Text="Refresh rate" Style="{StaticResource OptiCaption}" />
                                                        <ComboBox ItemsSource="{x:Bind RefreshOptions}"
                                                                  SelectedItem="{x:Bind SelectedRefresh, Mode=TwoWay}"
                                                                  HorizontalAlignment="Stretch"
                                                                  IsEnabled="{x:Bind IsApplying, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                                                  AutomationProperties.Name="Refresh rate" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="1" Spacing="4">
                                                        <TextBlock Text="Color depth" Style="{StaticResource OptiCaption}" />
                                                        <ComboBox ItemsSource="{x:Bind DepthOptions}"
                                                                  SelectedItem="{x:Bind SelectedDepth, Mode=TwoWay}"
                                                                  HorizontalAlignment="Stretch"
                                                                  IsEnabled="{x:Bind IsApplying, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                                                  AutomationProperties.Name="Color depth" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                                        <TextBlock Text="NVIDIA color" Style="{StaticResource OptiCaption}" />
                                                        <ComboBox ItemsSource="{x:Bind ColorRangeOptions}"
                                                                  SelectedItem="{x:Bind SelectedColorRange, Mode=TwoWay}"
                                                                  HorizontalAlignment="Stretch"
                                                                  IsEnabled="{x:Bind IsApplying, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                                                  AutomationProperties.Name="NVIDIA color range" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Spacing="4">
                                                        <TextBlock Text="Scaling" Style="{StaticResource OptiCaption}" />
                                                        <ComboBox ItemsSource="{x:Bind ScalingOptions}"
                                                                  SelectedItem="{x:Bind SelectedScaling, Mode=TwoWay}"
                                                                  HorizontalAlignment="Stretch"
                                                                  IsEnabled="{x:Bind IsApplying, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                                                  AutomationProperties.Name="Scaling" />
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </ContentControl>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>

                        <!-- Policy checklist -->
                        <StackPanel Spacing="10">
                            <TextBlock Text="POLICY" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <UniformGridLayout MaximumRowsOrColumns="2"
                                                       Orientation="Horizontal"
                                                       MinItemWidth="260"
                                                       MinColumnSpacing="10"
                                                       MinRowSpacing="10"
                                                       ItemsStretch="Fill" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:NvidiaPolicyRowViewModel">
                                        <Border Style="{StaticResource OptiFeatureTile}"
                                                Opacity="{x:Bind Opacity}">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Style="{StaticResource OptiIconWell}">
                                                    <FontIcon Glyph="{x:Bind Glyph}"
                                                              FontSize="14"
                                                              Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind Title}" Style="{StaticResource OptiFeatureTitle}" />
                                                    <TextBlock Text="{x:Bind Status}" Style="{StaticResource OptiFeatureDetail}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Footer actions -->
            <StackPanel Grid.Row="2" Spacing="12">
                <Border Style="{StaticResource OptiMessageBanner}"
                        Visibility="{x:Bind ViewModel.HasMessage, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="{x:Bind ViewModel.MessageGlyph, Mode=OneWay}"
                                  FontSize="15"
                                  Foreground="{x:Bind ViewModel.MessageBrush, Mode=OneWay}"
                                  VerticalAlignment="Top" />
                        <TextBlock Text="{x:Bind ViewModel.Message, Mode=OneWay}"
                                   Grid.Column="1"
                                   Style="{StaticResource OptiBody}"
                                   FontSize="12.5"
                                   TextWrapping="Wrap" />
                    </Grid>
                </Border>

                <StackPanel Spacing="6"
                            Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ProgressBar Minimum="0" Maximum="100"
                                 Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                                 Height="6"
                                 CornerRadius="3"
                                 Foreground="{ThemeResource OptiAccentBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.ProgressStatus, Mode=OneWay}"
                               Style="{StaticResource OptiCaption}"
                               TextAlignment="Center" />
                </StackPanel>

                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Style="{StaticResource OptiPrimaryButton}"
                            Content="{x:Bind ViewModel.ApplyAllLabel, Mode=OneWay}"
                            Click="ApplyAll_Click"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.CanApplyAll, Mode=OneWay}"
                            AutomationProperties.Name="Apply peak defaults" />
                    <Button Grid.Column="1"
                            Style="{StaticResource OptiQuietButton}"
                            Content="Refresh"
                            Click="Refresh_Click"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                    <Button Grid.Column="2"
                            Style="{StaticResource OptiQuietButton}"
                            Content="Clear tray"
                            Click="ClearTray_Click"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
