<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OptiHub.Views.NvidiaPanelPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:OptiHub.ViewModels"
      Background="Transparent">
    <Grid Padding="{StaticResource OptiPagePadding}" ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="{ThemeResource OptiCardFillBrush}"
                BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                BorderThickness="1" CornerRadius="14" Padding="20,18">
            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Spacing="6">
                    <TextBlock Text="DISPLAY" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                    <TextBlock Text="{x:Bind ViewModel.HeaderStatus, Mode=OneWay}" Style="{StaticResource OptiPageTitle}" FontSize="20" />
                    <TextBlock Text="{x:Bind ViewModel.HeaderDetail, Mode=OneWay}" Style="{StaticResource OptiCaption}" />
                </StackPanel>
                <Border Grid.Row="1" Style="{StaticResource OptiMessageBanner}" VerticalAlignment="Top"
                        Visibility="{x:Bind ViewModel.HasMessage, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="{x:Bind ViewModel.MessageGlyph, Mode=OneWay}" FontSize="15"
                                  Foreground="{x:Bind ViewModel.MessageBrush, Mode=OneWay}" VerticalAlignment="Top" />
                        <TextBlock Text="{x:Bind ViewModel.Message, Mode=OneWay}" Grid.Column="1"
                                   Style="{StaticResource OptiBody}" TextWrapping="Wrap" />
                    </Grid>
                </Border>
                <StackPanel Grid.Row="2" Spacing="10">
                    <StackPanel Spacing="6" Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ProgressBar Minimum="0" Maximum="100" Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                                     Height="4" CornerRadius="2" Foreground="{ThemeResource OptiAccentBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.ProgressStatus, Mode=OneWay}" Style="{StaticResource OptiCaption}" />
                    </StackPanel>
                    <Button Style="{StaticResource OptiPrimaryButton}" Content="{x:Bind ViewModel.ApplyAllLabel, Mode=OneWay}"
                            Click="ApplyAll_Click" HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                    <Button Style="{StaticResource OptiQuietButton}" Content="Refresh" Click="Refresh_Click" HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                    <Button Style="{StaticResource OptiQuietButton}" Content="Clear tray" Click="ClearTray_Click" HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="{ThemeResource OptiCardFillBrush}"
                BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                BorderThickness="1" CornerRadius="14" Padding="20,18">
            <Grid>
                <ProgressRing Width="28" Height="28" IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <StackPanel Spacing="18">
                        <StackPanel Spacing="10" Visibility="{x:Bind ViewModel.HasDisplays, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="MONITORS" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.Displays, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsStackPanel Orientation="Vertical" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:NvidiaDisplayColorRowViewModel">
                                        <Border Background="{ThemeResource OptiSurfaceBrush}"
                                                BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12" Padding="16,14" Margin="0,0,0,12">
                                            <StackPanel Spacing="12">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="{x:Bind Title}" Style="{StaticResource OptiFeatureTitle}" FontSize="15" />
                                                        <TextBlock Text="{x:Bind CurrentSummary, Mode=OneWay}" Style="{StaticResource OptiFeatureDetail}" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Style="{StaticResource OptiPrimaryButton}"
                                                            Content="Apply" MinWidth="96" MinHeight="40" Padding="16,8"
                                                            Click="ApplyDisplay_Click" Tag="{x:Bind}"
                                                            IsEnabled="{x:Bind CanApply, Mode=OneWay}"
                                                            AutomationProperties.Name="Apply display settings" />
                                                </Grid>
                                                <Grid ColumnSpacing="12" RowSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Text="Resolution" Style="{StaticResource OptiCaption}" />
                                                        <ComboBox ItemsSource="{x:Bind ResolutionOptions}" SelectedItem="{x:Bind SelectedResolution, Mode=TwoWay}"
                                                                  HorizontalAlignment="Stretch" MinHeight="36" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Spacing="4">
                                                        <TextBlock Text="Refresh rate" Style="{StaticResource OptiCaption}" />
                                                        <ComboBox ItemsSource="{x:Bind RefreshOptions}" SelectedItem="{x:Bind SelectedRefresh, Mode=TwoWay}"
                                                                  HorizontalAlignment="Stretch" MinHeight="36" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="1" Spacing="4">
                                                        <TextBlock Text="Color depth" Style="{StaticResource OptiCaption}" />
                                                        <ComboBox ItemsSource="{x:Bind DepthOptions}" SelectedItem="{x:Bind SelectedDepth, Mode=TwoWay}"
                                                                  HorizontalAlignment="Stretch" MinHeight="36" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                                        <TextBlock Text="NVIDIA color" Style="{StaticResource OptiCaption}" />
                                                        <ComboBox ItemsSource="{x:Bind ColorRangeOptions}" SelectedItem="{x:Bind SelectedColorRange, Mode=TwoWay}"
                                                                  HorizontalAlignment="Stretch" MinHeight="36" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Spacing="4">
                                                        <TextBlock Text="Scaling" Style="{StaticResource OptiCaption}" />
                                                        <ComboBox ItemsSource="{x:Bind ScalingOptions}" SelectedItem="{x:Bind SelectedScaling, Mode=TwoWay}"
                                                                  HorizontalAlignment="Stretch" MinHeight="36" />
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        <StackPanel Spacing="10">
                            <TextBlock Text="POLICY" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Vertical" Spacing="8" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:NvidiaPolicyRowViewModel">
                                        <Border Style="{StaticResource OptiFeatureTile}">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Style="{StaticResource OptiIconWell}">
                                                    <FontIcon Glyph="{x:Bind Glyph}" FontSize="14" Foreground="{ThemeResource OptiAccentBrush}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind Title}" Style="{StaticResource OptiFeatureTitle}" />
                                                    <TextBlock Text="{x:Bind Status}" Style="{StaticResource OptiFeatureDetail}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
