<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:OptiHub.ViewModels"
    Background="Transparent"
    Loaded="Page_Loaded">

    <!--
      Fixed 1180×760.
      Tagline = full-width centered hero.
      Cards = compact under it (clearly smaller than the title).
    -->
    <Grid x:Name="PageRoot"
          Padding="40,20,40,28"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="920"
                    Spacing="0">

            <!-- Hero: stretch to panel width so TextAlignment=Center is real center -->
            <TextBlock x:Name="HeroTagline"
                       Text="Maximum performance. No compromise."
                       Style="{StaticResource OptiTagline}"
                       FontSize="36"
                       LineHeight="44"
                       CharacterSpacing="-16"
                       TextWrapping="WrapWholeWords"
                       TextAlignment="Center"
                       HorizontalAlignment="Stretch"
                       Margin="0,0,0,24"
                       MaxWidth="880"
                       RenderTransformOrigin="0.5,0.5">
                <TextBlock.RenderTransform>
                    <CompositeTransform />
                </TextBlock.RenderTransform>
            </TextBlock>

            <ItemsControl x:Name="CardList"
                          HorizontalAlignment="Center"
                          ItemsSource="{x:Bind ViewModel.Cards, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       MaximumRowsOrColumns="3"
                                       HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:OptimizerCardViewModel">
                        <Button Style="{StaticResource OptiCardButton}"
                                Width="248"
                                Height="148"
                                Margin="6"
                                RenderTransformOrigin="0.5,0.5"
                                Click="CardButton_Click"
                                Tag="{x:Bind Definition.Id}"
                                AutomationProperties.Name="{x:Bind Definition.Title}"
                                IsEnabled="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                            <Border Style="{StaticResource OptiCard}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Padding="12,12,12,10"
                                    Opacity="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToOpacityConverter}}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Image Width="64"
                                           Height="64"
                                           Source="{x:Bind Definition.LogoPath, Mode=OneWay, Converter={StaticResource AssetPathToImageSourceConverter}}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Stretch="Uniform"
                                           AutomationProperties.AccessibilityView="Raw" />
                                    <StackPanel Grid.Row="1"
                                                Spacing="2"
                                                HorizontalAlignment="Center"
                                                Margin="0,6,0,0">
                                        <TextBlock Text="{x:Bind Definition.Title, Mode=OneWay}"
                                                   FontFamily="{StaticResource OptiUiFontSemiBold}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1" />
                                        <TextBlock Text="Coming soon"
                                                   FontFamily="{StaticResource OptiUiFont}"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource OptiMutedTextBrush}"
                                                   HorizontalAlignment="Center"
                                                   Visibility="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</Page>
