<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:OptiHub.ViewModels"
    Background="Transparent">

    <!-- FORGE hub: asymmetric rail + vertical optimizer list (not logo grid) -->
    <Grid x:Name="PageRoot" Padding="0" Loaded="PageRoot_Loaded">
        <Grid MaxWidth="1280"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              ColumnSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left brand rail -->
            <Border Grid.Column="0"
                    Background="{ThemeResource OptiSurfaceBrush}"
                    BorderBrush="{ThemeResource OptiDividerBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="28,36,24,32">
                <StackPanel x:Name="HeroPanel"
                            Spacing="18"
                            VerticalAlignment="Center"
                            Opacity="0"
                            RenderTransformOrigin="0,0.5">
                    <StackPanel.RenderTransform>
                        <CompositeTransform x:Name="HeroTransform" TranslateX="-12" />
                    </StackPanel.RenderTransform>
                    <Border Width="36" Height="36"
                            CornerRadius="6"
                            Background="{ThemeResource OptiRailBrush}"
                            HorizontalAlignment="Left" />
                    <TextBlock Text="OPTIHUB"
                               Style="{StaticResource OptiTagline}"
                               FontSize="28"
                               CharacterSpacing="80"
                               HorizontalAlignment="Left" />
                    <TextBlock Text="Aggressive optimizers for Discord, Steam, Internet, and NVIDIA — peak defaults with honest status."
                               Style="{StaticResource OptiTaglineSupport}"
                               TextWrapping="WrapWholeWords"
                               MaxWidth="240" />
                    <Border Height="1"
                            Background="{ThemeResource OptiDividerBrush}"
                            Margin="0,8,0,0" />
                    <TextBlock Text="SELECT A MODULE →"
                               FontFamily="{StaticResource OptiUiFontSemiBold}"
                               FontSize="11"
                               FontWeight="Bold"
                               CharacterSpacing="120"
                               Foreground="{ThemeResource OptiAccentBrush}" />
                </StackPanel>
            </Border>

            <!-- Right: vertical module list -->
            <Grid Grid.Column="1" Padding="28,32,32,28">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel MaxWidth="720"
                                HorizontalAlignment="Left"
                                Spacing="10">
                        <TextBlock Text="MODULES"
                                   Style="{StaticResource OptiSectionTitle}"
                                   Margin="0,0,0,4" />
                        <ItemsControl x:Name="CardList"
                                      ItemsSource="{x:Bind ViewModel.Cards, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsStackPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:OptimizerCardViewModel">
                                    <Button Style="{StaticResource OptiCardButton}"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Height="80"
                                            Margin="0,0,0,10"
                                            Click="CardButton_Click"
                                            Tag="{x:Bind Definition.Id}"
                                            AutomationProperties.Name="{x:Bind Definition.Title}"
                                            IsEnabled="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                            Opacity="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToOpacityConverter}}">
                                        <Border Style="{StaticResource OptiHubRow}"
                                                HorizontalAlignment="Stretch">
                                            <Grid ColumnSpacing="16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="4" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        Background="{ThemeResource OptiRailBrush}"
                                                        CornerRadius="2"
                                                        VerticalAlignment="Stretch"
                                                        Margin="0,2" />
                                                <Border Grid.Column="1"
                                                        Style="{StaticResource OptiLogoWell}"
                                                        Width="48"
                                                        Height="48"
                                                        CornerRadius="10"
                                                        Padding="8">
                                                    <Image Source="{x:Bind Definition.LogoPath, Mode=OneWay, Converter={StaticResource AssetPathToImageSourceConverter}}"
                                                           Stretch="Uniform"
                                                           AutomationProperties.AccessibilityView="Raw" />
                                                </Border>
                                                <StackPanel Grid.Column="2"
                                                            VerticalAlignment="Center"
                                                            Spacing="2">
                                                    <TextBlock Text="{x:Bind Definition.Title}"
                                                               FontFamily="{StaticResource OptiUiFontSemiBold}"
                                                               FontWeight="Bold"
                                                               FontSize="16"
                                                               Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                                                    <TextBlock Text="Peak optimizer"
                                                               FontFamily="{StaticResource OptiUiFont}"
                                                               FontSize="12"
                                                               Foreground="{ThemeResource OptiMutedTextBrush}"
                                                               Visibility="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                                    <TextBlock Text="Coming soon"
                                                               FontFamily="{StaticResource OptiUiFont}"
                                                               FontSize="12"
                                                               Foreground="{ThemeResource OptiMutedTextBrush}"
                                                               Visibility="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                </StackPanel>
                                                <Border Grid.Column="3"
                                                        Padding="10,4"
                                                        CornerRadius="4"
                                                        Background="{ThemeResource OptiAccentSoftBrush}"
                                                        VerticalAlignment="Center"
                                                        Visibility="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                    <TextBlock Text="LIVE"
                                                               FontSize="10"
                                                               FontWeight="Bold"
                                                               CharacterSpacing="80"
                                                               Foreground="{ThemeResource OptiAccentBrush}" />
                                                </Border>
                                                <FontIcon Grid.Column="4"
                                                          Glyph="&#xE76C;"
                                                          FontSize="12"
                                                          Foreground="{ThemeResource OptiMutedTextBrush}"
                                                          VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>
