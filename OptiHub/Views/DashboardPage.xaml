<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:OptiHub.ViewModels"
    Background="Transparent"
    Loaded="Page_Loaded">

    <!-- Fixed 1180×760 shell — large static 3-col product grid -->
    <Grid x:Name="PageRoot" Padding="24,10,24,16">
        <Grid MaxWidth="1120"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Start invisible — no flash before entrance motion -->
            <StackPanel x:Name="HeroPanel"
                        Spacing="0"
                        Margin="0,0,0,18"
                        HorizontalAlignment="Center"
                        Opacity="0"
                        IsHitTestVisible="False"
                        RenderTransformOrigin="0.5,0.5">
                <StackPanel.RenderTransform>
                    <CompositeTransform x:Name="HeroTransform" TranslateY="18" />
                </StackPanel.RenderTransform>
                <TextBlock Text="Maximum performance. No compromise."
                           Style="{StaticResource OptiTagline}"
                           FontSize="44"
                           LineHeight="52"
                           CharacterSpacing="-20"
                           TextWrapping="WrapWholeWords"
                           TextAlignment="Center"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Card host starts transparent so generated items never flash full opacity -->
            <ItemsControl x:Name="CardList"
                          Grid.Row="1"
                          HorizontalAlignment="Center"
                          Opacity="0"
                          ItemsSource="{x:Bind ViewModel.Cards, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       MaximumRowsOrColumns="3"
                                       HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:OptimizerCardViewModel">
                        <!-- Opacity on button is entrance-owned (code). Dim coming-soon on inner chrome only. -->
                        <Button Style="{StaticResource OptiCardButton}"
                                Width="340"
                                Height="190"
                                Margin="8"
                                Opacity="0"
                                Click="CardButton_Click"
                                Tag="{x:Bind Definition.Id}"
                                AutomationProperties.Name="{x:Bind Definition.Title}"
                                IsEnabled="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                            <Border Style="{StaticResource OptiCard}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Padding="14"
                                    Opacity="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToOpacityConverter}}">
                                <Grid>
                                    <Image Width="96"
                                           Height="96"
                                           Source="{x:Bind Definition.LogoPath, Mode=OneWay, Converter={StaticResource AssetPathToImageSourceConverter}}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Stretch="Uniform"
                                           AutomationProperties.AccessibilityView="Raw" />
                                    <TextBlock Text="Coming soon"
                                               FontFamily="{StaticResource OptiUiFont}"
                                               FontSize="12"
                                               Foreground="{ThemeResource OptiMutedTextBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Bottom"
                                               Margin="0,0,0,2"
                                               Visibility="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</Page>
