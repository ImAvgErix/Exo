<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:OptiHub.ViewModels"
    Background="Transparent">

    <!-- Dense module lanes — not equal SaaS cards, not generic grid -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Padding="28,20,28,28">
        <StackPanel MaxWidth="720" Spacing="20">

            <StackPanel Spacing="4">
                <TextBlock Text="Modules"
                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                <TextBlock Text="Pick one to open."
                           FontSize="13"
                           Foreground="{ThemeResource OptiMutedTextBrush}" />
            </StackPanel>

            <ItemsControl x:Name="CardList"
                          ItemsSource="{x:Bind ViewModel.Cards, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsStackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:OptimizerCardViewModel">
                        <Button Style="{StaticResource OptiCardButton}"
                                Margin="0,0,0,8"
                                HorizontalAlignment="Stretch"
                                Height="72"
                                Click="CardButton_Click"
                                Tag="{x:Bind Definition.Id}"
                                AutomationProperties.Name="{x:Bind Definition.Title}"
                                IsEnabled="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                Opacity="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToOpacityConverter}}">
                            <Border Background="{ThemeResource OptiCardFillBrush}"
                                    BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="14,10">
                                <Grid ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="48" Height="48"
                                            CornerRadius="10"
                                            Background="{ThemeResource OptiLogoWellFillBrush}"
                                            BorderBrush="{ThemeResource OptiLogoWellStrokeBrush}"
                                            BorderThickness="1"
                                            Padding="8">
                                        <Image Source="{x:Bind Definition.LogoPath, Mode=OneWay, Converter={StaticResource AssetPathToImageSourceConverter}}"
                                               Stretch="Uniform"
                                               AutomationProperties.AccessibilityView="Raw" />
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="{x:Bind Definition.Title}"
                                                   FontFamily="{StaticResource OptiUiFontSemiBold}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                                        <TextBlock FontSize="12"
                                                   Foreground="{ThemeResource OptiMutedTextBrush}"
                                                   Text="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource ComingSoonLabelConverter}}" />
                                    </StackPanel>

                                    <FontIcon Grid.Column="2"
                                              Glyph="&#xE76C;"
                                              FontSize="12"
                                              VerticalAlignment="Center"
                                              Foreground="{ThemeResource OptiMutedTextBrush}" />
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
