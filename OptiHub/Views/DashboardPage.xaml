<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:OptiHub.ViewModels"
    Background="Transparent">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition FromVerticalOffset="16" />
        </TransitionCollection>
    </Page.Transitions>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="20,4,20,20">
        <StackPanel MaxWidth="{StaticResource OptiPageMaxWidth}"
                    HorizontalAlignment="Center"
                    Spacing="22">

            <StackPanel Spacing="8" Margin="12,10,12,4">
                <TextBlock Text="A calm place for performance, privacy, and gaming tweaks."
                           Style="{StaticResource OptiTagline}"
                           HorizontalAlignment="Stretch" />
                <TextBlock Text="Pick a card to begin."
                           Style="{StaticResource OptiTaglineSupport}"
                           HorizontalAlignment="Stretch" />
            </StackPanel>

            <GridView x:Name="OptimizerGrid"
                      ItemsSource="{x:Bind ViewModel.Cards}"
                      SelectionMode="None"
                      IsItemClickEnabled="True"
                      ItemClick="OptimizerGrid_ItemClick"
                      HorizontalAlignment="Center">
                <GridView.ItemContainerTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="22" IsStaggeringEnabled="True" />
                    </TransitionCollection>
                </GridView.ItemContainerTransitions>
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       MaximumRowsOrColumns="3"
                                       ItemWidth="196"
                                       ItemHeight="188"
                                       HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem" BasedOn="{StaticResource OptiGridViewItemStyle}" />
                </GridView.ItemContainerStyle>
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="vm:OptimizerCardViewModel">
                        <Border Style="{StaticResource OptiCard}"
                                Opacity="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToOpacityConverter}}"
                                MinHeight="176"
                                MinWidth="184"
                                Padding="16,18">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="12">
                                <Border Width="60" Height="60"
                                        CornerRadius="16"
                                        Background="{ThemeResource OptiAccentSoftBrush}"
                                        BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                                        BorderThickness="1"
                                        HorizontalAlignment="Center">
                                    <Image Width="34" Height="34"
                                           Source="{x:Bind Definition.LogoPath, Mode=OneWay, Converter={StaticResource AssetPathToImageSourceConverter}}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Stretch="Uniform" />
                                </Border>
                                <TextBlock Text="{x:Bind Definition.Title}"
                                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="160" />
                                <TextBlock Text="Coming soon"
                                           FontFamily="{StaticResource OptiUiFont}"
                                           FontSize="12"
                                           FontWeight="Medium"
                                           Foreground="{ThemeResource OptiMutedTextBrush}"
                                           TextAlignment="Center"
                                           Visibility="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </StackPanel>
    </ScrollViewer>
</Page>

