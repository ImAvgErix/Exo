<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:OptiHub.ViewModels"
    Background="Transparent"
    Loaded="Page_Loaded">

    <!--
      Fixed 1180×760 shell.
      Hero tagline is the visual centerpiece (large, dead-center).
      Cards are compact tiles under it — never larger than the title band.
    -->
    <Grid x:Name="PageRoot" Padding="36,18,36,24">
        <Grid MaxWidth="960"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Full-width hero so TextAlignment=Center is truly middle of shell -->
            <Grid x:Name="HeroPanel"
                  HorizontalAlignment="Stretch"
                  Margin="0,0,0,22"
                  Opacity="1"
                  IsHitTestVisible="True">
                <TextBlock x:Name="HeroTagline"
                           Text="Maximum performance. No compromise."
                           Style="{StaticResource OptiTagline}"
                           FontSize="40"
                           LineHeight="48"
                           CharacterSpacing="-20"
                           TextWrapping="WrapWholeWords"
                           TextAlignment="Center"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Center"
                           MaxWidth="880" />
            </Grid>

            <!-- Compact cards under the hero (3-up, same center axis) -->
            <ItemsControl x:Name="CardList"
                          Grid.Row="1"
                          HorizontalAlignment="Center"
                          Opacity="1"
                          ItemsSource="{x:Bind ViewModel.Cards, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       MaximumRowsOrColumns="3"
                                       HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:OptimizerCardViewModel">
                        <Button Style="{StaticResource OptiCardButton}"
                                Width="268"
                                Height="132"
                                Margin="6"
                                Opacity="1"
                                Click="CardButton_Click"
                                Tag="{x:Bind Definition.Id}"
                                AutomationProperties.Name="{x:Bind Definition.Title}"
                                IsEnabled="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                            <Border Style="{StaticResource OptiCard}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Padding="10"
                                    Opacity="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToOpacityConverter}}">
                                <Grid>
                                    <Image Width="72"
                                           Height="72"
                                           Source="{x:Bind Definition.LogoPath, Mode=OneWay, Converter={StaticResource AssetPathToImageSourceConverter}}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Stretch="Uniform"
                                           AutomationProperties.AccessibilityView="Raw" />
                                    <TextBlock Text="Coming soon"
                                               FontFamily="{StaticResource OptiUiFont}"
                                               FontSize="11"
                                               Foreground="{ThemeResource OptiMutedTextBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Bottom"
                                               Margin="0,0,0,1"
                                               Visibility="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</Page>
