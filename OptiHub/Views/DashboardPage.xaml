<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:OptiHub.ViewModels"
    Background="Transparent">

    <!-- Linear/Raycast product hub: brand hero + large logo tiles -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="{StaticResource OptiPagePadding}">
        <StackPanel HorizontalAlignment="Stretch" Spacing="28">

            <StackPanel Spacing="8" HorizontalAlignment="Left">
                <TextBlock Text="Command center"
                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                           FontSize="28"
                           FontWeight="SemiBold"
                           CharacterSpacing="-40"
                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                <TextBlock Text="Peak optimizers for Discord, Steam, Internet &amp; NVIDIA."
                           FontSize="14"
                           Foreground="{ThemeResource OptiMutedTextBrush}"
                           TextWrapping="WrapWholeWords" />
            </StackPanel>

            <ItemsControl x:Name="CardList"
                          ItemsSource="{x:Bind ViewModel.Cards, Mode=OneWay}"
                          HorizontalAlignment="Left">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       MaximumRowsOrColumns="4"
                                       HorizontalAlignment="Left" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:OptimizerCardViewModel">
                        <Button Style="{StaticResource OptiCardButton}"
                                Width="200"
                                Height="180"
                                Margin="0,0,12,12"
                                Click="CardButton_Click"
                                Tag="{x:Bind Definition.Id}"
                                AutomationProperties.Name="{x:Bind Definition.Title}"
                                IsEnabled="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                Opacity="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToOpacityConverter}}">
                            <Border Background="{ThemeResource OptiCardFillBrush}"
                                    BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Border Width="64" Height="64"
                                            CornerRadius="16"
                                            Background="{ThemeResource OptiLogoWellFillBrush}"
                                            BorderBrush="{ThemeResource OptiLogoWellStrokeBrush}"
                                            BorderThickness="1"
                                            Padding="11"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top">
                                        <Image Source="{x:Bind Definition.LogoPath, Mode=OneWay, Converter={StaticResource AssetPathToImageSourceConverter}}"
                                               Stretch="Uniform"
                                               AutomationProperties.AccessibilityView="Raw" />
                                    </Border>
                                    <TextBlock Grid.Row="1"
                                               Text="{x:Bind Definition.Title}"
                                               FontFamily="{StaticResource OptiUiFontSemiBold}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Margin="0,14,0,2"
                                               Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                                    <TextBlock Grid.Row="2"
                                               FontSize="12"
                                               Foreground="{ThemeResource OptiMutedTextBrush}"
                                               Text="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource ComingSoonLabelConverter}}" />
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
