<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:OptiHub.ViewModels"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="32,8,32,32">
        <StackPanel MaxWidth="960" HorizontalAlignment="Left" Spacing="8">

            <TextBlock Text="Your optimizers"
                       Style="{StaticResource OptiPageTitle}"
                       Margin="0,8,0,4" />
            <TextBlock Text="A calm place for performance, privacy, and gaming tweaks. Pick a card to begin."
                       Style="{StaticResource OptiBody}"
                       Margin="0,0,0,24"
                       MaxWidth="560" />

            <GridView x:Name="OptimizerGrid"
                      ItemsSource="{x:Bind ViewModel.Cards}"
                      SelectionMode="None"
                      IsItemClickEnabled="True"
                      ItemClick="OptimizerGrid_ItemClick">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       MaximumRowsOrColumns="3"
                                       ItemWidth="280"
                                       ItemHeight="200" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="Margin" Value="0,0,16,16" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                    </Style>
                </GridView.ItemContainerStyle>
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="vm:OptimizerCardViewModel">
                        <Border Style="{StaticResource OptiCard}"
                                Opacity="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToOpacityConverter}}"
                                MinHeight="180">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Width="36" Height="36" CornerRadius="10"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            VerticalAlignment="Center">
                                        <FontIcon Glyph="{x:Bind Definition.AccentGlyph}"
                                                  FontSize="16"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Definition.Title}"
                                                   FontWeight="SemiBold"
                                                   FontSize="15" />
                                        <TextBlock Text="{x:Bind Definition.Subtitle}"
                                                   Style="{StaticResource OptiCaption}"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock Grid.Row="1"
                                           Text="{x:Bind StatusDetail, Mode=OneWay}"
                                           Style="{StaticResource OptiBody}"
                                           Margin="0,14,0,12"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="3" />

                                <Border Grid.Row="2"
                                        HorizontalAlignment="Left"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="8"
                                        Padding="10,4">
                                    <TextBlock Text="{x:Bind StatusBadge, Mode=OneWay}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Opacity="0.85" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <TextBlock Text="More optimizers will land here quietly over time."
                       Style="{StaticResource OptiCaption}"
                       Margin="0,8,0,0" />
        </StackPanel>
    </ScrollViewer>
</Page>
