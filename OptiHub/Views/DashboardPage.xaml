<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:OptiHub.ViewModels"
    Background="Transparent">

    <!-- v1.7 SPA home: centered italic hero + product cards (this IS the nav) -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="{StaticResource OptiPagePadding}">
        <StackPanel MaxWidth="900"
                    HorizontalAlignment="Center"
                    Spacing="8">

            <StackPanel Spacing="10"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,28">
                <TextBlock Style="{StaticResource OptiTagline}"
                           TextAlignment="Center"
                           HorizontalAlignment="Center">
                    <Run Text="Maximum performance." />
                    <LineBreak />
                    <Run Text="No compromise." />
                </TextBlock>
                <TextBlock Text="Pick a target. Live status is verified when you open it."
                           Style="{StaticResource OptiTaglineSupport}"
                           MaxWidth="420"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <ItemsControl x:Name="CardList"
                          ItemsSource="{x:Bind ViewModel.Cards, Mode=OneWay}"
                          HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       MaximumRowsOrColumns="3"
                                       HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:OptimizerCardViewModel">
                        <Button Style="{StaticResource OptiCardButton}"
                                Width="220"
                                Height="180"
                                Margin="8"
                                Click="CardButton_Click"
                                Tag="{x:Bind Definition.Id}"
                                AutomationProperties.Name="{x:Bind Definition.Title}"
                                IsEnabled="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                Opacity="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToOpacityConverter}}">
                            <Border Background="{ThemeResource OptiCardFillBrush}"
                                    BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="20"
                                    Width="220"
                                    Height="180"
                                    Padding="18">
                                <StackPanel Spacing="14"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <Border Width="64" Height="64"
                                            CornerRadius="18"
                                            Background="{ThemeResource OptiLogoWellFillBrush}"
                                            BorderBrush="{ThemeResource OptiLogoWellStrokeBrush}"
                                            BorderThickness="1"
                                            Padding="12"
                                            HorizontalAlignment="Center">
                                        <Image Source="{x:Bind Definition.LogoPath, Mode=OneWay, Converter={StaticResource AssetPathToImageSourceConverter}}"
                                               Stretch="Uniform"
                                               AutomationProperties.AccessibilityView="Raw" />
                                    </Border>
                                    <TextBlock Text="{x:Bind Definition.Title}"
                                               FontFamily="{StaticResource OptiUiFontSemiBold}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                                    <TextBlock FontSize="11.5"
                                               FontWeight="SemiBold"
                                               CharacterSpacing="40"
                                               HorizontalAlignment="Center"
                                               Foreground="{ThemeResource OptiMutedTextBrush}"
                                               Text="SOON"
                                               Visibility="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </StackPanel>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
