<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:OptiHub.ViewModels"
    Background="Transparent">

    <Grid x:Name="PageRoot" Padding="20,20,28,28" Loaded="PageRoot_Loaded">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="148" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left sidebar: Apps · Internet · GPU -->
        <Border Grid.Column="0"
                Background="{ThemeResource OptiCardFillBrush}"
                BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="10,14"
                Margin="0,0,16,0"
                VerticalAlignment="Stretch">
            <StackPanel Spacing="6" VerticalAlignment="Top">
                <TextBlock Text="OPTIHUB"
                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                           FontSize="10"
                           FontWeight="SemiBold"
                           CharacterSpacing="120"
                           Foreground="{ThemeResource OptiPrimaryTextBrush}"
                           Opacity="0.55"
                           Margin="8,0,8,10" />

                <Button x:Name="NavApps"
                        Style="{StaticResource OptiQuietButton}"
                        Content="Apps"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="14,10"
                        MinHeight="40"
                        Click="NavApps_Click"
                        Tag="Apps" />
                <Button x:Name="NavInternet"
                        Style="{StaticResource OptiQuietButton}"
                        Content="Internet"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="14,10"
                        MinHeight="40"
                        Click="NavInternet_Click"
                        Tag="Internet" />
                <Button x:Name="NavGpu"
                        Style="{StaticResource OptiQuietButton}"
                        Content="GPU"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="14,10"
                        MinHeight="40"
                        Click="NavGpu_Click"
                        Tag="Gpu" />
            </StackPanel>
        </Border>

        <Grid Grid.Column="1"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel x:Name="HeroPanel"
                        Spacing="6"
                        Margin="0,0,0,18"
                        HorizontalAlignment="Left"
                        Opacity="0"
                        RenderTransformOrigin="0,0.5">
                <StackPanel.RenderTransform>
                    <CompositeTransform x:Name="HeroTransform" TranslateY="12" />
                </StackPanel.RenderTransform>
                <TextBlock Text="{x:Bind ViewModel.SectionTitle, Mode=OneWay}"
                           Style="{StaticResource OptiTagline}"
                           FontSize="30"
                           LineHeight="36"
                           TextAlignment="Left"
                           HorizontalAlignment="Left" />
                <TextBlock Text="{x:Bind ViewModel.SectionCaption, Mode=OneWay}"
                           Style="{StaticResource OptiTaglineSupport}"
                           FontSize="13"
                           TextAlignment="Left"
                           HorizontalAlignment="Left" />
            </StackPanel>

            <Grid Grid.Row="1"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
                <ItemsControl x:Name="CardList"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Top"
                              ItemsSource="{x:Bind ViewModel.Cards, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal"
                                           MaximumRowsOrColumns="3"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Top" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:OptimizerCardViewModel">
                            <Button Style="{StaticResource OptiCardButton}"
                                    Width="280"
                                    Height="176"
                                    Margin="0,0,12,12"
                                    Click="CardButton_Click"
                                    Tag="{x:Bind Definition.Id}"
                                    AutomationProperties.Name="{x:Bind Definition.Title}"
                                    IsEnabled="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                    Opacity="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToOpacityConverter}}">
                                <ContentControl Style="{StaticResource OptiCard}"
                                        Width="280"
                                        Height="176"
                                        Padding="16,14">
                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Spacing="12">
                                        <Border Style="{StaticResource OptiLogoWell}">
                                            <Image Source="{x:Bind Definition.LogoPath, Mode=OneWay, Converter={StaticResource AssetPathToImageSourceConverter}}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Stretch="Uniform"
                                                   AutomationProperties.AccessibilityView="Raw" />
                                        </Border>
                                        <TextBlock Text="{x:Bind Definition.Title}"
                                                   FontFamily="{StaticResource OptiUiFontSemiBold}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="230" />
                                        <TextBlock Text="Coming soon"
                                                   FontFamily="{StaticResource OptiUiFont}"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                                   TextAlignment="Center"
                                                   Visibility="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </StackPanel>
                                </ContentControl>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Grid>
    </Grid>
</Page>
