<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:OptiHub.ViewModels"
    Background="Transparent">

    <!-- LUMEN hub: centered hero + soft product tiles (not a gray list) -->
    <Grid x:Name="PageRoot" Padding="40,24,40,36" Loaded="PageRoot_Loaded">
        <Grid MaxWidth="1100"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              RowSpacing="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel x:Name="HeroPanel"
                        Spacing="10"
                        HorizontalAlignment="Center"
                        Opacity="0"
                        RenderTransformOrigin="0.5,0.5">
                <StackPanel.RenderTransform>
                    <CompositeTransform x:Name="HeroTransform" TranslateY="12" />
                </StackPanel.RenderTransform>
                <Border Width="10" Height="10"
                        CornerRadius="5"
                        Background="{ThemeResource OptiAccentBrush}"
                        HorizontalAlignment="Center" />
                <TextBlock Text="OptiHub"
                           Style="{StaticResource OptiTagline}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Peak optimizers for Discord, Steam, Internet &amp; NVIDIA."
                           Style="{StaticResource OptiTaglineSupport}"
                           HorizontalAlignment="Center"
                           MaxWidth="420" />
            </StackPanel>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="CardList"
                              HorizontalAlignment="Center"
                              ItemsSource="{x:Bind ViewModel.Cards, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal"
                                           MaximumRowsOrColumns="4"
                                           HorizontalAlignment="Center" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:OptimizerCardViewModel">
                            <Button Style="{StaticResource OptiCardButton}"
                                    Width="220"
                                    Height="200"
                                    Margin="8"
                                    Click="CardButton_Click"
                                    Tag="{x:Bind Definition.Id}"
                                    AutomationProperties.Name="{x:Bind Definition.Title}"
                                    IsEnabled="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                    Opacity="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToOpacityConverter}}">
                                <Border Background="{ThemeResource OptiCardFillBrush}"
                                        BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                                        BorderThickness="1"
                                        CornerRadius="22"
                                        Width="220"
                                        Height="200"
                                        Padding="18">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Border Style="{StaticResource OptiLogoWell}"
                                                Width="72" Height="72"
                                                CornerRadius="20"
                                                Padding="12"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                            <Image Source="{x:Bind Definition.LogoPath, Mode=OneWay, Converter={StaticResource AssetPathToImageSourceConverter}}"
                                                   Stretch="Uniform"
                                                   AutomationProperties.AccessibilityView="Raw" />
                                        </Border>
                                        <TextBlock Grid.Row="1"
                                                   Text="{x:Bind Definition.Title}"
                                                   FontFamily="{StaticResource OptiUiFontSemiBold}"
                                                   FontWeight="SemiBold"
                                                   FontSize="16"
                                                   Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                                   TextAlignment="Center"
                                                   Margin="0,4,0,2" />
                                        <TextBlock Grid.Row="2"
                                                   Text="Coming soon"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource OptiMutedTextBrush}"
                                                   TextAlignment="Center"
                                                   Visibility="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <Border Grid.Row="2"
                                                HorizontalAlignment="Center"
                                                Padding="10,3"
                                                CornerRadius="999"
                                                Background="{ThemeResource OptiAccentSoftBrush}"
                                                Visibility="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                            <TextBlock Text="Live"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{ThemeResource OptiAccentBrush}" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
