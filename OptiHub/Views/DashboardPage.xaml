<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:OptiHub.ViewModels"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="32,16,32,32">
        <StackPanel MaxWidth="{StaticResource OptiPageMaxWidth}"
                    HorizontalAlignment="Center"
                    Spacing="28">

            <TextBlock Text="A calm place for performance, privacy, and gaming tweaks. Pick a card to begin."
                       Style="{StaticResource OptiTagline}"
                       HorizontalAlignment="Stretch"
                       Margin="8,12,8,4" />

            <GridView x:Name="OptimizerGrid"
                      ItemsSource="{x:Bind ViewModel.Cards}"
                      SelectionMode="None"
                      IsItemClickEnabled="True"
                      ItemClick="OptimizerGrid_ItemClick"
                      HorizontalAlignment="Center">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       MaximumRowsOrColumns="3"
                                       ItemWidth="200"
                                       ItemHeight="196"
                                       HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem" BasedOn="{StaticResource OptiGridViewItemStyle}" />
                </GridView.ItemContainerStyle>
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="vm:OptimizerCardViewModel">
                        <Border Style="{StaticResource OptiCard}"
                                Opacity="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToOpacityConverter}}"
                                MinHeight="168"
                                MinWidth="176">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="12">
                                <Border Width="56" Height="56"
                                        CornerRadius="14"
                                        Background="{ThemeResource OptiAccentSoftBrush}"
                                        HorizontalAlignment="Center">
                                    <Image Width="36" Height="36"
                                           Source="{x:Bind Definition.LogoPath, Mode=OneWay, Converter={StaticResource AssetPathToImageSourceConverter}}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Stretch="Uniform" />
                                </Border>
                                <TextBlock Text="{x:Bind Definition.Title}"
                                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="160" />
                                <TextBlock Text="Coming soon"
                                           FontFamily="{StaticResource OptiUiFont}"
                                           FontSize="12"
                                           Foreground="{ThemeResource OptiMutedTextBrush}"
                                           TextAlignment="Center"
                                           Visibility="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </StackPanel>
    </ScrollViewer>
</Page>
