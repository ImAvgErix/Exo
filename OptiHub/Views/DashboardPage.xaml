<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:OptiHub.ViewModels"
    Background="Transparent">

    <Grid x:Name="PageRoot" Padding="16,12,20,20" Loaded="PageRoot_Loaded">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="208" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Collapsible rail -->
        <Border x:Name="SidebarHost"
                Grid.Column="0"
                Background="{ThemeResource OptiCardFillBrush}"
                BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="10,12"
                Margin="0,0,14,0"
                VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Margin="2,0,2,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel x:Name="BrandBlock" Spacing="2" VerticalAlignment="Center" Margin="6,0,0,0">
                        <TextBlock Text="OPTIHUB"
                                   FontFamily="{StaticResource OptiUiFontSemiBold}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   CharacterSpacing="140"
                                   Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                   Opacity="0.5" />
                        <TextBlock x:Name="BrandSub"
                                   Text="Performance hub"
                                   FontSize="11"
                                   Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                   Opacity="0.7" />
                    </StackPanel>
                    <Button x:Name="CollapseButton"
                            Grid.Column="1"
                            Style="{StaticResource OptiIconButton}"
                            Width="34" Height="34"
                            Click="Collapse_Click"
                            ToolTipService.ToolTip="Collapse sidebar"
                            AutomationProperties.Name="Toggle sidebar">
                        <FontIcon x:Name="CollapseIcon"
                                  Glyph="&#xE76B;"
                                  FontSize="12"
                                  Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                    </Button>
                </Grid>

                <StackPanel Grid.Row="1" Spacing="4">
                    <Button x:Name="NavHome"
                            Style="{StaticResource OptiQuietButton}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="10,0"
                            MinHeight="42"
                            Click="NavHome_Click"
                            Tag="Home"
                            ToolTipService.ToolTip="Home">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE80F;" FontSize="15" Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                            <TextBlock x:Name="NavHomeLabel" Text="Home" VerticalAlignment="Center"
                                       FontFamily="{StaticResource OptiUiFontSemiBold}" FontSize="13"
                                       Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavApps"
                            Style="{StaticResource OptiQuietButton}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="10,0"
                            MinHeight="42"
                            Click="NavApps_Click"
                            Tag="Apps"
                            ToolTipService.ToolTip="Apps">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE8F1;" FontSize="15" Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                            <TextBlock x:Name="NavAppsLabel" Text="Apps" VerticalAlignment="Center"
                                       FontFamily="{StaticResource OptiUiFontSemiBold}" FontSize="13"
                                       Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavInternet"
                            Style="{StaticResource OptiQuietButton}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="10,0"
                            MinHeight="42"
                            Click="NavInternet_Click"
                            Tag="Internet"
                            ToolTipService.ToolTip="Internet">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE774;" FontSize="15" Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                            <TextBlock x:Name="NavInternetLabel" Text="Internet" VerticalAlignment="Center"
                                       FontFamily="{StaticResource OptiUiFontSemiBold}" FontSize="13"
                                       Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavGpu"
                            Style="{StaticResource OptiQuietButton}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="10,0"
                            MinHeight="42"
                            Click="NavGpu_Click"
                            Tag="Gpu"
                            ToolTipService.ToolTip="GPU">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE7F4;" FontSize="15" Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                            <TextBlock x:Name="NavGpuLabel" Text="GPU" VerticalAlignment="Center"
                                       FontFamily="{StaticResource OptiUiFontSemiBold}" FontSize="13"
                                       Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <TextBlock Grid.Row="2"
                           x:Name="SidebarHint"
                           Text="Collapse for more space"
                           FontSize="10"
                           Opacity="0.45"
                           Margin="8,10,8,2"
                           Foreground="{ThemeResource OptiPrimaryTextBrush}"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <!-- Main pane -->
        <Grid Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel x:Name="HeroPanel"
                        Spacing="4"
                        Margin="0,2,0,16"
                        Opacity="0"
                        RenderTransformOrigin="0,0.5">
                <StackPanel.RenderTransform>
                    <CompositeTransform x:Name="HeroTransform" TranslateY="12" />
                </StackPanel.RenderTransform>
                <TextBlock Text="{x:Bind ViewModel.SectionTitle, Mode=OneWay}"
                           Style="{StaticResource OptiTagline}"
                           FontSize="28"
                           LineHeight="34"
                           TextAlignment="Left"
                           HorizontalAlignment="Left" />
                <TextBlock Text="{x:Bind ViewModel.SectionCaption, Mode=OneWay}"
                           Style="{StaticResource OptiTaglineSupport}"
                           FontSize="13"
                           Opacity="0.85"
                           TextAlignment="Left"
                           HorizontalAlignment="Left" />
            </StackPanel>

            <!-- HOME -->
            <ScrollViewer Grid.Row="1"
                          x:Name="HomePane"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{x:Bind ViewModel.IsHome, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Spacing="14">
                    <ContentControl Style="{StaticResource OptiCard}" Padding="20,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Bind ViewModel.GreetingLine, Mode=OneWay}"
                                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                                <TextBlock Text="{x:Bind ViewModel.MachineLine, Mode=OneWay}"
                                           FontSize="12.5"
                                           Opacity="0.8"
                                           TextWrapping="Wrap"
                                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                                <TextBlock Text="{x:Bind ViewModel.StatusFooter, Mode=OneWay}"
                                           FontSize="11.5"
                                           Opacity="0.55"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Style="{StaticResource OptiQuietButton}"
                                    Content="Refresh"
                                    MinHeight="36"
                                    Padding="14,8"
                                    VerticalAlignment="Top"
                                    Click="RefreshStats_Click"
                                    IsEnabled="{x:Bind ViewModel.IsLoadingStats, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                        </Grid>
                    </ContentControl>

                    <Grid>
                        <ProgressRing Width="28" Height="28"
                                      IsActive="{x:Bind ViewModel.IsLoadingStats, Mode=OneWay}"
                                      Visibility="{x:Bind ViewModel.IsLoadingStats, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                      HorizontalAlignment="Center"
                                      Margin="0,40,0,0" />
                        <ItemsControl x:Name="StatList"
                                      ItemsSource="{x:Bind ViewModel.StatTiles, Mode=OneWay}"
                                      Visibility="{x:Bind ViewModel.IsLoadingStats, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal"
                                                   MaximumRowsOrColumns="4"
                                                   HorizontalAlignment="Left" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:HomeStatTileViewModel">
                                    <ContentControl Style="{StaticResource OptiCard}"
                                                    Width="210"
                                                    MinHeight="112"
                                                    Margin="0,0,12,12"
                                                    Padding="14,12">
                                        <StackPanel Spacing="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind Label}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           CharacterSpacing="40"
                                                           Opacity="0.55"
                                                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                                                <Border Grid.Column="1"
                                                        Width="28" Height="28"
                                                        CornerRadius="8"
                                                        Background="{ThemeResource OptiIconWellFillBrush}"
                                                        BorderBrush="{ThemeResource OptiIconWellStrokeBrush}"
                                                        BorderThickness="1">
                                                    <FontIcon Glyph="{x:Bind Glyph}"
                                                              FontSize="12"
                                                              Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{x:Bind Value}"
                                                       FontFamily="{StaticResource OptiUiFontSemiBold}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                                            <TextBlock Text="{x:Bind Detail}"
                                                       FontSize="11.5"
                                                       Opacity="0.7"
                                                       TextWrapping="Wrap"
                                                       Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                                            <ProgressBar Maximum="100"
                                                         Value="{x:Bind BarValue}"
                                                         Height="4"
                                                         Visibility="{x:Bind ShowBar, Converter={StaticResource BoolToVisibilityConverter}}"
                                                         Foreground="{ThemeResource OptiAccentBrush}"
                                                         Background="{ThemeResource OptiAccentSoftBrush}" />
                                        </StackPanel>
                                    </ContentControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <StackPanel Spacing="8" Margin="0,4,0,0">
                        <TextBlock Text="QUICK OPEN"
                                   FontFamily="{StaticResource OptiUiFontSemiBold}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   CharacterSpacing="100"
                                   Opacity="0.5"
                                   Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Style="{StaticResource OptiQuietButton}"
                                    Content="Internet"
                                    MinHeight="36"
                                    Padding="14,8"
                                    Click="QuickInternet_Click" />
                            <Button Style="{StaticResource OptiQuietButton}"
                                    Content="NVIDIA"
                                    MinHeight="36"
                                    Padding="14,8"
                                    Click="QuickNvidia_Click" />
                            <Button Style="{StaticResource OptiQuietButton}"
                                    Content="Discord"
                                    MinHeight="36"
                                    Padding="14,8"
                                    Click="QuickDiscord_Click" />
                            <Button Style="{StaticResource OptiQuietButton}"
                                    Content="Steam"
                                    MinHeight="36"
                                    Padding="14,8"
                                    Click="QuickSteam_Click" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- SECTION CARDS -->
            <Grid Grid.Row="1"
                  x:Name="CardsPane"
                  Visibility="{x:Bind ViewModel.IsHome, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <ItemsControl x:Name="CardList"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Top"
                              ItemsSource="{x:Bind ViewModel.Cards, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal"
                                           MaximumRowsOrColumns="3"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Top" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:OptimizerCardViewModel">
                            <Button Style="{StaticResource OptiCardButton}"
                                    Width="268"
                                    Height="168"
                                    Margin="0,0,12,12"
                                    Click="CardButton_Click"
                                    Tag="{x:Bind Definition.Id}"
                                    AutomationProperties.Name="{x:Bind Definition.Title}"
                                    IsEnabled="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                    Opacity="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToOpacityConverter}}">
                                <ContentControl Style="{StaticResource OptiCard}"
                                                Width="268"
                                                Height="168"
                                                Padding="16,14">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Border Style="{StaticResource OptiLogoWell}"
                                                Width="64" Height="64"
                                                CornerRadius="18"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Padding="10">
                                            <Image Source="{x:Bind Definition.LogoPath, Mode=OneWay, Converter={StaticResource AssetPathToImageSourceConverter}}"
                                                   Stretch="Uniform"
                                                   AutomationProperties.AccessibilityView="Raw" />
                                        </Border>
                                        <StackPanel Grid.Row="1" Spacing="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind Definition.Title}"
                                                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                                                           FontWeight="SemiBold"
                                                           FontSize="15"
                                                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="Soon"
                                                           FontSize="11"
                                                           Opacity="0.7"
                                                           Visibility="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                                            </Grid>
                                            <TextBlock Text="{x:Bind Caption}"
                                                       FontSize="12"
                                                       Opacity="0.7"
                                                       TextWrapping="Wrap"
                                                       MaxLines="2"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </ContentControl>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Grid>
    </Grid>
</Page>
