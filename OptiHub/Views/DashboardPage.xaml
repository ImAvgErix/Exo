<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:OptiHub.ViewModels"
    Background="Transparent"
    SizeChanged="Page_SizeChanged">

    <!-- Scroll so cards never clip at short/narrow window sizes -->
    <ScrollViewer x:Name="PageScroll"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  ZoomMode="Disabled">
        <Grid x:Name="PageRoot"
              Padding="40,28,40,32"
              Loaded="PageRoot_Loaded">
            <Grid x:Name="ContentHost"
                  MaxWidth="1000"
                  HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel x:Name="HeroPanel"
                            Spacing="8"
                            Margin="0,0,0,22"
                            HorizontalAlignment="Center"
                            Opacity="0"
                            RenderTransformOrigin="0.5,0.5">
                    <StackPanel.RenderTransform>
                        <CompositeTransform x:Name="HeroTransform" TranslateY="12" />
                    </StackPanel.RenderTransform>
                    <TextBlock x:Name="HeroTitle"
                               Text="Maximum performance. No compromise."
                               Style="{StaticResource OptiTagline}"
                               FontSize="34"
                               LineHeight="42"
                               TextWrapping="WrapWholeWords"
                               TextAlignment="Center"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Pick a target to open it."
                               Style="{StaticResource OptiTaglineSupport}"
                               FontSize="14"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <ItemsControl x:Name="CardList"
                              Grid.Row="1"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Top"
                              ItemsSource="{x:Bind ViewModel.Cards, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid x:Name="CardWrap"
                                           Orientation="Horizontal"
                                           MaximumRowsOrColumns="3"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:OptimizerCardViewModel">
                            <Button x:Name="CardBtn"
                                    Style="{StaticResource OptiCardButton}"
                                    Width="280"
                                    Height="168"
                                    Margin="8"
                                    Click="CardButton_Click"
                                    Tag="{x:Bind Definition.Id}"
                                    AutomationProperties.Name="{x:Bind Definition.Title}"
                                    IsEnabled="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                    Opacity="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToOpacityConverter}}">
                                <Border Style="{StaticResource OptiCard}"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Padding="16,14">
                                    <Grid>
                                        <Image Width="68"
                                               Height="68"
                                               Source="{x:Bind Definition.LogoPath, Mode=OneWay, Converter={StaticResource AssetPathToImageSourceConverter}}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Stretch="Uniform"
                                               AutomationProperties.AccessibilityView="Raw" />
                                        <TextBlock Text="Coming soon"
                                                   FontFamily="{StaticResource OptiUiFont}"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource OptiMutedTextBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Bottom"
                                                   Margin="0,0,0,4"
                                                   Visibility="{x:Bind IsComingSoon, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
