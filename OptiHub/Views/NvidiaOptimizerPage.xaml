<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.NvidiaOptimizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:OptiHub.ViewModels"
    Background="Transparent">

    <Grid Padding="{StaticResource OptiPagePadding}">
        <Grid MaxWidth="{StaticResource OptiPageMaxWidth}"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{ThemeResource OptiSurfaceBrush}"
                    BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="22,18">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{ThemeResource OptiRailBrush}" CornerRadius="2" />
                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock Text="NVIDIA" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                        <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" Style="{StaticResource OptiPageTitle}" />
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ToggleSwitch Header="G-SYNC"
                                          IsOn="{x:Bind ViewModel.UseGsync, Mode=TwoWay}"
                                          OnContent="On" OffContent="Off"
                                          IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                          AutomationProperties.Name="G-SYNC" />
                            <Button Grid.Column="1" Style="{StaticResource OptiQuietButton}" Content="Display panel"
                                    Click="Panel_Click" MinWidth="140" VerticalAlignment="Bottom"
                                    IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                    AutomationProperties.Name="Open NVIDIA Panel" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <ProgressRing Width="28" Height="28"
                              IsActive="{x:Bind ViewModel.IsStatusLoading, Mode=OneWay}"
                              Visibility="{x:Bind ViewModel.IsStatusLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{x:Bind ViewModel.IsStatusLoading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Features, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MaximumRowsOrColumns="2" Orientation="Horizontal"
                                               MinItemWidth="260" MinColumnSpacing="12" MinRowSpacing="12" ItemsStretch="Fill" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:FeatureRowViewModel">
                                <Border Style="{StaticResource OptiFeatureTile}" Opacity="{x:Bind Opacity}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Background="{ThemeResource OptiRailBrush}" CornerRadius="8,0,0,8" Opacity="0.85" />
                                        <Grid Grid.Column="1" ColumnSpacing="12" Padding="14,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Style="{StaticResource OptiIconWell}">
                                                <FontIcon Glyph="{x:Bind Glyph}" FontSize="14"
                                                          Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Title}" Style="{StaticResource OptiFeatureTitle}" />
                                                <TextBlock Text="{x:Bind Detail}" Style="{StaticResource OptiFeatureDetail}" />
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
            </Grid>

            <StackPanel Grid.Row="2" Spacing="12">
                <Border Style="{StaticResource OptiMessageBanner}"
                        Visibility="{x:Bind ViewModel.HasLastResult, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="{x:Bind ViewModel.LastResultGlyph, Mode=OneWay}" FontSize="15"
                                  Foreground="{x:Bind ViewModel.LastResultBrush, Mode=OneWay}" VerticalAlignment="Top" />
                        <TextBlock Text="{x:Bind ViewModel.LastResult, Mode=OneWay}" Grid.Column="1"
                                   Style="{StaticResource OptiBody}" FontSize="12.5" TextWrapping="Wrap" />
                    </Grid>
                </Border>
                <StackPanel Spacing="6"
                            Visibility="{x:Bind ViewModel.IsProgressVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ProgressBar Minimum="0" Maximum="100" Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                                 Height="6" CornerRadius="2" Foreground="{ThemeResource OptiAccentBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.ProgressStatus, Mode=OneWay}" Style="{StaticResource OptiCaption}" TextAlignment="Center" />
                </StackPanel>
                <Button Style="{StaticResource OptiPrimaryButton}" Content="{x:Bind ViewModel.RunButtonLabel, Mode=OneWay}"
                        Click="Run_Click" HorizontalAlignment="Stretch"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                        AutomationProperties.Name="Apply NVIDIA" />
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Style="{StaticResource OptiQuietButton}" Content="Reset" Click="Repair_Click"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                    <Button Grid.Column="1" Style="{StaticResource OptiQuietButton}" Content="Refresh" Click="Refresh_Click"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
