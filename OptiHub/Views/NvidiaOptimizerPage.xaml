<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OptiHub.Views.NvidiaOptimizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:OptiHub.ViewModels"
    Background="Transparent">

    <Grid Padding="{StaticResource OptiPagePadding}">
        <ContentControl Style="{StaticResource OptiCard}"
                        Padding="28,26"
                        MaxWidth="{StaticResource OptiPageMaxWidth}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,18">
                    <TextBlock Text="NVIDIA" Style="{StaticResource OptiSectionTitle}" Margin="0" />
                    <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                               Style="{StaticResource OptiPageTitle}" />
                    <Grid ColumnSpacing="12" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ToggleSwitch Header="G-SYNC"
                                      IsOn="{x:Bind ViewModel.UseGsync, Mode=TwoWay}"
                                      OnContent="On"
                                      OffContent="Off"
                                      IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                      ToolTipService.ToolTip="G-SYNC / Adaptive Sync only"
                                      AutomationProperties.Name="G-SYNC" />
                        <Button Grid.Column="1"
                                Style="{StaticResource OptiQuietButton}"
                                Content="NVIDIA Panel"
                                Click="Panel_Click"
                                VerticalAlignment="Bottom"
                                MinWidth="140"
                                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                AutomationProperties.Name="Open NVIDIA Panel" />
                    </Grid>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,0,0,18">
                    <ProgressRing Width="28" Height="28"
                                  IsActive="{x:Bind ViewModel.IsStatusLoading, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.IsStatusLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{x:Bind ViewModel.IsStatusLoading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.Features, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <UniformGridLayout MaximumRowsOrColumns="2"
                                                   Orientation="Horizontal"
                                                   MinItemWidth="240"
                                                   MinColumnSpacing="10"
                                                   MinRowSpacing="10"
                                                   ItemsStretch="Fill" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:FeatureRowViewModel">
                                    <Border Style="{StaticResource OptiFeatureTile}"
                                            Opacity="{x:Bind Opacity}">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Style="{StaticResource OptiIconWell}">
                                                <FontIcon Glyph="{x:Bind Glyph}"
                                                          FontSize="14"
                                                          Foreground="{ThemeResource OptiPrimaryTextBrush}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Title}" Style="{StaticResource OptiFeatureTitle}" />
                                                <TextBlock Text="{x:Bind Detail}" Style="{StaticResource OptiFeatureDetail}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </Grid>

                <StackPanel Grid.Row="2" Spacing="12">
                    <Border Style="{StaticResource OptiMessageBanner}"
                            Visibility="{x:Bind ViewModel.HasLastResult, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="{x:Bind ViewModel.LastResultGlyph, Mode=OneWay}"
                                      FontSize="15"
                                      Foreground="{x:Bind ViewModel.LastResultBrush, Mode=OneWay}"
                                      VerticalAlignment="Top" />
                            <TextBlock Text="{x:Bind ViewModel.LastResult, Mode=OneWay}"
                                       Grid.Column="1"
                                       Style="{StaticResource OptiBody}"
                                       FontSize="12.5"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </Border>

                    <StackPanel Spacing="6"
                                Visibility="{x:Bind ViewModel.IsProgressVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ProgressBar Minimum="0" Maximum="100"
                                     Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                                     Height="6"
                                     CornerRadius="3"
                                     Foreground="{ThemeResource OptiAccentBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.ProgressStatus, Mode=OneWay}"
                                   Style="{StaticResource OptiCaption}"
                                   TextAlignment="Center" />
                    </StackPanel>

                    <Button Style="{StaticResource OptiPrimaryButton}"
                            Content="{x:Bind ViewModel.RunButtonLabel, Mode=OneWay}"
                            Click="Run_Click"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                            AutomationProperties.Name="Apply NVIDIA" />
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Style="{StaticResource OptiQuietButton}"
                                Content="Reset"
                                Click="Repair_Click"
                                HorizontalAlignment="Stretch"
                                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                        <Button Grid.Column="1"
                                Style="{StaticResource OptiQuietButton}"
                                Content="Refresh"
                                Click="Refresh_Click"
                                HorizontalAlignment="Stretch"
                                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                    </Grid>
                </StackPanel>
            </Grid>
        </ContentControl>
    </Grid>
</Page>
