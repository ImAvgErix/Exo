<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OptiHub.Views.Controls.OptiLoader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="48"
    Height="48">

    <!--
      Premium loader (Kinetics-inspired):
      soft ring + orbiting bead + elastic core breath.
    -->
    <Grid x:Name="Root"
          Width="48"
          Height="48"
          HorizontalAlignment="Center"
          VerticalAlignment="Center">

        <Ellipse x:Name="Halo"
                 Width="44"
                 Height="44"
                 Fill="{ThemeResource OptiAccentBrush}"
                 Opacity="0.1"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 IsHitTestVisible="False"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="HaloScale" ScaleX="1" ScaleY="1" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <Ellipse Width="34"
                 Height="34"
                 Stroke="{ThemeResource OptiCardStrokeBrush}"
                 StrokeThickness="1.5"
                 Opacity="0.55"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 IsHitTestVisible="False" />

        <!-- Arc sweep (elastic progress feel) -->
        <Ellipse x:Name="Sweep"
                 Width="34"
                 Height="34"
                 Stroke="{ThemeResource OptiAccentBrush}"
                 StrokeThickness="2.5"
                 StrokeDashArray="1.2 6"
                 Opacity="0.95"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 IsHitTestVisible="False"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <RotateTransform x:Name="SweepRotate" Angle="0" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <Grid x:Name="Orbit"
              Width="34"
              Height="34"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5"
              IsHitTestVisible="False">
            <Grid.RenderTransform>
                <RotateTransform x:Name="OrbitRotate" Angle="0" />
            </Grid.RenderTransform>
            <Ellipse Width="7"
                     Height="7"
                     Fill="{ThemeResource OptiAccentBrush}"
                     VerticalAlignment="Top"
                     HorizontalAlignment="Center"
                     Margin="0,-2,0,0" />
        </Grid>

        <Grid x:Name="TrailOrbit"
              Width="34"
              Height="34"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5"
              IsHitTestVisible="False">
            <Grid.RenderTransform>
                <RotateTransform x:Name="TrailRotate" Angle="-40" />
            </Grid.RenderTransform>
            <Ellipse Width="5"
                     Height="5"
                     Fill="{ThemeResource OptiAccentBrush}"
                     VerticalAlignment="Top"
                     HorizontalAlignment="Center"
                     Margin="0,-1,0,0"
                     Opacity="0.4" />
        </Grid>

        <Grid x:Name="GhostOrbit"
              Width="34"
              Height="34"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5"
              IsHitTestVisible="False">
            <Grid.RenderTransform>
                <RotateTransform x:Name="GhostRotate" Angle="-78" />
            </Grid.RenderTransform>
            <Ellipse Width="3.5"
                     Height="3.5"
                     Fill="{ThemeResource OptiAccentBrush}"
                     VerticalAlignment="Top"
                     HorizontalAlignment="Center"
                     Opacity="0.2" />
        </Grid>

        <Ellipse x:Name="Core"
                 Width="9"
                 Height="9"
                 Fill="{ThemeResource OptiAccentBrush}"
                 Opacity="0.95"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 IsHitTestVisible="False"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="CoreScale" ScaleX="1" ScaleY="1" />
            </Ellipse.RenderTransform>
        </Ellipse>
    </Grid>
</UserControl>
