<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OptiHub.Views.Controls.OptiLoader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="40"
    Height="40">

    <!--
      Unique loader: three soft “ticks” orbit a common center with staggered
      opacity (not the stock ProgressRing). Accent color from theme.
    -->
    <Grid x:Name="Root"
          Width="40"
          Height="40"
          HorizontalAlignment="Center"
          VerticalAlignment="Center">

        <!-- Outer faint ring -->
        <Ellipse Width="36"
                 Height="36"
                 Stroke="{ThemeResource OptiCardStrokeBrush}"
                 StrokeThickness="1.5"
                 Opacity="0.55" />

        <!-- Rotating triad -->
        <Grid x:Name="Orbit"
              Width="40"
              Height="40"
              RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <RotateTransform x:Name="OrbitRotate" Angle="0" />
            </Grid.RenderTransform>

            <!-- Dot A — top -->
            <Ellipse x:Name="DotA"
                     Width="7" Height="7"
                     Fill="{ThemeResource OptiAccentBrush}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Top"
                     Margin="0,1,0,0"
                     Opacity="1" />

            <!-- Dot B — bottom-right (rotated layout via nested rotate) -->
            <Grid Width="40" Height="40" RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <RotateTransform Angle="120" />
                </Grid.RenderTransform>
                <Ellipse x:Name="DotB"
                         Width="7" Height="7"
                         Fill="{ThemeResource OptiAccentBrush}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Top"
                         Margin="0,1,0,0"
                         Opacity="0.55" />
            </Grid>

            <!-- Dot C — bottom-left -->
            <Grid Width="40" Height="40" RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <RotateTransform Angle="240" />
                </Grid.RenderTransform>
                <Ellipse x:Name="DotC"
                         Width="7" Height="7"
                         Fill="{ThemeResource OptiAccentBrush}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Top"
                         Margin="0,1,0,0"
                         Opacity="0.28" />
            </Grid>
        </Grid>

        <!-- Center micro-pulse -->
        <Ellipse x:Name="Core"
                 Width="5" Height="5"
                 Fill="{ThemeResource OptiAccentBrush}"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Opacity="0.35" />
    </Grid>
</UserControl>
