<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OptiHub.Views.Controls.OptiLoader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="44"
    Height="44">

    <!--
      OptiLoader — "orbit bead" (unique brand loader).
      Soft track ring + accent bead orbiting with a trailing ghost;
      core breathes. Not a ProgressRing, triad, or bar meter.
    -->
    <Grid x:Name="Root"
          Width="44"
          Height="44"
          HorizontalAlignment="Center"
          VerticalAlignment="Center">

        <!-- Soft outer halo (pulses) -->
        <Ellipse x:Name="Halo"
                 Width="40"
                 Height="40"
                 Fill="{ThemeResource OptiAccentBrush}"
                 Opacity="0.08"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 IsHitTestVisible="False"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="HaloScale" ScaleX="1" ScaleY="1" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Track ring -->
        <Ellipse Width="32"
                 Height="32"
                 Stroke="{ThemeResource OptiCardStrokeBrush}"
                 StrokeThickness="1.5"
                 Opacity="0.55"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 IsHitTestVisible="False" />

        <!-- Orbit host: bead + ghost sit at top, whole host rotates -->
        <Grid x:Name="Orbit"
              Width="32"
              Height="32"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5"
              IsHitTestVisible="False">
            <Grid.RenderTransform>
                <RotateTransform x:Name="OrbitRotate" Angle="0" />
            </Grid.RenderTransform>

            <!-- Lead bead (top of orbit) -->
            <Ellipse Width="7"
                     Height="7"
                     Fill="{ThemeResource OptiAccentBrush}"
                     VerticalAlignment="Top"
                     HorizontalAlignment="Center"
                     Margin="0,-2,0,0"
                     Opacity="1" />

            <!-- Ghost trail (offset angularly via second host) -->
        </Grid>

        <!-- Trail orbit (same size, phase-offset rotation) -->
        <Grid x:Name="TrailOrbit"
              Width="32"
              Height="32"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5"
              IsHitTestVisible="False">
            <Grid.RenderTransform>
                <RotateTransform x:Name="TrailRotate" Angle="0" />
            </Grid.RenderTransform>
            <Ellipse Width="5"
                     Height="5"
                     Fill="{ThemeResource OptiAccentBrush}"
                     VerticalAlignment="Top"
                     HorizontalAlignment="Center"
                     Margin="0,-1,0,0"
                     Opacity="0.4" />
        </Grid>

        <!-- Second softer ghost -->
        <Grid x:Name="GhostOrbit"
              Width="32"
              Height="32"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5"
              IsHitTestVisible="False">
            <Grid.RenderTransform>
                <RotateTransform x:Name="GhostRotate" Angle="0" />
            </Grid.RenderTransform>
            <Ellipse Width="3.5"
                     Height="3.5"
                     Fill="{ThemeResource OptiAccentBrush}"
                     VerticalAlignment="Top"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,0"
                     Opacity="0.22" />
        </Grid>

        <!-- Breathing core -->
        <Ellipse x:Name="Core"
                 Width="9"
                 Height="9"
                 Fill="{ThemeResource OptiAccentBrush}"
                 Opacity="0.9"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 IsHitTestVisible="False"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="CoreScale" ScaleX="1" ScaleY="1" />
            </Ellipse.RenderTransform>
        </Ellipse>
    </Grid>
</UserControl>
