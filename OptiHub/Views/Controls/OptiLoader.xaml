<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OptiHub.Views.Controls.OptiLoader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="52"
    Height="40">

    <!--
      OptiLoader — performance “signal” meter (not a ProgressRing).
      Four soft bars rise/fall out of phase; a thin scan tick sweeps across.
    -->
    <Grid x:Name="Root"
          Width="52"
          Height="40"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          ClipToBounds="True">

        <!-- Soft plate -->
        <Border Width="48"
                Height="36"
                CornerRadius="10"
                Background="{ThemeResource OptiCardFillBrush}"
                BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />

        <!-- Scan sweep (highlight bar that travels left → right) -->
        <Border x:Name="Scan"
                Width="10"
                Height="28"
                CornerRadius="5"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Margin="6,0,0,0"
                Opacity="0.14"
                IsHitTestVisible="False">
            <Border.Background>
                <SolidColorBrush Color="{ThemeResource SystemAccentColor}" />
            </Border.Background>
            <Border.RenderTransform>
                <TranslateTransform x:Name="ScanX" X="0" />
            </Border.RenderTransform>
        </Border>

        <!-- Four phase-shifted bars -->
        <StackPanel Orientation="Horizontal"
                    Spacing="5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Height="28">
            <Border x:Name="Bar0"
                    Width="5"
                    Height="8"
                    CornerRadius="2.5"
                    VerticalAlignment="Bottom"
                    Background="{ThemeResource OptiAccentBrush}"
                    Opacity="0.95"
                    RenderTransformOrigin="0.5,1">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="Bar0Scale" ScaleY="1" />
                </Border.RenderTransform>
            </Border>
            <Border x:Name="Bar1"
                    Width="5"
                    Height="8"
                    CornerRadius="2.5"
                    VerticalAlignment="Bottom"
                    Background="{ThemeResource OptiAccentBrush}"
                    Opacity="0.8"
                    RenderTransformOrigin="0.5,1">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="Bar1Scale" ScaleY="1" />
                </Border.RenderTransform>
            </Border>
            <Border x:Name="Bar2"
                    Width="5"
                    Height="8"
                    CornerRadius="2.5"
                    VerticalAlignment="Bottom"
                    Background="{ThemeResource OptiAccentBrush}"
                    Opacity="0.65"
                    RenderTransformOrigin="0.5,1">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="Bar2Scale" ScaleY="1" />
                </Border.RenderTransform>
            </Border>
            <Border x:Name="Bar3"
                    Width="5"
                    Height="8"
                    CornerRadius="2.5"
                    VerticalAlignment="Bottom"
                    Background="{ThemeResource OptiAccentBrush}"
                    Opacity="0.5"
                    RenderTransformOrigin="0.5,1">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="Bar3Scale" ScaleY="1" />
                </Border.RenderTransform>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
