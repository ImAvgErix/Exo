<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OptiHub.Views.Controls.SettingsSheet"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="UserControl_Loaded">

    <!--
      Same product language as home: centered hero + OptiCard tiles.
      Hosted in MainWindow overlay over the blurred dashboard.
    -->
    <Grid MaxWidth="720" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Hero — same family as home tagline -->
        <Grid Margin="0,0,0,16">
            <StackPanel HorizontalAlignment="Center" Spacing="0">
                <TextBlock Text="Settings"
                           Style="{StaticResource OptiTagline}"
                           FontSize="36"
                           LineHeight="42"
                           CharacterSpacing="-16"
                           TextAlignment="Center"
                           HorizontalAlignment="Center" />
            </StackPanel>
            <Button x:Name="CloseButton"
                    Style="{StaticResource OptiIconButton}"
                    AutomationProperties.Name="Close settings"
                    Width="36" Height="36"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,-4,-4,0"
                    Click="CloseButton_Click">
                <FontIcon Glyph="&#xE711;" FontSize="12" />
            </Button>
        </Grid>

        <!-- 2×2 product cards — same OptiCard chrome as home tiles -->
        <Grid Grid.Row="1" ColumnSpacing="12" RowSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="180" />
                <RowDefinition Height="180" />
            </Grid.RowDefinitions>

            <!-- Appearance -->
            <Border Grid.Row="0" Grid.Column="0"
                    Style="{StaticResource OptiCard}"
                    Padding="18"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Appearance"
                               FontFamily="{StaticResource OptiUiFontSemiBold}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               CharacterSpacing="40"
                               Foreground="{ThemeResource OptiMutedTextBrush}" />
                    <Border Grid.Row="1"
                            Background="{ThemeResource OptiPageBackgroundBrush}"
                            BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="4"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="2">
                            <RadioButton Content="Dark"
                                         GroupName="ThemeChoiceOverlay"
                                         Style="{StaticResource OptiThemeRadio}"
                                         AutomationProperties.Name="Use dark theme"
                                         IsChecked="{x:Bind ViewModel.IsDarkMode, Mode=TwoWay}" />
                            <RadioButton Content="Light"
                                         GroupName="ThemeChoiceOverlay"
                                         Style="{StaticResource OptiThemeRadio}"
                                         AutomationProperties.Name="Use light theme"
                                         IsChecked="{x:Bind ViewModel.IsLightMode, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Updates -->
            <Border Grid.Row="0" Grid.Column="1"
                    Style="{StaticResource OptiCard}"
                    Padding="18"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Updates"
                                   FontFamily="{StaticResource OptiUiFontSemiBold}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   CharacterSpacing="40"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource OptiMutedTextBrush}" />
                        <ToggleSwitch Grid.Column="1"
                                      AutomationProperties.Name="Check for OptiHub app updates automatically"
                                      IsOn="{x:Bind ViewModel.AutoUpdateScripts, Mode=TwoWay}"
                                      OnContent=""
                                      OffContent=""
                                      MinWidth="0"
                                      VerticalAlignment="Center" />
                    </Grid>

                    <Button Grid.Row="1"
                            Style="{StaticResource OptiPrimaryButton}"
                            Content="Check for updates"
                            AutomationProperties.Name="Check for OptiHub app updates"
                            Command="{x:Bind ViewModel.CheckForUpdatesCommand}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            MinHeight="40"
                            IsEnabled="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />

                    <StackPanel Grid.Row="2"
                                Spacing="6"
                                Margin="0,8,0,0"
                                Visibility="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <TextBlock Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}"
                                       Style="{StaticResource OptiCaption}"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1"
                                       Margin="0,0,40,0" />
                            <TextBlock Text="{x:Bind ViewModel.UpdateProgressLabel, Mode=OneWay}"
                                       FontFamily="{StaticResource OptiUiFontSemiBold}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right"
                                       Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                        </Grid>
                        <ProgressBar Minimum="0"
                                     Maximum="100"
                                     Value="{x:Bind ViewModel.UpdateProgressPercent, Mode=OneWay}"
                                     IsIndeterminate="{x:Bind ViewModel.IsUpdateProgressIndeterminate, Mode=OneWay}"
                                     Height="5"
                                     CornerRadius="3"
                                     Foreground="{ThemeResource OptiAccentBrush}" />
                    </StackPanel>

                    <TextBlock Grid.Row="2"
                               Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}"
                               Style="{StaticResource OptiCaption}"
                               FontSize="11"
                               Margin="0,8,0,0"
                               TextWrapping="WrapWholeWords"
                               MaxLines="2"
                               TextTrimming="CharacterEllipsis"
                               Visibility="{x:Bind ViewModel.ShowIdleUpdateStatus, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                               AutomationProperties.LiveSetting="Polite" />
                </Grid>
            </Border>

            <!-- About -->
            <Border Grid.Row="1" Grid.Column="0"
                    Style="{StaticResource OptiCard}"
                    Padding="18"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="About"
                               FontFamily="{StaticResource OptiUiFontSemiBold}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               CharacterSpacing="40"
                               Foreground="{ThemeResource OptiMutedTextBrush}" />
                    <StackPanel Grid.Row="1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                                   FontFamily="{StaticResource OptiUiFontSemiBold}"
                                   FontSize="36"
                                   FontWeight="SemiBold"
                                   CharacterSpacing="-28"
                                   HorizontalAlignment="Center"
                                   Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.KitVersion, Mode=OneWay}"
                                   Style="{StaticResource OptiCaption}"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Opacity="0.85" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Support -->
            <Border Grid.Row="1" Grid.Column="1"
                    Style="{StaticResource OptiCard}"
                    Padding="18"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Support"
                               FontFamily="{StaticResource OptiUiFontSemiBold}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               CharacterSpacing="40"
                               Foreground="{ThemeResource OptiMutedTextBrush}" />
                    <StackPanel Grid.Row="1"
                                VerticalAlignment="Center"
                                Spacing="10">
                        <Button Style="{StaticResource OptiWhiteButton}"
                                Content="Report issue"
                                AutomationProperties.Name="Report OptiHub issue on GitHub"
                                HorizontalAlignment="Stretch"
                                MinHeight="40"
                                Command="{x:Bind ViewModel.ReportIssueCommand}" />
                        <Button Style="{StaticResource OptiQuietButton}"
                                Content="Open logs"
                                AutomationProperties.Name="Open OptiHub logs folder"
                                HorizontalAlignment="Stretch"
                                MinHeight="40"
                                Command="{x:Bind ViewModel.OpenLogsFolderCommand}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
