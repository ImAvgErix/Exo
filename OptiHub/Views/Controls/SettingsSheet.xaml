<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OptiHub.Views.Controls.SettingsSheet"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="UserControl_Loaded">

    <!-- Modal sheet body (scrim lives on MainWindow) -->
    <Border MaxWidth="520"
            HorizontalAlignment="Stretch"
            Style="{StaticResource OptiCard}"
            Padding="0"
            Background="{ThemeResource OptiCardFillBrush}"
            BorderBrush="{ThemeResource OptiCardStrokeBrush}"
            BorderThickness="1"
            CornerRadius="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header + close -->
            <Grid Padding="22,18,14,14" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="Settings"
                               FontFamily="{StaticResource OptiUiFontSemiBold}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               CharacterSpacing="-12"
                               Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                    <TextBlock Text="Appearance, updates, and support"
                               Style="{StaticResource OptiCaption}"
                               FontSize="12"
                               Opacity="0.85" />
                </StackPanel>
                <Button x:Name="CloseButton"
                        Grid.Column="1"
                        Style="{StaticResource OptiIconButton}"
                        ToolTipService.ToolTip="Close"
                        AutomationProperties.Name="Close settings"
                        Width="36" Height="36"
                        Click="CloseButton_Click"
                        VerticalAlignment="Top">
                    <FontIcon Glyph="&#xE711;" FontSize="12" />
                </Button>
            </Grid>

            <StackPanel Grid.Row="1">
                <Rectangle Height="1" Fill="{ThemeResource OptiCardStrokeBrush}" Opacity="0.85" />

                <!-- Appearance -->
                <Grid Padding="22,16" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="Appearance"
                                   FontFamily="{StaticResource OptiUiFontSemiBold}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                        <TextBlock Text="Shell theme"
                                   Style="{StaticResource OptiCaption}"
                                   FontSize="12" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Background="{ThemeResource OptiPageBackgroundBrush}"
                            BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="3"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="2">
                            <RadioButton Content="Dark"
                                         GroupName="ThemeChoiceOverlay"
                                         Style="{StaticResource OptiThemeRadio}"
                                         ToolTipService.ToolTip="Dark shell"
                                         AutomationProperties.Name="Use dark theme"
                                         IsChecked="{x:Bind ViewModel.IsDarkMode, Mode=TwoWay}" />
                            <RadioButton Content="Light"
                                         GroupName="ThemeChoiceOverlay"
                                         Style="{StaticResource OptiThemeRadio}"
                                         ToolTipService.ToolTip="Light shell"
                                         AutomationProperties.Name="Use light theme"
                                         IsChecked="{x:Bind ViewModel.IsLightMode, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Rectangle Height="1" Fill="{ThemeResource OptiCardStrokeBrush}" Opacity="0.85" />

                <!-- Updates -->
                <StackPanel Padding="22,16" Spacing="12">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Updates"
                                       FontFamily="{StaticResource OptiUiFontSemiBold}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                            <TextBlock Text="Check GitHub on launch"
                                       Style="{StaticResource OptiCaption}"
                                       FontSize="12" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      ToolTipService.ToolTip="Check for OptiHub updates when the app starts"
                                      AutomationProperties.Name="Check for OptiHub app updates automatically"
                                      IsOn="{x:Bind ViewModel.AutoUpdateScripts, Mode=TwoWay}"
                                      OnContent=""
                                      OffContent=""
                                      MinWidth="0"
                                      VerticalAlignment="Center" />
                    </Grid>

                    <Button Style="{StaticResource OptiPrimaryButton}"
                            Content="Check for updates"
                            ToolTipService.ToolTip="Check GitHub for a newer OptiHub release"
                            AutomationProperties.Name="Check for OptiHub app updates"
                            Command="{x:Bind ViewModel.CheckForUpdatesCommand}"
                            HorizontalAlignment="Stretch"
                            MinHeight="42"
                            IsEnabled="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />

                    <StackPanel Spacing="8"
                                Visibility="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <TextBlock Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}"
                                       Style="{StaticResource OptiCaption}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1"
                                       Margin="0,0,48,0" />
                            <TextBlock Text="{x:Bind ViewModel.UpdateProgressLabel, Mode=OneWay}"
                                       FontFamily="{StaticResource OptiUiFontSemiBold}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                        </Grid>
                        <ProgressBar Minimum="0"
                                     Maximum="100"
                                     Value="{x:Bind ViewModel.UpdateProgressPercent, Mode=OneWay}"
                                     IsIndeterminate="{x:Bind ViewModel.IsUpdateProgressIndeterminate, Mode=OneWay}"
                                     Height="6"
                                     CornerRadius="3"
                                     Foreground="{ThemeResource OptiAccentBrush}" />
                    </StackPanel>

                    <TextBlock Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}"
                               Style="{StaticResource OptiCaption}"
                               FontSize="12"
                               TextWrapping="WrapWholeWords"
                               MaxLines="2"
                               TextTrimming="CharacterEllipsis"
                               Visibility="{x:Bind ViewModel.ShowIdleUpdateStatus, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                               AutomationProperties.LiveSetting="Polite" />
                </StackPanel>

                <Rectangle Height="1" Fill="{ThemeResource OptiCardStrokeBrush}" Opacity="0.85" />

                <!-- About -->
                <Grid Padding="22,16" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="About"
                                   FontFamily="{StaticResource OptiUiFontSemiBold}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                        <TextBlock Text="Installed build and optimizer kits"
                                   Style="{StaticResource OptiCaption}"
                                   FontSize="12" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Spacing="2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                                   FontFamily="{StaticResource OptiUiFontSemiBold}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   CharacterSpacing="-12"
                                   HorizontalAlignment="Right"
                                   Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.KitVersion, Mode=OneWay}"
                                   Style="{StaticResource OptiCaption}"
                                   FontSize="11"
                                   HorizontalAlignment="Right"
                                   Opacity="0.85" />
                    </StackPanel>
                </Grid>

                <Rectangle Height="1" Fill="{ThemeResource OptiCardStrokeBrush}" Opacity="0.85" />

                <!-- Support -->
                <StackPanel Padding="22,16,22,20" Spacing="12">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Support"
                                   FontFamily="{StaticResource OptiUiFontSemiBold}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                        <TextBlock Text="Issues and local logs"
                                   Style="{StaticResource OptiCaption}"
                                   FontSize="12" />
                    </StackPanel>
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Style="{StaticResource OptiWhiteButton}"
                                Content="Report issue"
                                ToolTipService.ToolTip="Open GitHub issues"
                                AutomationProperties.Name="Report OptiHub issue on GitHub"
                                HorizontalAlignment="Stretch"
                                MinHeight="40"
                                Command="{x:Bind ViewModel.ReportIssueCommand}" />
                        <Button Grid.Column="1"
                                Style="{StaticResource OptiQuietButton}"
                                Content="Open logs"
                                ToolTipService.ToolTip="Open OptiHub logs folder"
                                AutomationProperties.Name="Open OptiHub logs folder"
                                HorizontalAlignment="Stretch"
                                MinHeight="40"
                                Command="{x:Bind ViewModel.OpenLogsFolderCommand}" />
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
