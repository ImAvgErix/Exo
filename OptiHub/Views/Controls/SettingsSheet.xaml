<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OptiHub.Views.Controls.SettingsSheet"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="UserControl_Loaded">

    <!--
      Premium centered sheet. Host is never composition-Offset/Scaled —
      only row content staggers. Layout alignment keeps this card center-screen.
    -->
    <Border x:Name="SheetRoot"
            Width="400"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{ThemeResource OptiCardFillBrush}"
            BorderBrush="{ThemeResource OptiCardStrokeBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource OptiCardRadius}"
            Padding="22,18,22,20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Height="32" Margin="0,0,0,10">
                <Button x:Name="CloseButton"
                        Style="{StaticResource OptiIconButton}"
                        AutomationProperties.Name="Close settings"
                        Width="32" Height="32"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="CloseButton_Click">
                    <FontIcon Glyph="&#xE711;" FontSize="11" />
                </Button>
            </Grid>

            <StackPanel x:Name="RowsHost" Grid.Row="1" Spacing="0">

                <!-- Theme: current mode large + clear switch hint -->
                <StackPanel x:Name="RowAppearance" Spacing="10">
                    <TextBlock Text="Appearance"
                               FontFamily="{StaticResource OptiUiFontSemiBold}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                    <Button Style="{StaticResource OptiThemeToggleButton}"
                            AutomationProperties.Name="{x:Bind ViewModel.CurrentThemeLabel, Mode=OneWay}"
                            Command="{x:Bind ViewModel.ToggleThemeCommand}"
                            HorizontalAlignment="Stretch">
                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                            <TextBlock Text="{x:Bind ViewModel.CurrentThemeLabel, Mode=OneWay}"
                                       FontFamily="{StaticResource OptiUiFontSemiBold}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Foreground="{ThemeResource OptiThemeToggleTextBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.ThemeSwitchHint, Mode=OneWay}"
                                       FontFamily="{StaticResource OptiUiFont}"
                                       FontSize="12"
                                       Opacity="0.72"
                                       HorizontalAlignment="Center"
                                       Foreground="{ThemeResource OptiThemeToggleTextBrush}" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Rectangle x:Name="Div1" Height="1" Margin="0,16" Fill="{ThemeResource OptiCardStrokeBrush}" Opacity="0.7" />

                <!-- Live continuous control (not a binary toggle) -->
                <StackPanel x:Name="RowMotion" Spacing="10">
                    <Grid>
                        <TextBlock Text="Motion"
                                   FontFamily="{StaticResource OptiUiFontSemiBold}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.MotionIntensityLabel, Mode=OneWay}"
                                   FontFamily="{StaticResource OptiUiFontSemiBold}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource OptiSecondaryTextBrush}" />
                    </Grid>
                    <Slider x:Name="MotionSlider"
                            Style="{StaticResource OptiLiveSlider}"
                            Minimum="0"
                            Maximum="100"
                            StepFrequency="1"
                            SmallChange="1"
                            LargeChange="10"
                            TickFrequency="25"
                            TickPlacement="None"
                            IsThumbToolTipEnabled="False"
                            Value="{x:Bind ViewModel.MotionIntensity, Mode=TwoWay}"
                            AutomationProperties.Name="Motion intensity" />
                    <TextBlock Text="Entrance travel for home cards and sheets. Live — drag to feel it."
                               Style="{StaticResource OptiCaption}"
                               TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Rectangle x:Name="Div2" Height="1" Margin="0,16" Fill="{ThemeResource OptiCardStrokeBrush}" Opacity="0.7" />

                <!-- Updates -->
                <StackPanel x:Name="RowUpdates" Spacing="12">
                    <Grid>
                        <TextBlock Text="Updates"
                                   FontFamily="{StaticResource OptiUiFontSemiBold}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                        <ToggleSwitch Style="{StaticResource OptiCompactSwitch}"
                                      HorizontalAlignment="Right"
                                      AutomationProperties.Name="Check for updates on launch"
                                      IsOn="{x:Bind ViewModel.AutoUpdateScripts, Mode=TwoWay}"
                                      OnContent=""
                                      OffContent=""
                                      VerticalAlignment="Center" />
                    </Grid>
                    <Button Style="{StaticResource OptiPrimaryButton}"
                            Content="Check for updates"
                            AutomationProperties.Name="Check for OptiHub app updates"
                            Command="{x:Bind ViewModel.CheckForUpdatesCommand}"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                    <StackPanel Spacing="8"
                                Visibility="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{x:Bind ViewModel.UpdateProgressLabel, Mode=OneWay}"
                                   FontFamily="{StaticResource OptiUiFontSemiBold}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                        <ProgressBar Minimum="0"
                                     Maximum="100"
                                     Value="{x:Bind ViewModel.UpdateProgressPercent, Mode=OneWay}"
                                     IsIndeterminate="{x:Bind ViewModel.IsUpdateProgressIndeterminate, Mode=OneWay}"
                                     Height="4"
                                     CornerRadius="2"
                                     Foreground="{ThemeResource OptiAccentBrush}" />
                    </StackPanel>
                    <TextBlock Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}"
                               Style="{StaticResource OptiCaption}"
                               TextWrapping="WrapWholeWords"
                               MaxLines="2"
                               TextTrimming="CharacterEllipsis"
                               Visibility="{x:Bind ViewModel.ShowIdleUpdateStatus, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                               AutomationProperties.LiveSetting="Polite" />
                </StackPanel>

                <Rectangle x:Name="Div3" Height="1" Margin="0,16" Fill="{ThemeResource OptiCardStrokeBrush}" Opacity="0.7" />

                <Grid x:Name="RowVersion" MinHeight="36">
                    <TextBlock Text="App version"
                               FontFamily="{StaticResource OptiUiFontSemiBold}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                               FontFamily="{StaticResource OptiUiFontSemiBold}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               CharacterSpacing="-6"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                </Grid>

                <Rectangle x:Name="Div4" Height="1" Margin="0,16" Fill="{ThemeResource OptiCardStrokeBrush}" Opacity="0.7" />

                <!-- Secondary buttons: deliberate stroke → soft fill hover (Marcel craft) -->
                <StackPanel x:Name="RowSupport" Spacing="12">
                    <TextBlock Text="Support"
                               FontFamily="{StaticResource OptiUiFontSemiBold}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Style="{StaticResource OptiSecondaryButton}"
                                Content="Report issue"
                                AutomationProperties.Name="Report OptiHub issue on GitHub"
                                HorizontalAlignment="Stretch"
                                Command="{x:Bind ViewModel.ReportIssueCommand}" />
                        <Button Grid.Column="1"
                                Style="{StaticResource OptiQuietButton}"
                                Content="Open logs"
                                AutomationProperties.Name="Open OptiHub logs folder"
                                HorizontalAlignment="Stretch"
                                Command="{x:Bind ViewModel.OpenLogsFolderCommand}" />
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
