<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="OptiHub.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Styles/ThemeResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <!-- AMOLED pure black shell + near-black cards for OLED batteries / contrast -->
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="SystemAccentColor">#F5F5F4</Color>
                    <Color x:Key="SystemAccentColorLight1">#FAFAF9</Color>
                    <Color x:Key="SystemAccentColorLight2">#E7E5E4</Color>
                    <Color x:Key="SystemAccentColorLight3">#D6D3D1</Color>
                    <Color x:Key="SystemAccentColorDark1">#A8A29E</Color>
                    <Color x:Key="SystemAccentColorDark2">#78716C</Color>
                    <Color x:Key="SystemAccentColorDark3">#57534E</Color>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#F5F5F4" />
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#E7E5E4" />
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#D6D3D1" />
                    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#F5F5F4" />
                    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="#A8A29E" />
                    <SolidColorBrush x:Key="OptiPageBackgroundBrush" Color="#000000" />
                    <SolidColorBrush x:Key="OptiCardFillBrush" Color="#0A0A0A" />
                    <SolidColorBrush x:Key="OptiCardStrokeBrush" Color="#28FFFFFF" />
                    <SolidColorBrush x:Key="OptiAccentBrush" Color="#F5F5F4" />
                    <SolidColorBrush x:Key="OptiOnAccentBrush" Color="#000000" />
                    <SolidColorBrush x:Key="OptiAccentSoftBrush" Color="#14FFFFFF" />
                    <SolidColorBrush x:Key="OptiLogoWellFillBrush" Color="#14FFFFFF" />
                    <SolidColorBrush x:Key="OptiLogoWellStrokeBrush" Color="#40FFFFFF" />
                    <SolidColorBrush x:Key="OptiQuietButtonFillBrush" Color="#0A0A0A" />
                    <SolidColorBrush x:Key="OptiPrimaryTextBrush" Color="#FAFAF9" />
                    <SolidColorBrush x:Key="OptiSecondaryTextBrush" Color="#D6D3D1" />
                    <SolidColorBrush x:Key="OptiMutedTextBrush" Color="#A8A29E" />
                    <SolidColorBrush x:Key="OptiSuccessBrush" Color="#4ADE80" />
                    <SolidColorBrush x:Key="OptiWarningBrush" Color="#FBBF24" />
                    <SolidColorBrush x:Key="OptiWarningSoftBrush" Color="#22F59E0B" />
                    <SolidColorBrush x:Key="OptiErrorBrush" Color="#F87171" />
                    <!-- Theme control: pure black tile + white type so "Dark mode" is unmistakable -->
                    <SolidColorBrush x:Key="OptiThemeToggleFillBrush" Color="#0A0A0A" />
                    <SolidColorBrush x:Key="OptiThemeToggleTextBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="OptiThemeToggleStrokeBrush" Color="#55FFFFFF" />
                    <!-- Secondary button (Marcel): soft fill + deliberate stroke -->
                    <SolidColorBrush x:Key="OptiSecondaryButtonFillBrush" Color="#141414" />
                    <SolidColorBrush x:Key="OptiSecondaryButtonStrokeBrush" Color="#38FFFFFF" />
                    <SolidColorBrush x:Key="OptiSecondaryButtonSheenBrush" Color="#12FFFFFF" />
                </ResourceDictionary>
                <!-- Warm cream / beige light mode for easier long-session reading -->
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="SystemAccentColor">#3D3429</Color>
                    <Color x:Key="SystemAccentColorLight1">#4A4034</Color>
                    <Color x:Key="SystemAccentColorLight2">#5C5144</Color>
                    <Color x:Key="SystemAccentColorLight3">#6B5F50</Color>
                    <Color x:Key="SystemAccentColorDark1">#2A231C</Color>
                    <Color x:Key="SystemAccentColorDark2">#1C1712</Color>
                    <Color x:Key="SystemAccentColorDark3">#14100C</Color>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#3D3429" />
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#4A4034" />
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#5C5144" />
                    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#2A231C" />
                    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="#5C5144" />
                    <SolidColorBrush x:Key="OptiPageBackgroundBrush" Color="#F3EDE3" />
                    <SolidColorBrush x:Key="OptiCardFillBrush" Color="#FBF7F0" />
                    <SolidColorBrush x:Key="OptiCardStrokeBrush" Color="#663D3429" />
                    <SolidColorBrush x:Key="OptiAccentBrush" Color="#3D3429" />
                    <SolidColorBrush x:Key="OptiOnAccentBrush" Color="#FBF7F0" />
                    <SolidColorBrush x:Key="OptiAccentSoftBrush" Color="#1A3D3429" />
                    <SolidColorBrush x:Key="OptiLogoWellFillBrush" Color="#3D3429" />
                    <SolidColorBrush x:Key="OptiLogoWellStrokeBrush" Color="#FF2A231C" />
                    <SolidColorBrush x:Key="OptiQuietButtonFillBrush" Color="#FBF7F0" />
                    <SolidColorBrush x:Key="OptiPrimaryTextBrush" Color="#1C1712" />
                    <SolidColorBrush x:Key="OptiSecondaryTextBrush" Color="#3D3429" />
                    <SolidColorBrush x:Key="OptiMutedTextBrush" Color="#6B5F50" />
                    <SolidColorBrush x:Key="OptiSuccessBrush" Color="#15803D" />
                    <SolidColorBrush x:Key="OptiWarningBrush" Color="#B45309" />
                    <SolidColorBrush x:Key="OptiWarningSoftBrush" Color="#18B45309" />
                    <SolidColorBrush x:Key="OptiErrorBrush" Color="#B91C1C" />
                    <!-- Theme control: cream tile + dark type so "Light mode" is unmistakable -->
                    <SolidColorBrush x:Key="OptiThemeToggleFillBrush" Color="#FBF7F0" />
                    <SolidColorBrush x:Key="OptiThemeToggleTextBrush" Color="#1C1712" />
                    <SolidColorBrush x:Key="OptiThemeToggleStrokeBrush" Color="#993D3429" />
                    <SolidColorBrush x:Key="OptiSecondaryButtonFillBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="OptiSecondaryButtonStrokeBrush" Color="#333D3429" />
                    <SolidColorBrush x:Key="OptiSecondaryButtonSheenBrush" Color="#F7F7F7" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Default">
                    <Color x:Key="SystemAccentColor">#F5F5F4</Color>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#F5F5F4" />
                    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#F5F5F4" />
                    <SolidColorBrush x:Key="OptiPageBackgroundBrush" Color="#000000" />
                    <SolidColorBrush x:Key="OptiCardFillBrush" Color="#0A0A0A" />
                    <SolidColorBrush x:Key="OptiCardStrokeBrush" Color="#28FFFFFF" />
                    <SolidColorBrush x:Key="OptiAccentBrush" Color="#F5F5F4" />
                    <SolidColorBrush x:Key="OptiOnAccentBrush" Color="#000000" />
                    <SolidColorBrush x:Key="OptiAccentSoftBrush" Color="#14FFFFFF" />
                    <SolidColorBrush x:Key="OptiLogoWellFillBrush" Color="#14FFFFFF" />
                    <SolidColorBrush x:Key="OptiLogoWellStrokeBrush" Color="#40FFFFFF" />
                    <SolidColorBrush x:Key="OptiQuietButtonFillBrush" Color="#0A0A0A" />
                    <SolidColorBrush x:Key="OptiPrimaryTextBrush" Color="#FAFAF9" />
                    <SolidColorBrush x:Key="OptiSecondaryTextBrush" Color="#D6D3D1" />
                    <SolidColorBrush x:Key="OptiMutedTextBrush" Color="#A8A29E" />
                    <SolidColorBrush x:Key="OptiSuccessBrush" Color="#4ADE80" />
                    <SolidColorBrush x:Key="OptiWarningBrush" Color="#FBBF24" />
                    <SolidColorBrush x:Key="OptiWarningSoftBrush" Color="#22F59E0B" />
                    <SolidColorBrush x:Key="OptiErrorBrush" Color="#F87171" />
                    <SolidColorBrush x:Key="OptiThemeToggleFillBrush" Color="#0A0A0A" />
                    <SolidColorBrush x:Key="OptiThemeToggleTextBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="OptiThemeToggleStrokeBrush" Color="#55FFFFFF" />
                    <SolidColorBrush x:Key="OptiSecondaryButtonFillBrush" Color="#141414" />
                    <SolidColorBrush x:Key="OptiSecondaryButtonStrokeBrush" Color="#38FFFFFF" />
                    <SolidColorBrush x:Key="OptiSecondaryButtonSheenBrush" Color="#12FFFFFF" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
