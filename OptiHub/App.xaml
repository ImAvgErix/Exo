<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="OptiHub.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Styles/ThemeResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="SystemAccentColor">#FFFFFF</Color>
                    <Color x:Key="SystemAccentColorLight1">#FFFFFF</Color>
                    <Color x:Key="SystemAccentColorLight2">#E5E5E5</Color>
                    <Color x:Key="SystemAccentColorLight3">#CCCCCC</Color>
                    <Color x:Key="SystemAccentColorDark1">#B3B3B3</Color>
                    <Color x:Key="SystemAccentColorDark2">#808080</Color>
                    <Color x:Key="SystemAccentColorDark3">#666666</Color>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#E5E5E5" />
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#CCCCCC" />
                    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="#B3B3B3" />
                    <SolidColorBrush x:Key="OptiPageBackgroundBrush" Color="#000000" />
                    <SolidColorBrush x:Key="OptiCardFillBrush" Color="#121212" />
                    <SolidColorBrush x:Key="OptiCardStrokeBrush" Color="#22FFFFFF" />
                    <SolidColorBrush x:Key="OptiAccentBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="OptiOnAccentBrush" Color="#000000" />
                    <SolidColorBrush x:Key="OptiAccentSoftBrush" Color="#1AFFFFFF" />
                    <SolidColorBrush x:Key="OptiPrimaryTextBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="OptiSecondaryTextBrush" Color="#D1D1D1" />
                    <SolidColorBrush x:Key="OptiMutedTextBrush" Color="#9A9A9A" />
                    <SolidColorBrush x:Key="OptiSuccessBrush" Color="#22C55E" />
                    <SolidColorBrush x:Key="OptiErrorBrush" Color="#DC2626" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="SystemAccentColor">#111111</Color>
                    <Color x:Key="SystemAccentColorLight1">#333333</Color>
                    <Color x:Key="SystemAccentColorLight2">#555555</Color>
                    <Color x:Key="SystemAccentColorLight3">#777777</Color>
                    <Color x:Key="SystemAccentColorDark1">#000000</Color>
                    <Color x:Key="SystemAccentColorDark2">#000000</Color>
                    <Color x:Key="SystemAccentColorDark3">#000000</Color>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#111111" />
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#333333" />
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#555555" />
                    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#111111" />
                    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="#333333" />
                    <SolidColorBrush x:Key="OptiPageBackgroundBrush" Color="#F4F4F5" />
                    <SolidColorBrush x:Key="OptiCardFillBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="OptiCardStrokeBrush" Color="#1A000000" />
                    <SolidColorBrush x:Key="OptiAccentBrush" Color="#111111" />
                    <SolidColorBrush x:Key="OptiOnAccentBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="OptiAccentSoftBrush" Color="#0F000000" />
                    <SolidColorBrush x:Key="OptiPrimaryTextBrush" Color="#111111" />
                    <SolidColorBrush x:Key="OptiSecondaryTextBrush" Color="#3F3F46" />
                    <SolidColorBrush x:Key="OptiMutedTextBrush" Color="#71717A" />
                    <SolidColorBrush x:Key="OptiSuccessBrush" Color="#16A34A" />
                    <SolidColorBrush x:Key="OptiErrorBrush" Color="#DC2626" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Default">
                    <Color x:Key="SystemAccentColor">#FFFFFF</Color>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="OptiPageBackgroundBrush" Color="#000000" />
                    <SolidColorBrush x:Key="OptiCardFillBrush" Color="#121212" />
                    <SolidColorBrush x:Key="OptiCardStrokeBrush" Color="#22FFFFFF" />
                    <SolidColorBrush x:Key="OptiAccentBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="OptiOnAccentBrush" Color="#000000" />
                    <SolidColorBrush x:Key="OptiAccentSoftBrush" Color="#1AFFFFFF" />
                    <SolidColorBrush x:Key="OptiPrimaryTextBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="OptiSecondaryTextBrush" Color="#D1D1D1" />
                    <SolidColorBrush x:Key="OptiMutedTextBrush" Color="#9A9A9A" />
                    <SolidColorBrush x:Key="OptiSuccessBrush" Color="#22C55E" />
                    <SolidColorBrush x:Key="OptiErrorBrush" Color="#DC2626" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
