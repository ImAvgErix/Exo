<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="OptiHub.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Styles/ThemeResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Dark: pure AMOLED black surfaces -->
            <ResourceDictionary x:Key="Default">
                <SolidColorBrush x:Key="OptiPageBackgroundBrush" Color="#000000" />
                <SolidColorBrush x:Key="OptiCardFillBrush" Color="#0A0A0A" />
                <SolidColorBrush x:Key="OptiSubtleBrush" Color="#14FFFFFF" />
            </ResourceDictionary>
        </ResourceDictionary>
    </Application.Resources>
</Application>
