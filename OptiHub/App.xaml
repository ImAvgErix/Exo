<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="OptiHub.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Styles/ThemeResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <!-- Dark: pure black page, elevated charcoal cards, no outline strokes -->
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="SystemAccentColor">#F5F5F4</Color>
                    <Color x:Key="SystemAccentColorLight1">#FAFAF9</Color>
                    <Color x:Key="SystemAccentColorLight2">#E7E5E4</Color>
                    <Color x:Key="SystemAccentColorLight3">#D6D3D1</Color>
                    <Color x:Key="SystemAccentColorDark1">#A8A29E</Color>
                    <Color x:Key="SystemAccentColorDark2">#78716C</Color>
                    <Color x:Key="SystemAccentColorDark3">#57534E</Color>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#F5F5F4" />
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#E7E5E4" />
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#D6D3D1" />
                    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#F5F5F4" />
                    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="#A8A29E" />
                    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#FAFAF9" />
                    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#A1A1AA" />
                    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="#71717A" />
                    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="#52525B" />
                    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="#141414" />
                    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="#1A1A1A" />
                    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="#141414" />
                    <SolidColorBrush x:Key="ControlStrongStrokeColorDefaultBrush" Color="#E4E4E7" />
                    <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="#1A1A1A" />
                    <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush" Color="#222222" />
                    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#000000" />
                    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#141414" />
                    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="#141414" />
                    <SolidColorBrush x:Key="OptiPageBackgroundBrush" Color="#000000" />
                    <SolidColorBrush x:Key="OptiCardFillBrush" Color="#141414" />
                    <!-- Solid ring, slightly lighter than fill -->
                    <SolidColorBrush x:Key="OptiCardStrokeBrush" Color="#2E2E2E" />
                    <SolidColorBrush x:Key="OptiAccentBrush" Color="#FAFAFA" />
                    <SolidColorBrush x:Key="OptiOnAccentBrush" Color="#000000" />
                    <SolidColorBrush x:Key="OptiAccentSoftBrush" Color="#1C1C1C" />
                    <SolidColorBrush x:Key="OptiIconWellFillBrush" Color="#222222" />
                    <SolidColorBrush x:Key="OptiIconWellStrokeBrush" Color="#2E2E2E" />
                    <SolidColorBrush x:Key="OptiLogoWellFillBrush" Color="#0A0A0A" />
                    <SolidColorBrush x:Key="OptiLogoWellStrokeBrush" Color="#0A0A0A" />
                    <SolidColorBrush x:Key="OptiQuietButtonFillBrush" Color="#1C1C1C" />
                    <SolidColorBrush x:Key="OptiPrimaryTextBrush" Color="#FAFAFA" />
                    <SolidColorBrush x:Key="OptiSecondaryTextBrush" Color="#E4E4E7" />
                    <SolidColorBrush x:Key="OptiMutedTextBrush" Color="#A1A1AA" />
                    <SolidColorBrush x:Key="OptiSuccessBrush" Color="#4ADE80" />
                    <SolidColorBrush x:Key="OptiWarningBrush" Color="#FBBF24" />
                    <SolidColorBrush x:Key="OptiWarningSoftBrush" Color="#1C1C1C" />
                    <SolidColorBrush x:Key="OptiErrorBrush" Color="#F87171" />
                </ResourceDictionary>
                <!-- Light: clean neutral + true black text + solid card rings -->
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="SystemAccentColor">#111111</Color>
                    <Color x:Key="SystemAccentColorLight1">#27272A</Color>
                    <Color x:Key="SystemAccentColorLight2">#3F3F46</Color>
                    <Color x:Key="SystemAccentColorLight3">#52525B</Color>
                    <Color x:Key="SystemAccentColorDark1">#09090B</Color>
                    <Color x:Key="SystemAccentColorDark2">#000000</Color>
                    <Color x:Key="SystemAccentColorDark3">#000000</Color>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#111111" />
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#27272A" />
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#3F3F46" />
                    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#111111" />
                    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="#3F3F46" />
                    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#000000" />
                    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#000000" />
                    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="#171717" />
                    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="#525252" />
                    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="#F5F5F5" />
                    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="#D4D4D4" />
                    <SolidColorBrush x:Key="ControlStrongStrokeColorDefaultBrush" Color="#000000" />
                    <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="#F5F5F5" />
                    <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush" Color="#E5E5E5" />
                    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#F0F0F2" />
                    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="#D4D4D4" />
                    <SolidColorBrush x:Key="OptiPageBackgroundBrush" Color="#F0F0F2" />
                    <SolidColorBrush x:Key="OptiCardFillBrush" Color="#FFFFFF" />
                    <!-- Solid opaque ring color (used by nested-fill card chrome) -->
                    <SolidColorBrush x:Key="OptiCardStrokeBrush" Color="#D4D4D4" />
                    <SolidColorBrush x:Key="OptiAccentBrush" Color="#000000" />
                    <SolidColorBrush x:Key="OptiOnAccentBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="OptiAccentSoftBrush" Color="#F5F5F5" />
                    <SolidColorBrush x:Key="OptiIconWellFillBrush" Color="#F0F0F0" />
                    <SolidColorBrush x:Key="OptiIconWellStrokeBrush" Color="#D4D4D4" />
                    <SolidColorBrush x:Key="OptiLogoWellFillBrush" Color="#000000" />
                    <SolidColorBrush x:Key="OptiLogoWellStrokeBrush" Color="#000000" />
                    <SolidColorBrush x:Key="OptiQuietButtonFillBrush" Color="#F5F5F5" />
                    <!-- True black ink for all copy tiers in light mode -->
                    <SolidColorBrush x:Key="OptiPrimaryTextBrush" Color="#000000" />
                    <SolidColorBrush x:Key="OptiSecondaryTextBrush" Color="#000000" />
                    <SolidColorBrush x:Key="OptiMutedTextBrush" Color="#171717" />
                    <SolidColorBrush x:Key="OptiSuccessBrush" Color="#166534" />
                    <SolidColorBrush x:Key="OptiWarningBrush" Color="#9A3412" />
                    <SolidColorBrush x:Key="OptiWarningSoftBrush" Color="#F5F5F5" />
                    <SolidColorBrush x:Key="OptiErrorBrush" Color="#991B1B" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Default">
                    <Color x:Key="SystemAccentColor">#F5F5F4</Color>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#F5F5F4" />
                    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#F5F5F4" />
                    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#FAFAF9" />
                    <SolidColorBrush x:Key="OptiPageBackgroundBrush" Color="#000000" />
                    <SolidColorBrush x:Key="OptiCardFillBrush" Color="#141414" />
                    <SolidColorBrush x:Key="OptiCardStrokeBrush" Color="#2E2E2E" />
                    <SolidColorBrush x:Key="OptiAccentBrush" Color="#FAFAFA" />
                    <SolidColorBrush x:Key="OptiOnAccentBrush" Color="#000000" />
                    <SolidColorBrush x:Key="OptiAccentSoftBrush" Color="#1C1C1C" />
                    <SolidColorBrush x:Key="OptiIconWellFillBrush" Color="#222222" />
                    <SolidColorBrush x:Key="OptiIconWellStrokeBrush" Color="#2E2E2E" />
                    <SolidColorBrush x:Key="OptiLogoWellFillBrush" Color="#0A0A0A" />
                    <SolidColorBrush x:Key="OptiLogoWellStrokeBrush" Color="#0A0A0A" />
                    <SolidColorBrush x:Key="OptiQuietButtonFillBrush" Color="#1C1C1C" />
                    <SolidColorBrush x:Key="OptiPrimaryTextBrush" Color="#FAFAFA" />
                    <SolidColorBrush x:Key="OptiSecondaryTextBrush" Color="#E4E4E7" />
                    <SolidColorBrush x:Key="OptiMutedTextBrush" Color="#A1A1AA" />
                    <SolidColorBrush x:Key="OptiSuccessBrush" Color="#4ADE80" />
                    <SolidColorBrush x:Key="OptiWarningBrush" Color="#FBBF24" />
                    <SolidColorBrush x:Key="OptiWarningSoftBrush" Color="#1C1C1C" />
                    <SolidColorBrush x:Key="OptiErrorBrush" Color="#F87171" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
