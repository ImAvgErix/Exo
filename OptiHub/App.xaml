<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="OptiHub.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Styles/ThemeResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="SystemAccentColor">#F5F5F4</Color>
                    <Color x:Key="SystemAccentColorLight1">#FAFAF9</Color>
                    <Color x:Key="SystemAccentColorLight2">#E7E5E4</Color>
                    <Color x:Key="SystemAccentColorLight3">#D6D3D1</Color>
                    <Color x:Key="SystemAccentColorDark1">#A8A29E</Color>
                    <Color x:Key="SystemAccentColorDark2">#78716C</Color>
                    <Color x:Key="SystemAccentColorDark3">#57534E</Color>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#F5F5F4" />
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#E7E5E4" />
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#D6D3D1" />
                    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#F5F5F4" />
                    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="#A8A29E" />
                    <SolidColorBrush x:Key="OptiPageBackgroundBrush" Color="#0B0B0C" />
                    <SolidColorBrush x:Key="OptiCardFillBrush" Color="#141416" />
                    <SolidColorBrush x:Key="OptiCardStrokeBrush" Color="#33FFFFFF" />
                    <SolidColorBrush x:Key="OptiAccentBrush" Color="#F5F5F4" />
                    <SolidColorBrush x:Key="OptiOnAccentBrush" Color="#0B0B0C" />
                    <SolidColorBrush x:Key="OptiAccentSoftBrush" Color="#18FFFFFF" />
                    <!-- Soft light well so colored logos sit cleanly on dark UI -->
                    <SolidColorBrush x:Key="OptiLogoWellFillBrush" Color="#22FFFFFF" />
                    <SolidColorBrush x:Key="OptiLogoWellStrokeBrush" Color="#55FFFFFF" />
                    <SolidColorBrush x:Key="OptiQuietButtonFillBrush" Color="#1A1A1D" />
                    <SolidColorBrush x:Key="OptiPrimaryTextBrush" Color="#FAFAF9" />
                    <SolidColorBrush x:Key="OptiSecondaryTextBrush" Color="#D6D3D1" />
                    <SolidColorBrush x:Key="OptiMutedTextBrush" Color="#A8A29E" />
                    <SolidColorBrush x:Key="OptiSuccessBrush" Color="#4ADE80" />
                    <SolidColorBrush x:Key="OptiErrorBrush" Color="#F87171" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="SystemAccentColor">#1C1917</Color>
                    <Color x:Key="SystemAccentColorLight1">#292524</Color>
                    <Color x:Key="SystemAccentColorLight2">#44403C</Color>
                    <Color x:Key="SystemAccentColorLight3">#57534E</Color>
                    <Color x:Key="SystemAccentColorDark1">#0C0A09</Color>
                    <Color x:Key="SystemAccentColorDark2">#000000</Color>
                    <Color x:Key="SystemAccentColorDark3">#000000</Color>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#1C1917" />
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#292524" />
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#44403C" />
                    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#1C1917" />
                    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="#44403C" />
                    <SolidColorBrush x:Key="OptiPageBackgroundBrush" Color="#F0EFEE" />
                    <SolidColorBrush x:Key="OptiCardFillBrush" Color="#FFFFFF" />
                    <!-- Stronger charcoal outline so cards/controls don't wash out -->
                    <SolidColorBrush x:Key="OptiCardStrokeBrush" Color="#CC1C1917" />
                    <SolidColorBrush x:Key="OptiAccentBrush" Color="#1C1917" />
                    <SolidColorBrush x:Key="OptiOnAccentBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="OptiAccentSoftBrush" Color="#141C1917" />
                    <!-- Dark wells: white Steam/Epic logos stay readable in light mode -->
                    <SolidColorBrush x:Key="OptiLogoWellFillBrush" Color="#1C1917" />
                    <SolidColorBrush x:Key="OptiLogoWellStrokeBrush" Color="#FF0C0A09" />
                    <SolidColorBrush x:Key="OptiQuietButtonFillBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="OptiPrimaryTextBrush" Color="#0C0A09" />
                    <SolidColorBrush x:Key="OptiSecondaryTextBrush" Color="#292524" />
                    <SolidColorBrush x:Key="OptiMutedTextBrush" Color="#57534E" />
                    <SolidColorBrush x:Key="OptiSuccessBrush" Color="#15803D" />
                    <SolidColorBrush x:Key="OptiErrorBrush" Color="#B91C1C" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Default">
                    <Color x:Key="SystemAccentColor">#F5F5F4</Color>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#F5F5F4" />
                    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#F5F5F4" />
                    <SolidColorBrush x:Key="OptiPageBackgroundBrush" Color="#0B0B0C" />
                    <SolidColorBrush x:Key="OptiCardFillBrush" Color="#141416" />
                    <SolidColorBrush x:Key="OptiCardStrokeBrush" Color="#33FFFFFF" />
                    <SolidColorBrush x:Key="OptiAccentBrush" Color="#F5F5F4" />
                    <SolidColorBrush x:Key="OptiOnAccentBrush" Color="#0B0B0C" />
                    <SolidColorBrush x:Key="OptiAccentSoftBrush" Color="#18FFFFFF" />
                    <SolidColorBrush x:Key="OptiLogoWellFillBrush" Color="#22FFFFFF" />
                    <SolidColorBrush x:Key="OptiLogoWellStrokeBrush" Color="#55FFFFFF" />
                    <SolidColorBrush x:Key="OptiQuietButtonFillBrush" Color="#1A1A1D" />
                    <SolidColorBrush x:Key="OptiPrimaryTextBrush" Color="#FAFAF9" />
                    <SolidColorBrush x:Key="OptiSecondaryTextBrush" Color="#D6D3D1" />
                    <SolidColorBrush x:Key="OptiMutedTextBrush" Color="#A8A29E" />
                    <SolidColorBrush x:Key="OptiSuccessBrush" Color="#4ADE80" />
                    <SolidColorBrush x:Key="OptiErrorBrush" Color="#F87171" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
