<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OptiHub.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="OptiHub">

    <Grid x:Name="RootGrid" Background="{ThemeResource OptiPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- FORGE chrome: solid bar + amber underline, not a thin divider title -->
        <Grid x:Name="TitleBarHost"
              Grid.Row="0"
              Height="52"
              Background="{ThemeResource OptiChromeBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="CaptionSpacer" Width="138" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="3" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal"
                        Spacing="12"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0">
                <!-- Brand mark -->
                <Border Width="10" Height="10"
                        CornerRadius="2"
                        Background="{ThemeResource OptiRailBrush}"
                        VerticalAlignment="Center" />
                <TextBlock Text="OPTIHUB"
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                           FontSize="12"
                           FontWeight="Bold"
                           CharacterSpacing="180"
                           Foreground="{ThemeResource OptiAccentBrush}" />

                <Border Width="1" Height="18"
                        Background="{ThemeResource OptiDividerBrush}"
                        Opacity="0.9"
                        VerticalAlignment="Center"
                        Margin="4,0" />

                <Button x:Name="BackButton"
                        Style="{StaticResource OptiIconButton}"
                        ToolTipService.ToolTip="{x:Null}"
                        AutomationProperties.Name="Back to dashboard"
                        Click="BackButton_Click"
                        Visibility="Collapsed"
                        Width="34" Height="34"
                        VerticalAlignment="Center"
                        AllowFocusOnInteraction="True"
                        UseSystemFocusVisuals="False">
                    <FontIcon Glyph="&#xE72B;"
                              FontSize="13"
                              Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                </Button>

                <Border x:Name="ContextLogoHost"
                        Style="{StaticResource OptiLogoWellSmall}"
                        Visibility="Collapsed"
                        VerticalAlignment="Center">
                    <Image x:Name="ContextLogo"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Stretch="Uniform"
                           AutomationProperties.AccessibilityView="Raw" />
                </Border>

                <TextBlock x:Name="AppTitleText"
                           Text=""
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />

                <Button x:Name="SettingsButton"
                        Style="{StaticResource OptiIconButton}"
                        ToolTipService.ToolTip="{x:Null}"
                        AutomationProperties.Name="Settings"
                        Click="SettingsButton_Click"
                        Width="34" Height="34"
                        VerticalAlignment="Center"
                        AllowFocusOnInteraction="True"
                        UseSystemFocusVisuals="False">
                    <FontIcon Glyph="&#xE713;"
                              FontSize="14"
                              Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                </Button>
            </StackPanel>

            <Border Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Background="{ThemeResource OptiRailBrush}" />
        </Grid>

        <Frame x:Name="ContentFrame"
               Grid.Row="1"
               Padding="0"
               IsTabStop="True"
               IsNavigationStackEnabled="False"
               Background="{ThemeResource OptiPageBackgroundBrush}" />
    </Grid>
</Window>
