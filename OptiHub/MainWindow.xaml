<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OptiHub.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="OptiHub">

    <Grid x:Name="RootGrid" Background="{ThemeResource OptiPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBarHost"
              Grid.Row="0"
              Height="48"
              Background="{ThemeResource OptiChromeBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="CaptionSpacer" Width="138" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="2" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal"
                        Spacing="12"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0">
                <TextBlock Text="OPTIHUB"
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                           FontSize="13"
                           FontWeight="Bold"
                           CharacterSpacing="120"
                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />

                <Border Width="1" Height="16"
                        Background="{ThemeResource OptiDividerBrush}"
                        VerticalAlignment="Center" />

                <Button x:Name="BackButton"
                        Style="{StaticResource OptiIconButton}"
                        AutomationProperties.Name="Back to dashboard"
                        Click="BackButton_Click"
                        Visibility="Collapsed"
                        Width="34" Height="34"
                        VerticalAlignment="Center"
                        AllowFocusOnInteraction="True"
                        UseSystemFocusVisuals="False">
                    <FontIcon Glyph="&#xE72B;" FontSize="13"
                              Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                </Button>

                <Border x:Name="ContextLogoHost"
                        Style="{StaticResource OptiLogoWellSmall}"
                        Visibility="Collapsed"
                        VerticalAlignment="Center">
                    <Image x:Name="ContextLogo"
                           Stretch="Uniform"
                           AutomationProperties.AccessibilityView="Raw" />
                </Border>

                <TextBlock x:Name="AppTitleText"
                           Text=""
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />

                <Button x:Name="SettingsButton"
                        Style="{StaticResource OptiIconButton}"
                        AutomationProperties.Name="Settings"
                        Click="SettingsButton_Click"
                        Width="34" Height="34"
                        VerticalAlignment="Center"
                        AllowFocusOnInteraction="True"
                        UseSystemFocusVisuals="False">
                    <FontIcon Glyph="&#xE713;" FontSize="14"
                              Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                </Button>
            </StackPanel>

            <Border Grid.Row="1" Grid.ColumnSpan="2"
                    Background="{ThemeResource OptiRailBrush}" Opacity="0.35" />
        </Grid>

        <Frame x:Name="ContentFrame"
               Grid.Row="1"
               IsTabStop="True"
               IsNavigationStackEnabled="False"
               Background="{ThemeResource OptiPageBackgroundBrush}" />
    </Grid>
</Window>
