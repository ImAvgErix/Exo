<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OptiHub.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="OptiHub">

    <Grid x:Name="RootGrid" Background="{ThemeResource OptiPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Soft atmospheric glow -->
        <Ellipse x:Name="BackdropOrb"
                 Grid.RowSpan="2"
                 Width="640" Height="640"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Top"
                 Margin="0,-220,0,0"
                 IsHitTestVisible="False"
                 Opacity="0.5"
                 Fill="{ThemeResource OptiBackdropGlowBrush}">
            <Ellipse.RenderTransform>
                <CompositeTransform ScaleX="1.45" ScaleY="0.62" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <Grid x:Name="TitleBarHost"
              Grid.Row="0"
              Height="48"
              Padding="16,0,0,0"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <!-- Reserved for Windows caption buttons (min/max/close) -->
                <ColumnDefinition x:Name="CaptionSpacer" Width="140" />
            </Grid.ColumnDefinitions>

            <!-- Home chrome -->
            <StackPanel x:Name="HomeChrome"
                        Orientation="Horizontal"
                        Spacing="10"
                        VerticalAlignment="Center">
                <TextBlock x:Name="AppTitleText"
                           Text="OptiHub"
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource OptiDisplayFont}"
                           FontSize="22"
                           FontWeight="SemiBold"
                           CharacterSpacing="-20"
                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />
            </StackPanel>

            <!-- Contextual chrome (Discord / Settings) -->
            <StackPanel x:Name="ContextChrome"
                        Orientation="Horizontal"
                        Spacing="10"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                <Button x:Name="BackButton"
                        Style="{StaticResource OptiIconButton}"
                        ToolTipService.ToolTip="Back"
                        Click="BackButton_Click">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" />
                </Button>
                <Border x:Name="ContextLogoHost"
                        Width="28" Height="28"
                        CornerRadius="9"
                        Background="{ThemeResource OptiAccentSoftBrush}"
                        Visibility="Collapsed"
                        VerticalAlignment="Center">
                    <Image x:Name="ContextLogo"
                           Width="18" Height="18"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Stretch="Uniform" />
                </Border>
                <TextBlock x:Name="ContextTitleText"
                           Text=""
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource OptiDisplayFont}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           CharacterSpacing="-10"
                           Foreground="{ThemeResource OptiPrimaryTextBrush}" />
            </StackPanel>

            <Button x:Name="SettingsButton"
                    Grid.Column="1"
                    Style="{StaticResource OptiIconButton}"
                    ToolTipService.ToolTip="Settings"
                    Click="SettingsButton_Click"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0">
                <FontIcon Glyph="&#xE713;" FontSize="15" />
            </Button>
        </Grid>

        <Frame x:Name="ContentFrame"
               Grid.Row="1"
               Padding="0"
               IsNavigationStackEnabled="False" />
    </Grid>
</Window>
