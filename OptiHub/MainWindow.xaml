<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OptiHub.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OptiHub"
    Title="OptiHub">

    <Grid x:Name="RootGrid" Background="{ThemeResource OptiPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top bar: title + settings gear (no sidebar) -->
        <Grid x:Name="TitleBarHost"
              Grid.Row="0"
              Height="48"
              Padding="20,0,16,0"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="AppTitleText"
                       Grid.Column="0"
                       Text="OptiHub"
                       VerticalAlignment="Center"
                       FontFamily="{StaticResource OptiDisplayFont}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       CharacterSpacing="-20"
                       Foreground="{ThemeResource OptiPrimaryTextBrush}"
                       Margin="0,0,4,0" />

            <Button x:Name="SettingsButton"
                    Grid.Column="1"
                    Style="{StaticResource OptiIconButton}"
                    ToolTipService.ToolTip="Settings"
                    Click="SettingsButton_Click"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0">
                <FontIcon Glyph="&#xE713;" FontSize="16" />
            </Button>
        </Grid>

        <Frame x:Name="ContentFrame"
               Grid.Row="1"
               Padding="0"
               IsNavigationStackEnabled="True" />
    </Grid>
</Window>
