<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OptiHub.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:OptiHub.Views.Controls"
    Title="OptiHub">

    <Grid x:Name="RootGrid" Background="{ThemeResource OptiPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--
          Chrome buttons MUST live outside SetTitleBar. If they sit inside the
          drag region, WinUI treats clicks as non-client: first hit often does
          nothing useful, second hit can maximize the window.
        -->
        <Grid Grid.Row="0" Background="{ThemeResource OptiPageBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="CaptionSpacer" Width="138" />
            </Grid.ColumnDefinitions>

            <StackPanel x:Name="ChromeButtons"
                        Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="6"
                        VerticalAlignment="Center"
                        Margin="14,0,8,0"
                        Height="40"
                        Background="{ThemeResource OptiPageBackgroundBrush}">
                <Button x:Name="BackButton"
                        Style="{StaticResource OptiIconButton}"
                        AutomationProperties.Name="Back to dashboard"
                        Click="BackButton_Click"
                        Visibility="Collapsed"
                        Width="36" Height="36"
                        VerticalAlignment="Center"
                        AllowFocusOnInteraction="True"
                        IsTabStop="True"
                        UseSystemFocusVisuals="True">
                    <FontIcon Glyph="&#xE72B;" FontSize="13" />
                </Button>

                <Border x:Name="ContextLogoHost"
                        Width="28" Height="28"
                        CornerRadius="8"
                        Background="Transparent"
                        Visibility="Collapsed"
                        VerticalAlignment="Center"
                        IsHitTestVisible="False">
                    <Image x:Name="ContextLogo"
                           Width="20" Height="20"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Stretch="Uniform"
                           AutomationProperties.AccessibilityView="Raw" />
                </Border>

                <TextBlock x:Name="AppTitleText"
                           Text=""
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           CharacterSpacing="-8"
                           Foreground="{ThemeResource OptiPrimaryTextBrush}"
                           Margin="0,0,2,0"
                           IsHitTestVisible="False"
                           Visibility="Collapsed" />

                <Button x:Name="SettingsButton"
                        Style="{StaticResource OptiIconButton}"
                        AutomationProperties.Name="Settings"
                        Click="SettingsButton_Click"
                        Width="36" Height="36"
                        VerticalAlignment="Center"
                        AllowFocusOnInteraction="True"
                        IsTabStop="True"
                        UseSystemFocusVisuals="True">
                    <FontIcon x:Name="SettingsGearIcon"
                              Glyph="&#xE713;"
                              FontSize="14"
                              RenderTransformOrigin="0.5,0.5">
                        <FontIcon.RenderTransform>
                            <RotateTransform x:Name="SettingsGearRotate" Angle="0" />
                        </FontIcon.RenderTransform>
                    </FontIcon>
                    <FlyoutBase.AttachedFlyout>
                        <Flyout x:Name="SettingsFlyout"
                                Placement="BottomEdgeAlignedLeft"
                                Opened="SettingsFlyout_Opened"
                                Closed="SettingsFlyout_Closed">
                            <Flyout.FlyoutPresenterStyle>
                                <Style TargetType="FlyoutPresenter">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="CornerRadius" Value="0" />
                                    <Setter Property="MaxWidth" Value="360" />
                                </Style>
                            </Flyout.FlyoutPresenterStyle>
                            <controls:SettingsSheet x:Name="SettingsSheetHost" />
                        </Flyout>
                    </FlyoutBase.AttachedFlyout>
                </Button>
            </StackPanel>

            <Grid x:Name="TitleBarDragRegion"
                  Grid.Column="1"
                  Background="Transparent"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch" />
        </Grid>

        <Frame x:Name="ContentFrame"
               Grid.Row="1"
               Padding="0"
               IsTabStop="True"
               IsNavigationStackEnabled="False" />
    </Grid>
</Window>
