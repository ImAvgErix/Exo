<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OptiHub.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="OptiHub">

    <Grid x:Name="RootGrid" Background="{ThemeResource OptiPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Drag region + chrome; right column reserved for caption buttons -->
        <Grid x:Name="TitleBarHost"
              Grid.Row="0"
              Height="40"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="CaptionSpacer" Width="138" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal"
                        Spacing="6"
                        VerticalAlignment="Center"
                        Margin="14,0,0,0"
                        Height="40">
                <Button x:Name="BackButton"
                        Style="{StaticResource OptiIconButton}"
                        ToolTipService.ToolTip="Back"
                        Click="BackButton_Click"
                        Visibility="Collapsed"
                        Width="32" Height="32"
                        VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE72B;" FontSize="13" />
                </Button>

                <Border x:Name="ContextLogoHost"
                        Width="24" Height="24"
                        CornerRadius="7"
                        Background="{ThemeResource OptiAccentSoftBrush}"
                        Visibility="Collapsed"
                        VerticalAlignment="Center"
                        Margin="0,0,2,0">
                    <Image x:Name="ContextLogo"
                           Width="15" Height="15"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Stretch="Uniform" />
                </Border>

                <TextBlock x:Name="AppTitleText"
                           Text="OptiHub"
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           CharacterSpacing="-10"
                           Foreground="{ThemeResource OptiPrimaryTextBrush}"
                           Margin="2,0,2,0" />

                <Button x:Name="SettingsButton"
                        Style="{StaticResource OptiIconButton}"
                        ToolTipService.ToolTip="Settings"
                        Click="SettingsButton_Click"
                        Width="32" Height="32"
                        VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE713;" FontSize="14" />
                </Button>
            </StackPanel>
        </Grid>

        <Frame x:Name="ContentFrame"
               Grid.Row="1"
               Padding="0"
               IsNavigationStackEnabled="False" />
    </Grid>
</Window>
