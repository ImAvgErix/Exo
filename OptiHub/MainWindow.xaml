<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OptiHub.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="OptiHub">

    <!-- Thin WinUI host: drag title bar + full WebView2 product UI -->
    <Grid x:Name="RootGrid" Background="{ThemeResource OptiPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBarHost"
              Grid.Row="0"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="CaptionSpacer" Width="138" />
            </Grid.ColumnDefinitions>
        </Grid>

        <WebView2 x:Name="WebView"
                  Grid.Row="1"
                  DefaultBackgroundColor="Transparent" />
    </Grid>
</Window>
