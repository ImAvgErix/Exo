<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OptiHub.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="OptiHub">

    <!--
      Linear-style shell: custom dark sidebar + content stage.
      Not stock Windows NavigationView (that looked generic).
    -->
    <Grid x:Name="RootGrid" Background="{ThemeResource OptiPageBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR (Linear-like) ===== -->
        <Border Grid.Column="0"
                Background="{ThemeResource OptiSidebarBrush}"
                BorderBrush="{ThemeResource OptiDividerBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="52" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Brand -->
                <StackPanel Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center"
                            Margin="16,0,0,0">
                    <Border Width="24" Height="24" CornerRadius="7"
                            Background="{ThemeResource OptiAccentBrush}">
                        <FontIcon Glyph="&#xE945;" FontSize="11"
                                  Foreground="{ThemeResource OptiOnAccentBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="OptiHub"
                               FontFamily="{StaticResource OptiUiFontSemiBold}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource OptiPrimaryTextBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="10,4,10,8">
                    <StackPanel Spacing="2">
                        <TextBlock Text="WORKSPACE"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   CharacterSpacing="40"
                                   Foreground="{ThemeResource OptiMutedTextBrush}"
                                   Margin="10,8,10,8" />

                        <Button x:Name="NavHome" Style="{StaticResource OptiNavButton}"
                                Tag="home" Click="Nav_Click"
                                AutomationProperties.Name="Home" ToolTipService.ToolTip="Home">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE80F;" FontSize="14" />
                                <TextBlock Text="Home" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavDiscord" Style="{StaticResource OptiNavButton}"
                                Tag="discord" Click="Nav_Click"
                                AutomationProperties.Name="Discord" ToolTipService.ToolTip="Discord">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE8BD;" FontSize="14" />
                                <TextBlock Text="Discord" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavSteam" Style="{StaticResource OptiNavButton}"
                                Tag="steam" Click="Nav_Click"
                                AutomationProperties.Name="Steam" ToolTipService.ToolTip="Steam">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE7FC;" FontSize="14" />
                                <TextBlock Text="Steam" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavInternet" Style="{StaticResource OptiNavButton}"
                                Tag="internet" Click="Nav_Click"
                                AutomationProperties.Name="Internet" ToolTipService.ToolTip="Internet">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE774;" FontSize="14" />
                                <TextBlock Text="Internet" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavNvidia" Style="{StaticResource OptiNavButton}"
                                Tag="nvidia" Click="Nav_Click"
                                AutomationProperties.Name="NVIDIA" ToolTipService.ToolTip="NVIDIA">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE950;" FontSize="14" />
                                <TextBlock Text="NVIDIA" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="10,0,10,12" Spacing="2">
                    <Border Height="1" Background="{ThemeResource OptiDividerBrush}" Margin="6,0,6,8" />
                    <Button x:Name="NavSettings" Style="{StaticResource OptiNavButton}"
                            Tag="settings" Click="Nav_Click"
                            AutomationProperties.Name="Settings" ToolTipService.ToolTip="Settings">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE713;" FontSize="14" />
                            <TextBlock Text="Settings" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== CONTENT ===== -->
        <Grid Grid.Column="1" Background="{ThemeResource OptiPageBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Thin context strip (extends drag via SetTitleBar on TitleBarHost only —
                 use a second drag region partner: ContentTitleHost) -->
            <Grid x:Name="TitleBarHost" Grid.Row="0" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition x:Name="CaptionSpacer" Width="138" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="10"
                            VerticalAlignment="Center" Margin="24,0,0,0">
                    <Button x:Name="BackButton"
                            Style="{StaticResource OptiIconButton}"
                            Visibility="Collapsed"
                            Click="BackButton_Click"
                            AutomationProperties.Name="Back">
                        <FontIcon Glyph="&#xE72B;" FontSize="12"
                                  Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                    </Button>
                    <Border x:Name="ContextLogoHost"
                            Style="{StaticResource OptiLogoWellSmall}"
                            Visibility="Collapsed"
                            Width="18" Height="18">
                        <Image x:Name="ContextLogo" Stretch="Uniform"
                               AutomationProperties.AccessibilityView="Raw" />
                    </Border>
                    <TextBlock x:Name="AppTitleText" Text=""
                               FontSize="12"
                               Foreground="{ThemeResource OptiMutedTextBrush}"
                               VerticalAlignment="Center" />
                    <Button x:Name="SettingsButton"
                            Style="{StaticResource OptiIconButton}"
                            Visibility="Collapsed"
                            Width="1" Height="1"
                            Click="SettingsButton_Click" />
                </StackPanel>
            </Grid>

            <Frame x:Name="ContentFrame"
                   Grid.Row="1"
                   IsTabStop="True"
                   IsNavigationStackEnabled="False"
                   Background="Transparent" />
        </Grid>
    </Grid>
</Window>
