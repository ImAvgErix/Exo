<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OptiHub.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="OptiHub">

    <Grid x:Name="RootGrid" Background="#000000">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBarHost"
              Grid.Row="0"
              Background="#000000">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="CaptionSpacer" Width="138" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0">
                <Button x:Name="BackButton"
                        Width="32" Height="32"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="BackButton_Click"
                        Visibility="Collapsed"
                        ToolTipService.ToolTip="{x:Null}">
                    <FontIcon Glyph="&#xE72B;" FontSize="13" Foreground="#FAFAF9" />
                </Button>
                <TextBlock x:Name="HostStatus"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="#A8A29E"
                           Text="Starting…" />
                <TextBlock x:Name="AppTitleText"
                           VerticalAlignment="Center"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#FAFAF9"
                           Text="" />
            </StackPanel>

            <Button x:Name="SettingsButton"
                    Grid.Column="0"
                    HorizontalAlignment="Right"
                    Margin="0,0,8,0"
                    Width="32" Height="32"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="SettingsButton_Click"
                    ToolTipService.ToolTip="{x:Null}">
                <FontIcon Glyph="&#xE713;" FontSize="14" Foreground="#FAFAF9" />
            </Button>
        </Grid>

        <!-- Primary: WebView2 SPA -->
        <WebView2 x:Name="WebView"
                  Grid.Row="1"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  Visibility="Collapsed" />

        <!-- Fallback: classic WinUI pages if WebView2 cannot start -->
        <Frame x:Name="ContentFrame"
               Grid.Row="1"
               Visibility="Collapsed"
               IsNavigationStackEnabled="False" />
    </Grid>
</Window>
