<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OptiHub.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="OptiHub">

    <!-- Professional Fluent shell: Mica + NavigationView + content frame -->
    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar drag region -->
        <Grid x:Name="TitleBarHost"
              Grid.Row="0"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="CaptionSpacer" Width="138" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal"
                        Spacing="10"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0">
                <Button x:Name="BackButton"
                        Style="{StaticResource OptiIconButton}"
                        Visibility="Collapsed"
                        Click="BackButton_Click"
                        AutomationProperties.Name="Back">
                    <FontIcon Glyph="&#xE72B;" FontSize="12"
                              Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                </Button>
                <TextBlock Text="OptiHub"
                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource OptiPrimaryTextBrush}"
                           VerticalAlignment="Center" />
                <Border x:Name="ContextLogoHost"
                        Style="{StaticResource OptiLogoWellSmall}"
                        Visibility="Collapsed"
                        Width="20" Height="20">
                    <Image x:Name="ContextLogo" Stretch="Uniform"
                           AutomationProperties.AccessibilityView="Raw" />
                </Border>
                <TextBlock x:Name="AppTitleText"
                           Text=""
                           FontSize="13"
                           Foreground="{ThemeResource OptiMutedTextBrush}"
                           VerticalAlignment="Center" />
                <Button x:Name="SettingsButton"
                        Style="{StaticResource OptiIconButton}"
                        Visibility="Collapsed"
                        Width="1" Height="1"
                        Click="SettingsButton_Click" />
            </StackPanel>
        </Grid>

        <NavigationView x:Name="NavView"
                        Grid.Row="1"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="True"
                        PaneDisplayMode="Left"
                        OpenPaneLength="220"
                        CompactPaneLength="48"
                        IsPaneToggleButtonVisible="True"
                        IsPaneOpen="True"
                        SelectionChanged="NavView_SelectionChanged"
                        Background="Transparent">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Home" Tag="home" x:Name="NavHome">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Discord" Tag="discord" x:Name="NavDiscord">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8BD;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Steam" Tag="steam" x:Name="NavSteam">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7FC;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Internet" Tag="internet" x:Name="NavInternet">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE774;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="NVIDIA" Tag="nvidia" x:Name="NavNvidia">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE950;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame"
                   IsTabStop="True"
                   IsNavigationStackEnabled="False"
                   Background="Transparent">
                <Frame.ContentTransitions>
                    <TransitionCollection>
                        <NavigationThemeTransition />
                    </TransitionCollection>
                </Frame.ContentTransitions>
            </Frame>
        </NavigationView>
    </Grid>
</Window>
