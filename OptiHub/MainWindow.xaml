<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OptiHub.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="OptiHub">

    <Grid x:Name="RootGrid" Background="{ThemeResource OptiPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Floating pill chrome -->
        <Grid x:Name="TitleBarHost"
              Grid.Row="0"
              Height="56"
              Background="Transparent"
              Margin="12,10,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="CaptionSpacer" Width="138" />
            </Grid.ColumnDefinitions>

            <Border Background="{ThemeResource OptiChromeBrush}"
                    BorderBrush="{ThemeResource OptiCardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="10,0"
                    VerticalAlignment="Stretch"
                    Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center">
                    <Border Width="8" Height="8"
                            CornerRadius="4"
                            Background="{ThemeResource OptiAccentBrush}"
                            VerticalAlignment="Center"
                            Margin="6,0,2,0" />
                    <TextBlock Text="OptiHub"
                               VerticalAlignment="Center"
                               FontFamily="{StaticResource OptiUiFontSemiBold}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource OptiPrimaryTextBrush}" />

                    <Button x:Name="BackButton"
                            Style="{StaticResource OptiIconButton}"
                            AutomationProperties.Name="Back to dashboard"
                            Click="BackButton_Click"
                            Visibility="Collapsed"
                            Width="34" Height="34"
                            VerticalAlignment="Center"
                            AllowFocusOnInteraction="True"
                            UseSystemFocusVisuals="False">
                        <FontIcon Glyph="&#xE72B;" FontSize="13"
                                  Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                    </Button>

                    <Border x:Name="ContextLogoHost"
                            Style="{StaticResource OptiLogoWellSmall}"
                            Visibility="Collapsed"
                            VerticalAlignment="Center">
                        <Image x:Name="ContextLogo" Stretch="Uniform"
                               AutomationProperties.AccessibilityView="Raw" />
                    </Border>

                    <TextBlock x:Name="AppTitleText"
                               Text=""
                               VerticalAlignment="Center"
                               FontFamily="{StaticResource OptiUiFontSemiBold}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource OptiMutedTextBrush}" />

                    <Button x:Name="SettingsButton"
                            Style="{StaticResource OptiIconButton}"
                            AutomationProperties.Name="Settings"
                            Click="SettingsButton_Click"
                            Width="34" Height="34"
                            VerticalAlignment="Center"
                            AllowFocusOnInteraction="True"
                            UseSystemFocusVisuals="False">
                        <FontIcon Glyph="&#xE713;" FontSize="14"
                                  Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <Frame x:Name="ContentFrame"
               Grid.Row="1"
               IsTabStop="True"
               IsNavigationStackEnabled="False"
               Background="Transparent" />
    </Grid>
</Window>
