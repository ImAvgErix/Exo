<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OptiHub.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="OptiHub">

    <Grid x:Name="RootGrid" Background="{ThemeResource OptiPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Real window chrome: Settings ALWAYS top-left -->
        <Grid x:Name="TitleBarHost"
              Grid.Row="0"
              Background="{ThemeResource OptiPageBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="CaptionSpacer" Width="138" />
            </Grid.ColumnDefinitions>

            <!-- Settings gear is always the leftmost control (top-left of the window). -->
            <StackPanel Orientation="Horizontal"
                        Spacing="2"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Margin="8,0,0,0">
                <Button x:Name="SettingsButton"
                        Style="{StaticResource OptiIconButton}"
                        Width="40" Height="36"
                        Click="SettingsButton_Click"
                        ToolTipService.ToolTip="Settings"
                        AutomationProperties.Name="Settings">
                    <FontIcon Glyph="&#xE713;" FontSize="16" />
                </Button>
                <Button x:Name="BackButton"
                        Style="{StaticResource OptiIconButton}"
                        Width="36" Height="36"
                        Click="BackButton_Click"
                        Visibility="Collapsed"
                        ToolTipService.ToolTip="Back"
                        AutomationProperties.Name="Back">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" />
                </Button>
                <Image x:Name="ContextLogo"
                       Width="20" Height="20"
                       Margin="6,0,4,0"
                       Visibility="Collapsed"
                       Stretch="Uniform" />
                <TextBlock x:Name="AppTitleText"
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource OptiPrimaryTextBrush}"
                           Text="" />
                <TextBlock x:Name="HostStatus"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           FontSize="12"
                           Foreground="{ThemeResource OptiMutedTextBrush}"
                           Text=""
                           Visibility="Collapsed" />
            </StackPanel>
        </Grid>

        <!-- WebView must stay Visible (not Collapsed) or it never gets an HWND -->
        <WebView2 x:Name="WebView"
                  Grid.Row="1"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  Opacity="0"
                  IsHitTestVisible="False" />

        <Frame x:Name="ContentFrame"
               Grid.Row="1"
               Visibility="Collapsed"
               IsNavigationStackEnabled="False" />
    </Grid>
</Window>
