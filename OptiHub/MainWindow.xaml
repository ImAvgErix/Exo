<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OptiHub.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="OptiHub">

    <Grid x:Name="RootGrid" Background="{ThemeResource OptiPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Drag region + chrome; right column reserved for caption buttons -->
        <Grid x:Name="TitleBarHost"
              Grid.Row="0"
              Height="44"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="CaptionSpacer" Width="138" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal"
                        Spacing="10"
                        VerticalAlignment="Center"
                        Margin="14,0,0,0"
                        Height="44">
                <Button x:Name="BackButton"
                        Style="{StaticResource OptiIconButton}"
                        ToolTipService.ToolTip="{x:Null}"
                        AutomationProperties.Name="Back to dashboard"
                        Click="BackButton_Click"
                        Visibility="Collapsed"
                        Width="34" Height="34"
                        VerticalAlignment="Center"
                        AllowFocusOnInteraction="True"
                        UseSystemFocusVisuals="False">
                    <FontIcon Glyph="&#xE72B;"
                              FontSize="13"
                              Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                </Button>

                <Border x:Name="ContextLogoHost"
                        Style="{StaticResource OptiLogoWellSmall}"
                        Visibility="Collapsed"
                        VerticalAlignment="Center">
                    <Image x:Name="ContextLogo"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Stretch="Uniform"
                           AutomationProperties.AccessibilityView="Raw" />
                </Border>

                <TextBlock x:Name="AppTitleText"
                           Text=""
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           CharacterSpacing="-10"
                           Foreground="{ThemeResource OptiPrimaryTextBrush}"
                           Margin="0,0,2,0" />

                <Button x:Name="SettingsButton"
                        Style="{StaticResource OptiIconButton}"
                        ToolTipService.ToolTip="{x:Null}"
                        AutomationProperties.Name="Settings"
                        Click="SettingsButton_Click"
                        Width="34" Height="34"
                        VerticalAlignment="Center"
                        AllowFocusOnInteraction="True"
                        UseSystemFocusVisuals="False">
                    <FontIcon Glyph="&#xE713;"
                              FontSize="14"
                              Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Height="1"
                Background="{ThemeResource OptiDividerBrush}"
                Opacity="0.9"
                Margin="0" />

        <Frame x:Name="ContentFrame"
               Grid.Row="2"
               Padding="0"
               IsTabStop="True"
               IsNavigationStackEnabled="False" />
    </Grid>
</Window>
