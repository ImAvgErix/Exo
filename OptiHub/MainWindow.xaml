<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OptiHub.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="OptiHub">

    <!-- v1.7 shell: gear top-left, no sidebar — home cards are the nav -->
    <Grid x:Name="RootGrid" Background="{ThemeResource OptiPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBarHost"
              Grid.Row="0"
              Background="{ThemeResource OptiPageBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="CaptionSpacer" Width="138" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal"
                        Spacing="4"
                        VerticalAlignment="Center"
                        Margin="10,0,0,0">
                <Button x:Name="SettingsButton"
                        Style="{StaticResource OptiIconButton}"
                        Width="40" Height="36"
                        Click="SettingsButton_Click"
                        ToolTipService.ToolTip="Settings"
                        AutomationProperties.Name="Settings">
                    <FontIcon Glyph="&#xE713;" FontSize="15"
                              Foreground="{ThemeResource OptiSecondaryTextBrush}" />
                </Button>
                <Button x:Name="BackButton"
                        Style="{StaticResource OptiIconButton}"
                        Width="36" Height="36"
                        Click="BackButton_Click"
                        Visibility="Collapsed"
                        ToolTipService.ToolTip="Back"
                        AutomationProperties.Name="Back">
                    <FontIcon Glyph="&#xE72B;" FontSize="14"
                              Foreground="{ThemeResource OptiPrimaryTextBrush}" />
                </Button>
                <Border x:Name="ContextLogoHost"
                        Style="{StaticResource OptiLogoWellSmall}"
                        Visibility="Collapsed"
                        Width="22" Height="22"
                        Margin="4,0,0,0">
                    <Image x:Name="ContextLogo" Stretch="Uniform"
                           AutomationProperties.AccessibilityView="Raw" />
                </Border>
                <TextBlock x:Name="AppTitleText"
                           Text=""
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource OptiPrimaryTextBrush}"
                           Margin="4,0,0,0" />
            </StackPanel>
        </Grid>

        <Frame x:Name="ContentFrame"
               Grid.Row="1"
               IsTabStop="True"
               IsNavigationStackEnabled="False"
               Background="{ThemeResource OptiPageBackgroundBrush}" />
    </Grid>
</Window>
