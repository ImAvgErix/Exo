<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OptiHub.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:OptiHub.Views.Controls"
    Title="OptiHub">

    <Grid x:Name="RootGrid" Background="{ThemeResource OptiPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--
          Chrome buttons MUST live outside SetTitleBar. If they sit inside the
          drag region, WinUI treats clicks as non-client: first hit often does
          nothing useful, second hit can maximize the window.
        -->
        <Grid Grid.Row="0" Background="{ThemeResource OptiPageBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="CaptionSpacer" Width="138" />
            </Grid.ColumnDefinitions>

            <!-- Interactive chrome (not a drag surface) -->
            <StackPanel x:Name="ChromeButtons"
                        Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center"
                        Margin="12,0,8,0"
                        Height="40"
                        Background="{ThemeResource OptiPageBackgroundBrush}">
                <Button x:Name="BackButton"
                        Style="{StaticResource OptiIconButton}"
                        AutomationProperties.Name="Back to dashboard"
                        Click="BackButton_Click"
                        Visibility="Collapsed"
                        Width="36" Height="36"
                        VerticalAlignment="Center"
                        AllowFocusOnInteraction="True"
                        IsTabStop="True"
                        UseSystemFocusVisuals="True">
                    <FontIcon Glyph="&#xE72B;" FontSize="13" />
                </Button>

                <Border x:Name="ContextLogoHost"
                        Width="28" Height="28"
                        CornerRadius="8"
                        Background="Transparent"
                        Visibility="Collapsed"
                        VerticalAlignment="Center"
                        IsHitTestVisible="False">
                    <Image x:Name="ContextLogo"
                           Width="20" Height="20"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Stretch="Uniform"
                           AutomationProperties.AccessibilityView="Raw" />
                </Border>

                <TextBlock x:Name="AppTitleText"
                           Text=""
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource OptiUiFontSemiBold}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           CharacterSpacing="-8"
                           Foreground="{ThemeResource OptiPrimaryTextBrush}"
                           Margin="0,0,2,0"
                           IsHitTestVisible="False"
                           Visibility="Collapsed" />

                <Button x:Name="SettingsButton"
                        Style="{StaticResource OptiIconButton}"
                        AutomationProperties.Name="Settings"
                        Click="SettingsButton_Click"
                        Width="36" Height="36"
                        VerticalAlignment="Center"
                        AllowFocusOnInteraction="True"
                        IsTabStop="True"
                        UseSystemFocusVisuals="True">
                    <FontIcon Glyph="&#xE713;" FontSize="14" />
                </Button>
            </StackPanel>

            <!-- Drag-only strip — THIS is SetTitleBar, not the buttons -->
            <Grid x:Name="TitleBarDragRegion"
                  Grid.Column="1"
                  Background="Transparent"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch" />
        </Grid>

        <Frame x:Name="ContentFrame"
               Grid.Row="1"
               Padding="0"
               IsTabStop="True"
               IsNavigationStackEnabled="False" />

        <!--
          Settings modal — keep it dumb and reliable:
          scrim (full bleed) + sheet (centered sibling). No intermediate stage that
          steals hits. No composition motion. Visibility only.
        -->
        <Grid x:Name="SettingsOverlay"
              Grid.RowSpan="2"
              Visibility="Collapsed"
              Canvas.ZIndex="100">
            <Border x:Name="SettingsScrim"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Tapped="SettingsScrim_Tapped">
                <Border.Background>
                    <AcrylicBrush TintColor="#000000"
                                  TintOpacity="0.55"
                                  TintLuminosityOpacity="0.65"
                                  FallbackColor="#E6000000" />
                </Border.Background>
            </Border>

            <controls:SettingsSheet x:Name="SettingsSheetHost"
                                    Width="400"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    CloseRequested="SettingsSheet_CloseRequested" />
        </Grid>
    </Grid>
</Window>
